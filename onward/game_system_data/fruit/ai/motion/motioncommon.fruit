include "onward/game system data/fruit/ai/motion/motionenums.fruit"

class AngleRange
{
	float myAngle 0 < bhv=degree_angle min=-180 max=180 tooltip="Degrees. 0 is forward. Example: -45" >
	float myRange 180 < bhv=degree_angle min=0 max=180 tooltip="Degrees. For example, using range 45 with angle 0 will make this motion be used between -45 and +45 degrees." >
}
