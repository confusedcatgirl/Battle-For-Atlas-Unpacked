
class ThreatManager < uid=auto >
{
	float myDamageThreshold 100.0 < tooltip="Damage of a single type which triggers enemy evolution" >
	int myThreatPerLevel 100
	int myMaxThreat 1000
	file mySkillScript < types=*.mskillscriptgraph tooltip="The Skill Script that is owned by the ThreatManager" >
}
