class AttachmentConfig
{
	file myGraphTemplate "" < types=*.mgraphobject >
	string myAttachmentBone "" < tooltip="Bone on parent that this attachment is anchored to" >
	float myDetachedLifetimeSeconds 5.0 < tooltip="Lifetime of this attachment after being detached from the parent." >
}

list AttachmentList
{
	AttachmentConfig
}