class DamageAffector < abstract=1 >
{
}

class DamageAffectorMultiplier : DamageAffector < abstract=1 >
{
	float myDamageMultiplier < tooltip="0-1" >
}

list DamageAffectorList
{
	DamageAffector
}

class DamageAffector_StatusEffect : DamageAffectorMultiplier
{
	StatusEffectType myStatusEffectType
	bool myAnyStatusEffect false
	StatusEffectTypeList myStatusEffectTypes
}

class DamageAffector_CloseRange : DamageAffectorMultiplier
{
	float myWithinMeters
}

