	float myLifetime < tooltip="Override how long the projectile should remain" >
	file myEntityTemplate < bhv="asset" assettype="Entity Template" >
	bool mySpawnAtTarget < tooltip="Initial projectile position is at the target" >
	bool mySpawnAtPlayer < tooltip="Initial projectile position is at the player" >
	bool myTrajectoryPlayerToTarget < tooltip="trajectory is the vector between the player and target" >

