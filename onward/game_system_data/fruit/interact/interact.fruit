class PluckableStageConfigBase
{
}

class PluckableStageConfigCapture_SwayParams
{
	vec3f myMinOffset 5.0;5.0;0.0 < tooltip="Sway offset when 'Easy'" >
	vec3f myMaxOffset 5.0;5.0;0.0 < tooltip="Sway offset when 'Very Hard'" >
	
	vec3f myMinSineModifier 2.0;4.0;1.0 < tooltip="Sway sine modifier when 'Easy'" >
	vec3f myMaxSineModifier 2.0;4.0;1.0 < tooltip="Sway sine modifier when 'Very Hard'" >
}

class PluckableStageConfigCapture : PluckableStageConfigBase
{
	float myMinReticleSize 0.080 < tooltip="Reticle size when 'Easy'" >
	float myMaxReticleSize 0.040 < tooltip="Reticle size when 'Very Hard'" >
	
	int myMinLockOnDuration 675 < tooltip="Lock on duration in MS when 'Easy'" >
	int myMaxLockOnDuration 1250 < tooltip="Lock on duration in MS when 'Very Hard'" >
	
	PluckableStageConfigCapture_SwayParams mySwayParams1
	PluckableStageConfigCapture_SwayParams mySwayParams2
}

