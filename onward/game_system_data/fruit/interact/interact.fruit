class PluckableStageConfigButtonSequence : PluckableStageConfigBase
{
	float myDelayOnSuccessTime 1.5
	float myDelayOnRotationTime 1.0
	float myDelayOnShiftTime 0.5
	int myNumRings 3
	int myDegreesOfRotation 4
	int myLinkedRingsVariant 0
}

class PluckableStageConfigSweetSpot : PluckableStageConfigBase
{
	float mySweetSpot 10.0				< tooltip="<Base start of the sweet spot" >
	float mySweetSpotMax 10.0			< tooltip="<Max start of the sweet spot, set same as Sweet Spot to turn off randomness" >
	float mySweetSpotRange 10.0 		< tooltip="Size of the sweet spot" >
	float mySweetSpotDepletionRate 1.0 	< tooltip="How fast the sweet spot progress is lost" >
	float myTimeInSweetSpot 10.0 		< tooltip="How long to stay in the sweet spot to complete the pluck" >
    float myMinImpulse 5.0 				< tooltip="Min pulling force/frame" >
    float myMaxImpulse 10.0 			< tooltip="Max pulling force/frame" >
    float myOscillation 0.0 			< tooltip="Range of sweet spot movement" >
    float myOscillationRate 0.0 		< tooltip="Speed of sweet spot movement" >
}

class PluckableStageButtonMash
{
    int myTapCount 5
    float myTimeWindow 9999999
}

class PluckableStage
{
	float mySweetSpot 10.0				< tooltip="<Base start of the sweet spot" >
	float mySweetSpotMax 10.0			< tooltip="<Max start of the sweet spot, set same as Sweet Spot to turn off randomness" >
	float mySweetSpotRange 10.0 		< tooltip="Size of the sweet spot" >
	float mySweetSpotDepletionRate 1.0 	< tooltip="How fast the sweet spot progress is lost" >
	float myTimeInSweetSpot 10.0 		< tooltip="How long to stay in the sweet spot to complete the pluck" >
    float myMinImpulse 5.0 				< tooltip="Min pulling force/frame" >
    float myMaxImpulse 10.0 			< tooltip="Max pulling force/frame" >
    float myOscillation 0.0 			< tooltip="Range of sweet spot movement" >
    float myOscillationRate 0.0 		< tooltip="Speed of sweet spot movement" >
    PluckableStageButtonMash myButtonMashConfig
}

