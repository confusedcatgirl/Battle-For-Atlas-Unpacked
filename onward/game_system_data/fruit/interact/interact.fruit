	SimUnit*
}

class PluckableStageConfigSpawnItem : PluckableStageConfigBase
{
	SimUnit*	mySimUnitAsset
	bool		myAutomaticallyTow TRUE
	bool		myInheritParent FALSE < tooltip="If true, the spawned simunit will have the same parent as the pluckable" >
	bool		myUtilizeParentLocationID FALSE < tooltip="If true, it uses the spawn info location id to access the array below" >
	PluckableStageConfigSpawnItem_LocationIDAssets myLocationIDAssets
}

