class Pluckable_PostCompletionOptions
{
	bool myDestroy FALSE
	bool myKillIfAgent TRUE < tooltip="Requires 'myDestroy'" >
}

class Pluckable : Interactable
{
    PluckMiniGameType myMiniGameType SweetSpot
	float myMaxDistance 20.0			< tooltip="Max distance for play area" >
	float myMinImpulseDistance 5.0 		< tooltip="Distance that pulling forces start" >
	float myStageAdvanceImpulse 5.0		< tooltip="Inwards impulse to apply on stage complete" >
	float myDamage 100.0				< tooltip="Amount to damage pluckable" >
	float myDamageImpulse 5.0			< tooltip="Impulse to apply when damaging pluckable" >
    float myBreakDistance 200.0         < tooltip="Distance at which the link will break, cancelling the pluck" >
	bool myShouldSaveStage false
    bool myShouldPullInteractor false
    bool myShouldApplyImpactOnBreak true
    bool myShouldStartWhenShieldIsDown false
    bool myShouldDecreaseStageOnImpact false
    ImpactCategory myMinImpactCategoryForDecrease
	StoryEvent myDisableUntilStoryEvent NewGame
	Pluckable_PostCompletionOptions myPostCompletionOptions
    string myLootDropId < tooltip = "Loot Drop awarded to player upon completing interaction" >
    PluckableStageConfigs myStageConfigs
}

class Deliverable : Interactable
{
}

class Hackable : Interactable
{
	ReinforcementType myReinforcementType Legion	< tooltip="Type of reinforcements to spawn" >
	float myHackTime	30.0						< tooltip="How long the player needs to defend for" >
	float myReinforcementInterval	10.0			< tooltip="How often reinforcements are spawned" >
	float myMinSpawnRadius	10.0					< tooltip="Minimum distance from the hackable reinforcements are spawned" >
	float myMaxSpawnRadius	75.0					< tooltip="Maximum distance from the hackable reinforcements are spawned" >
	float myExceedsZonePercent 1.1 					< tooltip="How far outside of the interaction ( > 1.0 = outside the circle) the player will trigger the reentry phase" >
	float myZoneReentryTime 5						< tooltip="How long the player has to get back into the defend zone" >
	float myReinforcementsDelay 3					< tooltip="After the hack is initiated, how long before the first reinforcements spawn." >
	float myHackableZoneRadius 0					< tooltip="How big the radius is for the hackable zone, must be at least as big as interact range" >
	int   myMaxUnits 8                              < tooltip="How many agents can be spawned simultaneously" >
	ReinforcementTypes myReinforcementTypes			< tooltip="Use this list to defines waves of reinforcements" >
}

