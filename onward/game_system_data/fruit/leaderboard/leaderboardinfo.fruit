class LeaderboardInfo < uid=auto >
{
	string myDefinitionName < tooltip="Name of the definition used to create the stat on TGOPortal. If no split by field is defined, this will also be the stat name." >
	string mySplitByFieldName < tootltip="Optional - Name of the split by field specified in the stat definition on TGOPortal. If defined, mySplitByFieldValue should also be defined." >
	string mySplitByFieldValue < tooltip="Optional - One of the possible values accepted by the split by field as defined on TGOPortal. If defined, mySplitByFieldName should also be defined." >
	string myLeaderboardName < tootltip="Optional - Name of the leaderboard on TGOPortal. If left empty, leaderboard name is defaulted to the stat name." >
	varmap myLeaderboardUIName < bhv = "localization" tooltip="The name of the leaderboard as displayed in the menus" >
	string mySocialMenuSprite < default = "mySpriteId = -455779427, mySpritesheet = F\"onward/ui/spritesheets/ui-icon-placeholder.spritesheet\"" bhv="sprite" >
}