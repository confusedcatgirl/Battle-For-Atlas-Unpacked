list TrackModList
{
	PlayerMod*
}

class ModTrack
{
	ModTrackType myTrackType
	TrackModList myTrackMods
}

enum EnhancementType
{
	WeaponCore
	ShipCore
	Armour
	Mod
	PaintJob
	Unknown
}


class Enhancement < uid=auto >
{
	varmap myLocalizedName < bhv = "localization" >
	varmap myLocalizedDescription < bhv = "localization" >
	string myIconSprite < bhv="sprite" >
	varmap mySpecialNotes < bhv = "localization" >
	color mySpecialNotesColor
	bool myIsUbiClub
	bool myIsHullEnhancement
	ModRarityType myRarity
	int myLevel
	ChallengeType myOnAcquiredChallenge

	PartFlavorType myPartFlavor Unknown
	FactionType myFactionType Unaligned
	PlayerMod* myMod
	Buff* myBuff
	PaintJob* myPaintJob
	EnhancementType myEnhancementType Unknown
	EnhancementTrackType myEnhancementTrackType Unknown
	DamageAffectorList myDamageAffectors
	ImpactAffectorList myImpactAffectors
	ProgressionRewardList myRewardsOnAcquisition
}

class EnhancementLevelBase
{
	int myLevel
	PlayerMod* myMod
}

list EnhancementLevelBaseList
{
	EnhancementLevelBase
}

class EnhancementTypeBase
{
	EnhancementType myType
	EnhancementLevelBaseList myLevels
}

class EnhancementTrackBase
{
	EnhancementTrackType myTrackType
	PlayerMod* myMod
}

class EnhancementCloningCost
{
	ModRarityType myRarity
	int myElectrumCost
	int myNovaCost
}

class EnhancementFusionCost
{
	int myElectrumCost
	int myNovaCost
}

list EnhancementList
{
	Enhancement*
}
