list PartTypes
{
	PartType
}

list PartFlavorTypes
{
	PartFlavorType
}

list DeploymentTypes
{
	DeploymentType
}

enum ModActivationType
{
	OnEquip
	OnCold
	OnHeat
	OnShieldDown
}

list ModActivationTypes
{
	ModActivationType
}

enum ModRarityType
{
	Common
	Uncommon
	Rare
	Epic
	Legendary
	Warden
	UbiClub
}

class ModFusionCost
{
	int myLevel 1
	int myCost 0
}

class Mod < uid=auto >
{
	AttributeMods myAttributeMods
}

class NPCMod : Mod
{
}

class PlayerMod : Mod
{
	bool myIsSelfMod false < tooltip="Whether the mod only applies to the part it's equipped on" >
	bool myIsAgentMod false < tooltip="Whether the mod applies to the player's attributes eg. for health" >
	PartTypes myPartTypes
	PartFlavorTypes myPartFlavors
	DeploymentTypes myDeployments
	PartTypes myEquipPartTypes
	PartFlavorTypes myEquipPartFlavors
	DeploymentTypes myEquipDeployments
	AttributeMods myAttributeMods
}

