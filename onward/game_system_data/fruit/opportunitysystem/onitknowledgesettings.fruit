// Contains all the Knowledge-related settings related to On It Opportunities

class OnItKnowledgeConfig
{
	float myChanceOfFullKnowledge		< default = 0.2 min = 0 max = 1.0 tooltip = "(0 to 1.0) What percentage of OnIt accepts result in full knowledge of OnIt target." >
	float myDefaultOnItKnowledge		< default = 20.0 min = 0 max = 100.0 tooltip = "(0 to 100.0) The default knowledge value that will be applied to the OnIt target if full knowledge is not immediately granted." >
}