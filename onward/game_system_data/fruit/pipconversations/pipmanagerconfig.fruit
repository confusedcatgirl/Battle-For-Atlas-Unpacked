class PipManagerConfig
{
	int myOnItBufferWindow					< default = 7000 tooltip = "How many seconds to keep up a Pip with an \"On It\" after the speaker finishes" >
	int myConversationAddOnWindow			< default = 2000 tooltip = "How many seconds after a bark finishes can we add on to it" >
	int myConditionalNewConversationWindow	< default = 5000 tooltip = "After a conversation, there is a window where new Conversations have to pass more stringent tests in order to be queued" >
	int myMinTimeBetweenGlitch				< default = 1500 tooltip = "Minimum amount of time between random player pip glitches" >
	int myMaxTimeBetweenGlitch				< default = 6000 tooltip = "Maximum amount of time between random player pip glitches" >
	int myPipWindowCloseCountdown			< default = 1000 tooltip = "How many seconds after a window stops having content to we close it" >
}