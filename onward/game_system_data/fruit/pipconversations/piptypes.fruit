//
// A Context describes the general "mood" of a participant in a conversation (ie: is the participant angry, under fire, idling)
// (really what video should be playing)
//
enum OGame_PipContext
{
	Unknown
	Idle
	Talk
	CombatIdle
	CombatTalk
	VictoryCheer
	Special
	BigHit
	BigHitCrash
	Menu
}