enum ProgressionPointType
{
	Electrum
	Skill
	Experience
	Expedition
	Outlaw
	Prospector
	Nova
	Initiative
	OutlawReputation
}

enum ExperiencePointType
{
	Combat
	Exploration
	Navigation
	Assistance
	Repair
	CombatEvent
	CombatSpecial
}

enum ProgressionTarget
{
	Player
	Pilot
	Ship
}

class ProgressionPointAmount
{
	ProgressionPointType	myPointType
	int						myPointAmount
}

list ProgressionPointAmounts
{
	ProgressionPointAmount
}
