class PlanetModifier
{
	uid myPlanet < bhv = asset assettype = level >
	float myModifier 1
}

list PlanetModifierList
{
	PlanetModifier
}

class SimMovementModifiers
{
	PlanetModifierList myPlanetModifiers < tooltip="Global sim speed is scaled by the given modifier when the PLAYER is on the planet" >
}