	float mySecondsToWait < default = 3.0 >
}

class StoryDataAction_MakeOwnerStoryFlowSelected : StoryDataActionBase
{
}

class StoryDataAction_ConditionalAction : StoryDataActionBase
{
	StoryDataActionSetType myCompleteType
	StoryDataActionList myConditionalActions
	StoryDataActionList myOutcomeActions
	bool myBlockUpdateWhenComplete FALSE
}

class StoryDataAction_WaitForStoryEvent : StoryDataActionBase
{
	ObjectiveData* myObjectiveUID < hidden = 1 >
	bool myObjectiveAutoRemoves < hidden = 1 >
	StoryEvent myStoryEvent
	bool myCheckNotExists FALSE < tooltip="If true, will complete when that story event hasn't been completed" >
}

class StoryDataAction_SetObjectiveHeader : StoryDataActionBase
{
	ObjectiveData* myObjectiveUID < hidden = 1 >
	bool myObjectiveAutoRemoves < hidden = 1 >
	varmap myObjectiveHeader < bhv = "localization" >
}

class StoryDataAction_SetCustomStoryFaction : StoryDataActionBase
{
	ObjectiveData* myObjectiveUID < hidden = 1 >
	bool myObjectiveAutoRemoves < hidden = 1 >
	FactionType myCustomStoryFaction
}

class StoryDataAction_SetCustomStoryWaypoint : StoryDataActionBase
{
	ObjectiveData* myObjectiveUID < hidden = 1 >
	bool myObjectiveAutoRemoves < hidden = 1 >
	string myCustomWaypointSprite < bhv="sprite" >
}

class StoryDataAction_PreloadNPC : StoryDataActionBase
{
	file myNPCAssetPath "" < types=*.mnpc >
}

class StoryDataAction_SafetyRemovePreloadedNPC : StoryDataActionBase
{
	file myNPCAssetPath "" < types=*.mnpc >
}

class StoryDataAction_WaitForPlayerInventoryState : StoryDataActionBase
{
	TowableCategory myTowableCategory
	BasicCompareType myCompareType
	int myCountToCheck < tooltip="This is the 'right hand side' in the comparison">
}

class StoryDataAction_BreakTargetPluck : StoryDataActionBase
{
	bool myCompleteIfNoTarget TRUE < tooltip="If true, will complete if their is no story target" >
	bool myCompleteIfNoEntity TRUE < tooltip="If true, will complete if the target is not realized (not in the world)" >
	bool myCompleteIfNoInteraction TRUE < tooltip="If true, will complete if the target it not currently being plucked" >
}

class StoryDataAction_SelectObjectiveBlock : StoryDataActionBase
{
	bool mySelectMainStory FALSE < tooltip="If true, will select the main story flow" >
	string myPartStorySelection < tooltip="Name of the part story flow to select. Name matches what is found in the part stories folder (IE 'sidestory_prospector')" >
}

class StoryDataAction_WaitForShieldDown : StoryDataActionBase
{
	bool myCompleteIfNoTarget FALSE
}

class StoryDataAction_WaitForAssetInteraction : StoryDataActionBase
{
	InteractionType myInteractionType
	SimUnit* mySimUnitAsset	
}

class StoryDataAction_SetGlobalIntFact : StoryDataActionBase
{
	IntFactLabel myLabel Undefined
	int myValue 0
}

class StoryDataAction_SetGlobalStringFact : StoryDataActionBase
{
	StringFactLabel myLabel Undefined
	string myValue ""
}

class StoryDataAction_SetGlobalFloatFact : StoryDataActionBase
{
	FloatFactLabel myLabel Undefined
	float myValue 0
}

class StoryDataAction_ConstantSuppressNonStoryPips : StoryDataActionBase
{
	bool myShouldSuppress < tooltip="If true, there must be another action to set it to false at some point" >
}

class StoryDataAction_WaitForAssetTowed : StoryDataActionBase
{
	SimUnit* mySimUnitAsset	
}