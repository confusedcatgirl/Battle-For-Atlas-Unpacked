{
	AND
	OR
}

enum StoryDataActionState
{
	Inactive
	Active
	Complete
}

class StoryDataActionBase < abstract = 1 >
{
	ObjectiveData* myObjectiveUID
	bool myObjectiveAutoRemoves < default=true >
	bool myIsOptional FALSE
	bool myIgnoreReset FALSE
	bool myAllowCompleteFromLoad TRUE
	StoryBeatData_ForceCompleteOptions myForceCompleteOptions
}

list StoryDataActionList
{
	StoryDataActionBase
}

class StoryDataActionSet
{
	StoryDataActionSetType myStoryDataActionSetType
	StoryDataActionList myStoryDataActions
}

list StoryDataActionSetList
{
	StoryDataActionSet
}

class StoryDataAction_Dialog : StoryDataActionBase
{
	bool myIgnoreReset TRUE < tooltip="Only set to false if you want the dialogue to be killed" >
