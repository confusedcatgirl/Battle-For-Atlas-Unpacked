enum TutorialChannel
{
	Center
	Left
	Right
}

enum Tutorial
{
	Tutorial01
	Tutorial02	
	Starlink
	Movement
	CenteredMovement
	Boost
	OnIt
	Pods
	RightPod
	LeftPod
	PilotAbility
	Launch
