list GameActionList
{
	GameAction
}

class TutorialData
{
	Tutorial myTutorial
	varmap myMessage < bhv = "localization" >
	GameAction myGameAction	
	GameActionList myGameActions
    bool myRequiresOneGameActionToComplete FALSE
	bool myShowPrompt
	bool myHideBox
	bool myUseProgressButton
	TutorialChannel myChannel
	UIMenu myMenuToOpenOnDismiss
	uid myMenuSpecificUID
}

list TutorialDataList
{
	TutorialData
}
