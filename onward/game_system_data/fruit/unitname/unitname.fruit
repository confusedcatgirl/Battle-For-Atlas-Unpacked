	NameIndexList myInterestNameIndexList
}


class UnitNameData_ParentName : UnitNameDataBase
{
	NameIndexList myParentNameIndexList
}

class UnitNameData_LocationID_ID
{
	int myLocationID
	varmap myLocalizedName < bhv="localization" >
}

list UnitNameData_PlanetLocationIDs
{
	UnitNameData_LocationID_ID
