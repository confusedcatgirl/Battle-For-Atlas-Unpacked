			myLine "contextComment = \"\", description = \"\", enabled = true, guid = #3BC8B70A584874D40000000F8A193C05, lineVersion = 0, maxLength = 0, text = \"Nova?\""
		}
		Subtitle Line2
		{
			myFirstFrame 1270
			myLastFrame 1745
			myLine "contextComment = \"\", description = \"\", enabled = true, guid = #3BC8B70A584874D4000000120AE93909, lineVersion = 0, maxLength = 0, text = \"When the Warden Gods departed so long ago they took with them the secrets to Nova. You must feed my Legion.\""
		}
		Subtitle Line3
		{
			myFirstFrame 1749
			myLastFrame 1893
			myLine "contextComment = \"\", description = \"\", enabled = true, guid = #3BC8B70A584874D40000001438866AB7, lineVersion = 0, maxLength = 0, text = \"Look, if you want Nova, it's no trouble, but first I'm gonna need to get back to my crew.\""
