			myLastFrame 1174
			myLine "contextComment = \"\", description = \"\", enabled = true, guid = #3BC8B70A584874D40000000E11BEA5A6, lineVersion = 0, maxLength = 0, text = \"I have waited... so long for this. I foresaw this moment many years ago. The Wardens showed me and now...the gift appears. The time has come to harvest Nova.\""
		}
		Subtitle Line1
		{
			myFirstFrame 1199
