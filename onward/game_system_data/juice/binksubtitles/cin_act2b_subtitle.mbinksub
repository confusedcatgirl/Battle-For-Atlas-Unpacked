			myLastFrame 3713
			myLine "contextComment = \"\", description = \"\", enabled = true, guid = #3BC8B70A584874D40000002B7E36E828, lineVersion = 0, maxLength = 0, text = \"This is the only intel I trust. The Legion's got a hierarchy, and orders gotta come from somewhere. Let's crack a few more open and see where that gets us.\""
