			myLine "contextComment = \"\", description = \"\", enabled = true, guid = #3BC8B70A584874D400000029A434ACB4, lineVersion = 0, maxLength = 0, text = \"Listen, I got contacts. They might know who took St Grand. Let's talk to them first.\""
