		Subtitle Line4
		{
			myFirstFrame 1903
			myLastFrame 1971
			myLine "contextComment = \"\", description = \"\", enabled = true, guid = #AA5A640859CC0DEA00000001A65D8032, lineVersion = 0, maxLength = 0, text = \"[Inhales sharply]\""
