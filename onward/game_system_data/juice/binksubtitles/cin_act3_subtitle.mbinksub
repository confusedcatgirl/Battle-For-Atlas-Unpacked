			myLine "contextComment = \"\", description = \"\", enabled = true, guid = #AA5A6408589A30EF000000110D9E6A0E, lineVersion = 0, maxLength = 0, text = \"As the Wardens willed: Sacrifice the worlds of Atlas to the Harvest of Electrum.\""
