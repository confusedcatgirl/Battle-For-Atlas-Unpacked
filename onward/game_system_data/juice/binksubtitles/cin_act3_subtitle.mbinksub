			myLine "contextComment = \"\", description = \"\", enabled = true, guid = #AA5A640858A1FF13000000030FD06D42, lineVersion = 0, maxLength = 0, text = \"Finally.\""
		}
		Subtitle Line42
		{
			myFirstFrame 4941
			myLastFrame 5057
			myLine "contextComment = \"\", description = \"\", enabled = true, guid = #AA5A640858A1FF13000000049B13506C, lineVersion = 0, maxLength = 0, text = \"We are few in numbers, but armies smaller than ours have defeated --\""
		}
		Subtitle Line43
		{
			myFirstFrame 5006
			myLastFrame 5443
			myLine "contextComment = \"\", description = \"\", enabled = true, guid = #AA5A64085894911A0000000B342DDEF8, lineVersion = 0, maxLength = 0, text = \"<Laughs>. You guys. An army. Look, it's like Hunter said. Grax is just gonna keep getting stronger and stronger.\""
		}
		Subtitle Line44
		{
			myFirstFrame 5431
			myLastFrame 5465
			myLine "contextComment = \"\", description = \"\", enabled = true, guid = #AA5A64085A4D3677000000023E9F6043, lineVersion = 0, maxLength = 0, text = \"[Sharp exhale]\""
		}
		Subtitle Line45
		{
			myFirstFrame 5470
			myLastFrame 5579
			myLine "contextComment = \"\", description = \"\", enabled = true, guid = #AA5A64085894911A0000000DE9555DC8, lineVersion = 0, maxLength = 0, text = \"I'm looking out for myself, you guys should too.\""
		}
		Subtitle Line46
		{
			myFirstFrame 5500
			myLastFrame 5514
			myLine "contextComment = \"\", description = \"\", enabled = true, guid = #AA5A64085A4D563200000002F9C8F54E, lineVersion = 0, maxLength = 0, text = \"[Grunts quietly]\""
		}
