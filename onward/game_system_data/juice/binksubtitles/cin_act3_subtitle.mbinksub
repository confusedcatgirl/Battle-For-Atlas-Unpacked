			myLastFrame 7740
			myLine "contextComment = \"\", description = \"\", enabled = true, guid = #AA5A640858939A2D0000000A9BE28291, lineVersion = 0, maxLength = 0, text = \"I send you forth in...\""
		}
		Subtitle Line67
		{
