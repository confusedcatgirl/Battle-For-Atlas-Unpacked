			myLastFrame 5658
			myLine "contextComment = \"\", description = \"\", enabled = true, guid = #AA5A64085A4D5632000000048DBED422, lineVersion = 0, maxLength = 0, text = \"What?\""
		}
		Subtitle Line51
		{
			myFirstFrame 5664
			myLastFrame 5691
			myLine "contextComment = \"\", description = \"\", enabled = true, guid = #AA5A64085888C52F00000002CC1690CF, lineVersion = 0, maxLength = 0, text = \"We should split up!\""
		}
		Subtitle Line52
		{
			myFirstFrame 5692
			myLastFrame 5762
			myLine "contextComment = \"\", description = \"\", enabled = true, guid = #AA5A64085888C52F00000003498352A8, lineVersion = 0, maxLength = 0, text = \"Dude, that's intense!\""
		}
		Subtitle Line53
		{
			myFirstFrame 5767
			myLastFrame 5860
			myLine "contextComment = \"\", description = \"\", enabled = true, guid = #AA5A64085888C52F00000004748D711A, lineVersion = 0, maxLength = 0, text = \"There aren't enough of us. The Legion is growing...\""
		}
		Subtitle Line54
		{
			myFirstFrame 5868
			myLastFrame 6008
			myLine "contextComment = \"\", description = \"\", enabled = true, guid = #AA5A64085A678EBF000000025C834927, lineVersion = 0, maxLength = 0, text = \"...we need to keep growing. We spread out, find help from every planet in Atlas.\""
		}
		Subtitle Line55
		{
			myFirstFrame 6007
			myLastFrame 6100
			myLine "contextComment = \"\", description = \"\", enabled = true, guid = #3BC8B70A584988400000000CBD810910, lineVersion = 0, maxLength = 0, text = \"If we split up, we'll get picked off one by one.\""
		}
		Subtitle Line56
		{
			myFirstFrame 6097
			myLastFrame 6277
			myLine "contextComment = \"\", description = \"\", enabled = true, guid = #3BC8B70A584988400000000DCBC8B660, lineVersion = 0, maxLength = 0, text = \"Not while we have Starlink! We can combine our strengths from everywhere in Atlas.\""
		}
		Subtitle Line57
		{
			myFirstFrame 6302
			myLastFrame 6407
			myLine "contextComment = \"\", description = \"\", enabled = true, guid = #3BC8B70A58498840000000119FC8BF10, lineVersion = 0, maxLength = 0, text = \"The more of us there are, the stronger each of us is.\""
		}
		Subtitle Line58
		{
			myFirstFrame 6407
			myLastFrame 6438
			myLine "contextComment = \"\", description = \"\", enabled = true, guid = #AA5A6408589A30EF0000000AC1F43912, lineVersion = 0, maxLength = 0, text = \"Exactly!\""
		}
		Subtitle Line59
		{
			myFirstFrame 6543
			myLastFrame 6646
			myLine "contextComment = \"\", description = \"\", enabled = true, guid = #AA5A640858939A2D00000002BB1345EA, lineVersion = 0, maxLength = 0, text = \"The Wardens saved us.\""
		}
		Subtitle Line60
		{
			myFirstFrame 6683
			myLastFrame 6969
			myLine "contextComment = \"\", description = \"\", enabled = true, guid = #AA5A640858939A2D00000005C27CB1C0, lineVersion = 0, maxLength = 0, text = \"They gave us a path to the stars. Brought us out of a life of darkness.\""
		}
		Subtitle Line61
		{
			myFirstFrame 6991
			myLastFrame 7265
			myLine "contextComment = \"\", description = \"\", enabled = true, guid = #AA5A6408589A30EF0000000F4230CFDA, lineVersion = 0, maxLength = 0, text = \"Now, what are we? Lost.\""
		}
		Subtitle Line62
		{
			myFirstFrame 7052
			myLastFrame 7349
			myLine "contextComment = \"\", description = \"\", enabled = true, guid = #AA5A64085A75C0A6000000160C1AC716, lineVersion = 0, maxLength = 0, text = \"[pained efforts]\""
		}
		Subtitle Line63
		{
			myFirstFrame 7318
			myLastFrame 7434
			myLine "contextComment = \"\", description = \"\", enabled = true, guid = #AA5A6408589A30EF00000010E0BF2412, lineVersion = 0, maxLength = 0, text = \"I have found the key.\""
		}
		Subtitle Line64
		{
			myFirstFrame 7464
			myLastFrame 7596
			myLine "contextComment = \"\", description = \"\", enabled = true, guid = #AA5A640858A5DBB900000001E7427D1E, lineVersion = 0, maxLength = 0, text = \"We will redeem those unworthy.\""
		}
		Subtitle Line65
		{
