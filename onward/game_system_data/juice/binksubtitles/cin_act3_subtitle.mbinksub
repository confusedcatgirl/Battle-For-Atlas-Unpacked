		{
			myFirstFrame 5539
			myLastFrame 5567
			myLine "contextComment = \"\", description = \"\", enabled = true, guid = #AA5A64085A4D5632000000032C789CC9, lineVersion = 0, maxLength = 0, text = \"Just let her go.\""
		}
		Subtitle Line48
		{
