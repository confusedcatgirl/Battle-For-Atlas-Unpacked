TriggerGameAction "[Camera] Reset Framing"
{
	myConditionalInputActions
	{
		ConditionalActionGroup "Input Actions"
		{
			myOperator Or
			myConditionalInputActions
			{
				ConditionalInputAction "Hold Y"
				{
					myInputActionType PressedAfterTime
					myTimer 1000
					myInputAction = Y_TRIANGLE
				}
				ConditionalInputAction "Hold R"
				{
					myInputActionType PressedAfterTime
					myTimer 1000
					myInputAction = KB_UI_RELOAD
				}
			}
		}
	}
	myGameAction ResetFraming
	myIsUIAndGameAction TRUE
}

