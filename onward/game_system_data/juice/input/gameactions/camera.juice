TriggerGameAction "[Camera] Look Back"
{
	myConditionalInputActions
	{
		ConditionalActionGroup "INPUT LOOK BACK"
		{
			myOperator Or
			myConditionalInputActions
			{
				ConditionalInputAction "Keyboard Look Back"
				{
					myInputActionType HoldDown
					myInputAction = KB_REARVIEW
				}
				ConditionalInputAction "Click Left Thumbstick"
				{
					myInputActionType HoldDownAfterTime
					myTimer 150
					myInputAction = LEFT_STICK_BUTTON
				}
			}
		}
		ConditionalGameActionState IsReverseCameraEnabled
		{
			myGameActionState IsReverseCameraEnabled
		}
		ConditionalGameActionState InHyperspace
		{
			myNegate TRUE
			myGameActionState InHyperspace
		}
		ConditionalGameActionState IsInPlanetaryTransition
		{
			myNegate TRUE
			myGameActionState IsInPlanetaryTransition
		}
		ConditionalGameActionState IsDead
		{
			myNegate TRUE
			myGameActionState IsDead
		}
		ConditionalGameActionState IsPlucking
		{
			myNegate TRUE
			myGameActionState IsPlucking
		}
	}
	myGameAction LookBack
}

TriggerGameAction "[Camera] Zoom"
{
	myConditionalInputActions
	{
		ConditionalGameActionState InDialogue
		{
			myNegate TRUE
			myGameActionState InDialogue
		}
		ConditionalGameActionState IsOnSpline
		{
			myNegate TRUE
			myGameActionState IsOnSpline
		}
		ConditionalGameActionState IsEnteringSpline
		{
			myNegate TRUE
			myGameActionState IsEnteringSpline
		}
		ConditionalGameActionState IsCameraZoomEnabled
		{
			myGameActionState IsCameraZoomEnabled
		}
		ConditionalActionGroup "Not in race pre-start"
		{
			myOperator Or
			myConditionalInputActions
			{
				ConditionalGameActionState IsPilotTrialEventInProgress
				{
					myGameActionState IsPilotTrialEventInProgress
				}
				ConditionalGameActionState IsPilotTrialEventActive
				{
					myNegate TRUE
					myGameActionState IsPilotTrialEventActive
				}
			}
		}
		ConditionalActionGroup INPUT
		{
			myOperator Or
			myConditionalInputActions
			{
				ConditionalInputAction RS
				{
					myInputActionType Pressed
					myInputAction = RIGHT_STICK_BUTTON
				}
				ConditionalInputAction MB
				{
					myInputActionType Pressed
					myInputAction = KB_ZOOM
				}
			}
		}
	}
	myGameAction Zoom
}

TriggerGameAction PlayerQuery_ShouldDisplayReticle
{
	myConditionalInputActions
	{
		ConditionalGameActionState IsTakingOff
		{
			myNegate TRUE
			myGameActionState IsTakingOff
		}
		ConditionalGameActionState HasNPCAttached
		{
			myNegate TRUE
			myGameActionState HasNPCAttached
		}
		ConditionalGameActionState InHyperspace
		{
			myNegate TRUE
			myGameActionState InHyperspace
		}
		ConditionalGameActionState IsStartingHyperDrive
		{
			myNegate TRUE
			myGameActionState IsStartingHyperDrive
		}
		ConditionalGameActionState IsPlucking
		{
			myNegate TRUE
			myGameActionState IsPlucking
		}
		ConditionalGameActionState ShouldBeDowned
		{
			myNegate TRUE
			myGameActionState ShouldBeDowned
		}
		ConditionalActionGroup "Frozen Conditions"
		{
			myOperator Or
			myConditionalInputActions
			{
				ConditionalGameActionState IsFrozen
				{
					myNegate TRUE
					myGameActionState IsFrozen
				}
				ConditionalGameActionState HasFreezeMobility
				{
					myGameActionState HasFreezeMobility
				}
			}
		}
	}
	myGameAction PlayerQuery_ShouldDisplayReticle
}

TriggerGameAction "[Movement] Can Use Photo Mode"
{
	myConditionalInputActions
	{
		ConditionalGameActionState IsInPlanetaryTransition
		{
			myNegate TRUE
			myGameActionState IsInPlanetaryTransition
		}
	}
	myGameAction PlayerQuery_CanUsePhotoMode
}

TriggerGameAction "[Camera] Toggle Photo Mode"
{
	myConditionalInputActions
	{
		ConditionalGameAction PlayerQuery_CanUsePhotoMode
		{
			myGameAction PlayerQuery_CanUsePhotoMode
		}
		ConditionalActionGroup "INPUT PHOTO MODE"
		{
			myOperator Or
			myConditionalInputActions
			{
				ConditionalInputAction Back
				{
					myInputActionType PressedAfterTime
					myTimer 500
					myInputAction = BACK_SELECT
				}
				ConditionalInputAction "KB_PHOTOMODE Tap Action"
				{
					myInputActionType Released
					myInputAction = KB_PHOTOMODE
				}
			}
		}
		ConditionalGameAction "Player 1"
		{
			myGameAction PlayerQuery_IsPrimaryPlayer
		}
		ConditionalGameActionState "Photo Mode Shortcut Enabled"
		{
			myGameActionState IsPhotoModeShortcutEnabled
		}
	}
	myGameAction TogglePhotoMode
}

TriggerGameAction "[Camera] Is Initiating Photo Mode"
{
	myConditionalInputActions
	{
		ConditionalGameAction PlayerQuery_CanUsePhotoMode
		{
			myGameAction PlayerQuery_CanUsePhotoMode
		}
		ConditionalActionGroup "INPUT PHOTO MODE"
		{
			myOperator Or
			myConditionalInputActions
			{
				ConditionalInputAction Back
				{
					myInputActionType HoldDown
					myInputAction = BACK_SELECT
				}
				ConditionalInputAction "KB_PHOTOMODE Tap Action"
				{
					myInputActionType PressAndRelease
					myInputAction = KB_PHOTOMODE
				}
			}
		}
		ConditionalGameAction "Player 1"
		{
			myGameAction PlayerQuery_IsPrimaryPlayer
		}
		ConditionalGameActionState "Photo Mode Shortcut Enabled"
		{
			myGameActionState IsPhotoModeShortcutEnabled
		}
	}
	myGameAction PlayerQuery_IsInitiatingPhotoMode
}

TriggerGameAction "[Camera] Roll Up"
{
	myConditionalInputActions
	{
		ConditionalActionGroup "Input Actions"
		{
			myOperator Or
			myConditionalInputActions
			{
				ConditionalInputAction R1
				{
					myInputActionType Analog
					myInputAction = UI_RIGHT_BUMPER_R1
				}
				ConditionalInputAction "Keyboard Tab Right"
				{
					myInputActionType Analog
					myInputAction = KB_UI_TAB_RIGHT
				}
				ConditionalInputAction "Keyboard Tab Alt Right"
				{
					myInputActionType Analog
					myInputAction = KB_UI_DROP
				}
			}
		}
	}
	myGameAction RollUp
	myIsUIAndGameAction TRUE
}

