TriggerGameAction "[General] Can Start Follow"
{
	myConditionalInputActions
	{
		ConditionalGameActionState "Is Primary"
		{
			myNegate TRUE
			myGameActionState IsPrimaryPlayer
		}
		ConditionalGameActionState "Is Alive"
		{
			myNegate TRUE
			myGameActionState IsDead
		}
		ConditionalGameActionState "Is Primary player Alive"
		{
			myNegate TRUE
			myGameActionState IsPrimaryPlayerDead
		}
		ConditionalGameActionState NotInsideDreadnought
		{
			myNegate TRUE
			myGameActionState InsideDreadnought
		}
	}
	myGameAction PlayerQuery_CanStartFollow
}

TriggerGameAction "[General] Start Follow"
{
	myConditionalInputActions
	{
		ConditionalGameAction PlayerQuery_CanStartFollow
		{
			myRequireNewInput TRUE
			myGameAction PlayerQuery_CanStartFollow
		}
		ConditionalActionGroup Follow
		{
			myOperator Or
			myConditionalInputActions
			{
				ConditionalInputAction "Press d pad direction"
				{
					myInputActionType HoldDownAfterTime
					myTimer 500
					myInputAction = D_PAD_RIGHT
				}
				ConditionalInputAction "Press Tab"
				{
					myInputActionType HoldDownAfterTime
					myTimer 500
					myInputAction = KB_LOADOUTALT
				}
			}
		}
	}
	myGameAction StartFollow
}

TriggerGameAction "[General] Stop Follow"
{
	myConditionalInputActions
	{
		ConditionalGameActionState "Is Following"
		{
			myGameActionState IsInFollowMode
		}
		ConditionalGameActionState "Is Not In Planetary Transition"
		{
			myNegate TRUE
			myGameActionState IsInPlanetaryTransition
		}
		ConditionalGameActionState "Is Not Deactivated"
		{
			myNegate TRUE
			myGameActionState IsDeactivated
		}
		ConditionalGameActionState "Is Not Pilot Trial Disabling Inputs"
		{
			myNegate TRUE
			myGameActionState IsPilotTrialDisablingAllInputs
		}
		ConditionalActionGroup "Press Any Actions"
		{
			myOperator Or
			myConditionalInputActions
			{
				ConditionalGameAction PodOne
				{
					myGameAction PodOne
				}
				ConditionalGameAction PodTwo
				{
					myGameAction PodTwo
				}
				ConditionalGameAction PodThree
				{
					myGameAction PodThree
				}
				ConditionalInputAction LeftStickUp
				{
					myInputAction = LEFT_STICK_UP_45
				}
				ConditionalInputAction LeftStickDown
				{
					myInputAction = LEFT_STICK_DOWN_45
				}
				ConditionalInputAction LeftStickLeft
				{
					myInputAction = LEFT_STICK_LEFT_45
				}
				ConditionalInputAction LeftStickRight
				{
					myInputAction = LEFT_STICK_RIGHT_45
				}
				ConditionalInputAction RightStickUp
				{
					myInputAction = RIGHT_STICK_UP_45
				}
				ConditionalInputAction RightStickDown
				{
					myInputAction = RIGHT_STICK_DOWN_45
				}
				ConditionalInputAction RightStickLeft
				{
					myInputAction = RIGHT_STICK_LEFT_45
				}
				ConditionalInputAction RightStickRight
				{
					myInputAction = RIGHT_STICK_RIGHT_45
				}
				ConditionalGameAction DashStart
				{
					myGameAction DashStart
				}
				ConditionalGameAction ManeuverStart
				{
					myGameAction ManeuverStart
				}
				ConditionalGameAction JetEngine
				{
					myGameAction JetEngine
				}
				ConditionalGameAction FlightEngineStart
				{
					myGameAction FlightEngineStart
				}
				ConditionalInputAction LB
				{
					myInputActionType PressedAfterTime
					myTimer 300
					myInputAction = RIGHT_BUMPER_R1
				}
			}
		}
	}
	myGameAction StopFollow
}

