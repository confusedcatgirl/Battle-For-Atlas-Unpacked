TriggerGameAction "[General] Scan"
{
	myConditionalInputActions
	{
		ConditionalActionGroup "INPUT SCAN"
		{
			myOperator Or
			myConditionalInputActions
			{
				ConditionalInputAction "Press X (Square)"
				{
					myInputActionType PressAndReleaseBeforeTime
					myTimer 250
					myInputAction = X_SQUARE
				}
				ConditionalInputAction "Keyboard Scan"
				{
					myInputActionType PressAndReleaseBeforeTime
					myTimer 250
					myInputAction = KB_INTERACT
				}
			}
		}
	}
	myGameAction Scan
}

