TriggerGameAction "[General] Archeology Scan Pulse"
{
	myConditionalInputActions
	{
		ConditionalInputAction "Press L3"
		{
			myInputAction = LEFT_STICK_BUTTON
		}
		ConditionalGameActionState CanActivateArcheologyScanPulse
		{
			myGameActionState CanActivateArcheologyScanPulse
		}
		ConditionalGameActionState NotIsArcheologyScanPulseActive
		{
			myNegate TRUE
			myGameActionState IsArcheologyScanPulseActive
		}
	}
	myGameAction ArcheologyScanPulse
}

TriggerGameAction "[General] PlayerQuery_CanNPCAttach"
{
	myConditionalInputActions
	{
		ConditionalGameActionState IsRagdoll
		{
			myNegate TRUE
			myGameActionState IsRagdoll
		}
		ConditionalGameActionState IsFlippedOver
		{
			myNegate TRUE
			myGameActionState IsFlippedOver
		}
		ConditionalGameActionState InDialogue
		{
			myNegate TRUE
			myGameActionState InDialogue
		}
		ConditionalGameActionState IsShieldParryActive
		{
			myNegate TRUE
			myGameActionState IsShieldParryActive
		}
		ConditionalGameActionState IsImpAttachEnabled
		{
			myGameActionState IsImpAttachEnabled
		}
	}
	myGameAction PlayerQuery_CanNPCAttach
}

