include "onward/game system data/juice/input/inputactions.juice"
include "onward/game system data/juice/input/inputactions_alt.juice"
include "onward/game system data/fruit/input/gameinput.fruit"

TriggerGameAction "[General] Can Respawn"
{
	myConditionalInputActions
	{
		ConditionalActionGroup IsDead
		{
			myOperator Or
			myConditionalInputActions
			{
				ConditionalActionGroup NotOnSplineAndDead
				{
					myConditionalInputActions
					{
						ConditionalGameActionState "Not on Spline"
						{
							myNegate TRUE
							myGameActionState IsOnSpline
						}
						ConditionalGameActionState IsDead
						{
							myGameActionState IsDead
						}
					}
				}
				ConditionalActionGroup OnSplineAndAllDead
				{
					myConditionalInputActions
					{
						ConditionalGameActionState OnSpline
						{
							myGameActionState IsOnSpline
						}
						ConditionalGameActionState AllDead
						{
							myGameActionState AreAllPlayersDead
						}
					}
				}
			}
		}
		ConditionalGameActionState InFullScreenDialogue
		{
			myNegate TRUE
			myGameActionState InFullScreenDialogue
		}
	}
	myGameAction PlayerQuery_CanRespawn
}

TriggerGameAction "[General] Respawn"
{
	myConditionalInputActions
	{
		ConditionalGameActionState IsPrimaryPlayer
		{
			myGameActionState IsPrimaryPlayer
		}
		ConditionalGameAction PlayerQuery_CanRespawn
		{
			myRequireNewInput TRUE
			myGameAction PlayerQuery_CanRespawn
		}
		ConditionalActionGroup "INPUT RESPAWN"
		{
			myOperator Or
			myConditionalInputActions
			{
				ConditionalInputAction Hold
				{
					myInputActionType HoldDownAfterTime
					myTimer 2000
					myInputAction = Y_TRIANGLE
				}
				ConditionalInputAction "Keyboard Respawn"
				{
					myInputActionType HoldDownAfterTime
					myTimer 2000
					myInputAction = KB_JUMP
				}
			}
		}
	}
	myGameAction Respawn
}

