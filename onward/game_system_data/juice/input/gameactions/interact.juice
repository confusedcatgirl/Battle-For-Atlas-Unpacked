TriggerGameAction "[Interact] Can Start Scan"
{
	myConditionalInputActions
	{
		ConditionalGameAction PlayerQuery_CanInteract
		{
			myGameAction PlayerQuery_CanInteract
		}
		ConditionalGameActionState IsFlying
		{
			myNegate TRUE
			myGameActionState IsFlying
		}
		ConditionalGameActionState IsPlucking
		{
			myNegate TRUE
			myGameActionState IsPlucking
		}
		ConditionalGameActionState IsReticleOverScannable
		{
			myGameActionState IsReticleOverScannable
		}
		ConditionalGameActionState IsScanEnabled
		{
			myGameActionState IsScanEnabled
		}
	}
	myGameAction PlayerQuery_CanStartScan
}

TriggerGameAction "[Interact] Can Start Hack"
{
	myConditionalInputActions
	{
		ConditionalGameAction PlayerQuery_CanInteract
		{
			myGameAction PlayerQuery_CanInteract
		}
		ConditionalGameActionState IsHacking
		{
			myNegate TRUE
			myGameActionState IsHacking
		}
		ConditionalGameActionState IsReticleOverHackable
		{
			myGameActionState IsReticleOverHackable
		}
		ConditionalActionGroup "Not Flying Or In Space"
		{
			myOperator Or
			myConditionalInputActions
			{
				ConditionalGameActionState "Not Flying"
				{
					myNegate TRUE
					myGameActionState IsFlying
				}
				ConditionalGameActionState InSpace
				{
					myGameActionState InSpace
				}
			}
		}
		ConditionalGameActionState IsHackEnabled
		{
			myGameActionState IsHackEnabled
		}
	}
	myGameAction PlayerQuery_CanStartHack
}

TriggerGameAction "[Interact] Can Hail"
{
	myConditionalInputActions
	{
		ConditionalGameActionState IsReticleOverHailable
		{
			myGameActionState IsReticleOverHailable
		}
		ConditionalGameAction PlayerQuery_CanInteract
		{
			myGameAction PlayerQuery_CanInteract
		}
		ConditionalGameActionState IsOnFire
		{
			myNegate TRUE
			myGameActionState IsOnFire
		}
		ConditionalGameActionState IsInBlackHole
		{
			myNegate TRUE
			myGameActionState IsInBlackHole
		}
		ConditionalGameActionState InGravity
		{
			myNegate TRUE
			myGameActionState InGravity
		}
		ConditionalGameActionState IsInCombat
		{
			myNegate TRUE
			myGameActionState IsInCombat
		}
		ConditionalGameActionState IsHailableInCombat
		{
			myNegate TRUE
			myGameActionState IsHailableInCombat
		}
		ConditionalGameActionState InDialogue
		{
			myNegate TRUE
			myGameActionState InDialogue
		}
		ConditionalGameAction PlayerQuery_IsInitiatingPhotoMode
		{
			myNegate TRUE
			myGameAction PlayerQuery_IsInitiatingPhotoMode
		}
		ConditionalActionGroup "Not Flying Or In Space"
		{
			myOperator Or
			myConditionalInputActions
			{
				ConditionalGameActionState "Not Flying"
				{
					myNegate TRUE
					myGameActionState IsFlying
				}
				ConditionalGameActionState InSpace
				{
					myGameActionState InSpace
				}
			}
		}
		ConditionalGameActionState IsHailEnabled
		{
			myGameActionState IsHailEnabled
		}
		ConditionalActionGroup "Player 1 or No join forces in progress"
		{
			myOperator Or
			myConditionalInputActions
			{
				ConditionalGameActionState IsPrimaryPlayer
				{
					myGameActionState IsPrimaryPlayer
				}
				ConditionalGameActionState NotIsCoopJoinForcesInProgress
				{
					myNegate TRUE
					myGameActionState IsCoopJoinForcesInProgress
				}
			}
		}
	}
	myGameAction PlayerQuery_CanHail
}

