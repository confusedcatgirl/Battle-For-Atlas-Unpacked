TriggerGameAction "[Interact] Interact Fail since Combat"
{
	myConditionalInputActions
	{
		ConditionalGameActionState IsReticleOverHailable
		{
			myGameActionState IsReticleOverHailable
		}
		ConditionalGameAction PlayerQuery_CanInteract
		{
			myGameAction PlayerQuery_CanInteract
		}
		ConditionalGameActionState IsOnFire
		{
			myNegate TRUE
			myGameActionState IsOnFire
		}
		ConditionalGameActionState IsInBlackHole
		{
			myNegate TRUE
			myGameActionState IsInBlackHole
		}
		ConditionalGameActionState InGravity
		{
			myNegate TRUE
			myGameActionState InGravity
		}
		ConditionalGameActionState InDialogue
		{
			myNegate TRUE
			myGameActionState InDialogue
		}
		ConditionalActionGroup "Not Flying Or In Space"
		{
			myOperator Or
			myConditionalInputActions
			{
				ConditionalGameActionState "Not Flying"
				{
					myNegate TRUE
					myGameActionState IsFlying
				}
				ConditionalGameActionState InSpace
				{
					myGameActionState InSpace
				}
			}
		}
		ConditionalActionGroup "In Combat"
		{
			myOperator Or
			myConditionalInputActions
			{
				ConditionalGameActionState IsInCombat
				{
					myNegate TRUE
					myGameActionState IsInCombat
				}
				ConditionalGameActionState IsHailableInCombat
				{
					myNegate TRUE
					myGameActionState IsHailableInCombat
				}
			}
		}
		ConditionalGameActionState IsHailEnabled
		{
			myGameActionState IsHailEnabled
		}
	}
	myGameAction PlayerQuery_InteractFailInCombat
}

