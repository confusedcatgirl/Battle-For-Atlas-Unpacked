TriggerGameAction "[Interact] Can Use Towable"
{
	myConditionalInputActions
	{
		ConditionalGameActionState IsFlippedOver
		{
			myNegate TRUE
			myGameActionState IsFlippedOver
		}
		ConditionalGameActionState IsHoldingObject
		{
			myGameActionState IsHoldingObject
		}
		ConditionalGameActionState CanUseTowable
		{
			myGameActionState CanUseTowable
		}
		ConditionalActionGroup "No Valid Fast Travel Target or can't fast travel"
		{
			myOperator Or
			myConditionalInputActions
			{
				ConditionalGameActionState HasValidFastTravelTarget
				{
					myNegate TRUE
					myGameActionState HasValidFastTravelTarget
				}
				ConditionalGameAction PlayerQuery_CanFastTravel
				{
					myNegate TRUE
					myGameAction PlayerQuery_CanFastTravel
				}
			}
		}
		ConditionalGameActionState InHyperspace
		{
			myNegate TRUE
			myGameActionState InHyperspace
		}
		ConditionalGameActionState IsInPlanetaryTransition
		{
			myNegate TRUE
			myGameActionState IsInPlanetaryTransition
		}
		ConditionalGameActionState ShouldBeDowned
		{
			myNegate TRUE
			myGameActionState ShouldBeDowned
		}
		ConditionalGameActionState IsReticleOverScannable
		{
			myNegate TRUE
			myGameActionState IsReticleOverScannable
		}
		ConditionalGameActionState IsReticleOverHailable
		{
			myNegate TRUE
			myGameActionState IsReticleOverHailable
		}
		ConditionalGameActionState IsReticleOverRepairable
		{
			myNegate TRUE
			myGameActionState IsReticleOverRepairable
		}
		ConditionalGameActionState IsReticleOverOpenable
		{
			myNegate TRUE
			myGameActionState IsReticleOverOpenable
		}
		ConditionalActionGroup "Not Frozen or Has Freeze Mobility"
		{
			myOperator Or
			myConditionalInputActions
			{
				ConditionalGameActionState IsFrozen
				{
					myNegate TRUE
					myGameActionState IsFrozen
				}
				ConditionalGameActionState HasFreezeMobility
				{
					myGameActionState HasFreezeMobility
				}
			}
		}
		ConditionalGameActionState InStasis
		{
			myNegate TRUE
			myGameActionState InStasis
		}
		ConditionalGameActionState IsRagdoll
		{
			myNegate TRUE
			myGameActionState IsRagdoll
		}
		ConditionalGameActionState IsDead
		{
			myNegate TRUE
			myGameActionState IsDead
		}
		ConditionalGameActionState IsUseItemEnabled
		{
			myGameActionState IsUseItemEnabled
		}
		ConditionalGameActionState InDialogue
		{
			myNegate TRUE
			myGameActionState InDialogue
		}
	}
	myGameAction PlayerQuery_CanUseTowable
}

TriggerGameAction "[Interact] Can Start Pluck"
{
	myConditionalInputActions
	{
		ConditionalGameActionState "Not Plucking"
		{
			myNegate TRUE
			myGameActionState IsPlucking
		}
		ConditionalGameActionState IsReticleOverPluckable
		{
			myGameActionState IsReticleOverPluckable
		}
		ConditionalGameActionState IsRagdoll
		{
			myNegate TRUE
			myGameActionState IsRagdoll
		}
		ConditionalGameActionState IsFlippedOver
		{
			myNegate TRUE
			myGameActionState IsFlippedOver
		}
		ConditionalGameActionState IsPluckEnabled
		{
			myGameActionState IsPluckEnabled
		}
		ConditionalGameActionState IsPickupAnimating
		{
			myNegate TRUE
			myGameActionState IsPickupAnimating
		}
		ConditionalGameActionState InDialogue
		{
			myNegate TRUE
			myGameActionState InDialogue
		}
		ConditionalGameActionState IsInFollowMode
		{
			myNegate TRUE
			myGameActionState IsInFollowMode
		}
		ConditionalGameActionState InStasis
		{
			myNegate TRUE
			myGameActionState InStasis
		}
		ConditionalGameActionState IsFrozen
		{
			myNegate TRUE
			myGameActionState IsFrozen
		}
		ConditionalGameActionState ShouldBeDowned
		{
			myNegate TRUE
			myGameActionState ShouldBeDowned
		}
		ConditionalActionGroup "!CanStore || (CanStore && HasSpace)"
		{
			myOperator Or
			myConditionalInputActions
			{
				ConditionalActionGroup "CanStore && HasSpace"
				{
					myConditionalInputActions
					{
						ConditionalGameActionState CanStore
						{
							myGameActionState CanStoreReticleItem
						}
						ConditionalGameActionState HasSpace
						{
							myGameActionState InventoryHasSpaceForReticleItem
						}
					}
				}
				ConditionalGameActionState !CanStore
				{
					myNegate TRUE
					myGameActionState CanStoreReticleItem
				}
			}
		}
		ConditionalActionGroup "Is not flying / is in space"
		{
			myOperator Or
			myConditionalInputActions
			{
				ConditionalGameActionState NotFlying
				{
					myNegate TRUE
				}
				ConditionalGameActionState InSpace
				{
					myGameActionState InSpace
				}
			}
		}
		ConditionalGameActionState IsPickupAnimating
		{
			myNegate TRUE
			myGameActionState IsPickupAnimating
		}
	}
	myGameAction PlayerQuery_CanStartPluck
}

TriggerGameAction "[Interact] Pluck Fail Inventory"
{
	myConditionalInputActions
	{
		ConditionalGameActionState "Not Plucking"
		{
