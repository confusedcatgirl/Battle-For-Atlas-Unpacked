TriggerGameAction "[Interact] Can Start Towing"
{
	myConditionalInputActions
	{
		ConditionalGameActionState IsFlippedOver
		{
			myNegate TRUE
			myGameActionState IsFlippedOver
		}
		ConditionalGameActionState IsStalled
		{
			myNegate TRUE
			myGameActionState IsStalled
		}
		ConditionalGameActionState IsRagdoll
		{
			myNegate TRUE
			myGameActionState IsRagdoll
		}
		ConditionalGameActionState IsDead
		{
			myNegate TRUE
			myGameActionState IsDead
		}
		ConditionalGameActionState ShouldBeDowned
		{
			myNegate TRUE
			myGameActionState ShouldBeDowned
		}
		ConditionalGameActionState InHyperspace
		{
			myNegate TRUE
			myGameActionState InHyperspace
		}
		ConditionalGameActionState InStasis
		{
			myNegate TRUE
			myGameActionState InStasis
		}
		ConditionalGameActionState "Not Picking Up"
		{
			myNegate TRUE
			myGameActionState IsPickingUp
		}
		ConditionalGameActionState "Not Picking Animating"
		{
			myNegate TRUE
			myGameActionState IsPickupAnimating
		}
		ConditionalGameActionState "Not Plucking"
		{
			myNegate TRUE
			myGameActionState IsPlucking
		}
		ConditionalGameActionState IsReticleOverTowable
		{
			myGameActionState IsReticleOverTowable
		}
		ConditionalActionGroup "Not Flying Or In Space"
		{
			myOperator Or
			myConditionalInputActions
			{
				ConditionalGameActionState "Not Flying"
				{
					myNegate TRUE
					myGameActionState IsFlying
				}
				ConditionalGameActionState InSpace
				{
					myGameActionState InSpace
				}
			}
		}
		ConditionalGameActionState IsPickupEnabled
		{
			myGameActionState IsPickupEnabled
		}
		ConditionalActionGroup "!CanStore || (CanStore && HasSpace)"
		{
			myOperator Or
			myConditionalInputActions
			{
				ConditionalActionGroup "CanStore && HasSpace"
				{
					myConditionalInputActions
					{
						ConditionalGameActionState CanStore
						{
							myGameActionState CanStoreReticleItem
						}
						ConditionalGameActionState HasSpace
						{
							myGameActionState InventoryHasSpaceForReticleItem
						}
					}
				}
				ConditionalGameActionState !CanStore
				{
					myNegate TRUE
					myGameActionState CanStoreReticleItem
				}
			}
		}
		ConditionalGameActionState !IsPendingInventoryItem
		{
			myNegate TRUE
			myGameActionState IsPendingInventoryItem
		}
		ConditionalGameActionState IsPilotTrialEventActive
		{
			myNegate TRUE
			myGameActionState IsPilotTrialEventActive
		}
	}
	myGameAction PlayerQuery_CanStartTowing
}

