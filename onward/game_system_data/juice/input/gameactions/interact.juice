include "onward/game system data/juice/input/inputactions.juice"
include "onward/game system data/fruit/input/gameinput.fruit"

TriggerGameAction "[Interact] Can Interact"
{
	myConditionalInputActions
	{
		ConditionalGameActionState IsFlippedOver
		{
			myNegate TRUE
			myGameActionState IsFlippedOver
		}
		ConditionalGameActionState IsStalled
		{
			myNegate TRUE
			myGameActionState IsStalled
		}
		ConditionalGameActionState IsRagdoll
		{
			myNegate TRUE
			myGameActionState IsRagdoll
		}
		ConditionalGameActionState IsDead
		{
			myNegate TRUE
			myGameActionState IsDead
		}
		ConditionalGameActionState ShouldBeDowned
		{
			myNegate TRUE
			myGameActionState ShouldBeDowned
		}
		ConditionalGameActionState InHyperspace
		{
			myNegate TRUE
			myGameActionState InHyperspace
		}
		ConditionalGameActionState HasNPCAttached
		{
			myNegate TRUE
			myGameActionState HasNPCAttached
		}
		ConditionalGameActionState InStasis
		{
			myNegate TRUE
			myGameActionState InStasis
		}
		ConditionalGameActionState InDialogue
		{
			myNegate TRUE
			myGameActionState InDialogue
		}
		ConditionalGameActionState IsFrozen
		{
			myNegate TRUE
			myGameActionState IsFrozen
		}
		ConditionalGameActionState IsInFollowMode
		{
			myNegate TRUE
			myGameActionState IsInFollowMode
		}
		ConditionalGameActionState IsCoopEnterHandshake
		{
			myNegate TRUE
			myGameActionState IsCoopEnterHandshake
		}
		ConditionalGameActionState IsInFadeRequest
		{
			myNegate TRUE
			myGameActionState IsInFadeRequest
		}
	}
	myGameAction PlayerQuery_CanInteract
}

