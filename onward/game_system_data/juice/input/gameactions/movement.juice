		}
		ConditionalActionGroup "INPUT BOOST"
		{
			myOperator Or
			myConditionalInputActions
			{
				ConditionalInputAction "Hold B"
				{
					myInputActionType HoldDownAfterTime
					myTimer 150
					myInputAction = B_CRICLE
				}
				ConditionalInputAction "Keyboard boost"
				{
					myInputActionType HoldDownAfterTime
					myTimer 150
					myInputAction = KB_BOOST
