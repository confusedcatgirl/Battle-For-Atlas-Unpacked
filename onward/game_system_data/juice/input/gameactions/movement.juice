TriggerGameAction "[Movement] Can Start Flight Engines"
{
	myConditionalInputActions
	{
		ConditionalGameActionState InSpace
		{
			myNegate TRUE
			myGameActionState InSpace
		}
		ConditionalGameActionState IsFlippedOver
		{
			myNegate TRUE
			myGameActionState IsFlippedOver
		}
		ConditionalGameActionState IsRagdoll
		{
			myNegate TRUE
			myGameActionState IsRagdoll
		}
		ConditionalGameActionState IsHoldingHeavyObject
		{
			myNegate TRUE
			myGameActionState IsHoldingHeavyObject
		}
		ConditionalGameActionState IsFrozen
		{
			myNegate TRUE
			myGameActionState IsFrozen
		}
		ConditionalGameActionState InStasis
		{
			myNegate TRUE
			myGameActionState InStasis
		}
		ConditionalGameActionState AreFlightEnginesEnabled
		{
			myGameActionState AreFlightEnginesEnabled
		}
		ConditionalGameActionState ShouldBeDowned
		{
			myNegate TRUE
			myGameActionState ShouldBeDowned
		}
		ConditionalGameActionState InDialogue
		{
			myNegate TRUE
			myGameActionState InDialogue
		}
		ConditionalActionGroup "Not Flying or Launching"
		{
			myOperator Or
			myConditionalInputActions
			{
				ConditionalGameActionState "Not Flying"
				{
					myNegate TRUE
				}
				ConditionalGameActionState Launching
				{
					myGameActionState IsLaunching
				}
			}
		}
		ConditionalGameActionState "Not In Follow"
		{
			myNegate TRUE
			myGameActionState IsInFollowMode
		}
		ConditionalGameActionState IsPilotTrialEventActive
		{
			myNegate TRUE
			myGameActionState IsPilotTrialEventActive
		}
		ConditionalGameActionState NotIsPluckingButtonSequence
		{
			myNegate TRUE
			myGameActionState IsPluckingButtonSequence
		}
	}
	myGameAction PlayerQuery_CanStartFlightEngines
}

