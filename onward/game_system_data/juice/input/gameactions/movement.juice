		ConditionalGameActionState IsSkimmerEnabled
		{
			myGameActionState IsFeatureEnabled_Skimmer
		}
		ConditionalGameActionState IsInPlanetaryTransition
		{
			myNegate TRUE
			myGameActionState IsInPlanetaryTransition
		}
	}
	myGameAction PlayerQuery_CanStopFlightEngines
}

TriggerGameAction "[Movement] Can Start Hyper Drive"
{
	myConditionalInputActions
	{
		ConditionalGameActionState IsRagdoll
		{
			myNegate TRUE
			myGameActionState IsRagdoll
		}
		ConditionalGameActionState IsHyperDriveEnabled
		{
			myGameActionState IsHyperDriveEnabled
		}
		ConditionalGameActionState InSpace
		{
			myGameActionState InSpace
		}
		ConditionalGameActionState IsInPlanetaryTransition
		{
			myNegate TRUE
			myGameActionState IsInPlanetaryTransition
		}
		ConditionalGameActionState InStasis
		{
			myNegate TRUE
			myGameActionState InStasis
		}
		ConditionalGameActionState InGravity
		{
			myNegate TRUE
			myGameActionState InGravity
		}
		ConditionalGameActionState IsFrozen
		{
			myNegate TRUE
			myGameActionState IsFrozen
		}
		ConditionalGameActionState ShouldBeDowned
		{
			myNegate TRUE
			myGameActionState ShouldBeDowned
		}
		ConditionalGameActionState InDialogue
		{
			myNegate TRUE
			myGameActionState InDialogue
		}
		ConditionalGameActionState FastTravelInitiated
		{
			myNegate TRUE
			myGameActionState FastTravelInitiated
		}
		ConditionalActionGroup "Not in hyper space or starting"
		{
			myOperator Or
			myConditionalInputActions
			{
				ConditionalGameActionState IsInHyperDrive
				{
					myNegate TRUE
					myGameActionState InHyperspace
				}
				ConditionalGameActionState IsStartingHyperDrive
				{
					myGameActionState IsStartingHyperDrive
				}
			}
		}
		ConditionalGameActionState IsInReverseCamera
		{
			myNegate TRUE
			myGameActionState IsInReverseCamera
		}
		ConditionalGameActionState NotIsPluckingButtonSequence
		{
			myNegate TRUE
			myGameActionState IsPluckingButtonSequence
		}
		ConditionalGameActionState NotIsBeingTowed
		{
			myNegate TRUE
			myGameActionState IsBeingTowed
		}
	}
	myGameAction PlayerQuery_CanStartHyperDrive
}

TriggerGameAction "[Movement] Can Stop Hyper Drive"
{
	myConditionalInputActions
	{
		ConditionalGameActionState IsInHyperDrive
		{
			myGameActionState InHyperspace
		}
		ConditionalGameActionState IsInFollowMode
		{
			myNegate TRUE
			myGameActionState IsInFollowMode
		}
		ConditionalGameActionState IsStartingHyperDrive
		{
			myNegate TRUE
			myGameActionState IsStartingHyperDrive
		}
	}
	myGameAction PlayerQuery_CanStopHyperDrive
}

TriggerGameAction "[Movement] Flight Engine Start"
{
	myConditionalInputActions
	{
		ConditionalGameAction PlayerQuery_CanStartFlightEngines
		{
			myRequireNewInput TRUE
			myGameAction PlayerQuery_CanStartFlightEngines
		}
		ConditionalActionGroup "INPUT FLIGHT START"
		{
			myOperator Or
			myConditionalInputActions
			{
				ConditionalInputAction LB
				{
					myInputActionType HoldDownBeforeTime
					myTimer 550
					myInputAction = RIGHT_BUMPER_R1
				}
				ConditionalInputAction "Keyboard Fly Mode start"
				{
					myInputActionType HoldDownBeforeTime
					myTimer 550
					myInputAction = KB_FLIGHTMODE
				}
			}
		}
	}
	myGameAction FlightEngineStart
}

