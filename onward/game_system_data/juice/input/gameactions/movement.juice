TriggerGameAction "[Movement] Hyper Drive Stop"
{
	myConditionalInputActions
	{
		ConditionalActionGroup "Not Flying or Launching"
		{
			myOperator Or
			myConditionalInputActions
			{
				ConditionalGameActionState IsFrozen
				{
					myGameActionState IsFrozen
				}
				ConditionalGameActionState InStasis
				{
					myGameActionState InStasis
				}
				ConditionalGameActionState InGravity
				{
					myGameActionState InGravity
				}
				ConditionalGameActionState InDialogue
				{
					myGameActionState InDialogue
				}
				ConditionalGameActionState IsFastTravelling
				{
					myGameActionState IsFastTravelling
				}
				ConditionalActionGroup "INPUT HYPER DRIVE STOP"
				{
					myOperator Or
					myConditionalInputActions
					{
						ConditionalInputAction LB
						{
							myInputAction = RIGHT_BUMPER_R1
						}
						ConditionalInputAction "Keyboard HyperDrive Stop"
						{
							myInputAction = KB_FLIGHTMODE
						}
					}
				}
			}
		}
		ConditionalGameAction PlayerQuery_CanStopHyperDrive
		{
			myRequireNewInput TRUE
			myGameAction PlayerQuery_CanStopHyperDrive
		}
	}
	myGameAction StopHyperDrive
}

TriggerGameAction "[Movement] Reset Controller Orientation"
{
	myConditionalInputActions
	{
		ConditionalInputAction "Left Stick Click"
		{
			myInputAction = LEFT_STICK_BUTTON
		}
	}
	myGameAction ResetOrientation
}

TriggerGameAction "[Movement] Toggle Ghost"
{
	myConditionalInputActions
	{
		ConditionalActionGroup "LS Click + RS Click"
		{
			myOperator And
			myConditionalInputActions
			{
				ConditionalInputAction "LS Click"
				{
					myInputActionType Pressed
					myInputAction = LEFT_STICK_BUTTON
				}
				ConditionalInputAction "RS Click"
				{
					myInputActionType HoldDown
					myInputAction = RIGHT_STICK_BUTTON
				}
			}
		}
	}
	myGameAction ToggleGhost
}

TriggerGameAction "[Movement] Toggle Ghost2"
{
	myConditionalInputActions
	{
		ConditionalActionGroup "LS Click + RS Click"
		{
			myOperator And
			myConditionalInputActions
			{
				ConditionalInputAction "LS Click"
				{
					myInputActionType HoldDown
					myInputAction = LEFT_STICK_BUTTON
				}
