				}
				ConditionalInputAction "Keyboard Fly Start Tutorial Version"
				{
					myInputActionType HoldDownAfterTime
					myTimer 500
					myInputAction = KB_FLIGHTMODE
				}
			}
		}
	}
	myGameAction FlightEnginesStartTutorial
}

TriggerGameAction "[Movement] Flight Engine Start Fail"
{
	myConditionalInputActions
	{
		ConditionalGameAction PlayerQuery_CanStartFlightEngines
		{
			myNegate TRUE
			myRequireNewInput TRUE
			myGameAction PlayerQuery_CanStartFlightEngines
		}
		ConditionalGameActionState IsFlying
		{
			myNegate TRUE
			myGameActionState IsFlying
		}
		ConditionalGameActionState IsInFollowMode
		{
			myNegate TRUE
			myGameActionState IsInFollowMode
		}
		ConditionalActionGroup "INPUT FLY MODE START FAIL"
		{
			myOperator Or
			myConditionalInputActions
			{
				ConditionalInputAction LB
				{
					myInputActionType Pressed
					myInputAction = RIGHT_BUMPER_R1
				}
				ConditionalInputAction "Keyboard Fly Start Fail"
				{
					myInputAction = KB_FLIGHTMODE
				}
			}
		}
	}
	myGameAction FlightEngineFailStart
}

