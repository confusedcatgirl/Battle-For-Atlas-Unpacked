TriggerGameAction "[Movement] Hyper Drive Start Fail"
{
	myConditionalInputActions
	{
		ConditionalGameAction PlayerQuery_CanStartHyperDrive
		{
			myNegate TRUE
			myRequireNewInput TRUE
			myGameAction PlayerQuery_CanStartHyperDrive
		}
		ConditionalActionGroup "INPUT HYPERDRIVE FAIL"
		{
			myOperator Or
			myConditionalInputActions
			{
				ConditionalInputAction LB
				{
					myInputActionType HoldDownBeforeTime
					myTimer 550
					myInputAction = RIGHT_BUMPER_R1
				}
				ConditionalInputAction "New ConditionalInputAction (1)"
