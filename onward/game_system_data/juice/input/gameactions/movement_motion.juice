}

TriggerGameAction "[Movement] Maneuver Start"
{
	myConditionalInputActions
	{
		ConditionalInputAction A_Cross
		{
			myInputActionType Pressed
			myTimer 0
			myValidForTimer 250
			myInputAction = B_CRICLE
		}
		ConditionalGameAction PlayerQuery_CanManeuver
		{
			myGameAction PlayerQuery_CanManeuver
		}
	}
	myGameAction ManeuverStart
}

TriggerGameAction "[Movement] Dash Start"
{
	myConditionalInputActions
	{
		ConditionalInputAction A_Cross
		{
			myInputActionType Pressed
			myTimer 0
			myValidForTimer 250
			myInputAction = B_CRICLE
		}
		ConditionalGameAction PlayerQuery_CanDash
		{
			myGameAction PlayerQuery_CanDash
		}
	}
	myGameAction DashStart
}

TriggerGameAction "[Movement] ManeuverBack"
{
	myConditionalInputActions
	{
		ConditionalInputAction "LS Down"
		{
			myInputActionType HoldDown
			myValidForTimer 250
			myInputAction = PITCH_UP
		}
		ConditionalInputAction "Not LS Up"
		{
			myInputActionType HoldDown
			myNegate TRUE
			myInputAction = PITCH_DOWN
		}
		ConditionalInputAction "Not LS Left"
		{
			myInputActionType HoldDown
			myNegate TRUE
			myInputAction = ROLL_LEFT
		}
		ConditionalInputAction "Not LS Right"
		{
			myInputActionType HoldDown
			myNegate TRUE
			myInputAction = ROLL_RIGHT
		}
		ConditionalGameAction "Maneuver Start"
		{
			myGameAction ManeuverStart
		}
	}
	myGameAction ManeuverBack
}

TriggerGameAction "[Movement] Maneuver Front"
{
	myConditionalInputActions
	{
		ConditionalInputAction "LS Up"
		{
			myInputActionType HoldDown
