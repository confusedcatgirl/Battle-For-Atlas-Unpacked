TriggerGameAction "[Movement] Trick Neutral"
{
	myConditionalInputActions
	{
		ConditionalGameActionState IsFlying
		{
			myGameActionState IsFlying
		}
		ConditionalInputAction "Press RB"
		{
			myInputActionType Pressed
			myInputAction = B_CRICLE
		}
	}
	myGameAction TrickNeutral
}

TriggerGameAction "[Movement] Trick Left"
{
	myConditionalInputActions
	{
		ConditionalActionGroup Group
		{
			myOperator And
			myConditionalInputActions
			{
				ConditionalGameActionState InAirTrickWindow
				{
					myGameActionState InAirTrickWindow
				}
				ConditionalInputAction "Rotated Left Stick Left Analog"
				{
					myInputActionType HoldDown
					myValidForTimer 200
					myInputAction = ROLL_LEFT
				}
				ConditionalGameAction ManeuverStart
				{
					myGameAction ManeuverStart
				}
			}
		}
	}
	myGameAction TrickLeft
}

