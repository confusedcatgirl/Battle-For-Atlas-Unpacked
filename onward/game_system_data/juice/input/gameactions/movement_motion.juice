TriggerGameAction "[Movement] Maneuver Neutral"
{
	myConditionalInputActions
	{
		ConditionalGameAction "Maneuver Start"
		{
			myGameAction ManeuverStart
		}
		ConditionalGameActionState IsFalling
		{
			myNegate TRUE
			myGameActionState IsFalling
		}
		ConditionalGameActionState InStasis
		{
			myNegate TRUE
			myGameActionState InStasis
		}
	}
	myGameAction ManeuverNeutral
}

