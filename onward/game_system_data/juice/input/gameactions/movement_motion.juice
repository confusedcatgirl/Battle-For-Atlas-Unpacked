		{
			myInputActionType HoldDownBeforeTime
			myTimer 550
			myInputAction = LEFT_BUMPER_L1
		}
		ConditionalGameAction PlayerQuery_CanStartHyperDrive
		{
			myGameAction PlayerQuery_CanStartHyperDrive
