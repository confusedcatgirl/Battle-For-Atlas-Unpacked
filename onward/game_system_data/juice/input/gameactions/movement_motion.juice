TriggerGameAction "[Movement] Hop"
{
	myConditionalInputActions
	{
		ConditionalInputAction "Press RB"
		{
			myInputActionType Pressed
			myInputAction = RIGHT_BUMPER_R1
		}
		ConditionalGameActionState InHopWindow
		{
			myGameActionState InHopWindow
		}
		ConditionalGameActionState IsFalling
		{
			myNegate TRUE
			myGameActionState IsFalling
		}
		ConditionalGameActionState InStasis
		{
			myNegate TRUE
			myGameActionState InStasis
		}
		ConditionalGameAction PlayerQuery_CanManeuver
		{
			myGameAction PlayerQuery_CanManeuver
		}
	}
	myGameAction Hop
}

TriggerGameAction "[Movement] Flipped Over Recover"
{
	myConditionalInputActions
	{
		ConditionalInputAction R1
		{
			myInputActionType Pressed
			myInputAction = RIGHT_BUMPER_R1
		}
	}
	myGameAction FlippedOverRecover
}

TriggerGameAction "[Movement] Jet Engine"
{
	myConditionalInputActions
	{
		ConditionalInputAction "Hold R1"
		{
			myInputActionType HoldDown
			myInputAction = RIGHT_BUMPER_R1
		}
	}
	ConditionalGameActionState IsManeuvering
	{
		myNegate TRUE
		myGameActionState IsManeuvering
	}
	myGameAction JetEngine
}
