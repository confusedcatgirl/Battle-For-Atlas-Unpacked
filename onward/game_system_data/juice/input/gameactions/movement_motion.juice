include "onward/game system data/juice/input/inputactions.juice"
include "onward/game system data/fruit/input/gameinput.fruit"

TriggerGameAction "[Movement] Can Maneuver"
{
	myConditionalInputActions
	{
		ConditionalGameActionState IsFlippedOver
		{
			myNegate TRUE
			myGameActionState IsFlippedOver
		}
		ConditionalGameActionState IsHoldingHeavyObject
		{
			myNegate TRUE
			myGameActionState IsHoldingHeavyObject
		}
	}
	myGameAction PlayerQuery_CanManeuver
}

TriggerGameAction "[Movement] Can Dash"
{
	myConditionalInputActions
	{
		ConditionalGameActionState IsFlippedOver
		{
			myNegate TRUE
			myGameActionState IsFlippedOver
		}
		ConditionalGameActionState IsHoldingHeavyObject
		{
			myNegate TRUE
			myGameActionState IsHoldingHeavyObject
		}
		ConditionalGameActionState IsFalling
		{
			myNegate TRUE
			myGameActionState IsFalling
		}
		ConditionalGameActionState InHopWindow
		{
			myGameActionState InHopWindow
		}
		ConditionalGameActionState InStasis
		{
			myNegate TRUE
			myGameActionState InStasis
		}
	}
	myGameAction PlayerQuery_CanDash
}

TriggerGameAction "[Movement] Move Forward"
{
	myConditionalInputActions
	{
		ConditionalInputAction "Rotated Left Stick Up Analog"
		{
			myInputActionType Analog
			myInputAction = LEFT_STICK_UP
		}
	}
	myGameAction MoveForward
}

