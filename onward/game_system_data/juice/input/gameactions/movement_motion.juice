}

TriggerGameAction "[Movement] Reset Controller Orientation"
{
	myConditionalInputActions
	{
		ConditionalInputAction "Left Stick Click"
		{
			myInputAction = LEFT_STICK_BUTTON
		}
	}
	myGameAction ResetOrientation
}

TriggerGameAction "[Movement] Toggle Motion Controls"
{
	myConditionalInputActions
	{
		ConditionalActionGroup "Right Stick Click and D-Pad Down"
		{
			myOperator And
			myConditionalInputActions
			{
				ConditionalInputAction "Dpad Down Down"
				{
					myInputActionType HoldDown
					myToggle FALSE
					myInputAction = D_PAD_DOWN
				}
				ConditionalInputAction "RS Click"
				{
					myInputAction = RIGHT_STICK_BUTTON
				}
			}
		}
	}
	myGameAction ToggleMotion
}

TriggerGameAction "[Movement] Toggle Ghost"
{
	myConditionalInputActions
	{
		ConditionalActionGroup "LS Click + RS Click"
		{
			myOperator And
			myConditionalInputActions
			{
				ConditionalInputAction "LS Click"
				{
					myInputActionType Pressed
					myInputAction = LEFT_STICK_BUTTON
				}
				ConditionalInputAction "RS Click"
				{
					myInputActionType HoldDown
					myInputAction = RIGHT_STICK_BUTTON
				}
			}
		}
	}
	myGameAction ToggleGhost
}

TriggerGameAction "[Movement] Toggle Ghost2"
{
	myConditionalInputActions
	{
