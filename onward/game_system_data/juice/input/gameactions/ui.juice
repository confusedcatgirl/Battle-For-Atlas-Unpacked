TriggerGameAction "[UI] Database Shortcut"
{
	myConditionalInputActions
	{
		ConditionalActionGroup "INPUT DATABASE SHORTCUT"
		{
			myOperator Or
			myConditionalInputActions
			{
				ConditionalInputAction "Button Pressed"
				{
					myInputActionType HoldDownAfterTime
					myTimer 1000
					myInputAction = START
				}
				ConditionalInputAction "Keyboard DB Shortcut ALT"
				{
					myInputActionType HoldDownAfterTime
					myTimer 1000
					myInputAction = KB_LOADOUTALT
				}
			}
		}
		ConditionalGameActionState "Not in Photomode"
		{
			myNegate TRUE
			myGameActionState IsInPhotoMode
		}
	}
	myGameAction UIDatabaseShortcut
}

TriggerGameAction "[Interact] Can Accept OnIt"
{
	myConditionalInputActions
	{
		ConditionalGameActionState IsDead
		{
			myNegate TRUE
			myGameActionState IsDead
		}
		ConditionalGameActionState IsPilotTrialEventActive
		{
			myNegate TRUE
			myGameActionState IsPilotTrialEventActive
		}
		ConditionalGameActionState "Not In Camera Sequence"
		{
			myNegate TRUE
			myGameActionState InDialogue
		}
	}
	myGameAction PlayerQuery_CanAcceptMission
}

TriggerGameAction "[Interact] Can Cancel OnIt"
{
	myConditionalInputActions
	{
		ConditionalGameActionState CanCancelSelectedOpportunity
		{
			myGameActionState CanCancelSelectedOpportunity
		}
		ConditionalGameActionState IsPilotTrialEventActive
		{
			myNegate TRUE
			myGameActionState IsPilotTrialEventActive
		}
		ConditionalGameActionState "Not In Camera Sequence"
		{
			myNegate TRUE
			myGameActionState InDialogue
		}
	}
	myGameAction PlayerQuery_CanCancelMission
}

