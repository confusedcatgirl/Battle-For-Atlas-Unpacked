				{
					myInputActionType Pressed
					myInputAction = A_CROSS
					myInputActionAlt = UI_B_CIRCLE
				}
				ConditionalInputAction "Keyboard UI Accept"
				{
					myInputActionType Pressed
					myInputAction = KB_UI_INTERACT
					myInputActionAlt = KB_UI_INTERACT
				}
			}
		}
	}
	myGameAction UIAccept
	myIsUIAction TRUE
	myUseAltWhenConfirmSwapped TRUE
}

