InterestDistanceDefinitions InterestDistanceDefinitions
{
	InterestDistanceDefinition Zero
	{
	}
	InterestDistanceDefinition "Very Close"
	{
		myInterestDistance VeryClose
		myDistance 300.0
	}
	InterestDistanceDefinition Close
	{
		myInterestDistance Close
		myDistance 1000.0
	}
	InterestDistanceDefinition Medium
	{
		myInterestDistance Medium
		myDistance 1750.0
	}
	InterestDistanceDefinition Far
	{
		myInterestDistance Far
		myDistance 2500.0
	}
	InterestDistanceDefinition VeryFar
	{
		myInterestDistance VeryFar
		myDistance 4000.0
	}
	InterestDistanceDefinition "PlanetWide - distance defined in code but need this placeholder"
	{
		myInterestDistance PlanetWide
		myDistance -1.0
	}
	InterestDistanceDefinition "SolarSystem - distance defined in code but need this placeholder"
	{
		myInterestDistance SolarSystem
		myDistance -1.0
	}
}

