	NPCType Harvester_Imp_Cold Harvester_Imp_Cold
	NPCType Harvester_Imp_Heat Harvester_Imp_Heat
	NPCType Harvester_Imp_Crush Harvester_Imp_Crush
	NPCType Harvester_Imp_Crush Harvester_Imp_Crush
	NPCType Harvester_Drake Harvester_Drake
	NPCType Harvester_Drake_Heat Harvester_Drake_Heat
	NPCType Outlaw_Defender Outlaw_Defender
	NPCType Harvester_Probe Harvester_Probe
}

