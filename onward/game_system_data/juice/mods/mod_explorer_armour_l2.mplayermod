include ./template_hull.mplayermod
include ./tuning/mod_tuning_master.juice

PlayerMod mod_explorer_armour_l2 < uid=C91BB55159808875000F225F04E2B97E > : template_hull
{
	myAttributeMods
	{
		AttributeMod Weight
		{
			myType PartStat_Mass
			myAddValue = Explorer_Armor_l2_Mass
		}
		AttributeMod Defense
		{
			myType PartStat_Defense
			myAddValue = Explorer_Armor_l2_Defense
		}
	}
	myIsSelfMod TRUE
	myIsAgentMod TRUE
}

