include ./template_shipcore.mplayermod
include ./tuning/mod_tuning_master.juice

PlayerMod mod_fighter_shipcore_l2 < uid=C91BB551597F5285007FB71AEC71B642 > : template_shipcore
{
	myAttributeMods
	{
		AttributeMod Handling
		{
			myType PartStat_Handling
			myAddValue = Fighter_Core_l2_Handling
		}
		AttributeMod Speed
		{
			myType PartStat_Speed
			myAddValue = Fighter_Core_l2_Speed
		}
	}
	myIsSelfMod TRUE
}

