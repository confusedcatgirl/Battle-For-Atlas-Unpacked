PlayerMod mod_fighter_shipcore_l3 < uid=C91BB551597F528E007FB71B73C8F723 > : template_shipcore
{
	myAttributeMods
	{
		AttributeMod Handling
		{
			myType PartStat_Handling
			myAddValue = Fighter_Core_l3_Handling
		}
		AttributeMod Speed
		{
			myType PartStat_Speed
			myAddValue = Fighter_Core_l3_Speed
		}
	}
	myIsSelfMod TRUE
}

