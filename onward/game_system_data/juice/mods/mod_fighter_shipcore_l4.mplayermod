PlayerMod mod_fighter_shipcore_l4 < uid=C91BB551597F5295007FB71C220D9461 > : template_shipcore
{
	myAttributeMods
	{
		AttributeMod Handling
		{
			myType PartStat_Handling
			myAddValue = Fighter_Core_l4_Handling
		}
		AttributeMod Speed
		{
			myType PartStat_Speed
			myAddValue = Fighter_Core_l4_Speed
		}
	}
	myIsSelfMod TRUE
}

