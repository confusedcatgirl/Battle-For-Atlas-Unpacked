include ./template_pilot.mplayermod

PlayerMod mod_perk_group_hack < uid=C91BB55159CE6B8C006A3BDB445E9553 > : template_pilot
{
	myAttributeMods
	{
		AttributeMod "Group Hack Range"
		{
			myType Range
			myMultValue 1.0
			myAddValue = Group_Hack_l1_Range
			myPercentageValue 0.0
		}
		AttributeMod MaxNumber
		{
			myType Size
			myAddValue = Group_Hack_l1_HackLimit
		}
	}
	myIsSelfMod TRUE
}

