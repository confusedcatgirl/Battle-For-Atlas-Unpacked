include ./template_pilot.mplayermod

PlayerMod mod_perk_more_is_better_l1 < uid=C91BB5515A57B96000C55B7D3DF9D7AB > : template_pilot
{
	myAttributeMods
	{
		AttributeMod Projectiles
		{
			myType Projectile_Number
			myAddValue = More_Is_Better_l1_ExtraShots
			myPercentageValue 0.0
		}
		AttributeMod "Ability Duration"
		{
			myType Ability_DurationMax
			myAddValue = More_Is_Better_l1_ExtraTime
		}
	}
	myIsSelfMod TRUE
}

