include ./template_pilot.mplayermod

PlayerMod mod_perk_more_is_better_l2 < uid=C91BB5515A57B97800C55B86B1A9DD41 > : template_pilot
{
	myAttributeMods
	{
		AttributeMod Projectiles
		{
			myType Projectile_Number
			myAddValue = More_Is_Better_l2_ExtraShots
			myPercentageValue 0.0
		}
		AttributeMod "Ability Duration"
		{
			myType Ability_DurationMax
			myAddValue = More_Is_Better_l2_ExtraTime
		}
	}
	myIsSelfMod TRUE
}

