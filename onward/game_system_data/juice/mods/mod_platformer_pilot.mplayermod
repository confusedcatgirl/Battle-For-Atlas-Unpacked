include ./template_pilot.mplayermod

PlayerMod mod_platformer_pilot < uid=0A13A8F05AFEE1500000AA26B6B5FD56 > : template_pilot
{
	myAttributeMods
	{
		AttributeMod DashImpulseUp
		{
			myType Player_DashImpulseUp
			myMultValue 2.0
			myAddValue 0.0
		}
		AttributeMod Drag
		{
			myType Player_Drag
			myMultValue 1.5
		}
	}
	myIsAgentMod TRUE
}

