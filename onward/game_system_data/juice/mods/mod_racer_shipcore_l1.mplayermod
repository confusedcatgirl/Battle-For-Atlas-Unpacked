PlayerMod mod_racer_shipcore_l1 < uid=C91BB551596FBA3A0000021DAD51D6EB > : template_shipcore
{
	myAttributeMods
	{
		AttributeMod Speed
		{
			myType PartStat_Speed
			myAddValue = Racer_Core_l1_Speed
		}
		AttributeMod Handling
		{
			myType PartStat_Handling
			myAddValue = Racer_Core_l1_Handling
		}
	}
	myIsSelfMod TRUE
}

