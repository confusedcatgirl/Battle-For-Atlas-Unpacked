include ./template_shipcore.mplayermod
include ./tuning/mod_tuning_master.juice

PlayerMod mod_racer_shipcore_l2 < uid=C91BB551596FBA400000021E4DAF5A52 > : template_shipcore
{
	myAttributeMods
	{
		AttributeMod Speed
		{
			myType PartStat_Speed
			myAddValue = Racer_Core_l2_Speed
		}
		AttributeMod Handling
		{
			myType PartStat_Handling
			myAddValue = Racer_Core_l2_Handling
		}
	}
	myIsSelfMod TRUE
}

