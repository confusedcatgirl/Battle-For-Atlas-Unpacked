include ./template_shipcore.mplayermod
include ./tuning/mod_tuning_master.juice

PlayerMod mod_racer_shipcore_l3 < uid=C91BB551596FBA450000021F38BF5829 > : template_shipcore
{
	myAttributeMods
	{
		AttributeMod Speed
		{
			myType PartStat_Speed
			myAddValue = Racer_Core_l3_Speed
		}
		AttributeMod Handling
		{
			myType PartStat_Handling
			myAddValue = Racer_Core_l3_Handling
		}
	}
	myIsSelfMod TRUE
}

