include ./template_pod.mplayermod

float "Weapon Damage" = Stasis_Weapon_Mod_l3_Damage

PlayerMod mod_stasis_weaponmod_l3 < uid=C91BB551598368170000021D65119649 > : template_pod
{
	myAttributeMods
	{
		AttributeMod Stasis
		{
			myType DMG_Float
			myMultValue 1.0
			myPercentageValue  = "Weapon Damage"
		}
		AttributeMod UI_Weapon_Damage
		{
			myType UI_Weapon_Damage
			myPercentageValue = "Weapon Damage"
		}
	}
}

