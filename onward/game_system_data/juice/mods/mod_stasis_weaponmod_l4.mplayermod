include ./template_pod.mplayermod

float "Weapon Damage" = Stasis_Weapon_Mod_l4_Damage

PlayerMod mod_stasis_weaponmod_l4 < uid=C91BB5515983681D000002226C52BF10 > : template_pod
{
	myAttributeMods
	{
		AttributeMod Stasis
		{
			myType DMG_Float
			myMultValue 1.0
			myPercentageValue  = "Weapon Damage"
		}
		AttributeMod UI_Weapon_Damage
		{
			myType UI_Weapon_Damage
			myPercentageValue = "Weapon Damage"
		}
	}
}

