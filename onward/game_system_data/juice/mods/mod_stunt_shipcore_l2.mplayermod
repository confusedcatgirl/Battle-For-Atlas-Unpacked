include ./template_shipcore.mplayermod
include ./tuning/mod_tuning_master.juice

PlayerMod mod_stunt_shipcore_l2 < uid=C91BB551597F4226007FB23AF1DB62F9 > : template_shipcore
{
	myAttributeMods
	{
		AttributeMod Handing
		{
			myType PartStat_Handling
			myAddValue = Stunt_Core_l2_Handling
		}
		AttributeMod Speed
		{
			myType PartStat_Speed
			myAddValue = Stunt_Core_l2_Speed
		}
	}
}

