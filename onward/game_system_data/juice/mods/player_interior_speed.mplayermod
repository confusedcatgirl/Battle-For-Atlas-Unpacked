include ./template_pilot.mplayermod

PlayerMod player_interior_speed < uid=E22BA6D759512B4D0001D8B1A456AED2 > : template_pilot
{
	myAttributeMods
	{
		AttributeMod Thrust_TopSpeed
		{
			myType Player_Thrust_TopSpeed
			myMultValue 0.5
		}
		AttributeMod Strafe_TopSpeed
		{
			myType Player_Strafe_TopSpeed
			myMultValue 0.8
		}
	}
	myIcon onward/baked/textures/ui/pilot_skills/ui_pilotskills_icon_locked7.dds
}

