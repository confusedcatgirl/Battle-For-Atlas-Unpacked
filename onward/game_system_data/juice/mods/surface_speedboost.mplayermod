{
	myAttributeMods
	{
		AttributeMod Thrust_TopSpeed
		{
			myType Player_Thrust_TopSpeed
			myAddValue 30.0
		}
		AttributeMod Thrust_Accel
		{
			myType Player_Thrust_Accel
			myMultValue 0.1
		}
	}
	myIcon onward/baked/textures/ui/pilot_skills/ui_pilotskills_icon_locked7.dds
