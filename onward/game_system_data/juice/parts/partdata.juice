	PartData "Pilot Levi" < uid=C91BB551584B114B000000FA2F548AA1 >
	{
		myLocalizedName "contextComment = \"Pilot name for Levi McCrae\", description = \"\", enabled = true, guid = #939A354157B44BBA000036452B3DD52C, lineVersion = 1, maxLength = 6, text = \"Levi\""
		myLocalizedShortDescription "contextComment = \"[PLACEHOLDER - Do Not Translate] Short descriptive text for pilot Levi shown in pilot swap screen\", description = \"part_data_short_pilot_levi\", enabled = true, guid = #9E6AFEDA5A5FD36E02FE05DDD49267F5, lineVersion = 0, maxLength = 143, text = \"A daredevil and thrill-seeker who stowed away aboard the Equinox, Levi can't wait to prove himself as a pilot.\"}"
		myLocalizedNarrative "contextComment = \"[PLACEHOLDER - Do Not Translate] Narrative text for pilot Levi shown in collection database\", description = \"part_data_narrative_pilot_levi\", enabled = true, guid = #1ABBD50B585A97D4000031CB3E5490F6, lineVersion = 1, maxLength = 287, text = \"West Coast daredevil who snuck into the Equinox back on Earth, Levi McCrae has no boundaries, and likes to push people’s buttons. Full of energy, he can’t sit still for long, and is always looking for the next thrill.\""
		myDescription "Levi the Pilot"
