	PartData "Pilot Kharl" < uid=C91BB551584B114B000000FE4955227C >
	{
		myLocalizedName "contextComment = \"Name for the pilot Kharl Zeon\", description = \"\", enabled = true, guid = #383282CB57F267FD00740A99F08F17AC, lineVersion = 2, maxLength = 8, text = \"Kharl\""
		myLocalizedShortDescription "contextComment = \"[PLACEHOLDER - Do Not Translate] Short descriptive text for pilot Kharl shown in pilot swap screen\", description = \"part_data_short_pilot_kharl\", enabled = true, guid = #9E6AFEDA5A5FD55603417F8FD17BADAA, lineVersion = 0, maxLength = 117, text = 'A deep space explorer searching Atlas for an interdimensional portal called \"The Key Hole\"'"
		myLocalizedNarrative "contextComment = \"[PLACEHOLDER - Do Not Translate] Narrative text for pilot Kharl shown in collection database\", description = \"part_data_narrative_pilot_kharl\", enabled = true, guid = #1ABBD50B585A97FD000031CFD4964623, lineVersion = 1, maxLength = 395, text = 'Ambitious Expedition explorer unlocking the secrets of Atlas. Kharl Zeon’s big ideas about the universe can sometimes rub people the wrong way, but he’s happy to forge his own path. Obsessed with finding an interdimensional portal he calls \"The Key Hole,\" which he believes exists somewhere in Atlas.'"
		myDescription "Kharl the Pilot"
		myPartID 858
		myProductionID 1086
		myDualLinkID 858
		myFamilyID 858
		myAttributes = "Pilot Kharl"
		myLocalizedAbilityName "contextComment = \"[PLACEHOLDER - do not translate].\nThe name of Kharl's vortex ability, which causes a whirlwind of the projectiles fired at him and redirects them.\", description = \"part_data_pilotability_vortex\", enabled = true, guid = #A08A88CF58E3AE780000C3E000C300C0, lineVersion = 0, maxLength = 11, text = \"Vortex \"}"
		myLocalizedAbilityDescription "contextComment = \"[Placeholder - do not translate] Database description for Kharl's pilot ability, Vortex\", description = \"part-data-ability-description-kharl\", enabled = true, guid = #9E6AFEDA5A2EA48700002ABE17176111, lineVersion = 0, maxLength = 266, text = 'Kharl creates a swirling vortex shield that absorbs incoming damage.\n\n- Keep the vortex in front of you to block projectiles\n\n- Hold <gameaction src=\"PodTwo\"> to release the stored damage in a final attack'}"
		myAbilityFillColor 0xffaaff01
		myAbilityReadyColor 0xff00aaff
		myAbilityTexture onward/baked/textures/UI/pilot_abilities/ui_piliotability_Icon_chase.dds
		myAbilitySprite "mySpriteId = -14095716, mySpritesheet = F\"onward/ui/spritesheets/ui-icon-pilot-abilities-small.spritesheet\""
		myHUDFrameColor 0xffaaff01
		myMedallionSprite "mySpriteId = 1304905705, mySpritesheet = F\"onward/ui/spritesheets/ui-hud-icon-character-medallions.spritesheet\""
		mySkillScriptFile onward/skillscripts/ability_vortex.mskillscriptjuice
		myGameplayBink onward/baked/videos/ui-kharl-ability-preview.bk2
