	PartData "Pilot Rancor" < uid=C91BB551584B114B0000010149EA42A0 >
	{
		myLocalizedName "contextComment = \"[Placeholder - no not translate] Proper name for big Outlaw bruiser bird Rancor. Shown in menus when selecting/equipping Rancor.\", description = \"\", enabled = true, guid = #383282CB57F2680A0075FCB7D4C69EAE, lineVersion = 2, maxLength = 10, text = \"Rancor\""
		myLocalizedShortDescription "contextComment = \"[PLACEHOLDER - Do Not Translate] Short descriptive text for pilot Rancor shown in pilot swap screen\", description = \"part_data_short_pilot_rancor\", enabled = true, guid = #9E6AFEDA5A5FD620035DBF1D6CAF58D5, lineVersion = 0, maxLength = 112, text = \"Outlaw gang boss and expert mechanic with a short fuse, and a mean streak a mile long.\""
		myLocalizedNarrative "contextComment = \"[PLACEHOLDER - Do Not Translate] Narrative text for pilot Rancor shown in collection database\", description = \"part_data_narrative_pilot_rancor\", enabled = true, guid = #1ABBD50B585A982E000031D2DD42ECC3, lineVersion = 1, maxLength = 243, text = \"Outlaw gang boss and expert mechanic with a short fuse and a mean streak a mile long. He’s gruff and dangerous but always looks out for the little guy. If that’s not you… watch out.\""
		myPartID 861
		myProductionID 1280
		myDualLinkID 861
		myFamilyID 861
		myAttributes = "Pilot Rancor"
		myLocalizedAbilityName "contextComment = \"[PLACEHOLDER - do not translate].\nText name for Rancor's pilot ability. Damage taken while active increases the power of all Rancor's attacks.\", description = \"part_data_pilotability_beserk\", enabled = true, guid = #A08A88CF58E3AECA0000C41965280C81, lineVersion = 1, maxLength = 30, text = \"Berserk\""
		myLocalizedAbilityDescription "contextComment = \"[Placeholder - do not translate] Database description for Rancor's pilot ability, Berserk\", description = \"part-data-ability-description-rancor\", enabled = true, guid = #9E6AFEDA5A2EB3CE00002B0AF72EB7CB, lineVersion = 0, maxLength = 270, text = \"Rancor stokes his rage and unleashes it on his foes, dealing more damage the more hits he's taken\n\n- Resist incoming damage\n\n- Power up your rage with every hit\n\n- Deal bonus damage the higher your rage rises\""
		myAbilityFillColor 0xff346282
		myAbilityReadyColor 0xff16e6b9
		myAbilityTexture onward/baked/textures/UI/pilot_abilities/ui_piliotability_Icon_levi_mcrae.dds
