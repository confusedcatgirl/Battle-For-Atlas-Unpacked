	PartData "Pilot Haywire" < uid=C91BB551584B114B0000010624898E8F >
	{
		myLocalizedName "contextComment = \"Name for converted Legion AI pilot, Haywire\", description = \"\", enabled = true, guid = #3BC8B70A5875526F0000004FE369DE28, lineVersion = 1, maxLength = 11, text = \"Haywire\""
		myLocalizedShortDescription "contextComment = \"[PLACEHOLDER - Do Not Translate] Short descriptive text for pilot Haywire shown in pilot swap screen\", description = \"part_data_short_pilot_haywire\", enabled = true, guid = #9E6AFEDA5A5FD78F0390E3614572C266, lineVersion = 0, maxLength = 143, text = \"An experiment in restoring a Legion core by fusing it with Sage's AI, Haywire is a whole new robotic lifeform.\"}"
		myLocalizedNarrative "contextComment = \"[PLACEHOLDER - Do Not Translate] Narrative text for pilot Haywire shown in collection database\", description = \"part_data_narrative_pilot_haywire\", enabled = true, guid = #1ABBD50B585A984E000031D7FC9BF64F, lineVersion = 1, maxLength = 350, text = \"Haywire is the result of an experiment conducted by Mason, to see whether or not ancient Legion programming could safely interface with the Equinox's AI, Sage. Haywire is curious and optimistic, and beyond excited by his rebirth. He has only vague memories of his past.\"}"
		myDescription "Haywire the Pilot"
		myPartID 866
		myProductionID 1182
		myDualLinkID 866
		myFamilyID 866
		myAttributes = "Pilot Haywire"
		myLocalizedAbilityName "contextComment = \"[Placeholder - do not translate] Name for Haywire's pilot ability that hacks nearby Legion units\", description = \"part-data-ability-name-haywire\", enabled = true, guid = #9E6AFEDA5A662EBA00001B1B24D91DC6, lineVersion = 0, maxLength = 30, text = \"Hack\"}"
		myLocalizedAbilityDescription "contextComment = \"[Placeholder - do not translate] Database description for Haywire's pilot ability, Hack\", description = \"part-data-ability-description-haywire\", enabled = true, guid = #9E6AFEDA5A2EBB3400002B42EA43DCF6, lineVersion = 0, maxLength = 285, text = \"Haywire can tap into the programming of other Legion units to turn them into his allies, temporarily\n\n- Turn foes into friends, flipping the tide of battle\n\n- Level up Haywire's skills to Hack more advanced Legion units\""
		myAbilityFillColor 0xff8b6914
		myAbilityReadyColor 0xffed8500
		myAbilityTexture onward/baked/textures/UI/pilot_abilities/ui_piliotability_Icon_chase.dds
		myAbilitySprite "mySpriteId = -627210167, mySpritesheet = F\"onward/ui/spritesheets/ui-icon-pilot-abilities-small.spritesheet\""
		myHUDFrameColor 0xfff9f2d1
		myMedallionSprite "mySpriteId = 296110912, mySpritesheet = F\"onward/ui/spritesheets/ui-hud-icon-character-medallions.spritesheet\""
		mySkillScriptFile onward/skillscripts/ability_hack.mskillscriptjuice
		myGameplayBink onward/baked/videos/UI-HAYWIRE-ABILITY-PREVIEW.bk2
