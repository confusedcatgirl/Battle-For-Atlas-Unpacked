	PartData "Pilot Galla" < uid=C91BB551584B114B000001039022FFEE >
	{
		myLocalizedName "contextComment = \"Name for pilot Galla Joust\", description = \"\", enabled = true, guid = #3BC8B70A587552580000004D49ED8C05, lineVersion = 2, maxLength = 8, text = \"Galla\""
		myLocalizedShortDescription "contextComment = \"[PLACEHOLDER - Do Not Translate] Short descriptive text for pilot Galla shown in pilot swap screen\", description = \"part_data_short_pilot_galla\", enabled = true, guid = #9E6AFEDA5A5FD6FE037CA03F95E27A9E, lineVersion = 0, maxLength = 114, text = \"Valiant protector of the Atlas star system, following the legend of the ancient Lancers.\""
		myLocalizedNarrative "contextComment = \"[PLACEHOLDER - Do Not Translate] Narrative text for pilot Galla shown in collection database\", description = \"part_data_narrative_pilot_galla\", enabled = true, guid = #1ABBD50B585A983D000031D4C5A8DEB4, lineVersion = 1, maxLength = 287, text = \"Valiant skade who considers herself the protector of the Atlas star system. Cheerful and outgoing, Galla Joust is always there to help. Galla customised her starship to be so thick and heavy that no one can take her down.\""
		myDescription "Galla the Pilot"
		myPartID 863
		myProductionID 1180
		myDualLinkID 863
		myFamilyID 863
		myAttributes = "Pilot Galla"
		myLocalizedAbilityName "contextComment = \"Name of Galla's Pilot Ability\", description = \"part-data-ability-name-galla\", enabled = true, guid = #9E6AFEDA5A66300900001B21421015ED, lineVersion = 1, maxLength = 8, text = \"[EMP]\"}"
		myLocalizedAbilityDescription "contextComment = \"Database description for Galla's pilot ability EMP\", description = \"part-data-ability-description-galla\", enabled = true, guid = #9E6AFEDA5A2EB8AE00002B2614DC0A9E, lineVersion = 1, maxLength = 143, text = \"[Galla releases an Electro Magnetic Pulse that stuns and weakens hostiles in a wide area of effect around her]\"}"
		myAbilityFillColor 0xff72928e
		myAbilityReadyColor 0xffc9a163
		myAbilityTexture onward/baked/textures/UI/pilot_abilities/ui_piliotability_Icon_chase.dds
