	PartData "Pilot Razor" < uid=C91BB551584B114B00000102A94CCF23 >
	{
		myLocalizedName "contextComment = 'Name for pilot Zara \"Razor\" Lemay', description = \"\", enabled = true, guid = #383282CB57F268100076E141C1850D0C, lineVersion = 1, maxLength = 8, text = \"Razor\""
		myLocalizedShortDescription "contextComment = \"[PLACEHOLDER - Do Not Translate] Short descriptive text for pilot Razor shown in pilot swap screen\", description = \"part_data_short_pilot_razor\", enabled = true, guid = #9E6AFEDA5A5FD65503650BC367E3DA72, lineVersion = 0, maxLength = 82, text = \"Maverick metal head fighter pilot and navigator of the Equinox.\""
		myLocalizedNarrative "contextComment = \"[PLACEHOLDER - Do Not Translate] Narrative text for pilot Razor shown in collection database\", description = \"part_data_narrative_pilot_razor\", enabled = true, guid = #1ABBD50B585A9836000031D310A6B647, lineVersion = 2, maxLength = 338, text = 'Maverick metal head fighter pilot who joined the Starlink Initiative out of respect and the chance to fly a rockin’ ship. Zara \"Razor\" Lemay is a former army brat who excels at flying but has problems with authority figures who would seek to define her life.'"
		myPartID 862
		myProductionID 1183
		myDualLinkID 862
		myFamilyID 862
		myAttributes = "Pilot Razor"
		myLocalizedAbilityName "contextComment = \"[PLACEHOLDER - do not translate].\nText name for Razor's pilot ability. Power Chord basts surrounding targets with sound, damaging them\", description = \"part_data_pilotability_blowout\", enabled = true, guid = #A08A88CF58E3AF220000C440E225C408, lineVersion = 1, maxLength = 14, text = \"Power Chord\"}"
		myLocalizedAbilityDescription "contextComment = \"[Placeholder - do not translate] Database description for Razor's pilot ability, Power Chord. This plays like a Guitar Hero rhythm game, hitting on-screen buttons as they come down a track to execute the song flawlessly\", description = \"part-data-ability-description-razor\", enabled = true, guid = #9E6AFEDA5A2EB72400002B16E92CF53D, lineVersion = 0, maxLength = 213, text = \"Razor lets loose a sonic assault that damages all nearby targets\n\n- Hit each button at the right moment to play a note\n\n- Each note you hit amps up the damage dealt\"}"
		myAbilityFillColor 0xff5b86a9
		myAbilityReadyColor 0xfff4bc67
		myAbilityTexture onward/baked/textures/UI/pilot_abilities/ui_piliotability_Icon_levi_mcrae.dds
		myAbilitySprite "mySpriteId = -2017637924, mySpritesheet = F\"onward/ui/spritesheets/ui-icon-pilot-abilities-small.spritesheet\""
