	PartData "Pilot Fern" < uid=C91BB551584B114B000000FCC4B2AC4F >
	{
		myLocalizedName "contextComment = \"Name for the pilot Fern Wilder\", description = \"\", enabled = true, guid = #383282CB57F267F200727515B95FA0C2, lineVersion = 1, maxLength = 6, text = \"Fern\""
		myLocalizedShortDescription "contextComment = \"[PLACEHOLDER - Do Not Translate] Short descriptive text for pilot Fern shown in pilot swap screen\", description = \"part_data_short_pilot_fern\", enabled = true, guid = #9E6AFEDA5A5FD43B031A59B711F9BEFA, lineVersion = 0, maxLength = 143, text = \"A resourceful scientist with the skills to survive on long expeditions, Fern studies the native life of Atlas.\""
		myLocalizedNarrative "contextComment = \"[PLACEHOLDER - Do Not Translate] Narrative text for pilot Fern shown in collection database\", description = \"part_data_narrative_pilot_fern\", enabled = true, guid = #1ABBD50B585A97EA000031CD69FE9737, lineVersion = 1, maxLength = 296, text = \"Fern Wilder is a survivalist who wants to tear down the barrier between sentient beings and nature. She is incredibly resourceful and can craft her way out of any life-threatening situation using just the items at arm’s reach.\""
		myDescription "Fern the Pilot"
		myPartID 856
		myProductionID 1083
		myDualLinkID 856
		myFamilyID 856
		myAttributes = "Pilot Fern"
		myLocalizedAbilityName "contextComment = \"[PLACEHOLDER - do not translate].\nText naming Fern's pilot ability. This ability covers her ship in protective vines, rendering it invulnerable\", description = \"part_data_pilotability_entangle\", enabled = true, guid = #A08A88CF58E3AD750000BA548AF0175E, lineVersion = 1, maxLength = 13, text = \"Entangle\"}"
		myLocalizedAbilityDescription "contextComment = \"[Placeholder - do not translate] Database description for Fern's pilot ability, Entangle\", description = \"part-data-ability-description-fern\", enabled = true, guid = #9E6AFEDA5A2EA0A300002A9C5DCAD38F, lineVersion = 0, maxLength = 209, text = \"Using fast-growing vines, Fern winds a protective cage around her vessel, protecting it from all damage\n\n- Level up Fern's skills to cultivate new vine abilities\""
		myAbilityFillColor 0xff56a9ff
		myAbilityReadyColor 0xffff31f7
		myAbilityTexture onward/baked/textures/UI/pilot_abilities/ui_piliotability_Icon_chase.dds
