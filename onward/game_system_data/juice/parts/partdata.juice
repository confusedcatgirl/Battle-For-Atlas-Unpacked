	PartData "Pilot Judge" < uid=C91BB551584B114B000000F8F8B85058 >
	{
		myLocalizedName "contextComment = \"[Placeholder - do not translate] Name for the alien pilot Judge\", description = \"\", enabled = true, guid = #939A354157B44BAB0000358B7295B1C9, lineVersion = 1, maxLength = 8, text = \"Judge\""
		myLocalizedShortDescription "contextComment = \"[PLACEHOLDER - Do Not Translate] Short descriptive text for pilot Judge shown in pilot swap screen\", description = \"part_data_short_pilot_judge\", enabled = true, guid = #9E6AFEDA5A5FD2CF02E7E87FF739C86D, lineVersion = 0, maxLength = 113, text = \"A mysterios alien in search of their origins, Judge is protective of the Starlink team.\""
		myLocalizedNarrative "contextComment = \"[PLACEHOLDER - Do Not Translate] Narrative text for pilot Judge shown in collection database\", description = \"part_data_narrative_pilot_judge\", enabled = true, guid = #1ABBD50B585A954700006BD971DF0D3B, lineVersion = 1, maxLength = 283, text = \"St. Grand discovered Judge in a crashed alien vessel in the Antarctic, with no memory of where they came from. Working together, they developed the Nova and SpinDrive technology of the Equinox to learn Judge's origins.\"}"
		myDescription "Judge the Pilot"
		myPartID 852
		myProductionID 1081
		myDualLinkID 852
		myFamilyID 852
		myAttributes = "Pilot Judge"
		myLocalizedAbilityName "contextComment = \"[Placeholder - do not translate] Name for Judge's pilot ability, Slow Time\", description = \"part-data-ability-name-judge\", enabled = true, guid = #4E23AD1157F2916B000019980587661D, lineVersion = 1, maxLength = 1, text = \"Slow Time\"}"
		myLocalizedAbilityDescription "contextComment = \"[Placeholder - do not translate] Database summary of Judge's piloty ability, Slow Time\", description = \"part-data-ability-description-judge\", enabled = true, guid = #9E6AFEDA5A299DDC0176882DCB74CCAD, lineVersion = 0, maxLength = 208, text = \"Judge's alien physiology has a mysterious connection to Electrum and Nova, allowing them to distort time.\n\n- Access unlimited Weapon Energy while time is slowed\""
		myAbilityFillColor 0xff1d70d1
		myAbilityReadyColor 0xff00d1d6
		myAbilityTexture onward/baked/textures/UI/pilot_abilities/ui_piliotability_Icon_levi_judge.dds
