		myLocalizedName "contextComment = \"Name for the pilot Hunter Hakai\", description = \"\", enabled = true, guid = #383282CB57F267F90073642B85BF1092, lineVersion = 1, maxLength = 10, text = \"Hunter\""
		myLocalizedShortDescription "contextComment = \"[PLACEHOLDER - Do Not Translate] Short descriptive text for pilot Hunter shown in pilot swap screen\", description = \"part_data_short_pilot_hunter\", enabled = true, guid = #9E6AFEDA5A5FD43303194B8D1040F5BA, lineVersion = 0, maxLength = 104, text = \"A former soldier pursuing a spiritual quest, Hunter is deeply loyal to his team.\""
		myLocalizedNarrative "contextComment = \"[PLACEHOLDER - Do Not Translate] Narrative text for pilot Hunter shown in collection database\", description = \"part_data_narrative_pilot_hunter\", enabled = true, guid = #1ABBD50B585A97F3000031CE9F6B4E84, lineVersion = 1, maxLength = 307, text = \"A former soldier pursuing a spiritual quest. Hunter Hakai became a disciple of a mysterious monastery after his helicopter crashed during a black ops mission. Dedicated to protecting the Equinox Crew, Hunter is deeply loyal to his team.\""
		myDescription "Hunter the Pilot"
		myPartID 857
		myProductionID 1084
		myDualLinkID 857
		myFamilyID 857
		myAttributes = "Pilot Hunter"
		myLocalizedAbilityName "contextComment = \"[PLACEHOLDER - do not translate].\nHunter's pilot ability name. Rams into a number of enemies and delivers massive damage over a number of hits.\", description = \"part_data_pilotability_piercingarrow\", enabled = true, guid = #A08A88CF58E3ADBE0000BEFD56A0183B, lineVersion = 0, maxLength = 18, text = \"Piercing Arrow\"}"
		myLocalizedAbilityDescription "contextComment = \"[Placeholder - do not translate] Database description for Hunter's pilot ability, Piercing Arrow\", description = \"part-data-ability-description-hunter\", enabled = true, guid = #9E6AFEDA5A2EA29000002AA848845515, lineVersion = 0, maxLength = 272, text = \"Hunter moves faster than the eye can see, executing a flurry of precision strikes aginst nearby targets\n\n-Use it to thin a group of attackers,\nor deal massive damage to a single target\n\n- Never misses its mark\"}"
		myAbilityFillColor 0xfffc3410
		myAbilityReadyColor 0xff607089
