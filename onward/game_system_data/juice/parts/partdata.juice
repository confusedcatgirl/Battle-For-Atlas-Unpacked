		myLocalizedAbilityDescription "contextComment = \"[Placeholder - do not translate]  Database description of Levi's pilot ability, Danger Zone\", description = \"pilot-data-ability-description-levi\", enabled = true, guid = #9E6AFEDA5A2E997100002A7CA11619A8, lineVersion = 0, maxLength = 317, text = \"Levi rushes headlong into danger, counting on luck and quick thinking to make it through.\n\n- Ship becomes invulnerable for a short time\n\n- Damage anything that touches the ship - try it on Imps!\n\n- Cancel early to keep some Pilot Ability charge\"}"
