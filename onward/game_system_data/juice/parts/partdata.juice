	PartData "Pilot Eli" < uid=C91BB551584B114B000000FF2743C296 >
	{
		myLocalizedName "contextComment = \"Name for pilot Eli Westwood\", description = \"\", enabled = true, guid = #383282CB57F2680100749997DD390875, lineVersion = 1, maxLength = 5, text = \"Eli\""
		myLocalizedShortDescription "contextComment = \"[PLACEHOLDER - Do Not Translate] Short descriptive text for pilot Eli shown in pilot swap screen\", description = \"part_data_short_pilot_eli\", enabled = true, guid = #9E6AFEDA5A5FD59E034B85674DDA075D, lineVersion = 0, maxLength = 107, text = \"A lone drifter and gun-slinger known for taking on the toughest bounties in Atlas.\""
		myLocalizedNarrative "contextComment = \"[PLACEHOLDER - Do Not Translate] Narrative text for pilot Eli shown in collection database\", description = \"part_data_narrative_pilot_eli\", enabled = true, guid = #1ABBD50B585A9804000031D04C6095DE, lineVersion = 1, maxLength = 234, text = \"Eli Westwood is a lone drifter known for taking on the toughest bounties in the Atlas star system. He shows up on his own terms and takes down Outlaws no one else would dare touch.\""
		myDescription "Eli the Pilot"
		myPartID 859
		myProductionID 1087
		myDualLinkID 859
		myFamilyID 859
		myAttributes = "Pilot Eli"
