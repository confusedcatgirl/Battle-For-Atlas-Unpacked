		myLocalizedAbilityDescription "contextComment = \"[Placeholder - do not translate] Database description for Eli's Pilot Ability, Quickdraw\", description = \"part-data-ability-description-eli\", enabled = true, guid = #9E6AFEDA5A2EB06E00002AEA3A7DB6C5, lineVersion = 0, maxLength = 263, text = 'Time seems to slow down as Eli lines up his shots, letting loose a hail of projectiles with deadly precision\n\n- Target enemies to mark them\n\n- Press <gameaction src=\"PodTwo\"> to shoot all marked targets'}"
