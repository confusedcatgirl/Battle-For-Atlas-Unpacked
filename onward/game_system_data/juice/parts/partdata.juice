	PartData "Pilot Shaide" < uid=C91BB551584B114B000000FBFEB21951 >
	{
		myLocalizedName "contextComment = \"[PLACEHOLDER - Do Not Translate] Proper name for pilot Shaid, shown in Collections menus, Build Screen, Pilot Swap Screen, Starmap when selecting Shaid\", description = \"\", enabled = true, guid = #C91BB55157E2FDE1000054A68629C665, lineVersion = 2, maxLength = 8, text = \"Shaid\""
		myLocalizedShortDescription "contextComment = \"[PLACEHOLDER - Do Not Translate] Short descriptive text for pilot Shaid shown in pilot swap screen\", description = \"part_data_short_pilot_shaid\", enabled = true, guid = #9E6AFEDA5A5FD445031BB819D509DDD8, lineVersion = 0, maxLength = 121, text = \"A fast-talking smuggler and feared pirate in Atlas, Shaid is easy to like, but hard to trust.\""
		myLocalizedNarrative "contextComment = \"[PLACEHOLDER - Do Not Translate] Narrative text for pilot Shaid shown in collection database\", description = \"part_data_narrative_pilot_shaide\", enabled = true, guid = #1ABBD50B585A97E3000031CC1AB91B95, lineVersion = 2, maxLength = 294, text = \"A fast-talking smuggler who St Grand contracted to find leads on Judge's origins. Shaid’s a feared pirate in Atlas, and has spent years stealing precious cargo from dangerous people. Shaid is easy to like, but hard to trust.\"}"
		myDescription "Shaid the Pilot"
		myPartID 855
		myProductionID 1181
		myDualLinkID 855
		myFamilyID 855
		myAttributes = "Pilot Shaide"
		myLocalizedAbilityName "contextComment = \"[PLACEHOLDER - do not translate].\nText name for Shaid's pilot ability; causes the ship to go invisible to allow for sneak attacks.\", description = \"part_data_pilotability_vanish\", enabled = true, guid = #A08A88CF58E3AF660000C4799060721C, lineVersion = 0, maxLength = 10, text = \"Vanish\"}"
		myLocalizedAbilityDescription "contextComment = \"[Placeholder - do not translate]  Database description of Shaid's pilot ability, Vanish\", description = \"pilot-data-ability-description-shaid\", enabled = true, guid = #9E6AFEDA5A2E9D8B00002A84547BFF32, lineVersion = 0, maxLength = 321, text = \"Using secret Outlaw stealth tricks, Shaid makes her ship completely undetectable to enemies\n\n- Disappear and escape when a situation gets too rough\n\n- Sneak up on a target to get the drop on them\n\n- Shooting or picking up items will end the effect\"}"
		myAbilityFillColor 0xff72928e
		myAbilityReadyColor 0xffc9a163
		myAbilityTexture onward/baked/textures/UI/pilot_abilities/ui_piliotability_Icon_levi_mcrae.dds
		myAbilitySprite "mySpriteId = -45768693, mySpritesheet = F\"onward/ui/spritesheets/ui-icon-pilot-abilities-small.spritesheet\""
		myHUDFrameColor 0xff82baca
		myMedallionSprite "mySpriteId = -580840154, mySpritesheet = F\"onward/ui/spritesheets/ui-hud-icon-character-medallions.spritesheet\""
		mySkillScriptFile onward/skillscripts/ability_vanish.mskillscriptjuice
		myGameplayBink onward/baked/videos/ui-shaid-ability-preview.bk2
		myIntroBink onward/baked/videos/intro_shaid.bk2
		myPortraitBink onward/baked/videos/idle_shaid.bk2
		myEntityTemplateFile "onward/entity templates/ship_shaide_pilot.mentitytemplate"
		myPortrait onward/baked/textures/UI/ui_pilotscreen_ChasePose1.dds
		mySprite "mySpriteId = 407769950, mySpritesheet = F\"onward/ui/spritesheets/ui-icon-collection-toys.spritesheet\""
		myLeaderboardSprite "mySpriteId = -580840154, mySpritesheet = F\"onward/ui/spritesheets/ui-hud-icon-character-medallions.spritesheet\""
