	PartData "Pilot Startail" < uid=C91BB551584B114B0000010076C2C2E5 >
	{
		myLocalizedName "contextComment = \"Name for the alien pilot Startail\", description = \"\", enabled = true, guid = #383282CB57F26804007523E5F0B6FC12, lineVersion = 1, maxLength = 13, text = \"Startail\""
		myLocalizedShortDescription "contextComment = \"[PLACEHOLDER - Do Not Translate] Short descriptive text for pilot Startail shown in pilot swap screen\", description = \"part_data_short_pilot_startail\", enabled = true, guid = #9E6AFEDA5A5FD5D20352DA4F3EC01018, lineVersion = 0, maxLength = 100, text = \"A chaotic, unpredictable rebel keen on building her personal legend in Atlas.\""
		myLocalizedNarrative "contextComment = \"[PLACEHOLDER - Do Not Translate] Narrative text for pilot Startail shown in collection database\", description = \"part_data_narrative_pilot_startail\", enabled = true, guid = #1ABBD50B585A9826000031D1E5E67558, lineVersion = 1, maxLength = 324, text = \"A chaotic, mischeivous Cheeden who puts on a psychotic persona and spins a web of lies across Atlas to build her legend. Born on a prison colony, she staged a riot to cover her escape… or so she says. She may look cute, but she’s a ticking bomb.\""
		myDescription "Startail the Pilot"
		myPartID 860
		myProductionID 1088
		myDualLinkID 860
		myFamilyID 860
		myAttributes = "Pilot Startail"
		myLocalizedAbilityName "contextComment = \"[PLACEHOLDER - do not translate].\nText name for Startail's pilot ability; deals additional explosive damage.\", description = \"part_data_pilotability_loosecannon\", enabled = true, guid = #A08A88CF58E3AFB00000C4CA84404554, lineVersion = 2, maxLength = 17, text = \"Energy Mortar\"}"
		myLocalizedAbilityDescription "contextComment = \"[Placeholder - do not translate] Database description for Startail's Pilot Ability, Energy Mortar\", description = \"part-data-ability-description-startail\", enabled = true, guid = #9E6AFEDA5A2EB2FB00002AF22B7897ED, lineVersion = 0, maxLength = 237, text = \"Startail lobs a volley of volatile explosives for maximum carnage\n\n- Explosions hit a wide area - great on clusters of enemies\n\n- Aim & move during the volley to hit multiple targets\"}"
		myAbilityFillColor 0xff3b4c60
		myAbilityReadyColor 0xffec5300
		myAbilityTexture onward/baked/textures/UI/pilot_abilities/ui_piliotability_Icon_chase.dds
		myAbilitySprite "mySpriteId = -1575780793, mySpritesheet = F\"onward/ui/spritesheets/ui-icon-pilot-abilities-small.spritesheet\""
