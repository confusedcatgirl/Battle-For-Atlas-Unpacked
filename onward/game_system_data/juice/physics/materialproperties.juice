include "onward/game system data/fruit/physics/materialproperties.fruit"

MaterialPropertiesPreset global
{
	myPresetName global
	myMaterialProperties
	{
		MaterialProperties DeflectiveMetal
		{
			myMaterialType DeflectiveMetal
			myDeflectProjectiles TRUE
			myDeflectionMaxPerturbation 0.1
		}
		MaterialProperties DeflectiveAbilityShield
		{
			myMaterialType Deflective_Ability_Shield
			myDeflectProjectiles TRUE
			myDeflectionMaxPerturbation 0.1
		}
		MaterialProperties DeflectivePlayerShield
		{
			myMaterialType Deflective_Player_Shield
			myDeflectProjectiles TRUE
			myDeflectionMaxPerturbation 0.1
		}
		MaterialProperties VortexShield
		{
			myMaterialType Vortex_Shield
			myAllowFire FALSE
			myAllowSunder FALSE
			myAllowChill FALSE
			myAllowFreeze FALSE
			myAllowStasis FALSE
			myAllowStasisOverload FALSE
			myAllowGravity FALSE
		}
		MaterialProperties GallaShield
		{
			myMaterialType Galla_Shield
			myAllowFire FALSE
			myAllowSunder FALSE
			myAllowChill FALSE
			myAllowFreeze FALSE
			myAllowStasis FALSE
			myAllowStasisOverload FALSE
			myAllowGravity FALSE
		}
	}
}

MaterialPropertiesPreset gym_fx
{
	myPresetName gym_fx
	myMaterialProperties
	{
		MaterialProperties Water
		{
			myMaterialType Water
			myTrampoline 1.0
		}
		MaterialProperties Hard
		{
			myMaterialType Hard_Surface
			myShakyness 1.0
		}
		MaterialProperties "Viscous Liquid"
		{
			myMaterialType Viscous_Liquid
			mySlipperiness 1.0
		}
		MaterialProperties Loose
		{
			myMaterialType Loose_Surface
			myMuddiness 1.0
		}
		MaterialProperties Vegetation
		{
			myMaterialType Vegetation
			mySpeedBoost 1.0
		}
	}
}

MaterialPropertiesPreset planet_01
{
	myPresetName planet_01
	myMaterialProperties
