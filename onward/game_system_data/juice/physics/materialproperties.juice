MaterialPropertiesPreset gym_rcolonico
{
	myPresetName gym_rcolonico
	myMaterialProperties
	{
		MaterialProperties "Sunder Floor"
		{
			myMaterialType Viscous_Liquid
			myAllowFire FALSE
			myAllowFreeze FALSE
			mySunderPerSecond 100.0
		}
		MaterialProperties "Fire Floor"
		{
			myMaterialType Wood
			myAllowFreeze FALSE
			myFirePerSecond 100.0
		}
		MaterialProperties "Chill Floor"
		{
			myMaterialType Ice
			myAllowFire FALSE
			myAllowFreeze FALSE
			myChillPerSecond 100.0
		}
		MaterialProperties "Freeze Floor"
		{
			myMaterialType Crystal
			myAllowFire FALSE
			myFreezePerSecond 100.0
		}
		MaterialProperties "Stasis Floor"
		{
			myMaterialType Cloth
			myStasisPerSecond 100.0
		}
		MaterialProperties "Gravity Floor"
		{
			myMaterialType Vegetation
			myGravityPerSecond 100.0
		}
	}
}

