EquinoxUpgradeSet "Drive Reactor"
{
	myLocalizedName "contextComment = \"\", description = \"\", enabled = true, guid = #C91BB55158370BE9005509AE5DA54F25, lineVersion = 2, maxLength = 25, text = \"Core Systems\""
	myLocalizedDescription "contextComment = '[Placeholder - do not translate] Description for the \"Core Systems\" section of the Equinox Upgrades, which lets the player restore their flight engines, space sensors, and all other Equinox facilities. In Act 4 it also lets the player build a portal to reach the final boss.', description = \"\", enabled = true, guid = #C91BB55158370BE9005509B0C9754BF3, lineVersion = 2, maxLength = 100, text = \"Restore & enhance\nthe Starlink flagship\""
	mySprite "mySpriteId = -1932643252, mySpritesheet = F\"onward/ui/spritesheets/ui-equinox-centerpiece-icons.spritesheet\""
	myUpgrades
	{
		ProgressionPurchasable "Trigger Act 2" < uid=C91BB5515834BA0F0000004BF1CD6CEF >
		{
			myLocalizedName "contextComment = \"[PLACEHOLDER - do not translate].\", description = \"\", enabled = true, guid = #C91BB55158385CEA000DC1B8854C438B, lineVersion = 4, maxLength = 20, text = \"Restore Engines\""
			myLocalizedDescription "contextComment = \"[PLACEHOLDER - do not translate].\", description = \"\", enabled = true, guid = #C91BB55158385CEA000DC1BA79796E95, lineVersion = 3, maxLength = 112, text = \"Refuel the Equinox so that it can return to space and power your Ships' flight engines\"}"
			myLocalizedUnlockDescription "contextComment = \"[PLACEHOLDER - do not translate].\", description = \"Bring Nova to the Equinox\", enabled = true, guid = #2B55C72B592F11F60000017AA4EB4DD7, lineVersion = 1, maxLength = 140, text = \"Find a source of refined Electrum to bring back to the Equinox\""
			myOneOffUpgrade Unlock_FlightEngines
			myEnhancement < uid=C308E4DB59D77E8E000167F6D3D56840 > = drivereactor_upgrade_l1
			myUnlockRule
			{
				myCondition Challenge
				myFaction Unaligned
				myPilotID 0
				myReqSkillPoints 0
				myChallengeType Act1UnlockEquinoxUpgrade
			}
			mySkillPointCost 0
			myElectrumCost = GEN_EqUp_GAS_E1
			myNovaCost = GEN_EqUp_GAS_N1
		}
		ProgressionPurchasable "Unlock Other Upgrades" < uid=C91BB5515834BA0F0000004D2CAA74BF >
		{
			myLocalizedName "contextComment = \"[PLACEHOLDER - do not translate].\nThe name of the second equinox upgrade in the story category. This reveals the location of Primes infecting planets in the system, and unlocks all the other upgrade facilities\", description = \"\", enabled = true, guid = #C91BB55158385D2300159FFFB488F237, lineVersion = 4, maxLength = 18, text = \"Repair Systems\""
			myLocalizedDescription "contextComment = \"[PLACEHOLDER - do not translate].\nThe description of the second equinox upgrade in the story category. This reveals the location of Primes infecting planets in the system, and unlocks all the other upgrade facilities\", description = \"\", enabled = true, guid = #C91BB55158385D230015A001A35D32C5, lineVersion = 3, maxLength = 95, text = \"Repair the Equinox to restore its long-range sensors and other facilities\""
			myLocalizedUnlockDescription "contextComment = \"[PLACEHOLDER - do not translate] Unlock tip telling the player this upgrade won't unlock until they progress the story further.\", description = \"ui-equinox-upgrade-unlock-act2\", enabled = true, guid = #9E6AFEDA59A738560035109560E94EEA, lineVersion = 1, maxLength = 88, text = \"Follow Shaid's advice to find allies who can help repair the Equinox\""
			myOneOffUpgrade Unlock_AllEquinoxFacilities
			myEnhancement < uid=C308E4DB59D78E1C0003BC150317E166 > = drivereactor_upgrade_l2
			myUnlockRule
			{
				myCondition Challenge
				myChallengeType Act2_EquinoxComputersUnlocked
			}
			myElectrumCost = GEN_EqUp_GAS_E2
			myNovaCost = GEN_EqUp_GAS_N2
		}
		ProgressionPurchasable "Trigger Final Boss" < uid=A08A88CF585191D600030B185C2C4E75 >
		{
			myLocalizedName "contextComment = \"[PLACEHOLDER - do not translate].\", description = \"\", enabled = true, guid = #A08A88CF58543ED800003788FF4EA2C3, lineVersion = 2, maxLength = 30, text = \"Starlink Gate\""
			myLocalizedDescription "contextComment = \"[PLACEHOLDER - do not translate] Description of the 3rd Game Act Structure upgrade, which allows the player to access the final boss fight\", description = \"ui-equinox-upgrade-description-act4\", enabled = true, guid = #9E6AFEDA59A739E0006BD2916C2332B4, lineVersion = 1, maxLength = 140, text = \"Use Warden technology to supercharge the Starlink system take the battle to Grax\""
			myLocalizedUnlockDescription "contextComment = \"[PLACEHOLDER - do not translate] Unlock tip telling the player they need to build their alliance meter across the whole star system to unlock this upgrade\", description = \"ui-equinox-upgrade-unlock-act4\", enabled = true, guid = #9E6AFEDA59A739E0006BD2933658B8B9, lineVersion = 0, maxLength = 140, text = \"Recruit more allies across the planets of Atlas to help develop this upgrade\""
			myOneOffUpgrade Unlock_FinalBossFight
			myAcquireChallenge Progression_CompletelyUpgradeEquinox_DriveReactor
			myEnhancement < uid=C308E4DB59D78E1C0003BC16902C8E5D > = drivereactor_upgrade_l3
			myUnlockRule
			{
				myCondition Challenge
				myReqSkillPoints 0
				myChallengeType AtlasAllianceGained
				myReqChallengeRepeatCount 1
			}
			mySkillPointCost 0
			myElectrumCost = GEN_EqUp_GAS_E3
			myNovaCost = GEN_EqUp_GAS_N3
		}
	}
}

