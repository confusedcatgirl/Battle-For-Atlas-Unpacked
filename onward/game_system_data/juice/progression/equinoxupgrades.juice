EquinoxUpgradeSet "Towing Upgrades"
{
	myFacility Towing_Upgrades
	myLocalizedName "contextComment = \"[PLACEHOLDER - do not translate].\nThe facility that improves the player's ability to use/carry towed items.\", description = \"equinox-upgrades-towing_upgrades\", enabled = true, guid = #A08A88CF599C3F220000007E264A661D, lineVersion = 1, maxLength = 25, text = \"Tractor Beams\"}"
	myLocalizedDescription "contextComment = \"[PLACEHOLDER - do not translate].\nA description of the towing upgrade facility.Here the player can unlock a bigger inventory of carried items, and make it easier to pluck objects that are stuck.\", description = \"equinox-upgrades-towing_upgrades-description\", enabled = true, guid = #A08A88CF599C4093000000B8379C811E, lineVersion = 2, maxLength = 100, text = \"Improve Ships'\ncarrying capacity\"}"
