UnitPayloadList "Extractor Imperial Guard - Random Aggressor"
{
	UnitPayload "Random Aggressor Act 1"
	{
		myActsAndLevels
		{
			UnitPayloadActLevel "Act 1, All Levels"
			{
				myAct 1
			}
		}
		mySelections
		{
			UnitPayloadSelection "Generic Aggressor"
			{
				myConfiguration = "Extractor Imperial Guard - Generic Aggressor Payload"
			}
		}
	}
	UnitPayload "Random Aggressor"
	{
		myActsAndLevels
		{
			UnitPayloadActLevel "Act 2, All Levels"
			{
				myAct 2
			}
			UnitPayloadActLevel "Act 3, All Levels"
			{
				myAct 3
			}
			UnitPayloadActLevel "Act 4, All Levels"
			{
				myAct 4
			}
		}
		mySelections
		{
			UnitPayloadSelection "Fire Aggressor"
			{
				mySelectionChance 1.0
				myConfiguration = "Extractor Imperial Guard - Fire Aggressor Payload"
			}
			UnitPayloadSelection "Ice Aggressor"
			{
				mySelectionChance 1.0
				myConfiguration = "Extractor Imperial Guard - Ice Aggressor Payload"
			}
		}
	}
}

