include "onward/game system data/fruit/sim/outpostplacementparameters.fruit"

SimOutpostPlacementParametersList Parameters
{
	SimOutpostPlacementParameters Prospector
	{
		myFactionType Prospector
		myDesiredCountPerPlanet 5
		myClusterOutposts TRUE
		myMinDistanceToSameFactionOutposts 3000.0
		myMinDistanceToOtherFactionOutposts 0.0
	}
	SimOutpostPlacementParameters Harvester
	{
		myFactionType Harvester
		myClusterOutposts TRUE
		myMinDistanceToSameFactionOutposts 0.0
	}
	SimOutpostPlacementParameters Expedition
	{
		myFactionType Expedition
		myMinDistanceToSameFactionOutposts 5000.0
		myMinDistanceToOtherFactionOutposts 0.0
		mySpaceToPlanetOutpostRatio 0.0
		myMaxDistanceAroundPlanet 5000.0
	}
	SimOutpostPlacementParameters Outlaw
	{
		myFactionType Outlaw
		myMinDistanceToSameFactionOutposts 1000.0
		myMinDistanceToOtherFactionOutposts 0.0
	}
}

