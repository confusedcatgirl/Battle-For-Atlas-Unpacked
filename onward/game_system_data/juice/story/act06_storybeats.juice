StoryBeatData Act6_SEQ1_VictoryCinematic < uid=9FD9E81859F1026200000085D82C532A >
{
	myActStartFlag TRUE
	myIsCheckpoint TRUE
	myStoryDataActions
	{
		StoryDataAction_CompleteStoryEvent "Complete Story Event - Victory"
		{
			myStoryEvent Victory
		}
		StoryDataAction_Cinematic "Cinematic - Victory"
		{
			myNumBlackFramesOnCompletion 8
			myCinematicFile onward/baked/videos/CIN_ACT6A.bk2
		}
		StoryDataAction_CompleteChallenge "Complete Challenge - Grax Defeated"
		{
			myChallengeToComplete DefeatGrax
		}
		StoryDataAction_SetObjective "Close Chapter 6"
		{
			myObjectiveData < uid=1EE141815AB1791500001BCD4DF6D586 > = Act5.Chapter6.Header
			myObjectiveState Remove
		}
	}
}

