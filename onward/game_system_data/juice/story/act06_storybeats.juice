}

StoryBeatData Act6_SEQ1_Setup < uid=9FD9E81859E4C98E0000021CFB538A48 >
{
	myActStartFlag FALSE
	myIsCheckpoint FALSE
	myStoryDataActions
	{
		StoryDataAction_SetNumPrimes "Set Primes - 1"
		{
			myNumPrimes 1
		}
		StoryDataAction_SetPrimeTimeBetweenExtractors "Set Prime Time - 300"
		{
			myPrimeTimeBetweenExtractors 600.0
		}
		StoryDataAction_SetNumExtractors "Set Max Extractors - 24"
		{
			myNumExtractors 24
		}
		StoryDataAction_SetMaxExtractorLevel "Set Max Extractor Level - 4"
		{
			myMaxExtractorLevel 4
		}
		StoryDataAction_SetGameplayBounds "Clear Gameplay Bounds"
		{
		}
		StoryDataAction_ResetRespawnCheckpoint "Reset Respawn Checkpoint"
		{
		}
		StoryDataAction_SetGameAction "Enable Fast-Travel"
		{
			mySetGameActionList
			{
				SetGameAction "Enable Fast Travel"
				{
					myGameAction FastTravel
					myEnabled TRUE
				}
			}
		}
	}
}

StoryBeatData Act6_SEQ1_Cinematic < uid=9FD9E81859E4CBD10000024D38BB8148 >
{
	myStoryDataActions
	{
		StoryDataAction_SetGameplayBounds "Set Gameplay Bounds - Galaxy"
		{
			myBoundsRadius 125000.0
		}
		StoryDataAction_CompleteStoryEvent "Complete Event - Act 6"
		{
			myStoryEvent Act06
		}
		StoryDataAction_Cinematic Cinematic
		{
			myNumBlackFramesOnCompletion 8
			myCinematicFile onward/baked/videos/CIN_ACT6B.bk2
		}
		StoryDataAction_TeleportPlayer "Equinox Teleport"
		{
			myPlayer1Teleport
			{
				mySimUnitAssetPath "onward/game system data/juice/sim/onward_equinox_space.msimunit"
				myTeleportOffset 0.0;-325.274994;375.239014
				myTeleportRotation 0.0;0.0;0.0
				myIsOffsetInLocalSpace TRUE
			}
			myPlayer2Teleport
			{
				mySimUnitAssetPath "onward/game system data/juice/sim/onward_equinox_space.msimunit"
				myTeleportOffset 0.0;-315.274994;365.239014
				myIsOffsetInLocalSpace TRUE
			}
		}
		StoryDataAction_SetTarget "Clear Target"
		{
			myShowWaypoint FALSE
		}
		StoryDataAction_TransitionStorySection "Enter Story Section - Act 06"
		{
			myTransitionType Enter
			myStorySection Act_06
		}
	}
	myStoryDataActionSets
	{
	}
}

