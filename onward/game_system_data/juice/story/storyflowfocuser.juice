include "onward/game system data/fruit/story/storyflowfocuser.fruit"

StoryFlowFocuser StoryFlowFocuser
{
	mySections
	{
		StoryFlowFocuser_Section MoonIntro_Bink
		{
			mySection MoonIntro_Bink
			myFocus
			{
				myPrimary
				{
					myFocusMainFlow FALSE
					myPartStoryFocus sidestory_moon_intro
				}
				myOnlyUpdateThisFocus TRUE
			}
		}
	}
	myActs
	{
		StoryFlowFocuser_Act "New StoryFlowFocuser_Act (0)"
		{
			myAct 5
		}
	}
}

