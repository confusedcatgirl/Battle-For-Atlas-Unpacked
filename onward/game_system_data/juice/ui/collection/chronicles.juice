CustomDatabaseEntry Dreadnought < uid=9E6AFEDA5A85C1FD00001B670AB1EBC8 >
{
	myLocalizedDescription "contextComment = 'Left blank so the narrative paragraph can run longer.\nDatabase tactics notes for Chronicles entry about the discovery of the Dreadnought in Act 3, thanks to Outlaw intel.', description = \"chronicles-Act3Sorren-tactics\", enabled = true, guid = #B9EC7DA0D49642E380DE27F7DF5608B8, lineVersion = 1, maxLength = 350, text = \"\""
	myLocalizedNarrative "contextComment = '[PLACEHOLDER - do not translate]\nDatabase Chronicles entry about the discovery of the Dreadnought in Act 3, thanks to Outlaw intel.', description = \"chronicles-Act3Sorren-narrative\", enabled = true, guid = #D6FB2DE7772E4614BA766870AAA7C1FB, lineVersion = 1, maxLength = 700, text = 'An Outlaw came to us with intel on a giant Legion mothership called the Dreadnought. This ship can build new Primes to spread the Legion onto new planets.\n\nIt\'s also our best chance to find where St. Grand is being held.'"
	myPortrait onward/baked/textures/ui/icons/database_banner_large/chronicles/ui-database-chronicles-dreadnought.dds
	myDisplayVideo onward/baked/videos/CIN_ACT3.bk2
	mySprite "mySpriteId = -1239232827, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myBannerSprite "mySpriteId = -1239232827, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myAttachScreenSprite "mySpriteId = -1239232827, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myRevealedChallengeType Discover_Dreadnought
	myUnlockedChallengeType Discover_Dreadnought
	myCollectibleSubType Chronicles
	myLocalizedName "contextComment = \"[Placeholder - do not translate] Name for Chronicles entry about the discovery of the Dreadnought in Act 3, thanks to Outlaw intel\", description = \"chronicles-Act3Sorren-name\", enabled = true, guid = #7378499077E04FB49CDB98D18C72A633, lineVersion = 1, maxLength = 30, text = 'Dreadnought'}"
}

CustomDatabaseEntry Rescue < uid=9E6AFEDA5A85C1FD00001B68572640BE >
{
	myLocalizedDescription "contextComment = 'Left blank so the narrative paragraph can run longer.\nDatabase tactics notes for Chronicles entry about the defeat of the first Dreadnought, rescue, and death of St. Grand.', description = \"chronicles-Act3Complete-tactics\", enabled = true, guid = #943AFAADB9DF4FBEBBA3DD55322F959F, lineVersion = 1, maxLength = 350, text = \"\""
	myLocalizedNarrative "contextComment = '[PLACEHOLDER - do not translate]\nDatabase Chronicles entry about the defeat of the first Dreadnought, rescue, and death of St. Grand.', description = \"chronicles-Act3Complete-narrative\", enabled = true, guid = #377E7BFA5541499BB15D1C90CB334853, lineVersion = 1, maxLength = 700, text = 'In the chaos of the Dreadnought\'s destruction, St. Grand was able to commandeer a Drake and escape to the Equinox, but it was too late to save him from whatever Grax had done.\n\nWith his dying breath, he told us of a \"Warden Station,\" a massive fleet control hub near the third star of Atlas, that Grax is on the verge of re-activating fully.\n\nWith a full fleet of Dreadnoughts, and access to the Quantum Network to send them anywhere in the galaxy, there would be nowhere safe from Grax.\n\nWe have to stop him here.'"
	myPortrait onward/baked/textures/ui/icons/database_banner_large/chronicles/ui-database-chronicles-rescue.dds
	myDisplayVideo onward/baked/videos/CIN_ACT4.bk2
	mySprite "mySpriteId = -1552875536, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myBannerSprite "mySpriteId = -1552875536, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myAttachScreenSprite "mySpriteId = -1552875536, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myStarmapThreatKnownSprite "mySpriteId = -455779427, mySpritesheet = F\"onward/ui/spritesheets/ui-icon-placeholder.spritesheet\""
	myRevealedChallengeType Act3Complete
	myUnlockedChallengeType Act3Complete
	myCollectibleSubType Chronicles
	myLocalizedName "contextComment = \"[Placeholder - do not translate] Name for Chronicles entry about the defeat of the first Dreadnought, rescue, and death of St. Grand\", description = \"chronicles-Act3Complete-name\", enabled = true, guid = #827B1F05626D4300AAAAFA967951E18E, lineVersion = 1, maxLength = 30, text = 'Rescue'}"
}

CustomDatabaseEntry "Plan to Save Atlas" < uid=9E6AFEDA5A85C1FD00001B69628D99D9 >
{
	myLocalizedDescription "contextComment = 'Left blank so the narrative paragraph can run longer.\nDatabase tactics notes for Chronicles entry about Mason\'s plan to use Nova Capacitors to take the fight to Grax.', description = \"chronicles-Act4Plan-tactics\", enabled = true, guid = #BA20A125B2E140D49312565407BAF167, lineVersion = 1, maxLength = 350, text = \"\""
	myLocalizedNarrative "contextComment = '[PLACEHOLDER - do not translate]\nDatabase Chronicles entry about Mason\'s plan to use Nova Capacitors to take the fight to Grax.', description = \"chronicles-Act4Plan-narrative\", enabled = true, guid = #CD5D1FFA7ADF4670A5BAD8CDF799FA3C, lineVersion = 1, maxLength = 700, text = 'Grax is too far away to reach with the Skimmers\' engines, but too close for the Equinox SpinDrive to jump to, so we need another way to stop him.\n\nBy building three Nova Capacitors, one in each sector of Atlas, Mason thinks he can super-charge the Starlink system we use to transport parts onto our Skimmers to teleport us all the way to Grax.\n\nWe\'ll need a lot of allies to pull this off.'"
	myPortrait onward/baked/textures/ui/icons/database_banner_large/chronicles/ui-database-chronicles-saveatlas.dds
	mySprite "mySpriteId = -1362407558, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myBannerSprite "mySpriteId = -1362407558, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myAttachScreenSprite "mySpriteId = -1362407558, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myRevealedChallengeType Act3Complete
	myUnlockedChallengeType Act3Complete
	myCollectibleSubType Chronicles
	myLocalizedName "contextComment = \"[Placeholder - do not translate] Name for Chronicles entry about Mason\'s plan to use Nova Capacitors to take the fight to Grax\", description = \"chronicles-Act4Plan-name\", enabled = true, guid = #DB3115A837284C65A302ED1E4601883C, lineVersion = 1, maxLength = 30, text = 'Plan to Save Atlas'}"
}

CustomDatabaseEntry "The Warden Station" < uid=9E6AFEDA5A85C1FD00001B6A5347CAEF >
{
	myLocalizedDescription "contextComment = 'Left blank so the narrative paragraph can run longer.\nDatabase tactics notes for Chronicles entry about the completed upgrades to Starlink, allowing the team to reach Grax at the Warden Station for a final showdown.', description = \"chronicles-Act4Complete-tactics\", enabled = true, guid = #3A9293D81F1C470FAE8C0DB4193FE896, lineVersion = 1, maxLength = 350, text = \"\""
	myLocalizedNarrative "contextComment = '[PLACEHOLDER - do not translate]\nDatabase Chronicles entry about the completed upgrades to Starlink, allowing the team to reach Grax at the Warden Station for a final showdown.', description = \"chronicles-Act4Complete-narrative\", enabled = true, guid = #20059D48E05D44D29FADCA83574535BE, lineVersion = 1, maxLength = 700, text = 'With the Nova Capacitor network up and running, we\'ve completed the upgrades to the Equinox\'s Starlink core. We should now be able to transport whole Skimmers much deeper into space than ever before - far enough, we hope, to reach Grax at his Warden Station.\n\nThe battle ahead will be the hardest we\'ve faced, but we\'re the only ones who can stop Grax and keep the Earth, the whole galaxy, safe.'"
	myPortrait onward/baked/textures/ui/icons/database_banner_large/chronicles/ui-database-chronicles-wardenstation.dds
	myDisplayVideo onward/baked/videos/CIN_ACT5.bk2
	mySprite "mySpriteId = -1374269667, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myBannerSprite "mySpriteId = -1374269667, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myAttachScreenSprite "mySpriteId = -1374269667, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myRevealedChallengeType Act4Complete
	myUnlockedChallengeType Act4Complete
	myCollectibleSubType Chronicles
	myLocalizedName "contextComment = \"[Placeholder - do not translate] Name for Chronicles entry about the completed upgrades to Starlink, allowing the team to reach Grax at the Warden Station for a final showdown\", description = \"chronicles-Act4Complete-name\", enabled = true, guid = #525EB0902AD44149A9FC23AA9A7A1864, lineVersion = 1, maxLength = 30, text = 'The Warden Station'}"
}

CustomDatabaseEntry "The Final Showdown" < uid=9E6AFEDA5A85C1FD00001B6BD62D84E4 >
{
	myLocalizedDescription "contextComment = 'Left blank so the narrative paragraph can run longer.\nDatabase tactics notes for Chronicles entry about the player\'s defeat of Grax on the Warden Station.', description = \"chronicles-Act5Boss-tactics\", enabled = true, guid = #7D8A6B61784B430FB692C3F73A3B5FF9, lineVersion = 1, maxLength = 350, text = \"\""
	myLocalizedNarrative "contextComment = '[PLACEHOLDER - do not translate]\nDatabase Chronicles entry about the player\'s defeat of Grax on the Warden Station.', description = \"chronicles-Act5Boss-narrative\", enabled = true, guid = #FF08FFB2A7114A469F093A03ED4F51E0, lineVersion = 1, maxLength = 700, text = 'We defeated Grax and sunk the Warden Station into the surface of Atlas B, so that\'s one Warden hub that will no longer be a threat.\n\nWho knows how many more of their ancient facilities lie dormant across the galaxy…\n\nFor now, Grax\'s cult is scattered, and the galaxy is safe from an invasion of Dreadnoughts.'"
	myPortrait onward/baked/textures/ui/icons/database_banner_large/chronicles/ui-database-chronicles-finalshowdown.dds
	myDisplayVideo onward/baked/videos/CIN_ACT6A.bk2
	mySprite "mySpriteId = 318784959, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myBannerSprite "mySpriteId = 318784959, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myAttachScreenSprite "mySpriteId = 318784959, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myStarmapThreatKnownSprite "mySpriteId = -455779427, mySpritesheet = F\"onward/ui/spritesheets/ui-icon-placeholder.spritesheet\""
	myRevealedChallengeType DefeatGrax
	myUnlockedChallengeType DefeatGrax
	myCollectibleSubType Chronicles
	myLocalizedName "contextComment = \"[Placeholder - do not translate] Name for Chronicles entry about the player\'s defeat of Grax on the Warden Station\", description = \"chronicles-Act5Boss-name\", enabled = true, guid = #58BE89E5F0D044EBA3DF9B1D3BA22923, lineVersion = 1, maxLength = 30, text = 'The Final Showdown'}"
}

CustomDatabaseEntry "New Threats" < uid=9E6AFEDA5A85C1FD00001B6CB36B0D2F >
{
	myLocalizedDescription "contextComment = 'Left blank so the narrative paragraph can run longer.\nDatabase tactics notes for Chronicles entry about the player\'s return to Atlas after defeating Grax, and the new threats they face in the epilogue.', description = \"chronicles-Act6-tactics\", enabled = true, guid = #F01E8B1F17E744AC92FB5436CE53B869, lineVersion = 1, maxLength = 350, text = \"\""
	myLocalizedNarrative "contextComment = '[PLACEHOLDER - do not translate]\nDatabase Chronicles entry about the player\'s return to Atlas after defeating Grax, and the new threats they face in the epilogue.', description = \"chronicles-Act6-narrative\", enabled = true, guid = #DF6DB59202DB4476A10BFD0CF202360E, lineVersion = 1, maxLength = 700, text = 'Lieutenants of Grax\'s cult have taken the remaining Dreadnoughts and are still trying to take over Atlas. This system won\'t be safe unless we can stop them all.'"
	myPortrait onward/baked/textures/ui/icons/database_banner_large/chronicles/ui-database-chronicles-newthtreats.dds
	myDisplayVideo onward/baked/videos/CIN_ACT6B.bk2
