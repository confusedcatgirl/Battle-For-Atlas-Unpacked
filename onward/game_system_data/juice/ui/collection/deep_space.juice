SimUnitDatabaseEntry "Derelict Dreadnought" < uid=9E6AFEDA5A87456500001B6188878659 >
{
	myLocalizedDescription "contextComment = '[PLACEHOLDER - do not translate] Database tactics summary for the derelict dreadnought space landmark', description = \"database_space_landmark_Dreadnought_tactics\", enabled = true, guid = #9BF0A6A4B9864034A3B95B058EFE1175, lineVersion = 1, maxLength = 350, text = 'May contain Warden Mod Tech'"
	myLocalizedShortDescription "contextComment = '[PLACEHOLDER - do not translate] Starmap short description shown when selecting the derelict dreadnought space landmark', description = \"starmap_space_landmark_Dreadnought_shortdesc\", enabled = true, guid = #B086DBAF86BB4238971209DE64221706, lineVersion = 1, maxLength = 200, text = 'The husk of an ancient Warden mothership. Is anything left inside?'"
	myLocalizedNarrative "contextComment = '[PLACEHOLDER - do not translate] Database narrative blurb for the derelict dreadnought space landmark', description = \"database_space_landmark_Dreadnought_narrative\", enabled = true, guid = #607AFFF05DE44C289FF703F7C803C3BA, lineVersion = 1, maxLength = 350, text = 'This Dreadnought predates Grax\'s rise to power, and may date all the way back to the original Warden occupation of Atlas, discarded for unknown reasons. Most of the precious Warden technology has already been looted from it, but some may remain…'"
	myPortrait onward/baked/textures/UI/icons/database_banner_large/space/ui-database-space-derelict-dreadnought-large.dds
	mySprite "mySpriteId = 614606899, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myBannerSprite "mySpriteId = 614606899, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myAttachScreenSprite "mySpriteId = 614606899, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myRevealedChallengeType Discover_SpaceLandmark_07
	myUnlockedChallengeType Discover_SpaceLandmark_07
	myDeathChallengeType Discover_SpaceLandmark_07
	myCollectibleSubType XFactor
	mySimUnitFiles
	{
		file "" "onward/game system data/juice/sim/space_landmark_07.msimunit"
	}
}

SimUnitDatabaseEntry "Asteroid Quarry" < uid=9E6AFEDA5A87456500001B62A8B5DD9F >
{
	myLocalizedDescription "contextComment = '[PLACEHOLDER - do not translate] Database tactics summary for the asteroid quarry space landmark', description = \"database_space_landmark_Quarry_tactics\", enabled = true, guid = #CF3C10BFC68A4FEC9802816A3DEFC570, lineVersion = 1, maxLength = 350, text = 'May contain Mod Tech\nand leftover Electrum'"
	myLocalizedShortDescription "contextComment = '[PLACEHOLDER - do not translate] Starmap short description shown when selecting the asteroid quarry space landmark', description = \"starmap_space_landmark_Quarry_shortdesc\", enabled = true, guid = #F91D4F349B824397AF66CA5F74F8A44B, lineVersion = 1, maxLength = 200, text = 'An abandoned space mining operation. The Electrum tanks may still be full.'"
	myLocalizedNarrative "contextComment = '[PLACEHOLDER - do not translate] Database narrative blurb for the asteroid quarry space landmark', description = \"database_space_landmark_Quarry_narrative\", enabled = true, guid = #EF98592769B447F897ADCEE002DED8C7, lineVersion = 1, maxLength = 350, text = 'A space mining operation dating back to Atlas\'s Electrum Rush. Though yields of Electrum are lower in space than on the worlds of Atlas, so is exposure to roaming remnants of the Legion. That is, until recently.'"
	myPortrait onward/baked/textures/UI/icons/database_banner_large/space/ui-database-space-asteroid-quarry-large.dds
	mySprite "mySpriteId = -586761389, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myBannerSprite "mySpriteId = -586761389, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myAttachScreenSprite "mySpriteId = -586761389, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
