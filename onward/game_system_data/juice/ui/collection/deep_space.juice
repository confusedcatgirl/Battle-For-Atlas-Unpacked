CustomDatabaseEntry "Atlas Star System" < uid=A08A88CF59120A0B0000005CCF8DAF05 >
{
	myLocalizedDescription "contextComment = \"Database \", description = \"collectibles_database_deepspace_atlasstarsystem_tactics\", enabled = true, guid = #A08A88CF5912099E000000517AAA501B, lineVersion = 0, maxLength = 218, text = \"Triple Sar System:\n - Binary pair Altas A & a at the core\n - Atlas B orbits much further out\n\n7 Planets in highly unusual orbits\nshowing evidence of massive engineering\""
	myLocalizedNarrative "contextComment = \"[PLACEHOLDER - do not translate] Database narrative summary of the Atlas star system\", description = \"collectibles_database_deepspace_atlasstarsystem_narrative\", enabled = true, guid = #A08A88CF5912099E0000005362F019D8, lineVersion = 1, maxLength = 306, text = \"Atlas is a star system in the cluster called the Pleiades, clearly visible in the Earth's skies. Long ago, it was a nexus of activity for the mysterious Wardens, and whatever transpired here seems to have some links to Judge's origins.\""
	myPortrait onward/baked/textures/ui/icons/database_banner_large/space/ui-database-space-atlas-star-large.dds
	mySprite "mySpriteId = -145886626, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database.spritesheet\""
	myBannerSprite "mySpriteId = -145886626, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database.spritesheet\""
	myAttachScreenSprite "mySpriteId = -145886626, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database.spritesheet\""
	myPrimaryColor 0x00390000
	myRevealedChallengeType Act0
	myUnlockedChallengeType Act0
	myDeathChallengeType Act0
	myCollectibleSubType Planet
	myLocalizedName "contextComment = \"[PLACEHOLDER - do not translate].\", description = \"collectibles_database_deepspace_atlasstarsystem_name\", enabled = true, guid = #A08A88CF5912099E000000551DC14E31, lineVersion = 0, maxLength = 22, text = \"Atlas Star System\""
}

CustomDatabaseEntry "Sector A - Goldilocks" < uid=9E6AFEDA5A87456500001B5DAF26D10E >
{
	myLocalizedDescription "contextComment = '[PLACEHOLDER - do not translate] Database tactics summary for the sector of space containing Kirite, Haven, and Sonatus', description = \"database_space_landmark_SectorA_tactics\", enabled = true, guid = #490042B4D1154675AD953A6F9E714F2D, lineVersion = 1, maxLength = 350, text = 'Goldilocks Zone - most habitable zone\n\n3 Planets\n - Kirite\n - Haven\n - Sonatus\n\nLegion Threat readings: Mild'"
	myLocalizedNarrative "contextComment = '[PLACEHOLDER - do not translate] Database narrative blurb for the sector of space containing Kirite, Haven, and Sonatus', description = \"database_space_landmark_SectorA_narrative\", enabled = true, guid = #F9916889A5824BAF9839DBAD342306EF, lineVersion = 1, maxLength = 350, text = 'An area of space that currently contains the planets Kirite, Haven, and Sonatus, Sector A spans Atlas\'s Goldilocks Zone, the range from Atlas A & a where temperatures are most hospitable to liquid water and the emergence of life.'"
	myPortrait onward/baked/textures/UI/icons/database_banner_large/space/ui-database-space-sector-a-large.dds
	mySprite "mySpriteId = -1381426339, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myBannerSprite "mySpriteId = -1381426339, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myAttachScreenSprite "mySpriteId = -1381426339, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myRevealedChallengeType Act1Complete
	myUnlockedChallengeType Act1Complete
	myDeathChallengeType Act1Complete
	myCollectibleSubType XFactor
	myLocalizedName "contextComment = \"The name of the easy sector in Atlas.\", description = \"database_space_landmark_SectorA_name\", enabled = true, guid = #A08A88CF5ACBB0FA00001DA714B15581, lineVersion = 0, maxLength = 20, text = \"[SECTOR A NAME]\""
}

CustomDatabaseEntry "Sector B - Iceteroids" < uid=9E6AFEDA5A87456500001B5E9156288E >
{
	myLocalizedDescription "contextComment = '[PLACEHOLDER - do not translate] Database tactics summary for the sector of space containing Tundria and Vylus', description = \"database_space_landmark_SectorB_tactics\", enabled = true, guid = #7F4581DD13B44E0BAD075E29F1F47E4A, lineVersion = 1, maxLength = 350, text = 'Full of icy asteroids\n\n2 Planets\n - Vylus\n - Tundria\n\nLegion Threat readings: Medium'"
	myLocalizedNarrative "contextComment = '[PLACEHOLDER - do not translate] Database narrative blurb for the sector of space containing Tundria and Vylus', description = \"database_space_landmark_SectorB_narrative\", enabled = true, guid = #E225BF1B737E458D8D16E18AD724B643, lineVersion = 1, maxLength = 350, text = 'Encompassing the most distant orbit of Tundria, Sector B is populated by icy bodies, comets, and cometesimals.\n\nLong-range scans show elevated Legion activity in this sector, so please proceed with caution.'"
	myPortrait onward/baked/textures/UI/icons/database_banner_large/space/ui-database-space-sector-b-large.dds
	mySprite "mySpriteId = -1381640352, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myBannerSprite "mySpriteId = -1381640352, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myAttachScreenSprite "mySpriteId = -1381640352, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myRevealedChallengeType Discover_SpaceLandmark_04
	myUnlockedChallengeType Discover_SpaceLandmark_04
	myDeathChallengeType Discover_SpaceLandmark_04
	myCollectibleSubType XFactor
	myLocalizedName "contextComment = \"The name of the medium sector in Atlas.\", description = \"database_space_landmark_SectorB_name\", enabled = true, guid = #A08A88CF5ACBB12800001DB4AF4EC860, lineVersion = 0, maxLength = 20, text = \"[SECTOR B NAME]\""
}

CustomDatabaseEntry "Sector C - Junkyard" < uid=9E6AFEDA5A87456500001B5F3E6E7362 >
{
	myLocalizedDescription "contextComment = '[PLACEHOLDER - do not translate] Database tactics summary for the sector of space containing Necrom and Ashar', description = \"database_space_landmark_SectorC_tactics\", enabled = true, guid = #27797A59A9EA4EB7A5958455288BE97C, lineVersion = 1, maxLength = 350, text = 'High levels of spaceship debris\n\n2 Planets\n - Necrom\n - Ashar\n\nLegion Threat readings: HIGH'"
	myLocalizedNarrative "contextComment = '[PLACEHOLDER - do not translate] Database narrative blurb for the sector of space containing Necrom and Ashar', description = \"database_space_landmark_SectorC_narrative\", enabled = true, guid = #4F113D12367B43878BEEF65DD6283FDB, lineVersion = 1, maxLength = 350, text = 'Due to navigational anomalies, Sector C behaves much like the legends of the Bermuda Triangle on Earth, leading to countless shipwrecks that have turned it into a junkyard of debris.\n\nSome of the strongest Legion readings emanate from this sector, so be ready for a fight.'"
	myPortrait onward/baked/textures/UI/icons/database_banner_large/space/ui-database-space-sector-c-large.dds
	mySprite "mySpriteId = -1381854365, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myBannerSprite "mySpriteId = -1381854365, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myAttachScreenSprite "mySpriteId = -1381854365, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myRevealedChallengeType Discover_SpaceLandmark_03
	myUnlockedChallengeType Discover_SpaceLandmark_03
	myDeathChallengeType Discover_SpaceLandmark_03
	myCollectibleSubType XFactor
	myLocalizedName "contextComment = \"The name of the medium sector in Atlas.\", description = \"database_space_landmark_SectorB_name\", enabled = true, guid = #A08A88CF5ACBB1C100001DBFFC5F14BB, lineVersion = 0, maxLength = 20, text = \"[SECTOR C NAME]\""
}

SimUnitDatabaseEntry "Shattered Planet" < uid=9E6AFEDA5A87456500001B6011B08BC0 >
{
	myLocalizedDescription "contextComment = '[PLACEHOLDER - do not translate] Database tactics summary for the shattered planet space landmark', description = \"database_space_landmark_ShatteredPlanet_tactics\", enabled = true, guid = #E936EF8D4EDD458CADA7BDEEA9EDAD13, lineVersion = 1, maxLength = 350, text = 'May contain Mod Tech\nand leftover Electrum'"
	myLocalizedShortDescription "contextComment = '[PLACEHOLDER - do not translate] Starmap short description shown when selecting the shattered planet space landmark', description = \"starmap_space_landmark_ShatteredPlanet_shortdesc\", enabled = true, guid = #BCDC7AD90B1D4F3EA1FDD372F37795A0, lineVersion = 1, maxLength = 200, text = 'A former planet or moon of Atlas, broken apart by orbital instability.'"
	myLocalizedNarrative "contextComment = '[PLACEHOLDER - do not translate] Database narrative blurb for the shattered planet space landmark', description = \"database_space_landmark_ShatteredPlanet_narrative\", enabled = true, guid = #08A61E80A6FA4887B3AEF0546A8D0813, lineVersion = 1, maxLength = 350, text = 'Once an 8th planet of Atlas, or perhaps a moon, the system\'s unusual orbital patterns ultimately led it to destabilize and break apart.'"
	myPortrait onward/baked/textures/ui/icons/database_banner_large/space/ui-database-space-shattered-moon-large.dds
	mySprite "mySpriteId = -1357204258, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myBannerSprite "mySpriteId = -1357204258, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myAttachScreenSprite "mySpriteId = -1357204258, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
