SimUnitDatabaseEntry "Space Graveyard" < uid=9E6AFEDA5A87456500001B63E50D5E88 >
{
	myLocalizedDescription "contextComment = '[PLACEHOLDER - do not translate] Database tactics summary for the ship graveyard space landmark', description = \"database_space_landmark_Graveyard_tactics\", enabled = true, guid = #E6525A2BE6A94DA8834DEE73C3F04FD5, lineVersion = 1, maxLength = 350, text = 'May contain Mod Tech\nand leftover Electrum'"
	myLocalizedShortDescription "contextComment = '[PLACEHOLDER - do not translate] Starmap short description shown when selecting the ship graveyard space landmark', description = \"starmap_space_landmark_Graveyard_shortdesc\", enabled = true, guid = #BDF95640CD7B4F848DF15BB005E1C3ED, lineVersion = 1, maxLength = 200, text = 'This large asteroid is so studded with shipwrecks, even would-be looters stay away.'"
	myLocalizedNarrative "contextComment = '[PLACEHOLDER - do not translate] Database narrative blurb for the ship graveyard space landmark', description = \"database_space_landmark_Graveyard_narrative\", enabled = true, guid = #0E7C63A22D2241B0A8B422CDDA34AD07, lineVersion = 1, maxLength = 350, text = 'Unknown navigational anomalies caused by this asteroid have caused multiple ships to crash into it over Atlas\'s history. Approach with caution - we don\'t want to be next!'"
	myPortrait onward/baked/textures/UI/icons/database_banner_large/space/ui-database-space-space-graveyard-large.dds
