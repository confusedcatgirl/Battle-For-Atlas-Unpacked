	myLocalizedNarrative "contextComment = \"[Placeholder - do not translate] Database description for Fire affinity, categorizing weapons that set targets aflame.\", description = \"database-item-description-elementFire\", enabled = true, guid = #9E6AFEDA5A257C6902109A6021F3AB7E, lineVersion = 0, maxLength = 123, text = \"Fire affinity weapons ignite targets, dealing damage to them over time until the fire goes out.\""
