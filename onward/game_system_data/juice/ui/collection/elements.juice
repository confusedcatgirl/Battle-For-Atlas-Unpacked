CustomDatabaseEntry Lift < uid=9E6AFEDA5A2820792A331DE6E74C6A6B >
{
	myLocalizedDescription "contextComment = \"[Placeholder - do not translate] Database gameplay tips for use of the Lift weapon affinity\", description = \"database-item-gameplay-elementLift\", enabled = true, guid = #9E6AFEDA5A271C8D062A332BEF23278E, lineVersion = 0, maxLength = 199, text = \"- Stasis attacks are strong against Gravity-type targets\n\n- Pair with other affinities for devastating Blast combos\n\n- Very large targets can't be Lifted\"}"
	myLocalizedNarrative "contextComment = \"[Placeholder - do not translate] Database description for Lift affinity, categorizing weapons that put enemies into a floating slowed time state\", description = \"database-item-description-elementLift\", enabled = true, guid = #9E6AFEDA5A271C8D062A332F4106B9E8, lineVersion = 0, maxLength = 272, text = \"Lift affinity weapons slow down a target's time, leaving them floating and adrift. Snapping back into the time stream damages the target.\n\nUse it to put smaller enemies on time-out and focus on bigger threats.\"}"
