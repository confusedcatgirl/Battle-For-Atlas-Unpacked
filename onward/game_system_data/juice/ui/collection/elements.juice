{
	myLocalizedDescription "contextComment = \"[Placeholder - do not translate]  Database gameplay tips for using the Cold Vortex weapon combo (Black Hole + Cold)\", description = \"database-item-gameplay-comboColdVortex\", enabled = true, guid = #9E6AFEDA5A28563104F228613CCC3AE9, lineVersion = 0, maxLength = 100, text = \"- Combine Cold & Black Hole affinities\n\n- Penetrate even shielded weak points\""
	myLocalizedNarrative "contextComment = \"[Placeholder - do not translate]  Database description for the Cold Vortex weapon combo that causes an area-of-effect Fire attack when Heat weapons are used on a Black Hole, or a Black Hole hits Chilled / Frozen targets\", description = \"database-item-description-comboColdVortex\", enabled = true, guid = #9E6AFEDA5A28563104F228658F8DEE69, lineVersion = 0, maxLength = 280, text = \"When a Black Hole comes in contact with intense Cold, it can erupt into a freezing Cold Vortex that Chills everything trapped inside.\n\nThe Vortex can rip right through armor that might otherwise defend a weak point.\""
