{
	myLocalizedDescription "contextComment = \"[Placeholder - do not translate] Database gameplay tips for use of the Stasis Overload weapon affinity\", description = \"database-item-gameplay-elementStasisOverload\", enabled = true, guid = #9E6AFEDA5A28214F2A50DCEFD02C3122, lineVersion = 0, maxLength = 199, text = \"- Stasis attacks are strong against Gravity-type targets\n\n- Pair with other affinities for devastating Blast combos\n\n- Very large targets can't be Lifted\"}"
	myLocalizedNarrative "contextComment = \"[Placeholder - do not translate] Database description for Stasis Overload affinity, categorizing weapons that lift enemies then blast them on follow-up hits\", description = \"database-item-description-elementStasisOverload\", enabled = true, guid = #9E6AFEDA5A28214F2A50DCF3FE8A906A, lineVersion = 0, maxLength = 270, text = \"Stasis Overload weapons slow targets' time, floating them into the air. Follow up with a second hit to cause an Overload, blasting the target with extra damage and spreading the slowed time to nearby targets.\"}"
