{
	myLocalizedDescription "contextComment = \"[Placeholder - do not translate] Database gameplay tips for use of the Black Hole weapon affinity\", description = \"database-item-gameplay-elementBlackHole\", enabled = true, guid = #9E6AFEDA5A27118804A0CE4DAF0208F0, lineVersion = 0, maxLength = 190, text = \"- Gravity attacks are strong against Stasis-type targets\n\n- Trap clusters of enemies all at once\n\n- Combo with other affinities to create a Vortex\""
