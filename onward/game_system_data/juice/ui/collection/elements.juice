{
	myLocalizedDescription "contextComment = \"[Placeholder - do not translate] Database gameplay tips for use of the Freeze weapon affinity\", description = \"database-item-gameplay-elementFreeze\", enabled = true, guid = #9E6AFEDA5A27039C02BF0AD81600D8DF, lineVersion = 0, maxLength = 178, text = \"- Cold attacks are  strong against Heat-type targets\n\n- Damage or ram a Frozen target to Shatter it\n\n- Very large targets can't be Frozen\"}"
