{
	myLocalizedDescription "contextComment = \"[Placeholder - do not translate] Database gameplay tips for using the Shatter combo\", description = \"database-item-gameplay-comboShatter\", enabled = true, guid = #9E6AFEDA5A283A24011660DC6452052B, lineVersion = 0, maxLength = 120, text = \"- Most Heat weapons will cause a Thermal Shock instead\n\n- Very large targets can't be Frozen\"}"
	myLocalizedNarrative "contextComment = \"[Placeholder - do not translate] Database description for the Shatter weapon combo that deals major bonus damage when a Frozen target takes (non-heat / non-Freeze) damage\", description = \"database-item-description-comboShatter\", enabled = true, guid = #9E6AFEDA5A283A24011660E01259FAFF, lineVersion = 0, maxLength = 179, text = \"Freezing a target in ice makes it extremely brittle. Follow up with a strong hit to shatter the ice and deal massive damage to the target.\""
