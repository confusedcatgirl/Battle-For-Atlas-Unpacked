{
	myLocalizedDescription "contextComment = \"[Placeholder - do not translate]  Database gameplay tips for using the Heat Blast weapon combo (Stasis + Heat)\", description = \"database-item-gameplay-comboHeatBlast\", enabled = true, guid = #9E6AFEDA5A28454C02A5000F05742143, lineVersion = 0, maxLength = 130, text = \"- Use Heat on Lifted targets\nor\n- Use Stasis on hot targets\n\n- Blast will set nearby targets on Fire\""
	myLocalizedNarrative "contextComment = \"[Placeholder - do not translate]  Database description for the Heat Blast weapon combo that causes an area-of-effect Fire attack when Heat weapons are used on Lifted targets, or Stasis weapons are used on Overheated/on-Fire targets\", description = \"database-item-description-comboHeatBlast\", enabled = true, guid = #9E6AFEDA5A28454C02A500137B8303E9, lineVersion = 0, maxLength = 202, text = \"Combining Heat and Stasis affinity effects on one target will hyper-accelerate the heating, igniting a blast of flame that sets any nearby targets on Fire.\""
