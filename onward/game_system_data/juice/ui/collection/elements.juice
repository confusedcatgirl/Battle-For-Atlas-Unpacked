	myLocalizedNarrative "contextComment = \"[Placeholder - do not translate]  Database description for the Gravity Blast weapon combo that causes an area-of-effect Vacuum attack when Gravity weapons are used on Lifted targets, or Stasis weapons on Vacuum'd targets.\", description = \"database-item-description-comboGravityBlast\", enabled = true, guid = #9E6AFEDA5A283DF8019F380BBE832136, lineVersion = 0, maxLength = 239, text = \"Combining Gravity and Stasis affinity effects on a single target will unleash a violent Gravity Blast ripping through surrounding targets as the spacetime fabric snaps back into order.\"}"
