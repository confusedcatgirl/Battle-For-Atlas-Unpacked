CustomDatabaseEntry "Thermal Shock" < uid=9E6AFEDA5A257DDA02442C5373069E14 >
{
	myLocalizedDescription "contextComment = \"[Placeholder - do not translate] Database gameplay tips for using the Thermal Shock combo\", description = \"database-item-gameplay-comboThermalShock\", enabled = true, guid = #9E6AFEDA5A2838CD00E683620E319EA5, lineVersion = 0, maxLength = 107, text = \"- Deal extra damage with rapid temperature change\n\n- Stun targets for a short time\""
	myLocalizedNarrative "contextComment = \"[Placeholder - do not translate] Database description of the Thermal Shock combo, that deals extra damage and stuns enemies when cold & hot weapons are used consecutively\", description = \"database-item-description-comboThermalShock\", enabled = true, guid = #9E6AFEDA5A2838CD00E68366D7CCE25D, lineVersion = 0, maxLength = 233, text = \"First Chill or Freeze a target, then hit it with a Heat weapon to cause a hot Thermal Shock.\n\nOr, Ignite or Overheat a target, then hit it with Cold to cause a cold Thermal Shock.\""
	myPortrait onward/baked/textures/ui/icons/database_banner_large/technology/ui-database-technology-element-thermalshock.dds
	mySprite "mySpriteId = -261835830, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database.spritesheet\""
