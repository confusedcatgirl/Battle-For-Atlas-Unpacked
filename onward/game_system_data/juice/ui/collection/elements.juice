{
	myLocalizedDescription "contextComment = \"[Placeholder - do not translate] Database gameplay tips for use of the Vacuum (Gravity Field) weapon affinity\", description = \"database-item-gameplay-elementGravityField\", enabled = true, guid = #9E6AFEDA5A27058703038650F877A942, lineVersion = 0, maxLength = 205, text = \"- Gravity attacks are strong against Stasis-type targets\n\n- Stop fast targets from dodging your shots\n\n- Pair with fast-firing weapons to boost their accuracy\""
	myLocalizedNarrative "contextComment = \"[Placeholder - do not translate] Database description for Vacuum (Gravity Field) affinity, categorizing weapons that pull other projectiles in to strike their targets\", description = \"database-item-description-elementGravityField\", enabled = true, guid = #9E6AFEDA5A27058703038654A20E9580, lineVersion = 0, maxLength = 237, text = \"Vacuum affinity weapons pull surrounding projectiles in toward their targets, so even stray shots will hit home. Hitting a fast or evasive target with Vacuum can keep it from dodging\""
