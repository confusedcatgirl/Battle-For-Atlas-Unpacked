CustomDatabaseEntry Kinetic < uid=9E6AFEDA5A283DF8019F37EB60E19808 >
{
	myLocalizedDescription "contextComment = \"[Placeholder - do not translate] Database gameplay tips for use of the Kinetic weapon affinity\", description = \"database-item-gameplay-elementKinetic\", enabled = true, guid = #9E6AFEDA5A28344A004537E8E4788077, lineVersion = 0, maxLength = 127, text = \"- Switch to Neutral weapons to bypass affinity resistance\n\n- Knock targets around with brute force\""
	myLocalizedNarrative "contextComment = \"[Placeholder - do not translate] Database description for Neutral (Kinetic) affinity, categorizing weapons that don't have any special elemental effects.\", description = \"database-item-description-elementKinetic\", enabled = true, guid = #9E6AFEDA5A28344A004537EC06B1EE05, lineVersion = 0, maxLength = 261, text = \"Neutral affinity weapons damage their targets by pure impact force. They ignore most affinity resistances and weaknesses, making them a consistent, reliable option even against mixed groups of targets.\"}"
