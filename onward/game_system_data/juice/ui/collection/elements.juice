	myLocalizedDescription "contextComment = \"[Placeholder - do not translate] Database gameplay tips for use of the Overheat (sunder) weapon affinity\", description = \"database-item-gameplay-elementSunder\", enabled = true, guid = #9E6AFEDA5A26FC3901B70EC04F018507, lineVersion = 0, maxLength = 200, text = \"- Heat attacks are strong against Cold-type targets\n\n- Follow-up with a second weapon hit for extra damage\n\n- Heat & cool targets to cause a Thermal Shock\""
