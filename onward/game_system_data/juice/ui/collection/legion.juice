NPCDatabaseEntry Drake < uid=A08A88CF59C51698000230C54FCBBCF7 >
{
	myLocalizedDescription "contextComment = \"[PLACEHOLDER - do not translate].\", description = \"database-item-description-drake\", enabled = true, guid = #A08A88CF59C515B10002110BC8A7AB87, lineVersion = 1, maxLength = 139, text = \"Highly evasive: use Homing weapons\n\nWaves of Drakes will keep attacking,\nas long as a Legion ship is nearby\""
	myLocalizedNarrative "contextComment = \"[PLACEHOLDER - do not translate].\", description = \"database-item-narrative-drake\", enabled = true, guid = #A08A88CF59C515B10002110F4E96FB22, lineVersion = 1, maxLength = 281, text = \"The Legion's starfighters, these robotic drone craft patrol Legion-controlled space and attack any unknown ship indiscriminately, ensuring the ancient  Wardens had complete space supremacy. How were they reactivated?\"}"
	myPortrait onward/baked/textures/ui/icons/database_banner_large/legion/ui-database-legion-drake-large.dds
