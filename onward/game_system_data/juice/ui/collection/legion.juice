SimUnitDatabaseEntry "Legion Data Core" < uid=A08A88CF59A42B430001AE92967F00F1 >
{
	myLocalizedDescription "contextComment = \"[PLACEHOLDER - do not translate] Database tactical summary for Legion Data Cores (hackable drops)\", description = \"database-item-description-datacore\", enabled = true, guid = #A08A88CF59A42B430001AE96E8190DF9, lineVersion = 1, maxLength = 142, text = \"Stay close and defend the wreckage\nuntil the Hack is complete\n\nReveals Legion Extractors\nand may contain Mods\""
	myLocalizedShortDescription "contextComment = \"Short description for the legion data core (fallen unit the player can 'hack' for mods).\", description = \"database-item-shortdescription-datacore\", enabled = true, guid = #A08A88CF5ADDEFF400CB3EEBFE453BC9, lineVersion = 0, maxLength = 31, text = \"[DATE CORE: SHORT DESC.]\""
	myLocalizedNarrative "contextComment = \"[PLACEHOLDER - do not translate] Database narrative summary for Legion Data Cores (hackable drops)\", description = \"database-item-narrative-datacore\", enabled = true, guid = #A08A88CF59A42B430001AE9A4FADAF8D, lineVersion = 1, maxLength = 261, text = \"Legion wreckage from downed Probes or crashed Drakes can be Hacked to extract data from the Extractor network and reveal Legion assets. But the Legion will detect the intrusion and send reinforcements.\""
