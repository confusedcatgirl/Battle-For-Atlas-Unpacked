{
	myLocalizedDescription "contextComment = \"[PLACEHOLDER - do not translate] Database tactical summary for Ice Cyclops\", description = \"database-item-description-cyclops-generic-cold\", enabled = true, guid = #A08A88CF59C5217900018DD8BC44158E, lineVersion = 1, maxLength = 138, text = \"Fires Cold-Infused blasters at range\n\nThrows Freezing grenades when approached\n\nVulnerable to Heat Weapons\""
