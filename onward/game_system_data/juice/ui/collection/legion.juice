	myAttachScreenSprite "mySpriteId = 620184426, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database.spritesheet\""
	myStarmapThreatKnownSprite "mySpriteId = 1871237902, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-starmap-enemies.spritesheet\""
	myStarmapThreatUnknownSprite "mySpriteId = -1781501083, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-starmap-enemies.spritesheet\""
	myRevealedChallengeType Discover_ImpHeat
	myUnlockedChallengeType Discover_ImpHeat
	myDeathChallengeType Death_ImpHeat
	myCollectibleSubType Enemy
	myNPCFiles
	{
		file 1 "onward/game system data/juice/ai/npc/harvester_imp_heat.mnpc"
	}
}

NPCDatabaseEntry "Crush Imp" < uid=1ABBD50B594979BC0001DEAE6F7382B3 >
{
	myLocalizedDescription "contextComment = \"[PLACEHOLDER - do not translate].\nDatabase tactical summary of the crush imp.\", description = \"database-item-description-imp-crush\", enabled = true, guid = #A08A88CF588A41160000DF93007A4026, lineVersion = 1, maxLength = 70, text = \"Found on massive planets\n\nVulnerable to Stasis Weapons\""
	myLocalizedNarrative "contextComment = \"[PLACEHOLDER - do not translate].\nDatabase narrative summary of the crush imp.\", description = \"database-item-narrative-imp-crush\", enabled = true, guid = #A08A88CF588A41160000DF94B3D49630, lineVersion = 1, maxLength = 315, text = \"The crush imp, when strengthened by the power of gravity, will implode after attaching to a target. It will leave behind the shearing force of a black hole when it does so. Avoid becoming the target of one of these attacks by lifting the imp.\""
	myPortrait onward/baked/textures/ui/icons/database_banner_large/legion/ui-database-legion-crush-imp-large.dds
	mySprite "mySpriteId = 75693528, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database.spritesheet\""
