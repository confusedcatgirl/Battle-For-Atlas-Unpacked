NPCDatabaseEntry "Cold Imp" < uid=1ABBD50B594979BC0001DEAD081E6598 >
{
	myLocalizedDescription "contextComment = \"[PLACEHOLDER - do not translate].\nDatabase tactical summary of the cold-infused imp.\", description = \"database-item-description-imp-cold\", enabled = true, guid = #A08A88CF5877F2380000006C49D82677, lineVersion = 1, maxLength = 64, text = \"Found on Cold planets\n\nVulnerable to Heat Weapons\""
	myLocalizedNarrative "contextComment = \"[PLACEHOLDER - do not translate].\nDatabase narrative summary of the cold-infused imp.\", description = \"database-item-narrative-imp-cold\", enabled = true, guid = #A08A88CF588A41110000DE046F7F5633, lineVersion = 1, maxLength = 224, text = \"When attached, Cold Imps will consistently Chill and Freeze their target. Relying on colder temperatures to keep their CPU in check, a blast of Heat can disrupt these Imps.\""
	myPortrait onward/baked/textures/ui/icons/database_banner_large/legion/ui-database-legion-ice-imp-large.dds
