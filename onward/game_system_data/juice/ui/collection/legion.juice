SimUnitDatabaseEntry Dreadnought < uid=A08A88CF598B27CF0001A14F69B617B5 >
{
	myLocalizedDescription "contextComment = \"[Placeholder - do not translate]\nDatabase tactical points about Dreadnoughts, the giant space-based battleship bosses\", description = \"database-item-description-Dreadnought\", enabled = true, guid = #9E6AFEDA5A68ED32053981900690797D, lineVersion = 0, maxLength = 181, text = \"Primes supply Dreadnoughts with Nova;\ndestroy Primes to weaken Dreadnoughts\n\nDestroy its outer defenses, then\nfly inside to attack its core\""
	myLocalizedShortDescription "contextComment = \"[Placeholder - do not translate]\nShort summary of the Dreadnought battleship displayed when selecting one on the Starmap\", description = \"database-item-shortdescription-Dreadnought\", enabled = true, guid = #9E6AFEDA5A68ED47053B9874296D3308, lineVersion = 0, maxLength = 74, text = \"A deadly battleship that spreads units to nearby planets.\""
	myLocalizedNarrative "contextComment = \"[Placeholder - do not translate]\nDatabase backstory on Dreadnoughts, the giant space-based battleship bosses\", description = \"database-item-narrative-Dreadnought\", enabled = true, guid = #9E6AFEDA5A68ED180536E30C43C96582, lineVersion = 0, maxLength = 230, text = \"The Legion's spacefaring battlestations, and command post of the Nova harvesting operation. They seed planets with Primes and Legion ground forces, and patrol space with Drakes.\"}"
