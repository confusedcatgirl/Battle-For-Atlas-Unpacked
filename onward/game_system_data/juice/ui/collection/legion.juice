NPCDatabaseEntry "Frost Giant" < uid=1ABBD50B594979BC0001DEA84DF4C4C7 >
{
	myLocalizedDescription "contextComment = \"[PLACEHOLDER - do not translate].\nDatabase tactical summary of the Frost Giant\", description = \"database-item-description-cyclops-cold\", enabled = true, guid = #A08A88CF588A265500002F239C447256, lineVersion = 1, maxLength = 194, text = \"Attacks with homing waves of ice crystals,\nand sprays ice all around when approached\n\nShielded against projectile attacks\n\nVulnerable to Heat Weapons\""
	myLocalizedNarrative "contextComment = \"[PLACEHOLDER - do not translate].\nDatabase narrative summary of the Frost Giant\", description = \"database-item-narrative-cyclops-cold\", enabled = true, guid = #A08A88CF5877F1D20000005597D09D6E, lineVersion = 1, maxLength = 311, text = \"A stalwart defender, the Frost Giant has been infused with the power of Cold-Corrupted Nova. It is most often found leading troupes over frozen wastelands and flat tundras, impervious to the lashing winds and biting temperatures around it.\""
	myPortrait onward/baked/textures/ui/icons/database_banner_large/legion/ui-database-legion-base-frost-giant-large.dds
