{
	myLocalizedDescription "contextComment = \"[PLACEHOLDER - do not translate] Database tactical summary for Legion Probes\", description = \"database-item-description-probe\", enabled = true, guid = #A08A88CF58AF25AE000000C656D103AA, lineVersion = 1, maxLength = 108, text = \"Repairs other Legion Units\n\nFlees when threatened\n\nMay carry valuable intel or Mods\""
	myLocalizedNarrative "contextComment = \"[PLACEHOLDER - do not translate] Database narrative summary for Legion Probes\", description = \"database-item-narrative-probe\", enabled = true, guid = #A08A88CF58AF25AE000000C75CD72553, lineVersion = 1, maxLength = 251, text = \"Legion Probes scout the area around Extractors, and support the Legion ground forces.\n\nThey frequently steal equipment or materials from Expedition and Prospectors to take it back for analysis.\""
