NPCDatabaseEntry "Heat Infused Cyclops" < uid=A08A88CF59C522C70001AC4B6D22A60E >
{
	myLocalizedDescription "contextComment = \"[PLACEHOLDER - do not translate] Database tactical tips for Heat-infused Cyclops\", description = \"database-item-description-cyclops-generic-fire\", enabled = true, guid = #A08A88CF59C522830001A56E7326494B, lineVersion = 1, maxLength = 133, text = \"Fires Heat-Infused blasters at range\n\nThrows Fire grenades when approached\n\nVulnerable to Cold Weapons\""
	myLocalizedNarrative "contextComment = \"[PLACEHOLDER - do not translate] Database narrative blurb for Heat-infused Cyclops\", description = \"database-item-narrative-cyclops-generic-fire\", enabled = true, guid = #A08A88CF59C522830001A56F148463E1, lineVersion = 1, maxLength = 157, text = \"Infused with Heat-Corrupted Nova, these Cyclops are tougher than the regular variety, and their attacks are super-heated.\""
	myPortrait onward/baked/textures/ui/icons/database_banner_large/legion/ui-database-legion-fire-cyclops-large.dds
	mySprite "mySpriteId = -1817469281, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database.spritesheet\""
	myBannerSprite "mySpriteId = -1817469281, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database.spritesheet\""
