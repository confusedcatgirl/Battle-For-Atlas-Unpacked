{
	myLocalizedDescription "contextComment = \"[PLACEHOLDER - do not translate].\nDatabase tactical summary of the Fire Giant\", description = \"database-item-description-cyclops-heat\", enabled = true, guid = #A08A88CF588A22DE00002D6446A5EFE8, lineVersion = 1, maxLength = 100, text = \"Flying & evasive\n\nDodge to avoid homing fireballs\n\nVulnerable to Cold Weapons\""
