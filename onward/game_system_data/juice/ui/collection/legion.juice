NPCDatabaseEntry "Base Cyclops" < uid=1ABBD50B594979BC0001DEA7B0592DA4 >
{
	myLocalizedDescription "contextComment = \"[PLACEHOLDER - do not translate].\nDatabase tactical description for the standard ground unit for the Legion, non-elemental cyclopes.\", description = \"database-item-description-cyclops-base\", enabled = true, guid = #A08A88CF588A24F800002EA8F6E04EF5, lineVersion = 1, maxLength = 75, text = \"No Affinity or resistance\n\nAttacks with ranged projectiles\""
	myLocalizedNarrative "contextComment = \"[PLACEHOLDER - do not translate].\nDatabase description for the standard ground unit for the Legion, non-elemental cyclopes.\", description = \"database-item-narrative-cyclops-base\", enabled = true, guid = #A08A88CF588A22E300002D6A2264940D, lineVersion = 1, maxLength = 202, text = \"Cyclopes are the workhorse unit of the Legion's shock troops. Individually, they are quite easy to deal with, but can be a serious threat in larger groups.\"}"
	myPortrait onward/baked/textures/ui/icons/database_banner_large/legion/ui-database-legion-base-cyclops-large.dds
