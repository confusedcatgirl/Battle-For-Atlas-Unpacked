NPCDatabaseEntry "Crush Giant" < uid=1ABBD50B594979BC0001DEA9DCE8EEBA >
{
	myLocalizedDescription "contextComment = \"[PLACEHOLDER - do not translate].\nDatabase tactical summary for the Crush Giant\", description = \"database-item-description-cyclops-crush\", enabled = true, guid = #A08A88CF588A22DC00002D62C7B681D6, lineVersion = 1, maxLength = 159, text = \"Fire Black Hole mortars\nwatch for target zones on the ground\nand avoid approaching too close\n\nVulnerable to Stasis Weapons\""
	myLocalizedNarrative "contextComment = \"[PLACEHOLDER - do not translate].\nDatabase descriptive/narrative summary of the Crush Giant\", description = \"database-item-narrative-cyclops-crush\", enabled = true, guid = #A08A88CF588A27BC00002F62BDE50D62, lineVersion = 1, maxLength = 221, text = \"Infused with potent Gravity-Corrupted Nova, these rare and nearly indestructible Legion units are extremely slow moving, and leave nothing but destruction in their wake. \""
