NPCDatabaseEntry "Flawless Cyclops" < uid=A08A88CF5BA940DF0003C08EBC441E4C >
{
	myLocalizedDescription "contextComment = \"The tactical description of the golden cyclops enemy archetype.\", description = \"database-item-description-cyclops-generic-golden\", enabled = true, guid = #A08A88CF5BA940C10003B2A3D90D0066, lineVersion = 0, maxLength = 178, text = \"Infused with the power of the Swarm.\n\nDeals kinetic damage at moderate range.\n\nVulnerable to siege weapons and shots to the glowing eyes.\""
	myLocalizedShortDescription "contextComment = \"\", description = \"\", enabled = false, guid = #A08A88CF5BA940C10003B2A5D00EE051, lineVersion = 0, maxLength = 0, text = \"\""
	myLocalizedNarrative "contextComment = \"A brief narrative summary of the flawless/golden cyclops archetype.\", description = \"database-item-narrative-cyclops-generic-golden\", enabled = true, guid = #A08A88CF5BA940C10003B2A74F941265, lineVersion = 0, maxLength = 239, text = \"Flawless cyclopes are rare, ancient relics of the time of the Wardens. They are imbued with the remaining power of the scattered Swarm, and seek to return to it by any means necessary.\""
	myPortrait onward/baked/textures/UI/icons/database_banner_large/legion/ui-database-legion-golden-cyclops-large.dds
