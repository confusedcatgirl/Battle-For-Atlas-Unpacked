{
	myLocalizedDescription "contextComment = \"[PLACEHOLDER - do not translate] Database tactical summary of Crush Cyclops\", description = \"database-item-description-cyclops-generic-crush\", enabled = true, guid = #A08A88CF59C5222D00019DAFB77E538D, lineVersion = 1, maxLength = 147, text = \"Fires Gravity-Infused blasters at range\n\nThrows Black Hole grenades when approached\n\nVulnerable to Stasis Weapons\""
