SimUnitDatabaseEntry Prime < uid=A08A88CF59B96FB90001E43D2B1289FD >
{
	myLocalizedDescription "contextComment = \"[PLACEHOLDER - do not translate].\nDatabase tactical points about the Legion's primary unit (and a major boss battle during the game), the Prime.\", description = \"database-item-description-prime\", enabled = true, guid = #9E6AFEDA5A68AF8C0013BD1F8B34B377, lineVersion = 0, maxLength = 186, text = \"Extractors feed power to their Prime;\ndestroy Extractors to locate & weaken the Prime\n\nVulnerable to Piercing damage\n\nContain advanced Mod tech\"}"
	myLocalizedShortDescription "contextComment = \"[PLACEHOLDER - do not translate].\nA short description of the Legion's prime unit. \", description = \"database-item-shortdescription-prime\", enabled = true, guid = #A08A88CF59B9747100022598C706BCDC, lineVersion = 0, maxLength = 153, text = \"Primes are gargantuan, slow-moving fortresses that roam the surface of planets looking for ideal extractor locations. \"}"
	myLocalizedNarrative "contextComment = \"[PLACEHOLDER - do not translate].\nDatabase backstory for the Legion's primary unit (and a major boss battle during the game), the Prime.\", description = \"database-item-narrative-prime\", enabled = true, guid = #A08A88CF59B96F770001E43A3E470129, lineVersion = 1, maxLength = 260, text = \"Primes are gargantuan fortresses that comb planets for ideal sites to plant Extractors, part of the ancient Warden Electrum harvesting network. When challenged, they will defend that network fiercely.\"}"
	myPortrait onward/baked/textures/ui/icons/database_banner_large/legion/ui-database-legion-prime-large.dds
	mySprite "mySpriteId = -326599141, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database.spritesheet\""
	myBannerSprite "mySpriteId = -326599141, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database.spritesheet\""
	myAttachScreenSprite "mySpriteId = -326599141, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database.spritesheet\""
	myRevealedChallengeType Discover_Prime
	myUnlockedChallengeType Discover_Prime
	myDeathChallengeType Death_Prime
	myCollectibleSubType Prime
	mySimUnitFiles
	{
		file "" "onward/game system data/juice/sim/harvester_prime.msimunit"
	}
}

SimUnitDatabaseEntry Extractor < uid=1ABBD50B594979BC0001DEA489EE97C7 >
{
	myLocalizedDescription "contextComment = \"[PLACEHOLDER - do not translate].\nA database bullet point summary of extractors, the tools by which the Legion mines electrum from the planets of Atlas.\", description = \"database-item-description-extractor\", enabled = true, guid = #A08A88CF588A20AC00002CE6E4BF8B7E, lineVersion = 2, maxLength = 187, text = \"Devastating mining creates pollution storms,\ndisabling flight engines\n\nVulnerable to Piercing damage\n\nOutposts can extract Nova from their Cores\""
	myLocalizedShortDescription "contextComment = \"[PLACEHOLDER - do not translate].\nA short summary about Extractors shown when selecting an Extractor icon on the Starmap\", description = \"database-item-shortdescription-extractor\", enabled = true, guid = #9E6AFEDA59DFE0A20000003969BFD53C, lineVersion = 0, maxLength = 200, text = \"These Electrum harvesting towers supply the Legion forces. Destroy Extractors to help liberate the planet.\""
	myLocalizedNarrative "contextComment = \"[PLACEHOLDER - do not translate].\nA database narrative description of extractors, the tools by which the Legion mines electrum from the planets of Atlas.\", description = \"database-item-narrative-extractor\", enabled = true, guid = #A08A88CF591B03AD0000983CA8923665, lineVersion = 0, maxLength = 247, text = \"Extractors are the environmentally disastrous mining tools of the ancient Wardens. Planted on Electrum Veins, the Extractor rips the valuable mineral from the planet to fuel Nova production.\""
	myPortrait onward/baked/textures/ui/icons/database_banner_large/legion/ui-database-legion-extractor-large.dds
	mySprite "mySpriteId = 2145453820, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database.spritesheet\""
	myBannerSprite "mySpriteId = 2145453820, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database.spritesheet\""
	myAttachScreenSprite "mySpriteId = 2145453820, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database.spritesheet\""
