NPCDatabaseEntry "Shielded Cyclops" < uid=A08A88CF59C523250001B46B91A07D5F >
{
	myLocalizedDescription "contextComment = \"[PLACEHOLDER - do not translate] Database tactical summary for Shielded Cyclops\", description = \"database-item-description-cyclops-shielded\", enabled = true, guid = #A08A88CF59C522E00001AE8D8D29B989, lineVersion = 1, maxLength = 181, text = \"Hit it with a strong impact to make it drop its guard\n\nAim past the target with missiles, or use\nexplosive weapons to get around the shield\""
	myLocalizedNarrative "contextComment = \"[PLACEHOLDER - do not translate] Database narrative summary for Shielded Cyclops\", description = \"database-item-narrative-cyclops-shielded\", enabled = true, guid = #A08A88CF59C522E00001AE8E164672AF, lineVersion = 1, maxLength = 294, text = \"The adamantine shield carried by these robots can deflect any projectile, so pilots will need counter-measures to defeat them. Slowing or freezing the target, getting behind it, or using weapons with a blast radius might help.\""
	myPortrait onward/baked/textures/ui/icons/database_banner_large/legion/ui-database-legion-shielded-cyclops-large.dds
	mySprite "mySpriteId = -1276047927, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myBannerSprite "mySpriteId = -1276047927, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
