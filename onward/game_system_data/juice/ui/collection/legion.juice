SimUnitDatabaseEntry "Imp Shed" < uid=1ABBD50B594979BC0001DEA567BEC66D >
{
	myLocalizedDescription "contextComment = \"[PLACEHOLDER - do not translate].\nDatabase tactical points about Imp Hives (formerly called Imp Sheds/Nests). These structues are built by Legion Imps, occupy an Outpost Site, and spawn additional Imps to defend the hive and harrass players & neutral factions in the surrounding area.\", description = \"database-item-description-impshed\", enabled = true, guid = #A08A88CF58FA077100000051E3B98223, lineVersion = 2, maxLength = 157, text = \"Hives send Imps to raid their surroundings\n\nVulnerable to Piercing damage\n\nDestroy Hives to clear space to build Outposts\""
	myLocalizedShortDescription "contextComment = \"[PLACEHOLDER - do not translate]\nA short summary about Imp sheds (hives) shown when selecting a shed icon on the Starmap.\", description = \"database-item-shortdescription-impshed\", enabled = true, guid = #A08A88CF59B9746A000225907914E682, lineVersion = 0, maxLength = 200, text = \"Stray Imps build these hives at ideal outpost sites, waking more Imps long-buried underground.\""
	myLocalizedNarrative "contextComment = \"[PLACEHOLDER - do not translate].\nDatabase backstory of Imp Hives (formerly called Imp Sheds/Nests). These structues are built by Legion Imps, occupy an Outpost Site, and spawn additional Imps to defend the hive and harrass players & neutral factions in the surrounding area.\", description = \"database-item-narrative-impshed\", enabled = true, guid = #9E6AFEDA5A68B91000B5E83AD9389F5F, lineVersion = 0, maxLength = 272, text = \"Left aimless without the Wardens' control, Imps assemble these crude structures on any building site they can find. The Hive is able to awaken and attract more Imp units, buried underground over the centuries.\"}"
	myPortrait onward/baked/textures/ui/icons/database_banner_large/legion/ui-database-legion-imp-shed-large.dds
	mySprite "mySpriteId = 1996553614, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database.spritesheet\""
	myBannerSprite "mySpriteId = 1996553614, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database.spritesheet\""
	myAttachScreenSprite "mySpriteId = 1996553614, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database.spritesheet\""
	myRevealedChallengeType Death_ImpShed
	myUnlockedChallengeType Death_ImpShed
	myDeathChallengeType Death_ImpShed
	myCollectibleSubType ImpShed
	mySimUnitFiles
	{
		file 1 "onward/game system data/juice/sim/creep_shed.msimunit"
		file "Act One Imp Shed" "onward/game system data/juice/sim/act1_imp_shed.msimunit"
	}
}

NPCDatabaseEntry "Base Imp" < uid=1ABBD50B594979BC0001DEAC9318D47F >
{
	myLocalizedDescription "contextComment = \"[PLACEHOLDER - do not translate].\nA Database tactical summary of the base imp's fighting style.\", description = \"database-item-description-imp-base\", enabled = true, guid = #A08A88CF588A410A0000DC0D5D77953A, lineVersion = 1, maxLength = 177, text = \"Vicious melee attackers;\nshake them off if they grab your Ship\n\nClose-range, wide-spread weapons\nare most effective against their swarms\"}"
	myLocalizedNarrative "contextComment = \"[PLACEHOLDER - do not translate].\nA Satabase narrative description of the base imp unit.\", description = \"database-item-narrative-imp-base\", enabled = true, guid = #A08A88CF588A410A0000DC0E840EB959, lineVersion = 1, maxLength = 285, text = \"The smallest Legion unit, cheap to build and deploy, Imps rely on sheer numbers to pose any threat. They are attracted to nearby sources of power, building Hives on outpost foundations and wreaking havoc for the locals.\""
	myPortrait onward/baked/textures/ui/icons/database_banner_large/legion/ui-database-legion-base-imp-large.dds
	mySprite "mySpriteId = 937381632, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database.spritesheet\""
	myBannerSprite "mySpriteId = 937381632, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database.spritesheet\""
	myAttachScreenSprite "mySpriteId = 937381632, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database.spritesheet\""
	myStarmapThreatKnownSprite "mySpriteId = 1461540135, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-starmap-enemies.spritesheet\""
	myStarmapThreatUnknownSprite "mySpriteId = -1267872488, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-starmap-enemies.spritesheet\""
	myRevealedChallengeType Discover_ImpGeneric
	myUnlockedChallengeType Discover_ImpGeneric
	myDeathChallengeType Death_ImpGeneric
	myCollectibleSubType Enemy
	myNPCFiles
	{
		file 1 "onward/game system data/juice/ai/npc/harvester_imp_base.mnpc"
	}
}

NPCDatabaseEntry "Heat Imp" < uid=1ABBD50B594979BC0001DEAF188FF1E8 >
{
	myLocalizedDescription "contextComment = \"[PLACEHOLDER - do not translate].\nA tactical summary of the heat imp unit.\", description = \"database-item-description-imp-heat\", enabled = true, guid = #A08A88CF588A41190000E0D740FD359E, lineVersion = 1, maxLength = 62, text = \"Found on Hot planets\n\nVulnerable to Cold Weapons\""
	myLocalizedNarrative "contextComment = \"[PLACEHOLDER - do not translate].\nA descriptive/narrative short about the heat imp unit. \", description = \"database-item-narrative-imp-heat\", enabled = true, guid = #A08A88CF588A41190000E0D8A390166C, lineVersion = 1, maxLength = 312, text = \"The combination of high-octane and low-viscosity fuels make fire imps highly volatile, creating fiery explosions when they overheat. Chill them out with an ice weapon to slow down their processes and prevent them from burning you in combat.\""
	myPortrait onward/baked/textures/ui/icons/database_banner_large/legion/ui-database-legion-fire-imp-large.dds
	mySprite "mySpriteId = 620184426, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database.spritesheet\""
