include "onward/game system data/fruit/ui/collection/databasesubcategory.fruit"

CustomDatabaseEntry "Swap Technology" < uid=A08A88CF586EC433000029BC59B4E7EB >
{
	myLocalizedDescription "contextComment = \"[PLACEHOLDER - do not translate].\nDatabase tactics tips for Swap Technology, the force by which pilots of the Onward Initiative can build and rebuild their ship into a plethora of combinations.\", description = \"database-item-tactics-swaptechnology\", enabled = true, guid = #A08A88CF588A1BFF00002DDEF33D1C60, lineVersion = 0, maxLength = 280, text = \"Swap weapons to counter target weaknesses,\nsolve puzzles, and overcome obstacles\n\nWhen one ship gets shot down, swap your whole\nship to get back into the fight instantly\n\nAdd wings to fine-tune ship handling & stats\""
	myLocalizedNarrative "contextComment = \"[PLACEHOLDER - do not translate].\nA description of Swap Technology, the force by which pilots of the Onward Initiative can build and rebuild their ship into a plethora of combinations.\", description = \"database-item-description-swaptechnology\", enabled = true, guid = #A08A88CF589A385A000022070E4081B8, lineVersion = 1, maxLength = 400, text = \"Invented by Mason Rana, Starlink technology can transport objects across vast distances instantaneously, letting pilots link new Ships, Wings, and Weapons withut returning to the Equinox. \""
	myPortrait onward/baked/textures/ui/icons/database_banner_large/technology/ui-database-technology-starlink.dds
	mySprite "mySpriteId = 1734099578, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database.spritesheet\""
	myBannerSprite "mySpriteId = 1734099578, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database.spritesheet\""
	myAttachScreenSprite "mySpriteId = 1734099578, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database.spritesheet\""
	myRevealedChallengeType Act0
	myUnlockedChallengeType Act0
	myLocalizedName "contextComment = \"\", description = \"\", enabled = true, guid = #A08A88CF586FA75F00003476E463C089, lineVersion = 2, maxLength = 25, text = \"Starlink Technology\""
}

CustomDatabaseEntry Skimmers < uid=A08A88CF586EC433000029BDD8778CB4 >
{
	myLocalizedDescription "contextComment = \"[PLACEHOLDER - do not translate].\nTactics for use of the Skimmers' flight/skim mode switch\", description = \"database-item-tactics-skimmers\", enabled = true, guid = #A08A88CF588A1ABE00002DD8B5CD4089, lineVersion = 0, maxLength = 257, text = 'Hold <gameaction src=\"FlightEngineStart\"> to launch into Flight\n\nHold again in Flight to Cut Engine and glide back down to the surface\n\nTap or hold <gameaction src=\"Hop\"> to hop & hover on jump jets'}"
	myLocalizedNarrative "contextComment = \"[PLACEHOLDER - do not translate].\nA database entry description for skimmers, the types of ships used by pilots of the Starlink Initiative.\", description = \"database-item-description-skimmers\", enabled = true, guid = #A08A88CF589A386E00002218F0F25A00, lineVersion = 2, maxLength = 350, text = 'Skimmers can fly between planets, in-atmosphere, and \"skim\" along the planet surface, making them ideal exploration craft.\n\nEach skimmer is modular so pilots can customize them to deal with any situation.'"
	myPortrait onward/baked/textures/ui/icons/database_banner_large/technology/ui-database-technology-skimmers.dds
	mySprite "mySpriteId = 87925780, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database.spritesheet\""
	myBannerSprite "mySpriteId = 87925780, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database.spritesheet\""
	myAttachScreenSprite "mySpriteId = 87925780, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database.spritesheet\""
	myRevealedChallengeType Act0
	myUnlockedChallengeType Act0
	myLocalizedName "contextComment = \"Database name for the player's ships\", description = \"\", enabled = true, guid = #A08A88CF586FA75F00003473699DC073, lineVersion = 1, maxLength = 30, text = \"Skimmers\"}"
}

CustomDatabaseEntry Boost < uid=9E6AFEDA5A972600000252E854E468B2 >
{
	myLocalizedDescription "contextComment = \"[Placeholder - do not translate] Database tactics tip for entry on ship Boost ability to dash forward\", description = \"database-item-tactics-boost\", enabled = true, guid = #9E6AFEDA5A980C5F00001B69FDEED30A, lineVersion = 0, maxLength = 224, text = 'Hold <gameaction src=\"Boost\"> with <gameaction src=\"PushForward\"> centered to accelerate forward\n\nBoosting uses up your Maneuver bar\ntry to keep a little left to Dodge with'"
	myLocalizedNarrative "contextComment = \"[Placeholder - do not translate] Database narrative for entry on ship Boost ability to dash forward\", description = \"database-item-narrative-boost\", enabled = true, guid = #9E6AFEDA5A980C5F00001B6DA749422C, lineVersion = 0, maxLength = 350, text = \"Afterburners give Skimmers a burst of extra speed\""
	myPortrait onward/baked/textures/ui/icons/database_banner_large/technology/ui-database-technology-boost.dds
	mySprite "mySpriteId = 339790517, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myBannerSprite "mySpriteId = 339790517, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myAttachScreenSprite "mySpriteId = 339790517, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myRevealedChallengeType Act0
	myUnlockedChallengeType Act0
	myLocalizedName "contextComment = \"[Placeholder - do not translate] Database name for entry on ship Boost ability to dash forward\", description = \"database-item-name-boost\", enabled = true, guid = #9E6AFEDA5A980C5F00001B6F510CF504, lineVersion = 0, maxLength = 8, text = \"Boost\""
}

CustomDatabaseEntry Dodge < uid=9E6AFEDA5A972600000252E638BC14BB >
{
	myLocalizedDescription "contextComment = \"[Placeholder - do not translate]  Database tactics tips for using the Dodge move players can use to evade damage\", description = \"database-item-tactics-dodge\", enabled = true, guid = #9E6AFEDA5A981A4D00001B7FAA085EED, lineVersion = 0, maxLength = 295, text = 'Tap <gameaction src=\"TrickStart\">  while pushing <gameaction src=\"PushRight\"> sideways to evade incoming attacks\n\nDodging depletes your Maneuver bar, so time your moves carefully\n\nUse Dodge in the air to perform an Aerial Trick'"
	myLocalizedNarrative "contextComment = \"[Placeholder - do not translate]  Database narrative about the Dodge move players can use to evade damage\", description = \"database-item-narrative-dodge\", enabled = true, guid = #9E6AFEDA5A981A4D00001B8341D634EC, lineVersion = 0, maxLength = 350, text = \"Skimmers are nimble craft that can use attitude jets to dash out of the way of hazards.\n\nHornet Class ships are the most adept at tight maneuvers, followed by Specialist and Rocket types. Tank Class ships are the least evasive.\""
	myPortrait onward/baked/textures/ui/icons/database_banner_large/technology/ui-database-technology-dodge.dds
	mySprite "mySpriteId = 522070533, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myBannerSprite "mySpriteId = 522070533, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myAttachScreenSprite "mySpriteId = 522070533, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myRevealedChallengeType Act0
	myUnlockedChallengeType Act0
	myLocalizedName "contextComment = \"[Placeholder - do not translate]  Database name for the Dodge move players can use to evade damage\", description = \"database-item-name-dodge\", enabled = true, guid = #9E6AFEDA5A981A4D00001B85147309DC, lineVersion = 0, maxLength = 30, text = \"Dodge\""
}

CustomDatabaseEntry Block < uid=9E6AFEDA5A972600000252E7DCD7ED8D >
{
	myLocalizedDescription "contextComment = \"[Placeholder - do not translate] Database tactics tips on the Block / Shield & Parry ability\", description = \"database-item-tactics-block\", enabled = true, guid = #9E6AFEDA5A981D6300001B9B197204AE, lineVersion = 0, maxLength = 286, text = 'Press <gameaction src=\"Block\"> to Block projectiles\n\nTime it just right to Counter the projectile and send a blast back at your attacker\n\nBlocking depletes your Maneuver bar\nTank Class & high-Defense ships can Block more'"
	myLocalizedNarrative "contextComment = \"[Placeholder - do not translate] Database narrative for the Block / Shield & Parry ability\", description = \"database-item-narrative-block\", enabled = true, guid = #9E6AFEDA5A981D6300001B9FEA889B90, lineVersion = 0, maxLength = 307, text = \"Super-charging their structural integrity fields for a short window, Skimmers can shrug off damage from collisions with space debris and worse.\n\nThe effect is short-lived and draining, requiring expert timing or an extremely tough Ship.\""
	myPortrait onward/baked/textures/ui/icons/database_banner_large/technology/ui-database-technology-block.dds
	mySprite "mySpriteId = -332842457, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myBannerSprite "mySpriteId = -332842457, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myAttachScreenSprite "mySpriteId = -332842457, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myRevealedChallengeType Act0
	myUnlockedChallengeType Act0
	myLocalizedName "contextComment = \"[Placeholder - do not translate] Database name for the Block / Shield & Parry ability\", description = \"database-item-name-block\", enabled = true, guid = #9E6AFEDA5A981D6300001BA10621AF6D, lineVersion = 0, maxLength = 8, text = \"Block\""
}

CustomDatabaseEntry "Shield Slam" < uid=A08A88CF5BD759810005D36392CD2B6F >
{
	myLocalizedDescription "contextComment = \"A tactical description of the uses of the Shield Slam action. At the time of writing, the player can do it by pressing boost or shield and then rapidly pressing the other with a valid target. Their ship then makes a ramming attack on whatever the valid target is. Typically, bullet points.\", description = \"database-item-tactics-shieldslam\", enabled = true, guid = #A08A88CF5BD7588A000535EC7842666B, lineVersion = 0, maxLength = 44, text = \"[Shield Slam Tactical Description]\""
