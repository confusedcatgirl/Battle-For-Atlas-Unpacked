{
	myLocalizedDescription "contextComment = \"[PLACEHOLDER - do not translate].\nText describing the strategies associated with the Starlink/Alliance Tower (a final outpost type that allows the player to progress to the end game).\", description = \"database-item-description-alliancetower\", enabled = true, guid = #A08A88CF5A0A1B930021F7EFA36799B4, lineVersion = 0, maxLength = 209, text = \"Alliance Towers help the Starlink Initiative to pinpoint Grax's home base in the Atlas galaxy; build them to help Starlink find and defeat Grax once and for all!\"}"
	myLocalizedShortDescription "contextComment = \"[PLACEHOLDER - do not translate].\nA shorter text describing the strategies associated with the Starlink/Alliance Tower (a final outpost type that allows the player to progress to the end game).\", description = \"database-item-shortdescription-alliancetower\", enabled = true, guid = #A08A88CF5A0A1B930021F7F170FBA73C, lineVersion = 0, maxLength = 122, text = \"Alliance Towers help the Starlink Initiative to pinpoint Grax's home base in the Atlas galaxy.\"}"
