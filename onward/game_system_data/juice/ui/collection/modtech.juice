	myLocalizedDescription "contextComment = \"[Placeholder - do not translate] Database description for entry on Weapon Boosters, currently lists main (non-Warden relic) types\", description = \"database-item-description-ModWeaponBooster\", enabled = true, guid = #9E6AFEDA5A73ABDA00001BCA56F01E64, lineVersion = 1, maxLength = 152, text = \"Heat / Cold / Gravity / Stasis\nRange / Energy / Rate of Fire\nImpact / Shield Splinter / Recoil\nXP / Warden / Alliance\""
	myLocalizedNarrative "contextComment = \"[Placeholder - do not translate] Database narrative for entry on Weapon Boosters\", description = \"database-item-narrative-ModWeaponBooster\", enabled = true, guid = #9E6AFEDA5A73ABDA00001BCE1B00C9A6, lineVersion = 0, maxLength = 329, text = \"Weapon Booster mods allow pilots to fine-tune their Weapons in a variety of ways, mixing & matching to double down on the Weapon & Ammo's strengths, or compensate for weaknesses.\n\nBy upgrading the Equinox, we can equip even more Boosters on our Weapons.\"}"
	myPortrait onward/baked/textures/ui/icons/database_banner_large/technology/ui-database-technology-mods-weaponbooster.dds
