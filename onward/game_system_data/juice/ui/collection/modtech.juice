	myLocalizedDescription "contextComment = \"A tactical description for paint jobs. For the other mod types, this entails a list of the mods of that given type (Ex: deflection uner armour or what have you). Typically a three point bullet list for other types of entry. \", description = \"database-item-description-PaintJobs\", enabled = true, guid = #A08A88CF5BF5A5920000AFB8A388365A, lineVersion = 0, maxLength = 47, text = \"[TACTICAL PAINT JOB EXPLANATION (?)]\""
