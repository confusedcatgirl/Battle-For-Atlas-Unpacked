	myLocalizedDescription "contextComment = \"[Placeholder - do not translate] Database description for entry on Warden Mods, listing the 5 types\", description = \"database-item-description-ModWarden\", enabled = true, guid = #9E6AFEDA5A73B41A0006E7EDED3DBC47, lineVersion = 0, maxLength = 101, text = \"Warden Core\nWarden Armor\nWarden Ship Booster\nWarden Ammo\nWarden Weapon Booster\""
