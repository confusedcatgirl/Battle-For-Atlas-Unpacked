CustomDatabaseEntry "Ship Core" < uid=9E6AFEDA5A73A42800001B8AB278BB5E >
{
	myLocalizedDescription "contextComment = \"[Placeholder - do not translate] Database description of Ship Core mods - currently lists each type, divided into 4 tiers from most common to most advanced\", description = \"database-item-description-ModShipCore\", enabled = true, guid = #9E6AFEDA5A73A3D200001B81E93806E5, lineVersion = 0, maxLength = 84, text = \"Racer  /  Stunt\n\nDefender / Fighter\n\nCommander\n\nWarden / Alliance\""
	myLocalizedShortDescription ""
	myLocalizedNarrative "contextComment = \"[Placeholder - do not translate] Database narrative for Ship Core mods \", description = \"database-item-narrative-ModShipCore\", enabled = true, guid = #9E6AFEDA5A73A0B700001B6B8364443A, lineVersion = 0, maxLength = 260, text = \"Ship Cores enhance the Skimmer's reactor and engines, customizing its flight, Weapon Energy, and Pilot Ability characteristics to suit its pilot's style.\n\nCores can be found from Extractors and Ruins.\""
	myPortrait onward/baked/textures/ui/icons/database_banner_large/technology/ui-database-technology-mods-shipcore.dds
	mySprite "mySpriteId = -1204068260, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-03.spritesheet\""
	myBannerSprite "mySpriteId = -1204068260, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-03.spritesheet\""
	myRevealedChallengeType Progression_AcquirePartEnhancementCommon
	myUnlockedChallengeType Progression_AcquirePartEnhancementCommon
	myLocalizedName "contextComment = \"[Placeholder - do not translate] Database name for Ship Core mods entry\", description = \"database-item-name-ModShipCore\", enabled = true, guid = #9E6AFEDA5A73A0B700001B6D4D3AE36E, lineVersion = 0, maxLength = 14, text = \"Ship Core\""
}

CustomDatabaseEntry "Ship Armor" < uid=9E6AFEDA5A73A42800001B8BE01110F0 >
{
	myLocalizedDescription "contextComment = \"[Placeholder - do not translate] Database description of Ship Armor mods - currently lists each type, divided into 4 tiers from most common to most advanced\", description = \"database-item-description-ModShipArmor\", enabled = true, guid = #9E6AFEDA5A73A1C800001B7375F811CE, lineVersion = 1, maxLength = 166, text = \"Deflection / Scrapper\n\nHeat / Cold / Gravity / Stasis\n\nPrototype / Commander\nExpedition / Prospector / Outlaw\n\nWarden / Alliance\""
	myLocalizedNarrative "contextComment = \"[Placeholder - do not translate] Database narrative for Ship Armor mods \", description = \"database-item-narrative-ModShipArmor\", enabled = true, guid = #9E6AFEDA5A73A1C800001B77D2CFF292, lineVersion = 0, maxLength = 322, text = \"By plating a skimmer's Hull in advanced materials and augmenting its shields, Armor mods can resist damage, boost shield regeneration, and enhance the ship with a variety of special traits.\n\nArmors can be found from Primes and Expedition Workshops.\"}"
	myPortrait onward/baked/textures/ui/icons/database_banner_large/technology/ui-database-technology-mods-shiparmour.dds
	mySprite "mySpriteId = 322657245, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-03.spritesheet\""
	myBannerSprite "mySpriteId = 322657245, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-03.spritesheet\""
	myRevealedChallengeType Progression_AcquirePartEnhancementCommon
	myUnlockedChallengeType Progression_AcquirePartEnhancementCommon
	myLocalizedName "contextComment = \"[Placeholder - do not translate] Database name for Ship Armor Mods entry\", description = \"database-item-name-ModShipArmor\", enabled = true, guid = #9E6AFEDA5A73A1C800001B79F25627A1, lineVersion = 0, maxLength = 16, text = \"Ship Armor\""
}

CustomDatabaseEntry "Ship Booster" < uid=9E6AFEDA5A73A42800001B8C9A6FF70E >
{
	myLocalizedDescription "contextComment = \"[Placeholder - do not translate] Database description for entry on Ship Booster mods, currently lists available types (other than Warden Relics)\", description = \"database-item-description-ModShipBooster\", enabled = true, guid = #9E6AFEDA5A73A7E000001B9E8C33D3B3, lineVersion = 0, maxLength = 248, text = \"Speed / Handling / Energy / Defense\nHeat / Cold / Gravity /Kinetic Resist\nHeatsink / Antifreeze / Antigrav\nRegeneration / Recharge / Hover Booster\nStabilizer / Pilot Booster / Last Stand / XP\""
	myLocalizedNarrative "contextComment = \"[Placeholder - do not translate] Database narrative for entry on Ship Booster mods - weakest mod type, but multiple slots lets players stack several Boosters to customize in detail\", description = \"database-item-narrative-ModShipBooster\", enabled = true, guid = #9E6AFEDA5A73A7E000001BA2480FCE3F, lineVersion = 0, maxLength = 334, text = \"Ship Booster mods allow pilots to fine-tune their Skimmer in a variety of ways, mixing & matching to double down on the strengths of their Cores & Armors, or compensate for weaknesses.\n\nBy upgrading the Equinox, we can equip even more Boosters on our ships.\""
	myPortrait onward/baked/textures/ui/icons/database_banner_large/technology/ui-database-technology-mods-shipbooster.dds
	mySprite "mySpriteId = 1384547672, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-03.spritesheet\""
	myBannerSprite "mySpriteId = 1384547672, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-03.spritesheet\""
	myRevealedChallengeType Progression_AcquirePartEnhancementCommon
	myUnlockedChallengeType Progression_AcquirePartEnhancementCommon
	myLocalizedName "contextComment = \"[Placeholder - do not translate] Database name for entry on Ship Booster mods\", description = \"database-item-name-ModShipBooster\", enabled = true, guid = #9E6AFEDA5A73A7E000001BA4B7F921DF, lineVersion = 0, maxLength = 16, text = \"Ship Booster\""
}

