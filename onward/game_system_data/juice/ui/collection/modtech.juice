	myLocalizedNarrative "contextComment = \"A more flavourful history/background on the Shield Slam maneuvre. Typically full sentences.\", description = \"database-item-narrative-shieldslam\", enabled = true, guid = #A08A88CF5BD7588A000535F004FA1949, lineVersion = 0, maxLength = 46, text = \"[Shield Slam Narrative Description]\""
	myPortrait onward/baked/textures/UI/icons/database_banner_large/technology/ui-database-technology-shieldslam.dds
	mySprite "mySpriteId = 1710179028, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-03.spritesheet\""
	myRevealedChallengeType Act0
	myUnlockedChallengeType Act0
	myDeathChallengeType Act0
	myLocalizedName "contextComment = \"The name of the 'Shield Slam' attack, which is a small ramming attack generated by (at the time of writing) hitting shield and boost in quick succession.\", description = \"database-item-name-shieldslam\", enabled = true, guid = #A08A88CF5BD7588A000535F26EAE5050, lineVersion = 0, maxLength = 17, text = \"[Shield Slam]\""
}

