CustomDatabaseEntry "Weapon Core" < uid=9E6AFEDA5A73A42800001B8DF82BE311 >
{
	myLocalizedDescription "contextComment = \"[Placeholder - do not translate] Database description for entry on Weapon Core mods. Currently lists types, roughly divided into tiers from least to most advanced\", description = \"database-item-description-ModWeaponCore\", enabled = true, guid = #9E6AFEDA5A73A9A000001BB2C46AC2CE, lineVersion = 0, maxLength = 125, text = \"Gunner / Operator / Assault\n\nFire / Ice / Gravity / Stasis\n\nRevenant / Sniper\n\nWarden / Alliance\""
	myLocalizedNarrative "contextComment = \"[Placeholder - do not translate] Database narrative for entry on Weapon Core mods.\", description = \"database-item-Narrative-ModWeaponCore\", enabled = true, guid = #9E6AFEDA5A73A9A000001BB671E995E7, lineVersion = 0, maxLength = 231, text = \"Mod technology can infuse Weapons' ammunition to boost their damage output, firing behaviour, or special effects on targets they hit.\n\nAmmo can be found from Extractors and Ruins\"}"
	myPortrait onward/baked/textures/ui/icons/database_banner_large/technology/ui-database-technology-mods-weaponcore.dds
	mySprite "mySpriteId = 1284856965, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-03.spritesheet\""
	myBannerSprite "mySpriteId = 1284856965, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-03.spritesheet\""
	myRevealedChallengeType Progression_AcquirePartEnhancementCommon
	myUnlockedChallengeType Progression_AcquirePartEnhancementCommon
	myLocalizedName "contextComment = '[Placeholder - do not translate] Database name for entry on Weapon Core mods. Termed \"Ammo\" to avoid confusion with Ship Cores', description = \"database-item-name-ModWeaponCore\", enabled = true, guid = #9E6AFEDA5A73A9A000001BB8D94FA4FC, lineVersion = 0, maxLength = 14, text = \"Weapon Ammo\""
}

