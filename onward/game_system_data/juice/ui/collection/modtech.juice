CustomDatabaseEntry Hyperdrive < uid=9E6AFEDA5A972600000252E9734949A2 >
{
	myLocalizedDescription "contextComment = \"[Placeholder - do not translate] Database tactics tips for the Hyperdrive ability, used to travel quickly between planets\", description = \"database-item-tactics-hyperdrive\", enabled = true, guid = #9E6AFEDA5A980B1C00001B596649ACBD, lineVersion = 0, maxLength = 348, text = 'In space, hold <gameaction src=\"StartHyperDrive\"> to start Hyperdrive,\nand press again to drop back to normal speed\n\nOutlaws and Legion can disrupt Hyperdrive engines - defeat them to escape\n\nMap planets to unlock Fast Travel jumps to cross large distances even faster'"
	myLocalizedNarrative "contextComment = \"[Placeholder - do not translate] Database narrative for the Hyperdrive ability, used to travel quickly between planets\", description = \"database-item-narrative-hyperdrive\", enabled = true, guid = #9E6AFEDA5A980B1C00001B5D42122AB7, lineVersion = 0, maxLength = 350, text = \"All Skimmers are equipped with a Hyperdrive engine that can massively accelerate space travel. Use it to cross interplanetary distances in minutes.\""
	myPortrait onward/baked/textures/ui/icons/database_banner_large/technology/ui-database-technology-hyperdrive.dds
	mySprite "mySpriteId = -292522745, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myBannerSprite "mySpriteId = -292522745, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myAttachScreenSprite "mySpriteId = -292522745, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myRevealedChallengeType Unlock_Hyperdrive
	myUnlockedChallengeType Unlock_Hyperdrive
	myDeathChallengeType Unlock_Hyperdrive
	myLocalizedName "contextComment = \"[Placeholder - do not translate] Database name for the Hyperdrive ability, used to travel quickly between planets\", description = \"database-item-name-hyperdrive\", enabled = true, guid = #9E6AFEDA5A980B1C00001B5F1D6F8B2E, lineVersion = 0, maxLength = 30, text = \"Hyperdrive\""
}

CustomDatabaseEntry Precision < uid=9E6AFEDA5A972600000252EAAB8892BC >
{
	myLocalizedDescription "contextComment = \"[Placeholder - do not translate] Database tactics tips for using Precision weapons, ones that can score headshot damage\", description = \"database-item-tactics-precision\", enabled = true, guid = #9E6AFEDA5A981FFB00001BBD807CBD7E, lineVersion = 0, maxLength = 256, text = \"Aim for the head for maximum Critical damage\n\nSniper Ammo mods are ideal for Precision Weapons\n\nShredder, Guass Gun, Iron Fist, Volcano, Hailstorm, Freeze Gun, and Crusher are all Precision weapons\""
	myLocalizedNarrative "contextComment = \"[Placeholder - do not translate] Database narrative Precision weapons, ones that can score headshot damage\", description = \"database-item-narrative-precision\", enabled = true, guid = #9E6AFEDA5A981FFB00001BC13F5CA734, lineVersion = 0, maxLength = 164, text = \"Precision projectile weapons can be aimed carefully to strike targets' most vulnerable spots, dealing massive Critical damage.\"}"
	myPortrait onward/baked/textures/ui/icons/database_banner_large/technology/ui-database-technology-precisionweapons.dds
	mySprite "mySpriteId = 996910714, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myBannerSprite "mySpriteId = 996910714, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myAttachScreenSprite "mySpriteId = 996910714, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myRevealedChallengeType Act0
	myUnlockedChallengeType Act0
	myLocalizedName "contextComment = \"[Placeholder - do not translate] Database name for using Precision weapons, ones that can score headshot damage\", description = \"database-item-name-precision\", enabled = true, guid = #9E6AFEDA5A981FFB00001BC3B6F67BAB, lineVersion = 0, maxLength = 22, text = \"Precision Weapons\""
}

CustomDatabaseEntry Piercing < uid=9E6AFEDA5A972600000252EBC850B9C5 >
{
	myLocalizedDescription "contextComment = \"[Placeholder - do not translate] Database tactics tips for Piercing (Siege) Weapons, which do critical damage to bosses & structures\", description = \"database-item-tactics-siege\", enabled = true, guid = #9E6AFEDA5A98221600001BCF9218013A, lineVersion = 0, maxLength = 377, text = 'Switch to Piercing Weapons to demolish structures \nlike Imp Hives and Extractors, or even bigger Legion targets\n\nTargets with <color hex=\"ffffff00\">yellow</color> health bars are Armored \nand most vulnerable to Piercing\n\nGauss Gun, Fireball, Imploder, and Levitator are all Piercing Weapons'"
	myLocalizedNarrative "contextComment = \"[Placeholder - do not translate] Database narrative for Piercing (Siege) Weapons, which do critical damage to bosses & structures\", description = \"database-item-narrative-siege\", enabled = true, guid = #9E6AFEDA5A98221600001BD36DE2B823, lineVersion = 0, maxLength = 230, text = \"Piercing Weapons can punch, rip, and blast through even the thickest armor on buildings or capital ships, dealing Critical damage where other weapons struggle to make a scratch.\""
	myPortrait onward/baked/textures/ui/icons/database_banner_large/technology/ui-database-technology-siegeweapons.dds
	mySprite "mySpriteId = 1860590076, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myBannerSprite "mySpriteId = 1860590076, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myAttachScreenSprite "mySpriteId = 1860590076, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myRevealedChallengeType Discover_Extractor
	myUnlockedChallengeType Discover_Extractor
	myLocalizedName "contextComment = \"[Placeholder - do not translate] Database name for Piercing (Siege) Weapons, which do critical damage to bosses & structures\", description = \"database-item-name-siege\", enabled = true, guid = #9E6AFEDA5A98221600001BD594D7AD3E, lineVersion = 0, maxLength = 21, text = \"Piercing Weapons\""
}

CustomDatabaseEntry "Electrum & Nova" < uid=A08A88CF586EC433000029BABBBCD33B >
{
	myLocalizedDescription "contextComment = \"Database description of Electrum & Nova, the main economic resources in the game (Electrum is currently described in the companion field)\", description = \"database-item-gameplay-electrumNova\", enabled = true, guid = #A08A88CF588A18CB00002D59A1561B1E, lineVersion = 0, maxLength = 400, text = \"Electrum can be refined into what the aliens of Atlas call \\"Nova,\\" the greatest source of energy in the known galaxy, but the secrets to creating it were lost long ago. \n\nSt. Grand rediscovered these techniques and used Nova to power the Equinox's SpinDrive engines.\"}"
	myLocalizedNarrative "contextComment = \"[PLACEHOLDER - do not translate].\nDatabase description of Electrum & Nova, the main economic resources in the game. (Nova is currently described in the companion field)\", description = \"database-item-description-nova\", enabled = true, guid = #A08A88CF589A37FA000021E88EDC2551, lineVersion = 1, maxLength = 400, text = \"Electrum is a crystalline energy source that's the foundation for all Starlink technology. It is unusually plentiful on the planets of Atlas, perhaps connected to their spectacular native life.\"}"
	myPortrait onward/baked/textures/ui/icons/database_banner_large/onward_initiative/ui-database-onward-nova-large.dds
	mySprite "mySpriteId = -941678237, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database.spritesheet\""
	myBannerSprite "mySpriteId = -941678237, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database.spritesheet\""
	myAttachScreenSprite "mySpriteId = -941678237, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database.spritesheet\""
	myRevealedChallengeType Act1NovaAcquired
	myUnlockedChallengeType Act1NovaAcquired
	myLocalizedName "contextComment = \"\", description = \"\", enabled = true, guid = #A08A88CF586FA7570000346DE608344A, lineVersion = 1, maxLength = 30, text = \"Electrum & Nova\""
}

