include "onward/game system data/fruit/ui/collection/databasesubcategory.fruit"

CustomDatabaseEntry Profile < uid=1ABBD50B584AE9F70000393F1FAF8671 >
{
	myLocalizedDescription "contextComment = \"Left blank to leave more room for the narrative text. Database tactics tips about the Outlaw faction.\", description = \"collectibles_database_outlaws_profile_tactics\", enabled = true, guid = #1ABBD50B584AE9DA00003824E3D6DD1D, lineVersion = 1, maxLength = 0, text = \"|empty|\""
	myLocalizedNarrative "contextComment = \"[PLACEHOLDER - do not translate].\nDatabase narrative blurb about the Outlaw faction\", description = \"collectibles_database_outlaws_profile_description\", enabled = true, guid = #A08A88CF589A3A7D000030C1411527D4, lineVersion = 1, maxLength = 770, text = \"The Outlaws who roam the wild space between the worlds of Atlas are a formidable force to be reckoned with. Like vultures circling a dying animal, they wait in space while the Legion devastates Atlas, jumping at the chance to plunder from any traveller foolish enough to wander through their territory. \n\nThey are a disconnected, scattered collection of criminal scum, opportunistic in the extreme and allergic to infrastructure or organized governance.\n\nThe few Outlaw friends we've made in Atlas seem to work with us more to further their own ends, than out of any greater sense of loyalty.\"}"
	myPortrait onward/baked/textures/ui/icons/database_banner_large/outlaws/ui-database-outlaws-large.dds
	mySprite "mySpriteId = -1530616979, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database.spritesheet\""
	myBannerSprite "mySpriteId = -1530616979, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database.spritesheet\""
	myAttachScreenSprite "mySpriteId = -1530616979, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database.spritesheet\""
	myRevealedChallengeType Discover_Outlaws
	myUnlockedChallengeType Discover_Outlaws
	myCollectibleSubType Faction
	myLocalizedName "contextComment = \"Name for Database entry about the Outlaw faction\", description = \"collectibles_database_outlaws_profile_name\", enabled = true, guid = #1ABBD50B584AE9DA00003822BD6FC6DB, lineVersion = 1, maxLength = 30, text = \"Outlaws\""
}

SimUnitDatabaseEntries Outposts
{
	SimUnitDatabaseEntry "Outlaw Outposts" < uid=A08A88CF59A06ED10003DE429F5CFD7D >
	{
		myLocalizedDescription "contextComment = \"[PLACEHOLDER - do not translate].\", description = \"collectibles_database_outlaws_base_description\", enabled = true, guid = #A08A88CF59A06E690003DE2FE232F1AD, lineVersion = 1, maxLength = 248, text = \"Raid Strongholds to gain access to some\nof the rarest loot in space\n\nWith the help of an Outlaw pilot, we can\nset up a transportation network to quickly\njump to any defeated Outlaw Stronghold\""
		myLocalizedShortDescription "contextComment = \"[PLACEHOLDER - do not translate].\nA short description for outlaw outposts, typically displayed on starmap rollover panels.\", description = \"collectibles_database_outlaws_base_shortdescription\", enabled = true, guid = #A08A88CF5AC3F0290001B34361BAE7AB, lineVersion = 0, maxLength = 42, text = \"Outlaw Outpost Short Description\""
		myLocalizedNarrative "contextComment = \"[PLACEHOLDER - do not translate].\", description = \"collectibles_database_outlaws_base_narrative\", enabled = true, guid = #A08A88CF59A06EA50003DE3F7B4513DE, lineVersion = 1, maxLength = 337, text = \"When an Outlaw Captain gains enough clout & scavenged booty, they set about fortifying a space wreck to defend their holdings from other opportunists. Outlaws in their employ help defend these Strongholds and raid the surrounding space to add to their riches.\""
		myPortrait onward/baked/textures/ui/icons/database_banner_large/outlaws/ui-database-outlaws-base-large.dds
		mySprite "mySpriteId = 1779018103, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database.spritesheet\""
		myBannerSprite "mySpriteId = 1779018103, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database.spritesheet\""
		myAttachScreenSprite "mySpriteId = 1779018103, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database.spritesheet\""
		myRevealedChallengeType Discover_OutlawBase
		myUnlockedChallengeType Discover_OutlawBase
		myDeathChallengeType Death_OutlawStronghold
		myCollectibleSubType Structure
		mySimUnitFiles
		{
			file "" "onward/game system data/juice/sim/outlaw_outpost.msimunit"
			file "Collaborator Stronghold" "onward/game system data/juice/sim/collab_outlaw_outpost_base.msimunit"
			file "" "onward/game system data/juice/sim/outlaw_outpost_base.msimunit"
			file Wreck "onward/game system data/juice/sim/outlaw_outpost_wreck.msimunit"
			file Turret "onward/game system data/juice/sim/outlaw_outpost_turret_01.msimunit"
			file Turret "onward/game system data/juice/sim/outlaw_outpost_turret_02.msimunit"
			file Turret "onward/game system data/juice/sim/outlaw_outpost_turret_03.msimunit"
		}
	}
	SimUnitDatabaseEntry "Outlaw Hub" < uid=A08A88CF5BFEEAEE00009BFE1BC7F63A >
	{
		myLocalizedDescription "contextComment = \"A tactical summary of the Outlaw Hub. For other outpost types, this typically involves something to do with what they bring to the table/how they function.\", description = \"database-outlaw-description-outlawhub\", enabled = true, guid = #A08A88CF5BFEEB350000B904571A10C9, lineVersion = 0, maxLength = 30, text = \"[Outlaw Hub - Tactics.]\""
		myLocalizedShortDescription "contextComment = \"A short description of the outlaw \", description = \"database-outlaw-shortdescription-outlawhub\", enabled = true, guid = #A08A88CF5C1BEA58000378DEA1192F83, lineVersion = 0, maxLength = 42, text = \"[Outlaw Hub - Short Description]\""
		myLocalizedNarrative "contextComment = \"A narrative summary of the Outlaw Hub, and it's role in Atlas as the leader of the circus that is the outlaw games.\", description = \"database-outlaw-narrative-outlawhub\", enabled = true, guid = #A08A88CF5BFEEB350000B9089FFE569A, lineVersion = 0, maxLength = 32, text = \"[Outlaw Hub - Narrative.]\"}"
