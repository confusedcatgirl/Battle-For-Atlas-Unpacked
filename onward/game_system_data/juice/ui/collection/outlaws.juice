	SimUnitDatabaseEntry Mine < uid=9E6AFEDA5AB128F30001DD59E3BE3522 >
	{
		myLocalizedDescription "contextComment = \"Database tactics tips for dealing with Outlaw minefields\", description = \"collectibles_database_outlaws_mines_description\", enabled = true, guid = #9E6AFEDA5AB117C000001BED2F84CDE3, lineVersion = 0, maxLength = 142, text = \"[Shoot mines before they can reach you\n\nCladding ships in Outlaw Armor will prevent the mines from attacking]\""
		myLocalizedNarrative "contextComment = \"Database narrative desciption regarding Outlaw minefields\", description = \"collectibles_database_outlaws_mines_narrative\", enabled = true, guid = #9E6AFEDA5AB117C000001BF1E936A007, lineVersion = 0, maxLength = 246, text = \"[Outlaws booby trap space close to their strongholds with proximity-activated space mines to keep intruders out. The mines recognize outsiders and approach them before exploding violently.]\""
		myPortrait onward/baked/textures/ui/icons/database_banner_large/outlaws/ui-database-outlaws-mine.dds
		mySprite "mySpriteId = -416961074, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-03.spritesheet\""
		myBannerSprite "mySpriteId = -416961074, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-03.spritesheet\""
		myAttachScreenSprite "mySpriteId = -416961074, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-03.spritesheet\""
		myRevealedChallengeType Discover_OutlawMine
		myUnlockedChallengeType Discover_OutlawMine
		myDeathChallengeType Death_OutlawMine
		myCollectibleSubType Structure
		mySimUnitFiles
		{
			file Mine "onward/game system data/juice/sim/outlaw_mine.msimunit"
			file Single "onward/game system data/juice/sim/outlaw_mine_single.msimunit"
			file Laser "onward/game system data/juice/sim/outlaw_laser_mine.msimunit"
			file "Laser Single" "onward/game system data/juice/sim/outlaw_laser_mine_single.msimunit"
		}
	}
}

NPCDatabaseEntries Units
{
	NPCDatabaseEntry Basic < uid=1ABBD50B594979C90001E21C2F521943 >
	{
		myLocalizedDescription "contextComment = \"[Placeholder - do not translate] Database tactics tips for the basic Outlaw unit type\", description = \"database-outlaw-worker-tactics\", enabled = true, guid = #9E6AFEDA5A8602BA00001B72093060F4, lineVersion = 0, maxLength = 224, text = \"Attack unwary ships in space\nand use hyperdrive jammers\nto keep prey from escaping\n\nWait in ambush to catch would-be scavengers\nat shipwrecks and ruins on land and in space\""
		myLocalizedNarrative "contextComment = \"[Placeholder - do not translate] Database narrative summary for the basic Outlaw unit type\", description = \"database-outlaw-worker-narrative\", enabled = true, guid = #9E6AFEDA5A8602BA00001B76248B7CFB, lineVersion = 0, maxLength = 270, text = \"Loose bands of Outlaws roam the lawless space of the Atlas system, scavenging shipwrecks and raiding unwary transports.\n\nDevious thieves will use valuable salvage sites as bait, to ambush would-be scavengers.\""
		myPortrait onward/baked/textures/ui/icons/database_banner_large/outlaws/ui-database-outlaws-ship-large.dds
		mySprite "mySpriteId = 1744423589, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database.spritesheet\""
		myBannerSprite "mySpriteId = 1744423589, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database.spritesheet\""
		myAttachScreenSprite "mySpriteId = 1744423589, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database.spritesheet\""
		myRevealedChallengeType Discover_OutlawWorker
		myUnlockedChallengeType Discover_OutlawWorker
		myDeathChallengeType Death_OutlawWorker
		myCollectibleSubType Enemy
		myNPCFiles
		{
			file 1 "onward/game system data/juice/ai/npc/outlaw_defender.mnpc"
			file 2 "onward/game system data/juice/ai/npc/outlaw_shattered_planet.mnpc"
			file "Ground Units" "onward/game system data/juice/ai/npc/outlaw_defender_ground.mnpc"
		}
	}
	NPCDatabaseEntry Elite < uid=1ABBD50B594979C90001E21BF172D3DA >
	{
		myLocalizedDescription "contextComment = \"[Placeholder - do not translate] Database tactics tips for the Outlaw elite unit type\", description = \"database-outlaw-elite-tactics\", enabled = true, guid = #9E6AFEDA5A86022700001B6885D27C54, lineVersion = 0, maxLength = 52, text = \"May drop valuable Mod tech when defeated\""
		myLocalizedNarrative "contextComment = \"[Placeholder - do not translate] Database narrative summary for the Outlaw elite unit type\", description = \"database-outlaw-elite-narrative\", enabled = true, guid = #9E6AFEDA5A86022700001B6CE53D7D8B, lineVersion = 0, maxLength = 272, text = \"The right and left hands of powerful Outlaw Captains, these elite fighters tend to fly more durable ships with better weaponry, but also carry better salvage for those skilled or lucky enough to take one down.\""
		myPortrait onward/baked/textures/ui/icons/database_banner_large/outlaws/ui-database-outlaws-elict-large.dds
		mySprite "mySpriteId = -1454461691, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
		myBannerSprite "mySpriteId = -1454461691, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
		myRevealedChallengeType Discover_OutlawElite
		myUnlockedChallengeType Discover_OutlawElite
		myDeathChallengeType Death_OutlawElite
		myCollectibleSubType Enemy
		myNPCFiles
		{
			file 1 "onward/game system data/juice/ai/npc/outlaw_defender_elite.mnpc"
		}
	}
	NPCDatabaseEntry Leader < uid=9E6AFEDA5A8603C400001B7B2A6067F4 >
	{
		myLocalizedDescription "contextComment = \"[Placeholder - do not translate] Database tactics tips for the Outlaw leader unit type\", description = \"database-outlaw-leader-tactics\", enabled = true, guid = #9E6AFEDA5A85FFF800001B5E840B024D, lineVersion = 0, maxLength = 177, text = \"Most formidable of the Outlaw space forces\n\nLeaders let their underlings attack first,\nand show up in later waves\n\nCarry the rarest loot\""
		myLocalizedNarrative "contextComment = \"[Placeholder - do not translate] Database narrative summary of the Outlaw Leader unit type\", description = \"database-outlaw-leader-narrative\", enabled = true, guid = #9E6AFEDA5A85FFF800001B624A51DA10, lineVersion = 0, maxLength = 270, text = \"The most successful Outlaws, through luck or cunning or sheer combat prowess, tend to amass holdings of valuable salvage, as well as followers from the weaker Outlaws, looking to ride their coattails to glory\""
		myPortrait onward/baked/textures/ui/icons/database_banner_large/outlaws/ui-database-outlaws-leader-large.dds
		mySprite "mySpriteId = -1839079876, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database.spritesheet\""
		myBannerSprite "mySpriteId = -1839079876, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database.spritesheet\""
		myRevealedChallengeType Discover_OutlawLeader
		myUnlockedChallengeType Discover_OutlawLeader
		myDeathChallengeType Death_OutlawLeader
		myCollectibleSubType Enemy
		myNPCFiles
		{
			file 1 "onward/game system data/juice/ai/npc/outlaw_defender_leader.mnpc"
			file 2 "onward/game system data/juice/ai/npc/outlaw_leader_shattered_planet.mnpc"
		}
	}
}

