{
	myLocalizedDescription "contextComment = \"Database tactics tips for Kirite's \\"secret\\" database entry, awarded for discovering everything else on the planet.\nCurrently left blank so narrative text can use the full height of the card.\", description = \"database-description-planet-secrets-01\", enabled = true, guid = #9E6AFEDA5A9700FC00001C71170D6AA5, lineVersion = 0, maxLength = 2, text = \" \"}"
	myLocalizedNarrative "contextComment = \"[Placeholder - do not translate] Database narrative for Kirite's \\"secret\\" database entry, awarded for discovering everything else on the planet.\", description = \"database-narrative-planet-secrets-01\", enabled = true, guid = #9E6AFEDA5A9700FC00001C7554230DDC, lineVersion = 0, maxLength = 750, text = 'An unforgiving desert wasteland ripped apart by a colossal meteorite, Kirite (pronounced \"kee-reet\") is a harsh, hot planet that appears as a red-brown orb from space. Once a thriving ocean world, it is now home to Prospectors praying to strike it rich, and Expedition scientists eager to decipher the planet’s mysteries.'}"
