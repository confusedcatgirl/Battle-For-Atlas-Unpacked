SimUnitDatabaseEntry XFactor < uid=A08A88CF598A09000001AD5444385DA1 >
{
	myLocalizedDescription "contextComment = \"Database tactics tip for Kirite's X-Factor site.\nCurrently left blank so narrative text can use this field's vertical space\", description = \"collectibles_database_xfactor_planet_01_tactics\", enabled = true, guid = #A08A88CF598A08EF0001ABD6D022915C, lineVersion = 0, maxLength = 2, text = \" \""
	myLocalizedShortDescription "contextComment = \"[Placeholder - do not translate] Short descriptive text for Kirite's X-Factor site, shown when selecting it on the Starmap\", description = \"Starmap_shortDesc_planet_01_xfactor\", enabled = true, guid = #9E6AFEDA5A8333D100001BDAF7ECFFFE, lineVersion = 0, maxLength = 88, text = \"The crater of an ancient impact - was it a Warden relic that struck?\"}"
	myLocalizedNarrative "contextComment = \"[PLACEHOLDER - do not translate] Database narrative blurb for the Eye of Kirite, the unique X-Factor location on the desert planet.\", description = \"collectibles_database_xfactor_planet_01_description\", enabled = true, guid = #A08A88CF598A08EF0001ABD7F255DF4E, lineVersion = 1, maxLength = 467, text = \"A massive crater marking the impact of an ancient meteorite. The initial impact boiled away the oceans, shaping Kirite into the planet it is today. The heart of the crater is bizarrely cold, thanks to the presence of an ancient Warden artifact. Religious settlers look upon The Eye as a sort of mecca, making treks across the Bone Wastes to bask in its glory.\""
	myPortrait onward/baked/textures/ui/icons/database_banner_large/planet_arrid/ui-database-arrid-eye-of-kirite-large.dds
	mySprite "mySpriteId = 479382648, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myBannerSprite "mySpriteId = 479382648, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myAttachScreenSprite "mySpriteId = 479382648, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myRevealedChallengeType Discover_Planet01_XFactor
	myUnlockedChallengeType Discover_Planet01_XFactor
	myCollectibleSubType XFactor
	mySimUnitFiles
	{
		file planet_01 "onward/game system data/juice/sim/container_x_factor_base_planet_01.msimunit"
	}
}

CustomDatabaseEntry FloraSample01 < uid=9E6AFEDA5A82347F00001B5FE8405C85 >
{
	myLocalizedDescription "contextComment = \"[Placeholder - do not translate] Database tactical summary for Gritfish Roe, a sample the player can pluck from environment props on Kirite\", description = \"database-description-FloraSample01\", enabled = true, guid = #A1467EAF33854CF3830D61A0E3F28FF7, lineVersion = 0, maxLength = 250, text = \"Valued by Expedition Observatories\n\nCan be used to develop Heat Mods\""
	myLocalizedNarrative "contextComment = \"[Placeholder - do not translate] Database narrative description for Gritfish Roe, a sample the player can pluck from environment props on Kirite\", description = \"database-narrative-FloraSample01\", enabled = true, guid = #2313048288234C3D955367201991EFF0, lineVersion = 0, maxLength = 300, text = \"Gritfish egg clusters resemble the offspring of many aquatic species, further evidence that they were once water-based animals. It seems like the eggs would dry out when left high up on Kirite's mesas, but they somehow retain water to a degree never before thought possible.\""
	myPortrait onward/baked/textures/ui/icons/database_banner_large/planet_arrid/ui-database-arrid-flora-sample-01-large.dds
	mySprite "mySpriteId = 2058716644, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myBannerSprite "mySpriteId = 2058716644, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myAttachScreenSprite "mySpriteId = 2058716644, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myRevealedChallengeType Discover_FloraSample01
	myUnlockedChallengeType Discover_FloraSample01
	myCollectibleSubType Samples
	myLocalizedName "contextComment = \"[Placeholder - do not translate] Database name for Gritfish Roe, a sample the player can pluck from environment props on Kirite\", description = \"database-name-FloraSample01\", enabled = true, guid = #6ECCF65F553B4BF1BF3221D0DA351811, lineVersion = 0, maxLength = 30, text = \"Gritfish Roe\""
}

CustomDatabaseEntry FloraSample02 < uid=9E6AFEDA5A82347F00001B60E7C7D88C >
{
	myLocalizedDescription "contextComment = \"[Placeholder - do not translate] Database tactical summary for Bonefruit, a sample the player can pluck from environment props on Kirite\", description = \"database-description-FloraSample02\", enabled = true, guid = #9BFA773E8F9D47C9AAAB2ED619E1BFB4, lineVersion = 0, maxLength = 250, text = \"Valued by Expedition Observatories\n\nCan be used to develop Regenerative Mods\""
	myLocalizedNarrative "contextComment = \"[Placeholder - do not translate] Database narrative description for Bonefruit, a sample the player can pluck from environment props on Kirite\", description = \"database-narrative-FloraSample02\", enabled = true, guid = #9F651C2BE18849E4952276284254E0ED, lineVersion = 0, maxLength = 300, text = 'Found in the skeletal remains of Kirite\'s ancient Leviathans, these \"plants\" are actually parasitic growths once living inside the massive creatures. They persist long after their hosts, even in the baking heat. Perhaps they draw water from the prey they attract with their musky odor?'"
	myPortrait onward/baked/textures/ui/icons/database_banner_large/planet_arrid/ui-database-arrid-flora-sample-02-large.dds
	mySprite "mySpriteId = -493333072, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myBannerSprite "mySpriteId = -493333072, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myAttachScreenSprite "mySpriteId = -493333072, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myRevealedChallengeType Discover_FloraSample02
	myUnlockedChallengeType Discover_FloraSample02
	myCollectibleSubType Samples
	myLocalizedName "contextComment = \"[Placeholder - do not translate] Database name for Bonefruit, a sample the player can pluck from environment props on Kirite\", description = \"database-name-FloraSample02\", enabled = true, guid = #3B6814C1D3C646FBA7F00D32068827CB, lineVersion = 0, maxLength = 30, text = \"Bonefruit\""
}

CustomDatabaseEntry FloraSample03 < uid=9E6AFEDA5A82347F00001B6109638F5E >
{
	myLocalizedDescription "contextComment = \"[Placeholder - do not translate] Database tactical summary for Skylobite, a sample the player can pluck from environment props on Kirite\", description = \"database-description-FloraSample03\", enabled = true, guid = #7E762B27C7AB4766A4712D89D2151419, lineVersion = 0, maxLength = 250, text = \"Valued by Expedition Observatories\n\nCan be used to develop Defensive Mods\""
	myLocalizedNarrative "contextComment = \"[Placeholder - do not translate] Database narrative description for Skylobite, a sample the player can pluck from environment props on Kirite\", description = \"database-narrative-FloraSample03\", enabled = true, guid = #9DABDEE3E40E455E9A4DFA610C0289A6, lineVersion = 0, maxLength = 300, text = \"Crustaceans were common in the lush ecosystem of Kirite's coral reefs, but once the oceans boiled away, only their tough shells remained - still clinging to their coral homes. Now the shells themselves are home to alien bacteria, subsisting on dew that collects inside them.\""
	myPortrait onward/baked/textures/ui/icons/database_banner_large/planet_arrid/ui-database-arrid-flora-sample-03-large.dds
	mySprite "mySpriteId = 58078596, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myBannerSprite "mySpriteId = 58078596, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myAttachScreenSprite "mySpriteId = 58078596, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myRevealedChallengeType Discover_FloraSample03
	myUnlockedChallengeType Discover_FloraSample03
	myCollectibleSubType Samples
	myLocalizedName "contextComment = \"[Placeholder - do not translate] Database name for Skylobite, a sample the player can pluck from environment props on Kirite\", description = \"database-name-FloraSample03\", enabled = true, guid = #8D8F032AFFD147EFBC7D96FA968D37F5, lineVersion = 0, maxLength = 30, text = \"Skylobite\""
}

CustomDatabaseEntry FaunaSample01 < uid=9E6AFEDA5A82347F00001B62E3B179E7 >
{
	myLocalizedDescription "contextComment = \"[Placeholder - do not translate] Database tactical summary for Nomadon Scale, a piece that can be collected from an animal on Kirite\", description = \"database-description-FaunaSample01\", enabled = true, guid = #51B5C8E40963437EA4D198AB91DB688D, lineVersion = 0, maxLength = 250, text = \"Valued by Expedition Workshops\n\nCan be used to develop Defensive Mods\""
	myLocalizedNarrative "contextComment = \"[Placeholder - do not translate] Database narrative description for Nomadon Scale, a piece that can be collected from an animal on Kirite\", description = \"database-narrative-FaunaSample01\", enabled = true, guid = #4B01CC39D58D4BEDB2CAF52AAE251938, lineVersion = 0, maxLength = 300, text = \"The thick armor plates of the Nomadon are infused with Electrum, forming a unique bio-mineral alloy tougher than anything found or synthesized on Earth. Expedition scientists believe new ship-building and armor materials could be developed based on its study.\""
