include "onward/game system data/fruit/ui/collection/databasesubcategory.fruit"

PlanetDatabaseEntry Overview < uid=1ABBD50B594979E20001E7E18DCFEFB7 >
{
	myLocalizedDescription "contextComment = \"[PLACEHOLDER - do not translate] Database tactical summary for the desert planet Kirite, listing its sector, environment conditions, expected threat & rewards\", description = \"collectibles_database_planet_01_overview_tactics\", enabled = true, guid = #1ABBD50B5859942200002F46B2690680, lineVersion = 1, maxLength = 99, text = \"Sector A\n\nHigh Temperatures\n\nHeat-type Legion and \nHeat Mods are common here\""
	myLocalizedNarrative "contextComment = \"[PLACEHOLDER - do not translate] Database narrative summary for the desert planet Kirite\", description = \"collectibles_database_planet_01_overview_description\", enabled = true, guid = #A08A88CF589A3BCB0000004BC2DD304A, lineVersion = 1, maxLength = 464, text = \"An unforgiving desert wasteland ripped apart by a colossal meteorite, Kirite is a harsh, hot planet that appears as a red-brown orb from space. Once a thriving ocean world, it is now home to superstitious Prospectors praying to strike it rich, Expedition scientists eager to decipher the planet's mysteries, and restless Outlaws shadowing every canyon bend.\"}"
	myPortrait onward/baked/textures/ui/icons/database_banner_large/planet_arrid/ui-database-planet-arrid-large.dds
	mySprite "mySpriteId = 295698578, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database.spritesheet\""
	myBannerSprite "mySpriteId = 295698578, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database.spritesheet\""
	myAttachScreenSprite "mySpriteId = 295698578, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database.spritesheet\""
	myUnlockedChallengeType Discover_Planet01
	myPlanetUIDs
	{
		uid 1 2B55C72B560154A200000053621E3961
	}
	myLocalizedName "contextComment = \"Name for the desert planet Kirite where the player crashlands at the start of the game\", description = \"collectibles_database_planet_01_overview_name\", enabled = true, guid = #1ABBD50B5859942200002F45AAEA487A, lineVersion = 2, maxLength = 10, text = \"Kirite\""
}

SimUnitDatabaseEntries Landmarks
{
	SimUnitDatabaseEntry "The Outlands" < uid=1ABBD50B594979E20001E7E27A9F3327 >
	{
		myLocalizedDescription "contextComment = \"[PLACEHOLDER - do not translate]. A tactical description of Planet_01's named place A: The Outlands.\", description = \"database-item-namedarea-planet_01-a-tactical\", enabled = true, guid = #A08A88CF588B91FB0000E8B2EBE6469C, lineVersion = 1, maxLength = 52, text = \"Gritfish Roe can be found atop the Mesas\"}"
		myLocalizedNarrative "contextComment = \"[PLACEHOLDER - do not translate].\nA narrative description of Planet_01's named place A: The Outlands.\", description = \"database-item-namedarea-planet_01-a\", enabled = true, guid = #A08A88CF588B91FB0000E8B3B032ACB6, lineVersion = 1, maxLength = 334, text = \"The Outlands are marked by the conjunction of two major geological features of Kirite. Broad swaths of salt flats meet with towering mesas to create narrow, winding canyons where once great rivers may have run. Oceans once covered the surface of this world.\"}"
		myPortrait onward/baked/textures/ui/icons/database_banner_large/planet_arrid/ui-database-arrid-outlands-large.dds
		mySprite "mySpriteId = -91492272, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database.spritesheet\""
		myBannerSprite "mySpriteId = -91492272, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database.spritesheet\""
		myUnlockedChallengeType Discover_Planet01_NamedAreaA
		myCollectibleSubType Biome
		mySimUnitFiles
		{
			file 1 "onward/game system data/juice/sim/named_place_planet_01_c.msimunit"
		}
	}
	SimUnitDatabaseEntry "Briggman's Reef" < uid=1ABBD50B594979E20001E7E33D330219 >
	{
		myLocalizedDescription "contextComment = \"[PLACEHOLDER - do not translate].\nA tactical tip about Planet_01's named area; Briggman's Reef.\", description = \"database-item-namedarea-planet_01-b-tactical\", enabled = true, guid = #A08A88CF588B91FF0000E9A3E984DFB8, lineVersion = 0, maxLength = 64, text = \"Find Skylobite shells still clinking to the coral\""
		myLocalizedNarrative "contextComment = \"[PLACEHOLDER - do not translate].\nA narrative blurb about Planet_01's named area; Briggman's Reef.\", description = \"database-item-namedarea-planet_01-b\", enabled = true, guid = #A08A88CF588B91FF0000E9A4C13ACA6B, lineVersion = 0, maxLength = 389, text = \"Briggman's reef today is the graveyard of a thriving underwater ecosystem. The landscape boasts a number of superheated, mineral-rich pools and the fossils of ancient aquatic life. Though by no means a lush environment, it remains the most fertile and habitable environment on the surface of Kirite.\"}"
		myPortrait onward/baked/textures/ui/icons/database_banner_large/planet_arrid/ui-database-arrid-briggman-reef-large.dds
		mySprite "mySpriteId = 192384813, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database.spritesheet\""
		myBannerSprite "mySpriteId = 192384813, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database.spritesheet\""
		myUnlockedChallengeType Discover_Planet01_NamedAreaB
		myCollectibleSubType Biome
		mySimUnitFiles
		{
			file 1 "onward/game system data/juice/sim/named_place_planet_01_b.msimunit"
		}
	}
	SimUnitDatabaseEntry "The Bone Wastes" < uid=1ABBD50B594979E20001E7E48EEFFE3A >
	{
		myLocalizedDescription "contextComment = \"[PLACEHOLDER - do not translate].\nA tactical tip for the third named area of Planet_01 - The Bone Wastes.\", description = \"database-item-namedarea-planet_01-c-tactical\", enabled = true, guid = #A08A88CF588B92050000EB65A3850C59, lineVersion = 0, maxLength = 60, text = \"Bonefruit can be found among the ribs & skulls\""
		myLocalizedNarrative "contextComment = \"[PLACEHOLDER - do not translate].\nA narrative blurb for the third named area of Planet_01 - The Bone Wastes.\", description = \"database-item-namedarea-planet_01-c\", enabled = true, guid = #A08A88CF588B92050000EB66E478E923, lineVersion = 0, maxLength = 332, text = \"The Bone Wastes earned its nickname from the massive crater, known as the Eye, that features predominantly on the landscape. The Eye aside, the Bone Wastes are home to twisting, shifting sand dunes broken only by the bones of long-dead, massive creatures.\""
		myPortrait onward/baked/textures/ui/icons/database_banner_large/planet_arrid/ui-database-arrid-face-large.dds
		mySprite "mySpriteId = 1885213495, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database.spritesheet\""
		myBannerSprite "mySpriteId = 1885213495, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database.spritesheet\""
		myUnlockedChallengeType Discover_Planet01_NamedAreaC
		myCollectibleSubType Biome
		mySimUnitFiles
		{
			file 1 "onward/game system data/juice/sim/named_place_planet_01_a.msimunit"
		}
	}
}

SimUnitDatabaseEntries Fauna
{
	SimUnitDatabaseEntry Nomadon < uid=1ABBD50B594979E20001E7E57CAF0A07 >
	{
		myLocalizedDescription "contextComment = \"[PLACEHOLDER - do not translate]. \nDatabase tactical summary for the Snapdragon fauna (now Nomadon), a giant armored dinosaur-turtle found on Kirite\", description = \"database-item-fauna-snapdragon-tactics\", enabled = true, guid = #A08A88CF588B9B230001239A268D8CE7, lineVersion = 0, maxLength = 136, text = \"Defends itself with an all-around attack if threatened\n\nLoose armor plates can be used in Mod development\""
		myLocalizedNarrative "contextComment = \"[PLACEHOLDER - do not translate]. \nDatabase narrative blurb for the Snapdragon fauna (now Nomadon), a giant armored dinosaur-turtle found on Kirite\", description = \"database-item-fauna-snapdragon\", enabled = true, guid = #A08A88CF588B9B230001239B9160243C, lineVersion = 1, maxLength = 477, text = \"Snapdragons are a massive, saurian creature that roam the dunes of the Face of Kirite. Though they appear ferocious, the Snapdragon is a typically peaceful, solitary beast that fills the days consuming what it can of the local Spinecones. It is generally oblivious to smaller beings, having been known to crush settlements in it's path, but rarely does so on purpose.\"}"
		myPortrait onward/baked/textures/ui/icons/database_banner_large/planet_arrid/ui-database-arrid-snapdragon-large.dds
		mySprite "mySpriteId = -762642641, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database.spritesheet\""
		myBannerSprite "mySpriteId = -762642641, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database.spritesheet\""
		myRevealedChallengeType FullyScan_Fauna01
		myUnlockedChallengeType FullyScan_Fauna01
		myCollectibleSubType Fauna
		mySimUnitFiles
		{
			file 1 "onward/game system data/juice/sim/fauna_01.msimunit"
		}
	}
	SimUnitDatabaseEntry Razorbeak < uid=1ABBD50B594979E20001E7E6FF2A08BE >
	{
		myLocalizedDescription "contextComment = \"[PLACEHOLDER - do not translate]. \nDatabase tactical summary for the Razorbeak fauna, an avian gazelle found on Kirite\", description = \"database-item-fauna-razorbeak-tactics\", enabled = true, guid = #A08A88CF588B9B2F000123A2D6F2859C, lineVersion = 0, maxLength = 25, text = \"Flees if threatened\""
		myLocalizedNarrative "contextComment = \"[PLACEHOLDER - do not translate]. \nDatabase narrative summary for the Razorbeak fauna, an avian gazelle found on Kirite\", description = \"database-item-fauna-razorbeak\", enabled = true, guid = #A08A88CF588B9B2F000123A3A49030C6, lineVersion = 1, maxLength = 474, text = \"Razorbeaks evolved from cliff-dwelling avian species that called the sheer cliff faces of mesas home. It is speculated they lost flight primarily as a result of the vicious sandy winds that punctuate Kirite, developing instead nimble, strong legs. Fiercely territorial and aggressive, Razorbeaks have often been smuggled off-planet to be used for arena-based sport.\""
		myPortrait onward/baked/textures/ui/icons/database_banner_large/planet_arrid/ui-database-arrid-scrabblebeak-large.dds
		mySprite "mySpriteId = -2050288345, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database.spritesheet\""
		myBannerSprite "mySpriteId = -2050288345, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database.spritesheet\""
		myRevealedChallengeType FullyScan_Fauna14
		myUnlockedChallengeType FullyScan_Fauna14
		myCollectibleSubType Fauna
		mySimUnitFiles
		{
			file 1 "onward/game system data/juice/sim/fauna_14.msimunit"
		}
	}
	SimUnitDatabaseEntry Blub-Blub < uid=1ABBD50B594979E20001E7E75AACFE88 >
	{
		myLocalizedDescription "contextComment = \"[PLACEHOLDER - do not translate]. \nDatabase tactical summary for the Blub-Blub fauna, now the Gritfish, a slick multi-armed amphibian\", description = \"database-item-fauna-blubblub-tactics\", enabled = true, guid = #A08A88CF588B9B2E000123A022A9050F, lineVersion = 0, maxLength = 31, text = \"Flees from any intruders\""
		myLocalizedNarrative "contextComment = \"PLACEHOLDER - do not translate]. \nDatabase narrativel summary for the Blub-Blub fauna, now the Gritfish, a slick multi-armed amphibian\", description = \"database-item-fauna-blubblub\", enabled = true, guid = #A08A88CF588B9B2E000123A13A1BE651, lineVersion = 1, maxLength = 468, text = \"In a remarkable case of adaptation, the Gritfish evolved legs in response to the the dwindling oceans on Kirite. Strong and fast, as well as easily trained, the Gritfish is a choice beast of burden for the local population transporting valuables over the harsh desert. The nickname Blub-Blub came from the soft bubbling sounds the species makes while in herds.\""
		myPortrait onward/baked/textures/ui/icons/database_banner_large/planet_arrid/ui-database-arrid-blub-large.dds
		mySprite "mySpriteId = -364146890, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database.spritesheet\""
		myBannerSprite "mySpriteId = -364146890, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database.spritesheet\""
		myRevealedChallengeType FullyScan_Fauna03
		myUnlockedChallengeType FullyScan_Fauna03
		myCollectibleSubType Fauna
		mySimUnitFiles
		{
			file 1 "onward/game system data/juice/sim/fauna_03.msimunit"
		}
	}
}

