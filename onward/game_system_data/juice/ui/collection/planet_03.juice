CustomDatabaseEntry FloraSample04 < uid=9E6AFEDA5A835A2F00001CB5163A3B39 >
{
	myLocalizedDescription "contextComment = \"[Placeholder - do not translate] Database tactical summary for Quillhart Pellet, a sample the player can pluck from environment props on Haven\", description = \"database-description-FloraSample04\", enabled = true, guid = #5CA6644CF746457CBF71916096EFC3A8, lineVersion = 0, maxLength = 250, text = \"Valued by Expedition Observatories\n\nCan be used to develop Mobility Mods\""
	myLocalizedNarrative "contextComment = \"[Placeholder - do not translate] Database narrative description for Quillhart Pellet, a sample the player can pluck from environment props on Haven\", description = \"database-narrative-FloraSample04\", enabled = true, guid = #FA1E7C778F31438A9A60F34768115F2C, lineVersion = 0, maxLength = 300, text = \"The Quillhart vomits the toxic stingers, skeletons, and sacs that the it cannot digest in the form of these pellets. Analyzing the contents of Quillhart pellets gives us clues about their migration patterns.\""
	myPortrait onward/baked/textures/ui/icons/database_banner_large/planet_haven/ui-database-haven-flora-sample-04-large.dds
	mySprite "mySpriteId = 1145569474, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myBannerSprite "mySpriteId = 1145569474, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myRevealedChallengeType Discover_FloraSample04
	myUnlockedChallengeType Discover_FloraSample04
	myCollectibleSubType Samples
	myLocalizedName "contextComment = \"[Placeholder - do not translate] Database name for Quillhart Pellet, a sample the player can pluck from environment props on Haven\", description = \"database-name-FloraSample04\", enabled = true, guid = #792C23FA71E940A2BD3784ED3C70FAD3, lineVersion = 0, maxLength = 30, text = \"Quillhart Pellet\""
}

CustomDatabaseEntry FloraSample05 < uid=9E6AFEDA5A835A2F00001CB6069400A5 >
{
	myLocalizedDescription "contextComment = \"[Placeholder - do not translate] Database tactical summary for Stonebee Hive, a sample the player can pluck from environment props on Haven\", description = \"database-description-FloraSample05\", enabled = true, guid = #0813507C17954F4A9DE8F332187AB062, lineVersion = 0, maxLength = 250, text = \"Valued by Expedition Observatories\n\nCan be used to develop Offensive Mods\""
	myLocalizedNarrative "contextComment = \"[Placeholder - do not translate] Database narrative description for Stonebee Hive, a sample the player can pluck from environment props on Haven\", description = \"database-narrative-FloraSample05\", enabled = true, guid = #85FC7C61E5A5469BA2596AC4904E6F2B, lineVersion = 0, maxLength = 300, text = \"Playing a critical role in pollinating Haven's rich plant life, the Stonebee somehow thrives inside the grooves Skittertusk horns make in meadow stones. It may be their deadly stingers help keep the beetles from trampling their hives.\""
	myPortrait onward/baked/textures/ui/icons/database_banner_large/planet_haven/ui-database-haven-flora-sample-05-large.dds
	mySprite "mySpriteId = 784830230, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myBannerSprite "mySpriteId = 784830230, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myAttachScreenSprite "mySpriteId = 784830230, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myRevealedChallengeType Discover_FloraSample05
	myUnlockedChallengeType Discover_FloraSample05
	myCollectibleSubType Samples
	myLocalizedName "contextComment = \"[Placeholder - do not translate] Database name for Stonebee Hive, a sample the player can pluck from environment props on Haven\", description = \"database-name-FloraSample05\", enabled = true, guid = #E4294A98865846A9A99D70CDC19E94D1, lineVersion = 0, maxLength = 30, text = \"Stonebee Hive\""
}

CustomDatabaseEntry FloraSample06 < uid=9E6AFEDA5A835A2F00001CB728C02017 >
{
	myLocalizedDescription "contextComment = \"[Placeholder - do not translate] Database tactical summary for Bask Blossom, a sample the player can pluck from environment props on Haven\", description = \"database-description-FloraSample06\", enabled = true, guid = #C870F98F5B0E403FBE50DA77CD7FC128, lineVersion = 0, maxLength = 250, text = \"Valued by Expedition Observatories\n\nCan be used to develop Evasive Mods\""
	myLocalizedNarrative "contextComment = \"[Placeholder - do not translate] Database narrative description for Bask Blossom, a sample the player can pluck from environment props on Haven\", description = \"database-narrative-FloraSample06\", enabled = true, guid = #99FDA824636A4F9FBBDFF94A7C3C268C, lineVersion = 0, maxLength = 300, text = \"Bask Blossoms spend most of their life hiding underwater from herbivores that would consume them. When the time comes, their roots slither up on to the riverbank and create a luminous flower. Wind and water carry their seeds downstream.\""
	myPortrait onward/baked/textures/ui/icons/database_banner_large/planet_haven/ui-database-haven-flora-sample-06-large.dds
	mySprite "mySpriteId = 819643768, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myBannerSprite "mySpriteId = 819643768, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myAttachScreenSprite "mySpriteId = 819643768, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myStarmapThreatKnownSprite "mySpriteId = -455779427, mySpritesheet = F\"onward/ui/spritesheets/ui-icon-placeholder.spritesheet\""
	myRevealedChallengeType Discover_FloraSample06
	myUnlockedChallengeType Discover_FloraSample06
	myCollectibleSubType Samples
	myLocalizedName "contextComment = \"[Placeholder - do not translate] Database name for Bask Blossom, a sample the player can pluck from environment props on Haven\", description = \"database-name-FloraSample06\", enabled = true, guid = #FE4CCFA4D92D4E52B5904B2997605AD4, lineVersion = 0, maxLength = 30, text = \"Bask Blossom\""
}

CustomDatabaseEntry FaunaSample06 < uid=9E6AFEDA5A835A2F00001CB804E3FDA3 >
{
	myLocalizedDescription "contextComment = \"[Placeholder - do not translate] Database tactical summary for Sunstrider Plume, a piece that can be collected from an animal on Haven\", description = \"database-description-FaunaSample06\", enabled = true, guid = #948FA637D3B842FFAAF3D97E214EC9AD, lineVersion = 0, maxLength = 250, text = \"Valued by Expedition Workshops\n\nCan be used to develop Mobility Mods\""
	myLocalizedNarrative "contextComment = \"[Placeholder - do not translate] Database narrative description for Sunstrider Plume, a piece that can be collected from an animal on Haven\", description = \"database-narrative-FaunaSample06\", enabled = true, guid = #610E7517ACBA4D54AA50C06BB2DEF7A6, lineVersion = 0, maxLength = 300, text = \"Sunstriders develop beautiful, vivid feathers to attract mates. But they're not just for show - their unique fronds hold the key to their spectacular speed and acrobatic displays too. Perhaps they could teach our Skimmers a few tricks!\""
	myPortrait onward/baked/textures/ui/icons/database_banner_large/planet_haven/ui-database-haven-fauna-sample-06-large.dds
	mySprite "mySpriteId = 594033090, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myBannerSprite "mySpriteId = 594033090, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myAttachScreenSprite "mySpriteId = 594033090, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myRevealedChallengeType Discover_FaunaSample06
	myUnlockedChallengeType Discover_FaunaSample06
	myCollectibleSubType Samples
	myLocalizedName "contextComment = \"[Placeholder - do not translate] Database name for Sunstrider Plume, a piece that can be collected from an animal on Haven\", description = \"database-name-FaunaSample06\", enabled = true, guid = #7B9B9484E5904539AD7239761B4784AC, lineVersion = 0, maxLength = 30, text = \"Sunstrider Plume\""
}

CustomDatabaseEntry Secrets < uid=9E6AFEDA5A96F3A300001B5E2E914CAB >
{
	myLocalizedDescription "contextComment = \"Database tactics tips for Haven's \\"secret\\" database entry, awarded for discovering everything else on the planet.\nCurrently left blank so narrative text can use the full height of the card.\", description = \"database-description-planet-secrets-03\", enabled = true, guid = #9E6AFEDA5A96F2F800001B51D666573F, lineVersion = 0, maxLength = 2, text = \" \"}"
	myLocalizedNarrative "contextComment = \"[Placeholder - do not translate] Database narrative for Haven's \\"secret\\" database entry, awarded for discovering everything else on the planet.\", description = \"database-narrative-planet-secrets-03\", enabled = true, guid = #9E6AFEDA5A96F2F800001B55983B6869, lineVersion = 0, maxLength = 750, text = \"At first approach, the temperate air, lush vegetation and inviting glow of firefly rock lanterns give Haven the appearance of Utopia. But this Garden of Eden deceives with disarming dangers that lured more than one Prospector from their prize, and lulled even the most objective Expeditionary from their research. Unable to meet its own needs, the planet requires a constant supply of outside nourishment - so it finds clever ways to attract it.\"}"
