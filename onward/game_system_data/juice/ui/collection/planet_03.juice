include "onward/game system data/fruit/ui/collection/databasesubcategory.fruit"

PlanetDatabaseEntry Overview < uid=1ABBD50B594979ED0001EAE9CA14253A >
{
	myLocalizedDescription "contextComment = \"[PLACEHOLDER - do not translate] Database tactics tips for the lush forest world Haven\", description = \"collectibles_database_planet_03_overview_tactics\", enabled = true, guid = #1ABBD50B584B05E300003126B15BB2B9, lineVersion = 1, maxLength = 86, text = \"Sector A\n\nTemperate\n\nBoth Heat and Cold-type\nLegion are found here\""
	myLocalizedNarrative "contextComment = \"[PLACEHOLDER - do not translate] Database narrative blurb for the lush forest world Haven\", description = \"collectibles_database_planet_03_overview_description\", enabled = true, guid = #A08A88CF589A3BE80000004EA04E72A6, lineVersion = 1, maxLength = 578, text = \"At first approach, the temperate air, lush vegetation and inviting glow of firefly rock lanterns give Haven the appearance of Utopia. But this Garden of Eden deceives with disarming dangers that lured more than one prospector from their prize, and lulled even the most objective expeditioner from their research. Unable to meet its own needs, the planet requires a constant supply out outside nourishment, and it finds clever ways to attract it.\""
	myPortrait onward/baked/textures/ui/icons/database_banner_large/planet_haven/ui-database-planet-haven-large.dds
	mySprite "mySpriteId = -1651109324, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database.spritesheet\""
	myBannerSprite "mySpriteId = -1651109324, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database.spritesheet\""
	myAttachScreenSprite "mySpriteId = -1651109324, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database.spritesheet\""
	myUnlockedChallengeType Discover_Planet03
	myPlanetUIDs
	{
		uid 1 2B55C72B560BF25A00000071749BE491
	}
	myLocalizedName "contextComment = \"Database name for the lush forest planet Haven\", description = \"collectibles_database_planet_03_overview_name\", enabled = true, guid = #1ABBD50B584B05E300003124E65A244D, lineVersion = 1, maxLength = 1, text = \"Haven\""
}

SimUnitDatabaseEntries Landmarks
{
	SimUnitDatabaseEntry "The Twilight Divide" < uid=1ABBD50B594979ED0001EAEADB7670E0 >
	{
		myLocalizedDescription "contextComment = \"[PLACEHOLDER - do not translate].\nDatabase tactics tips for Planet_03, named area A: the Twilight Divide.\", description = \"database-item-namedarea-planet_03-a-localized_description\", enabled = true, guid = #A08A88CF588BA01B0000379BBE24CD07, lineVersion = 1, maxLength = 126, text = \"Giant satellite dish-like flowers called Sun Sirens grow here\n\nNesting grounds of the Sunstriders\""
		myLocalizedNarrative "contextComment = \"[PLACEHOLDER - do not translate].\nPlaceholder narrative blurb for Planet_03, named area A: the Twilight Divide.\", description = \"database-item-namedarea-planet_03-a\", enabled = true, guid = #A08A88CF588BA01B0000379CEED43148, lineVersion = 2, maxLength = 274, text = \"These wetlands where light and dark meet form a refuge on Haven, both from the predatory Quillharts and the endless droning of the Skittertusk. Most of the mining towns sprung up in rich ecosystem of the Divide.\""
		myPortrait onward/baked/textures/ui/icons/database_banner_large/planet_haven/ui-database-haven-twilight-divide-large.dds
		mySprite "mySpriteId = -328358081, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database.spritesheet\""
		myUnlockedChallengeType Discover_Planet03_NamedAreaA
		myCollectibleSubType Biome
		mySimUnitFiles
		{
			file 1 "onward/game system data/juice/sim/named_place_planet_03_a.msimunit"
		}
	}
	SimUnitDatabaseEntry "Peril's Glade" < uid=1ABBD50B594979ED0001EAEBCDCC21BB >
	{
		myLocalizedDescription "contextComment = \"[PLACEHOLDER - do not translate].\nDatabase tactics tips for Planet_03, named area B: Peril's Glade.\", description = \"database-item-namedarea-planet_03-b-localized_description\", enabled = true, guid = #A08A88CF588BA020000037E0953FF307, lineVersion = 1, maxLength = 55, text = \"Hunting grounds of the predatory Quillhart\"}"
		myLocalizedNarrative "contextComment = \"[PLACEHOLDER - do not translate].\nDatabase narrative blurb for Planet_03, named area B: Peril's Glade.\", description = \"database-item-namedarea-planet_03-b\", enabled = true, guid = #A08A88CF588BA020000037E1AE7901FE, lineVersion = 2, maxLength = 159, text = \"Thick with vegetation, where rapid growth means rapid evolution, Peril’s Glade is the densest of Haven's floral forests.\""
		myPortrait onward/baked/textures/ui/icons/database_banner_large/planet_haven/ui-database-haven-peril-glade-large.dds
		mySprite "mySpriteId = -816095819, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database.spritesheet\""
		myUnlockedChallengeType Discover_Planet03_NamedAreaB
		myCollectibleSubType Biome
		mySimUnitFiles
		{
			file 1 "onward/game system data/juice/sim/named_place_planet_03_b.msimunit"
		}
	}
	SimUnitDatabaseEntry "The Glimmering Shroud" < uid=1ABBD50B594979ED0001EAEC6D7BA90B >
	{
		myLocalizedDescription "contextComment = \"[PLACEHOLDER - do not translate].\nDatabase tactics tips for Planet_03, named area C: The Glimmering Shroud.\", description = \"database-item-namedarea-planet_03-c-tactics\", enabled = true, guid = #A08A88CF588BA022000037E289C555C3, lineVersion = 0, maxLength = 94, text = \"Populated by hive-bulding Stonebees\nand the invasive Skittertusk beetles\""
		myLocalizedNarrative "contextComment = \"[PLACEHOLDER - do not translate].\nDatabase narrative blurb for Planet_03, named area C: The Glimmering Shroud.\", description = \"database-item-namedarea-planet_03-c\", enabled = true, guid = #A08A88CF588BA022000037E34DE54F50, lineVersion = 1, maxLength = 261, text = \"Fixed on the night side of the planet, the Glimmering Shroud is home to the nocturnal Skittertusks. These beetles fill the shroud with a constant scraping sound as they carve the mushroom-shaped rocks.\""
		myPortrait onward/baked/textures/ui/icons/database_banner_large/planet_haven/ui-database-haven-glimmering-shroud-large.dds
		mySprite "mySpriteId = 163810136, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database.spritesheet\""
		myUnlockedChallengeType Discover_Planet03_NamedAreaC
		myCollectibleSubType Biome
		mySimUnitFiles
		{
			file 1 "onward/game system data/juice/sim/named_place_planet_03_c.msimunit"
		}
	}
}

SimUnitDatabaseEntries Fauna
{
	SimUnitDatabaseEntry Sunstrider < uid=1ABBD50B594979ED0001EAED062D6C6B >
	{
		myLocalizedDescription "contextComment = \"[PLACEHOLDER - do not translate].\nDatabase tactics tips for the Sun Sister fauna, now Sunstrider, a tall colourful bird with strange tendril-tails\", description = \"database-item-fauna-sunsister-tactics\", enabled = true, guid = #A08A88CF588BA52000005DF0BAAD12B5, lineVersion = 0, maxLength = 88, text = \"Retaliates if threatened\n\nLost Plumes can be used in Mod development\""
		myLocalizedNarrative "contextComment = \"[PLACEHOLDER - do not translate].\nDatabase narrative description for the Sun Sister fauna, now Sunstrider, a tall colourful bird with strange tendril-tails\", description = \"database-item-fauna-sunsister\", enabled = true, guid = #A08A88CF588BA52000005DF157D59760, lineVersion = 1, maxLength = 246, text = \"Sunstriders develop beautiful, vivid feathers to attract mates. They're not all looks, though, and will ferociously defend their young with a projectile attack meant to scare off predators.\"}"
		myPortrait onward/baked/textures/ui/icons/database_banner_large/planet_haven/ui-database-haven-sunsister-large.dds
		mySprite "mySpriteId = 1568238197, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database.spritesheet\""
		myRevealedChallengeType FullyScan_Fauna06
		myUnlockedChallengeType FullyScan_Fauna06
		myCollectibleSubType Fauna
		mySimUnitFiles
		{
			file 1 "onward/game system data/juice/sim/fauna_06.msimunit"
		}
	}
	SimUnitDatabaseEntry Quillhart < uid=1ABBD50B594979ED0001EAEE6EB4ED3E >
	{
		myLocalizedDescription "contextComment = \"[PLACEHOLDER - do not translate].\nDatabase tactics tips for the Furbeak fauna, now Quillhart,a kind of predatory bird-moose\", description = \"database-item-fauna-furbeak-tactics\", enabled = true, guid = #A08A88CF588BA51F00005DEEC07E35B6, lineVersion = 0, maxLength = 25, text = \"Flees if threatened\""
		myLocalizedNarrative "contextComment = \"[PLACEHOLDER - do not translate].\nDatabase narrative description for the Furbeak fauna, now Quillhart,a kind of predatory bird-moose\", description = \"database-item-fauna-furbeak\", enabled = true, guid = #A08A88CF588F5A39000037BBE2B874FE, lineVersion = 1, maxLength = 451, text = \"The dense, labyrinthine flora isn't the only danger visitors face when they enter Peril's Glade. The Quillhart is a stealthy predator known for patience when stalking prey. It has been recorded waiting for two or three days for the opportune moment to strike, unleashing a flurry of razor sharp claws and vicious, stabbing pecks on unwary victims.\""
		myPortrait onward/baked/textures/ui/icons/database_banner_large/planet_haven/ui-database-haven-furbeak-large.dds
		mySprite "mySpriteId = -126142299, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database.spritesheet\""
		myRevealedChallengeType FullyScan_Fauna02
		myUnlockedChallengeType FullyScan_Fauna02
		myCollectibleSubType Fauna
		mySimUnitFiles
		{
			file 1 "onward/game system data/juice/sim/fauna_02.msimunit"
		}
	}
	SimUnitDatabaseEntry Skittertusk < uid=1ABBD50B594979ED0001EAEFC2D9D8AA >
	{
		myLocalizedDescription "contextComment = \"[PLACEHOLDER - do not translate].\nDatabase tactics tips for the Grinder Beetle fauna, now Skittertusk, a huge insect with red drill-like antennae\", description = \"database-item-fauna-grinderbeetle-tactics\", enabled = true, guid = #A08A88CF588BA51D00005DEC8C354AD1, lineVersion = 0, maxLength = 26, text = \"Flees from intruders\""
		myLocalizedNarrative "contextComment = \"[PLACEHOLDER - do not translate].\nDatabase narrative description for the Grinder Beetle fauna, now Skittertusk, a huge insect with red drill-like antennae\", description = \"database-item-fauna-grinderbeetle\", enabled = true, guid = #A08A88CF588F5A3B000037BCF31EC4D7, lineVersion = 1, maxLength = 292, text = \"Introduced in the early First Settlement, the Lesser Grinder Beetle is an invasive species with no natural predators, named for its habit of grinding its sharp, incredibly hard horns against every surface it can find to mark.\""
		myPortrait onward/baked/textures/ui/icons/database_banner_large/planet_haven/ui-database-haven-grinderbeetle-large.dds
		mySprite "mySpriteId = 79533129, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database.spritesheet\""
		myRevealedChallengeType FullyScan_Fauna05
		myUnlockedChallengeType FullyScan_Fauna05
		myCollectibleSubType Fauna
		mySimUnitFiles
		{
			file 1 "onward/game system data/juice/sim/fauna_05.msimunit"
		}
	}
}

SimUnitDatabaseEntry XFactor < uid=A08A88CF598A08C00001A781C69A6D22 >
{
	myLocalizedDescription "contextComment = \"Database tactics tip for Haven's X-Factor site.\nCurrently left blank so narrative text can use this field's vertical space\", description = \"collectibles_database_xfactor_planet_03_tactics\", enabled = true, guid = #A08A88CF598A08B50001A68A97DD410C, lineVersion = 0, maxLength = 2, text = \" \""
	myLocalizedShortDescription "contextComment = \"[Placeholder - do not translate] Short descriptive text for Haven's X-Factor site, shown when selecting it on the Starmap\", description = \"Starmap_shortDesc_planet_03_xfactor\", enabled = true, guid = #9E6AFEDA5A83637F00001CBE4C2FD482, lineVersion = 0, maxLength = 118, text = \"A buried Warden statue containing Relics that have supercharged the growth of life on Haven\"}"
	myLocalizedNarrative "contextComment = \"[PLACEHOLDER - do not translate] Database narrative blurb for the Seed of Life, the unique X-Factor location on the forest planet.\", description = \"collectibles_database_xfactor_planet_03_description\", enabled = true, guid = #A08A88CF598A08B50001A689F3D4BA2B, lineVersion = 1, maxLength = 902, text = \"Haven’s designer was a Warden named Ward Raba, a self-styled “patron saint” of life itself. Her goal was the promotion of fast growth and the proliferation of life, no matter the form. In a clearing deep in the woods, she implanted the planet with a “Seed of Life” that broadcast a radioactive pulse, promoting gigantism in flora and fauna planetwide She housed the seed in a colossal statue - a likeness of herself.\n\nCenturies later, the planet's wild growth has entombed Raba's statue, so that only her head and outstretched arm remain visible. The \\"Seed\\" itself - cleft in two  - rests nearby, still pulsing with ancient power... and still drawing the unwary inexorably towards it.\""
	myPortrait onward/baked/textures/ui/icons/database_banner_large/planet_haven/ui-database-haven-seed-of-life-large.dds
	mySprite "mySpriteId = 341334870, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myBannerSprite "mySpriteId = 341334870, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myAttachScreenSprite "mySpriteId = 341334870, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myRevealedChallengeType Discover_Planet03_XFactor
	myUnlockedChallengeType Discover_Planet03_XFactor
	myCollectibleSubType XFactor
	mySimUnitFiles
	{
		file planet_03 "onward/game system data/juice/sim/container_x_factor_base_planet_03.msimunit"
	}
}

