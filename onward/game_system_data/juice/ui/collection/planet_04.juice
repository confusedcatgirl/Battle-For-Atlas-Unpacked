CustomDatabaseEntry FloraSample08 < uid=9E6AFEDA5A830A7A00001B787B600184 >
{
	myLocalizedDescription "contextComment = \"[Placeholder - do not translate] Database tactical summary for Ghoul Clutch, a sample the player can pluck from environment props on Necrom\", description = \"database-description-FloraSample08\", enabled = true, guid = #4B0CF4828D274DA8B2B02B83F0CEC053, lineVersion = 0, maxLength = 250, text = \"Valued by Expedition Observatories\n\nCan be used to develop Energetic Mods\""
	myLocalizedNarrative "contextComment = \"[Placeholder - do not translate] Database narrative description for Ghoul Clutch, a sample the player can pluck from environment props on Necrom\", description = \"database-narrative-FloraSample08\", enabled = true, guid = #41BD47996254463E82AC29D0492F75D2, lineVersion = 0, maxLength = 300, text = \"Unique among insect species, the Ghoulcrab doesn't try to hide its eggs from predators. In fact, you can see their egg clutches glowing in the darkness, almost luring scavengers in.\""
	myPortrait onward/baked/textures/ui/icons/database_banner_large/planet_necrom/ui-database-necom-flora-sample-07-large.dds
	mySprite "mySpriteId = 903778512, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myBannerSprite "mySpriteId = 903778512, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myAttachScreenSprite "mySpriteId = 903778512, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myStarmapThreatKnownSprite "mySpriteId = -455779427, mySpritesheet = F\"onward/ui/spritesheets/ui-icon-placeholder.spritesheet\""
	myRevealedChallengeType Discover_FloraSample08
	myUnlockedChallengeType Discover_FloraSample08
	myCollectibleSubType Samples
	myLocalizedName "contextComment = \"[Placeholder - do not translate] Database name for Ghoul Clutch, a sample the player can pluck from environment props on Necrom\", description = \"database-name-FloraSample08\", enabled = true, guid = #AB315347D53643E0B9294405CDD4E8CA, lineVersion = 0, maxLength = 30, text = \"Ghoul Clutch\""
}

CustomDatabaseEntry FloraSample07 < uid=9E6AFEDA5A830A7A00001B778E99E11F >
{
	myLocalizedDescription "contextComment = \"[Placeholder - do not translate] Database tactical summary for Death Cap, a sample the player can pluck from environment props on Necrom\", description = \"database-description-FloraSample07\", enabled = true, guid = #37CDB84222704F69BFD63B0627F21FCC, lineVersion = 0, maxLength = 250, text = \"Valued by Expedition Observatories\n\nCan be used to develop Defensive Mods\""
	myLocalizedNarrative "contextComment = \"[Placeholder - do not translate] Database narrative description for Death Cap, a sample the player can pluck from environment props on Necrom\", description = \"database-narrative-FloraSample07\", enabled = true, guid = #C51B4938E2AE4B169CE849ABE8CA5AA6, lineVersion = 0, maxLength = 300, text = \"Death Caps sit on top of putrid air vents that dot the surface of Necrom, known as the Morchella Masts. Most avoid these vents, because the microbes wafting from them can be lethal. By consuming these microbes, Death Caps help make life possible on Necrom.\""
	myPortrait onward/baked/textures/ui/icons/database_banner_large/planet_necrom/ui-database-necom-flora-sample-08-large.dds
	mySprite "mySpriteId = -252966925, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myBannerSprite "mySpriteId = -252966925, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myAttachScreenSprite "mySpriteId = -252966925, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myRevealedChallengeType Discover_FloraSample07
	myUnlockedChallengeType Discover_FloraSample07
	myCollectibleSubType Samples
	myLocalizedName "contextComment = \"[Placeholder - do not translate] Database name for Death Cap, a sample the player can pluck from environment props on Necrom\", description = \"database-name-FloraSample07\", enabled = true, guid = #CCA758ECDF834059B69C4DB46FC4519C, lineVersion = 0, maxLength = 30, text = \"Death Cap\""
}

CustomDatabaseEntry FloraSample09 < uid=9E6AFEDA5A830A7A00001B791515FCE0 >
{
	myLocalizedDescription "contextComment = \"[Placeholder - do not translate] Database tactical summary for Tomb Sap Fossil, a sample the player can pluck from environment props on Necrom\", description = \"database-description-FloraSample09\", enabled = true, guid = #42084C8F053D4E2A8D3166557B69CC71, lineVersion = 0, maxLength = 250, text = \"Valued by Expedition Observatories\n\nCan be used to develop Exotic Mods\""
	myLocalizedNarrative "contextComment = \"[Placeholder - do not translate] Database narrative description for Tomb Sap Fossil, a sample the player can pluck from environment props on Necrom\", description = \"database-narrative-FloraSample09\", enabled = true, guid = #51B5C8E40963437EA4D198AB91DB688D, lineVersion = 0, maxLength = 300, text = \"A thick, sticky substance traps the small animals who feed on Necrom's mushrooms. Like the fossilized insects from Earth's Jurassic era,  studying these fossils can tell us about Necrom's past, making them highly valued as keepsakes and scientific oddities.\""
	myPortrait onward/baked/textures/ui/icons/database_banner_large/planet_necrom/ui-database-necom-flora-sample-09-large.dds
	mySprite "mySpriteId = 870328544, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myBannerSprite "mySpriteId = 870328544, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myAttachScreenSprite "mySpriteId = 870328544, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myRevealedChallengeType Discover_FloraSample09
	myUnlockedChallengeType Discover_FloraSample09
	myCollectibleSubType Samples
	myLocalizedName "contextComment = \"[Placeholder - do not translate] Database name for Tomb Sap Fossil, a sample the player can pluck from environment props on Necrom\", description = \"database-name-FloraSample09\", enabled = true, guid = #9E6AFEDA5AA3011D00001BA215605274, lineVersion = 0, maxLength = 30, text = \"Tomb Sap Fossil\""
}

CustomDatabaseEntry FaunaSample12 < uid=9E6AFEDA5A830A7A00001B7ADA293283 >
{
	myLocalizedDescription "contextComment = \"[Placeholder - do not translate] Database tactical summary for Ghoulcrab Polyp, a piece that can be collected from an animal on Necrom\", description = \"database-description-FaunaSample12\", enabled = true, guid = #2C77A049B87244CA98BDC6A38DC15ABE, lineVersion = 0, maxLength = 250, text = \"Valued by Expedition Workshops\n\nCan be used to develop Defensive Mods\""
	myLocalizedNarrative "contextComment = \"[Placeholder - do not translate] Database narrative description for Ghoulcrab Polyp, a piece that can be collected from an animal on Necrom\", description = \"database-narrative-FaunaSample12\", enabled = true, guid = #F06D53889BC24AFC9FFB5D8A76A158D7, lineVersion = 0, maxLength = 300, text = \"Ghoulcrabs bristle with these symbiotic fungi, which shower shrapnel-like shards when the host is provoked. It is very easy to provoke these combative creatures, so keeping one's distance is advised.\""
	myPortrait onward/baked/textures/ui/icons/database_banner_large/planet_necrom/ui-database-necom-fauna-sample-12-large.dds
	mySprite "mySpriteId = -1441404039, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myBannerSprite "mySpriteId = -1441404039, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myAttachScreenSprite "mySpriteId = -1441404039, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myRevealedChallengeType Discover_FaunaSample12
	myUnlockedChallengeType Discover_FaunaSample12
	myCollectibleSubType Samples
	myLocalizedName "contextComment = \"[Placeholder - do not translate] Database name for Ghoulcrab Polyp, a piece that can be collected from an animal on Necrom\", description = \"database-name-FaunaSample12\", enabled = true, guid = #68452AFE2A6A460EADDB932D9BB74183, lineVersion = 0, maxLength = 30, text = \"Ghoulcrab Polyp\""
}

CustomDatabaseEntry Secrets < uid=9E6AFEDA5A96F4BC00001B7152FFB266 >
{
	myLocalizedDescription "contextComment = \"Database tactics tips for Necrom's \\"secret\\" database entry, awarded for discovering everything else on the planet.\nCurrently left blank so narrative text can use the full height of the card.\", description = \"database-description-planet-secrets-04\", enabled = true, guid = #9E6AFEDA5A96F3B900001B623D8325A1, lineVersion = 0, maxLength = 2, text = \" \"}"
	myLocalizedNarrative "contextComment = \"[Placeholder - do not translate] Database narrative for Necrom's \\"secret\\" database entry, awarded for discovering everything else on the planet.\", description = \"database-narrative-planet-secrets-04\", enabled = true, guid = #9E6AFEDA5A96F3B900001B66C5F4F3DF, lineVersion = 0, maxLength = 750, text = 'Necrom is a cold planet with low gravity and a thin atmosphere, appearing as a swirling green and brown orb from space. Notable for its chimney-like flora (which emit a thick toxic fog), the planet is seemingly inhospitable, yet teeming with Electrum – and therefore irresistible to THE GIFTED. But something about this planet has always felt \"off\" to those who visit. Many superstitious Prospectors believe the planet is cursed, and that WARDEN spirits are angry because the Gifted are slowly destroying it.'}"
	myPortrait onward/baked/textures/ui/icons/database_banner_large/planet_necrom/ui-database-planet-necrom-large.dds
