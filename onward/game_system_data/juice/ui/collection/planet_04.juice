include "onward/game system data/fruit/ui/collection/databasesubcategory.fruit"

PlanetDatabaseEntry Overview < uid=1ABBD50B594979FE0001EFED9D66F9C7 >
{
	myLocalizedDescription "contextComment = \"[PLACEHOLDER - do not translate] Database tactics for the fungal graveyard world Necrom\", description = \"collectibles_database_planet_04_overview_tactics\", enabled = true, guid = #1ABBD50B584B05E5000031353869BCE4, lineVersion = 1, maxLength = 104, text = \"Sector C\n\nLow Gravity\n\nGravity, Cold, and Heat-type\nLegion can all be found here\""
	myLocalizedNarrative "contextComment = \"[PLACEHOLDER - do not translate] Database narrative for the fungal graveyard world Necrom\", description = \"collectibles_database_planet_04_overview_description\", enabled = true, guid = #A08A88CF589A3BFB000000517FE60029, lineVersion = 1, maxLength = 638, text = \"Necrom is a cold planet with low gravity and a thin atmosphere, appearing as a swirling green and brown orb from space. Notable for its chimney-like flora (which emit a cauldron like fog), the planet is seemingly inhospitable, yet teeming with Electrum – and therefore irresistible to the Gifted. But something about this planet has always felt off to those who visit. Many Outlaws believe the planet is cursed and that Warden spirits are angry because the Gifted are slowly destroying it.\""
	myPortrait onward/baked/textures/ui/icons/database_banner_large/planet_necrom/ui-database-planet-necrom-large.dds
	mySprite "mySpriteId = -1352932729, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database.spritesheet\""
	myBannerSprite "mySpriteId = 1521098024, mySpritesheet = F\"onward/ui/spritesheets/ui-icon-planets.spritesheet\""
	myUnlockedChallengeType Discover_Planet04
	myPlanetUIDs
	{
		uid 1 CC9485AB560BFF1000000066C27E74E9
	}
	myLocalizedName "contextComment = \"Database name for the fungal graveyard world Necrom\", description = \"collectibles_database_planet_04_overview_name\", enabled = true, guid = #1ABBD50B584B05E500003133A2EB3EBB, lineVersion = 1, maxLength = 1, text = \"Necrom\""
}

SimUnitDatabaseEntries Landmarks
{
	SimUnitDatabaseEntry "The City of Souls" < uid=1ABBD50B594979FE0001EFEEC116527F >
	{
		myLocalizedDescription "contextComment = \"[PLACEHOLDER - do not translate].\nPlaceholder tactics tip for Planet_04, named area A: The City of Souls.\", description = \"database-item-namedarea-planet_04-a-tactics\", enabled = true, guid = #A08A88CF588F630A00004F3F04DFFCDB, lineVersion = 0, maxLength = 72, text = \"Home to the aggressive Ghoulcrab\nand their egg clusters\""
		myLocalizedNarrative "contextComment = \"[PLACEHOLDER - do not translate].\nPlaceholder narrative blurb for Planet_04, named area A: The City of Souls.\", description = \"database-item-namedarea-planet_04-a\", enabled = true, guid = #A08A88CF588F630A00004F40711E0626, lineVersion = 0, maxLength = 268, text = \"This mushroom forest is distinguished by massive fungal growths that resemble skyscrapers, complete with phosphorescent “lamps” that, at night, pour light onto the winding “streets” at ground level.\""
		myPortrait onward/baked/textures/ui/icons/database_banner_large/planet_necrom/ui-database-necrom-city-of-souls-large.dds
		mySprite "mySpriteId = 676808914, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database.spritesheet\""
		myUnlockedChallengeType Discover_Planet04_NamedAreaA
		myCollectibleSubType Biome
		mySimUnitFiles
		{
			file 1 "onward/game system data/juice/sim/named_place_planet_04_a.msimunit"
		}
	}
	SimUnitDatabaseEntry "Morchella Masts" < uid=1ABBD50B594979FE0001EFEF97995A33 >
	{
		myLocalizedDescription "contextComment = \"[PLACEHOLDER - do not translate].\nDatabase tactical tip for Planet_04, named area B: Morchella Masts.\", description = \"database-item-namedarea-planet_04-b-tactics\", enabled = true, guid = #A08A88CF588F630A00004F41207948E8, lineVersion = 0, maxLength = 55, text = \"Home to the Platiflap\nand Death Cap fungus\""
		myLocalizedNarrative "contextComment = \"[PLACEHOLDER - do not translate].\nDatabase narrative blurb for Planet_04, named area B: Morchella Masts.\", description = \"database-item-namedarea-planet_04-b\", enabled = true, guid = #A08A88CF588F630A00004F42382AE19D, lineVersion = 0, maxLength = 373, text = \"This area of Necrom is marked by stacks of fungal matter that constantly spew noxious fumes into Necrom's atmosphere, looking like eerie, polluting factories. They provide an ideal breeding ground for Crypt Mushrooms, a highly toxic type of fungus rumoured to have anti-aging properties.\"}"
		myPortrait onward/baked/textures/ui/icons/database_banner_large/planet_necrom/ui-database-necrom-morchella-masts-large.dds
		mySprite "mySpriteId = 1355306430, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database.spritesheet\""
		myUnlockedChallengeType Discover_Planet04_NamedAreaB
		myCollectibleSubType Biome
		mySimUnitFiles
		{
			file 1 "onward/game system data/juice/sim/named_place_planet_04_b.msimunit"
		}
	}
	SimUnitDatabaseEntry "The Isles of Gloomb" < uid=1ABBD50B594979FE0001EFF0FA367651 >
	{
		myLocalizedDescription "contextComment = \"[PLACEHOLDER - do not translate].\nDatabase tactics tip for Planet_04, named area C: The Isles of Gloomb.\", description = \"database-item-namedarea-planet_04-c-tactics\", enabled = true, guid = #A08A88CF588F630A00004F43C3E8FB67, lineVersion = 0, maxLength = 79, text = \"Golgoth herds and Tomb Sap\nfossils can be found on the plains\""
		myLocalizedNarrative "contextComment = \"[PLACEHOLDER - do not translate].\nDatabase narrative blurb for Planet_04, named area C: The Isles of Gloomb.\", description = \"database-item-namedarea-planet_04-c\", enabled = true, guid = #A08A88CF588F630A00004F444246FA0A, lineVersion = 0, maxLength = 315, text = \"Open plains dotted by acid pools, where thick psychotropic fog and unusual magnetism have led many an unwary traveller to an untimely end. The first Gifted settlers established processing facilities here to harvest Necrom’s giant mushrooms.\""
		myPortrait onward/baked/textures/ui/icons/database_banner_large/planet_necrom/ui-database-necrom-isles-of-gloomb-large.dds
		mySprite "mySpriteId = 1657862905, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database.spritesheet\""
		myUnlockedChallengeType Discover_Planet04_NamedAreaC
		myCollectibleSubType Biome
		mySimUnitFiles
		{
			file 1 "onward/game system data/juice/sim/named_place_planet_04_c.msimunit"
		}
	}
}

SimUnitDatabaseEntries Fauna
{
	SimUnitDatabaseEntry Ghoulcrab < uid=1ABBD50B594979FE0001EFF150340011 >
	{
		myLocalizedDescription "contextComment = \"[PLACEHOLDER - do not translate].\nDatabase tactics tip for the Ghoulcrab fauna.\", description = \"database-item-fauna-ghoulcrab-tactics\", enabled = true, guid = #9E6AFEDA5A830E8E00001B7CE0EEFF1A, lineVersion = 0, maxLength = 91, text = \"Highly aggressive\n\nPolyps from its back can be used in Mod development\""
		myLocalizedNarrative "contextComment = \"[PLACEHOLDER - do not translate].\nDatabase description for the Ghoulcrab fauna.\", description = \"database-item-fauna-ghoulcrab\", enabled = true, guid = #A08A88CF588F639500005F9D76F8EB21, lineVersion = 0, maxLength = 229, text = \"Nothing on Necrom haunted the first Atlas settlers as much as the Ghoulcrab did. Fast, aggressive, and deadly. Some feel that they represent the vengeful spirit of the Wardens.\""
		myPortrait onward/baked/textures/ui/icons/database_banner_large/planet_necrom/ui-database-necrom-ghoulcrab-large.dds
		mySprite "mySpriteId = -1347588971, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database.spritesheet\""
		myRevealedChallengeType FullyScan_Fauna12
		myUnlockedChallengeType FullyScan_Fauna12
		myCollectibleSubType Fauna
		mySimUnitFiles
		{
			file 1 "onward/game system data/juice/sim/fauna_12.msimunit"
		}
	}
	SimUnitDatabaseEntry Platiflap < uid=1ABBD50B594979FE0001EFF223C225C2 >
	{
		myLocalizedDescription "contextComment = \"[PLACEHOLDER - do not translate].\nDatabase tactical tip for the Platiflap fauna.\", description = \"database-item-fauna-platiflap-tactics\", enabled = true, guid = #A08A88CF588F638D00005F0B9115427A, lineVersion = 0, maxLength = 31, text = \"Flees from any intruders\""
		myLocalizedNarrative "contextComment = \"[PLACEHOLDER - do not translate].\nDatabase description for the Platiflap fauna.\", description = \"database-item-fauna-platiflap\", enabled = true, guid = #A08A88CF588F638D00005F0C2A8D56C6, lineVersion = 0, maxLength = 270, text = \"A grazing creature, the Platiflap has adapted to eat insects from deep inside the hollow Morchella Masts. The Platiflap evolved a blue mane to resemble Ghoulcrab egg sacs in an effort to seem non-threatening.\""
		myPortrait onward/baked/textures/ui/icons/database_banner_large/planet_necrom/ui-database-necrom-platiflap-large.dds
		mySprite "mySpriteId = 1335631188, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database.spritesheet\""
		myRevealedChallengeType FullyScan_Fauna11
		myUnlockedChallengeType FullyScan_Fauna11
		myCollectibleSubType Fauna
		mySimUnitFiles
		{
			file 1 "onward/game system data/juice/sim/fauna_11.msimunit"
		}
	}
	SimUnitDatabaseEntry Golgoth < uid=1ABBD50B594979FE0001EFF37ED7AB4B >
	{
		myLocalizedDescription "contextComment = \"[PLACEHOLDER - do not translate].\nDatabase tactical tip for the Golgoth fauna.\", description = \"database-item-fauna-golgoth-tactics\", enabled = true, guid = #9E6AFEDA5A8314DC00001B8691F263D4, lineVersion = 0, maxLength = 25, text = \"Flees if threatened\""
		myLocalizedNarrative "contextComment = \"[PLACEHOLDER - do not translate].\nDatabase narrative description for the Golgoth fauna.\", description = \"database-item-fauna-golgoth\", enabled = true, guid = #A08A88CF588F639A000060176D700522, lineVersion = 0, maxLength = 225, text = \"|empty|Known as the 'Undertaker of Atlas', Golgoths are seen tending to the mushrooms of Necrom. Scientists debte whether the Golgoths nurture the mushrooms or feed on them.\""
		myPortrait onward/baked/textures/ui/icons/database_banner_large/planet_necrom/ui-database-necrom-golgoth-large.dds
		mySprite "mySpriteId = 1964590875, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database.spritesheet\""
		myRevealedChallengeType FullyScan_Fauna15
		myUnlockedChallengeType FullyScan_Fauna15
		myCollectibleSubType Fauna
		mySimUnitFiles
		{
			file 1 "onward/game system data/juice/sim/fauna_15.msimunit"
		}
	}
}

SimUnitDatabaseEntry XFactor < uid=A08A88CF598A089F0001A465083F1DC2 >
{
	myLocalizedDescription "contextComment = \"Database tactics tip for Necrom's X-Factor site.\nCurrently left blank so narrative text can use this field's vertical space\", description = \"collectibles_database_xfactor_planet_04_tactics\", enabled = true, guid = #A08A88CF598A08780001A0D5742EBF6B, lineVersion = 0, maxLength = 2, text = \" \""
	myLocalizedShortDescription "contextComment = \"[Placeholder - do not translate] Short descriptive text for Necrom's X-Factor site, shown when selecting it on the Starmap\", description = \"Starmap_shortDesc_planet_04_xfactor\", enabled = true, guid = #9E6AFEDA5A83336800001BD217F9C033, lineVersion = 0, maxLength = 65, text = \"An ancient Warden tomb that may hold unique relics\"}"
	myLocalizedNarrative "contextComment = \"[PLACEHOLDER - do not translate] Database narrative blurb for the Warden Mausoleum, the unique X-Factor location on the fungal planet.\", description = \"collectibles_database_xfactor_planet_04_description\", enabled = true, guid = #A08A88CF598A08780001A0D48E8AF75C, lineVersion = 1, maxLength = 512, text = \"Among the immortal Wardens, there were those who believed that death of the physical form was the only way to achieve true everlasting life. They constructed Necrom not as a living planet, but rather as a tomb that would contain the Warden Lord named Mortus and two other members of his death cult. Their final request was to be buried in the grim Mausoleum they had constructed for themselves.\""
	myPortrait onward/baked/textures/ui/icons/database_banner_large/planet_necrom/ui-database-necrom-warden-mausoleum-large.dds
	mySprite "mySpriteId = 1160283767, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myBannerSprite "mySpriteId = 1160283767, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myAttachScreenSprite "mySpriteId = 1160283767, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myRevealedChallengeType Discover_Planet04_XFactor
	myUnlockedChallengeType Discover_Planet04_XFactor
	myCollectibleSubType XFactor
	mySimUnitFiles
	{
		file planet_04 "onward/game system data/juice/sim/container_x_factor_base_planet_04.msimunit"
	}
}

