CustomDatabaseEntry FloraSample10 < uid=9E6AFEDA5A83175000001B9779955804 >
{
	myLocalizedDescription "contextComment = \"[Placeholder - do not translate] Database tactical summary for Frost Pearl, a sample the player can pluck from environment props on Tundria\", description = \"database-description-FloraSample10\", enabled = true, guid = #0F6637EE1BA343168E3B080BF5FB8628, lineVersion = 0, maxLength = 250, text = \"Valued by Expedition Observatories\n\nCan be used to develop Cold Mods\""
	myLocalizedNarrative "contextComment = \"[Placeholder - do not translate] Database narrative description for Frost Pearl, a sample the player can pluck from environment props on Tundria\", description = \"database-narrative-FloraSample10\", enabled = true, guid = #208635D68E7D438B90CF6A69F5C48156, lineVersion = 0, maxLength = 300, text = \"At first thought to be mammals, Sasquid are actually closer in biology to fish. This means they lay eggs. Somehow able to resist the intense heat of Tundria's geothermal vents, these egg clusters are merely warmed by them while incubating.\""
	myPortrait onward/baked/textures/ui/icons/database_banner_large/planet_tundria/ui-database-tundria-flora-sample-10-large.dds
	mySprite "mySpriteId = 516846771, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myBannerSprite "mySpriteId = 516846771, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myAttachScreenSprite "mySpriteId = 516846771, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myRevealedChallengeType Discover_FloraSample10
	myUnlockedChallengeType Discover_FloraSample10
	myCollectibleSubType Samples
	myLocalizedName "contextComment = \"[Placeholder - do not translate] Database name for Frost Pearl, a sample the player can pluck from environment props on Tundria\", description = \"database-name-FloraSample10\", enabled = true, guid = #2FD75D5F90CC47ADB68BA0404CCA804A, lineVersion = 0, maxLength = 30, text = \"Frost Pearl\""
}

CustomDatabaseEntry FloraSample11 < uid=9E6AFEDA5A83175000001B986A99EFCA >
{
	myLocalizedDescription "contextComment = \"[Placeholder - do not translate] Database tactical summary for Topsy Cone, a sample the player can pluck from environment props on Tundria\", description = \"database-description-FloraSample11\", enabled = true, guid = #0C22B9A1C40D4B78971BD99E471E2F91, lineVersion = 0, maxLength = 250, text = \"Valued by Expedition Observatories\n\nCan be used to develop Stasis Mods\""
	myLocalizedNarrative "contextComment = \"[Placeholder - do not translate] Database narrative description for Topsy Cone, a sample the player can pluck from environment props on Tundria\", description = \"database-narrative-FloraSample11\", enabled = true, guid = #643FC66A012F47F5A2093E7B074BB4AA, lineVersion = 0, maxLength = 300, text = \"Tundria's native trees are bizarre, seeming to grow upside-down, but the cones that grow from them are stranger still. They seem like they would be too heavy for the trees to support, but they rarely drop to the ground.\""
	myPortrait onward/baked/textures/ui/icons/database_banner_large/planet_tundria/ui-database-tundria-flora-sample-11-large.dds
	mySprite "mySpriteId = 321301734, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myBannerSprite "mySpriteId = 321301734, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myAttachScreenSprite "mySpriteId = 321301734, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myRevealedChallengeType Discover_FloraSample11
	myUnlockedChallengeType Discover_FloraSample11
	myCollectibleSubType Samples
	myLocalizedName "contextComment = \"[Placeholder - do not translate] Database name for Topsy Cone, a sample the player can pluck from environment props on Tundria\", description = \"database-name-FloraSample11\", enabled = true, guid = #2E704C81EFD94A688D935C81AC4C6841, lineVersion = 0, maxLength = 30, text = \"Topsy Cone\""
}

CustomDatabaseEntry FloraSample12 < uid=9E6AFEDA5A83175000001B99167EA09C >
{
	myLocalizedDescription "contextComment = \"[Placeholder - do not translate] Database tactical summary for Shellcicle, a sample the player can pluck from environment props on Tundria\", description = \"database-description-FloraSample12\", enabled = true, guid = #33F895E048CB4460A48FBABCF6E0B3AB, lineVersion = 0, maxLength = 250, text = \"Valued by Expedition Observatories\n\nCan be used to develop Defensive Mods\""
	myLocalizedNarrative "contextComment = \"[Placeholder - do not translate] Database narrative description for Shellcicle, a sample the player can pluck from environment props on Tundria\", description = \"database-narrative-FloraSample12\", enabled = true, guid = #3E52B1F3B4024D279A5C32B48D8BD40F, lineVersion = 0, maxLength = 300, text = \"Tickers are far too volatile to study up-close, but we can examine the shells they shed as they grow. Most insectoid species would perish in Tundria's freezing climate, but Tickers thrive. Perhaps their shells can reveal how they stave off the cold.\""
	myPortrait onward/baked/textures/ui/icons/database_banner_large/planet_tundria/ui-database-tundria-flora-sample-12-large.dds
	mySprite "mySpriteId = -495360221, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myBannerSprite "mySpriteId = -495360221, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myAttachScreenSprite "mySpriteId = -495360221, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myRevealedChallengeType Discover_FloraSample12
	myUnlockedChallengeType Discover_FloraSample12
	myCollectibleSubType Samples
	myLocalizedName "contextComment = \"[Placeholder - do not translate] Database name for Shellcicle, a sample the player can pluck from environment props on Tundria\", description = \"database-name-FloraSample12\", enabled = true, guid = #14F20350659949CFAC3E923F523AF00B, lineVersion = 0, maxLength = 30, text = \"Shellcicle\""
}

CustomDatabaseEntry FaunaSample08 < uid=9E6AFEDA5A83175000001B9A778E1686 >
{
	myLocalizedDescription "contextComment = \"[Placeholder - do not translate] Database tactical summary for Sasquid Tusk, a piece that can be collected from an animal on Tundria\", description = \"database-description-FaunaSample08\", enabled = true, guid = #7A8EEBCB047D4A989E3385F0BEA3005E, lineVersion = 0, maxLength = 90, text = \"Valued by Expedition Workshops\n\nCan be used to develop Offensive Mods\""
	myLocalizedNarrative "contextComment = \"[Placeholder - do not translate] Database narrative description for Sasquid Tusk, a piece that can be collected from an animal on Tundria\", description = \"database-narrative-FaunaSample08\", enabled = true, guid = #D3752668B1104AD2A3CD36B963A0F778, lineVersion = 0, maxLength = 153, text = \"Sasquid Tusks are finely-honed natural weapons, with the potential to inform the design of high-precision projectiles.\""
	myPortrait onward/baked/textures/ui/icons/database_banner_large/planet_tundria/ui-database-tundria-fauna-sample-08-large.dds
	mySprite "mySpriteId = -277901417, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myBannerSprite "mySpriteId = -277901417, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myAttachScreenSprite "mySpriteId = -277901417, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myRevealedChallengeType Discover_FaunaSample08
	myUnlockedChallengeType Discover_FaunaSample08
	myCollectibleSubType Samples
	myLocalizedName "contextComment = \"[Placeholder - do not translate] Database name for Sasquid Tusk, a piece that can be collected from an animal on Tundria\", description = \"database-name-FaunaSample08\", enabled = true, guid = #C2F1FD13639143D4AF2D446C3031B47D, lineVersion = 0, maxLength = 30, text = \"Sasquid Tusk\""
}

CustomDatabaseEntry Secrets < uid=9E6AFEDA5A96E0DA00001B5ED7436612 >
{
	myLocalizedDescription "contextComment = \"Database tactics tips for Tundria's \\"secret\\" database entry, awarded for discovering everything else on the planet.\nCurrently left blank so narrative text can use the full height of the card.\", description = \"database-description-planet-secrets-075\", enabled = true, guid = #9E6AFEDA5A96DF9A00001B51519E81CD, lineVersion = 0, maxLength = 2, text = \" \"}"
	myLocalizedNarrative "contextComment = \"[Placeholder - do not translate] Database narrative for Tundria's \\"secret\\" database entry, awarded for discovering everything else on the planet.\", description = \"database-narrative-planet-secrets-05\", enabled = true, guid = #9E6AFEDA5A96DF9A00001B5508408698, lineVersion = 0, maxLength = 750, text = \"(Note for narrative: this might be a good place to talk about the sea monster Ben Millwood added to some of Tundria's lakes, as a teaser for explorer players)\""
	myPortrait onward/baked/textures/ui/icons/database_banner_large/planet_tundria/ui-database-planet-tundria-large.dds
	mySprite "mySpriteId = 669462277, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myBannerSprite "mySpriteId = 669462277, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myAttachScreenSprite "mySpriteId = 669462277, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myRevealedChallengeType Discover_Planet05_AllCollectibles
