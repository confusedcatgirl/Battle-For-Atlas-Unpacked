include "onward/game system data/fruit/ui/collection/databasesubcategory.fruit"

PlanetDatabaseEntry Overview < uid=1ABBD50B59497A0F0001F56DAB139344 >
{
	myLocalizedDescription "contextComment = \"[PLACEHOLDER - do not translate] Database tactics tips for Vylus, the gross planet\", description = \"collectibles_database_planet_08_overview_description\", enabled = true, guid = #1ABBD50B584B05EA0000317F62074A3E, lineVersion = 1, maxLength = 82, text = \"Sector B\n\nGravity, Heat, and Cold-type\nLegion can be found here\""
	myLocalizedNarrative "contextComment = \"[PLACEHOLDER - do not translate] Database narrative description for Vylus, the gross planet\", description = \"collectibles_database_planet_08_overview_description\", enabled = true, guid = #A08A88CF589A3C400000005A12D4845C, lineVersion = 1, maxLength = 546, text = \"Formerly the universe's largest petri dish, Vylus is now home to the universe's largest sentient slime mould. The rich algae beds of the planet's natural state are currently languishing due to the putrid wounds of a planetwide bacterial infection, which somehow gave birth to this main attraction – luring in Outlaws looking to make a quick buck, unnerving Prospectors, and consuming overzealous Expedition scientists.\"}"
	myPortrait onward/baked/textures/ui/icons/database_banner_large/planet_vylus/ui-database-planet-vylus-large.dds
	mySprite "mySpriteId = 298379883, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database.spritesheet\""
	myBannerSprite "mySpriteId = 298379883, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database.spritesheet\""
	myRevealedChallengeType Visit_Planet08
	myUnlockedChallengeType Discover_Planet08
	myPlanetUIDs
	{
		uid 1 CC9485AB560D8193000001B70208D164
	}
	myLocalizedName "contextComment = \"Database name for Vylus, the vile, gross planet\", description = \"collectibles_database_planet_08_overview_name\", enabled = true, guid = #1ABBD50B584B05EA0000317D7C0AE918, lineVersion = 1, maxLength = 30, text = \"Vylus\""
}

SimUnitDatabaseEntries Landmarks
{
	SimUnitDatabaseEntry "The Rash" < uid=1ABBD50B59497A0F0001F56E8D4507BA >
	{
		myLocalizedDescription "contextComment = \"[PLACEHOLDER - do not translate].\nDatabase tactics summary for Planet_08's named area A: The Rash.\", description = \"database-item-namedarea-planet_08-a-tactics\", enabled = true, guid = #9E6AFEDA5A8365B800001CD4B1508F74, lineVersion = 0, maxLength = 129, text = \"Habitat of the Gas Glob and \nhopping grounds of the Noxitoad\n\nYou may find their discarded Stomachs\"}"
		myLocalizedNarrative "contextComment = \"[PLACEHOLDER - do not translate].\nDatabase narrative description for Planet_08's named area A: The Rash.\", description = \"database-item-namedarea-planet_08-a\", enabled = true, guid = #A08A88CF588F6B3600009186FCF9D259, lineVersion = 0, maxLength = 389, text = \"Wounded, festering terrain that oozes poison bile and a horrendous stench. In addition to an abundance of Electrum, Prospectors found the bile pools of The Rash to house a cornucopia of rare minerals. Those who could stomach the stench tried to set up along the pools but found the ground too soggy.\"}"
		myPortrait onward/baked/textures/ui/icons/database_banner_large/planet_vylus/ui-database-vylus-rash-large.dds
		mySprite "mySpriteId = -928593587, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database.spritesheet\""
		myUnlockedChallengeType Discover_Planet08_NamedAreaA
		myCollectibleSubType Biome
		mySimUnitFiles
		{
			file 1 "onward/game system data/juice/sim/named_place_planet_08_a.msimunit"
		}
	}
	SimUnitDatabaseEntry Oospore < uid=1ABBD50B59497A0F0001F56F12775E63 >
	{
		myLocalizedDescription "contextComment = \"[PLACEHOLDER - do not translate].\nDatabase tactics tips for Planet_08's named area B: Oospore.\", description = \"database-item-namedarea-planet_08-b-tactics\", enabled = true, guid = #9E6AFEDA5A83677B00001CDAA56B8186, lineVersion = 0, maxLength = 60, text = \"Spornacles can be found growing on the Oospore\"}"
		myLocalizedNarrative "contextComment = \"[PLACEHOLDER - do not translate].\nDatabase narrative description for Planet_08's named area B: Oospore.\", description = \"database-item-namedarea-planet_08-b\", enabled = true, guid = #A08A88CF588F6B38000091CA4DEE1824, lineVersion = 0, maxLength = 328, text = \"A pulsating, interconnected sentient slime,  the Oospore has the bizarre and frightening ability to bend other beings to its will, encroaching upon them and infecting them from the inside out, until their mental faculties are no longer truly their own.\"}"
		myPortrait onward/baked/textures/ui/icons/database_banner_large/planet_vylus/ui-database-vylus-oospare-large.dds
		mySprite "mySpriteId = 998122515, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database.spritesheet\""
		myUnlockedChallengeType Discover_Planet08_NamedAreaB
		myCollectibleSubType Biome
		mySimUnitFiles
		{
			file 1 "onward/game system data/juice/sim/named_place_planet_08_b.msimunit"
		}
	}
	SimUnitDatabaseEntry Panacea < uid=1ABBD50B59497A0F0001F5704FD944B9 >
	{
		myLocalizedDescription "contextComment = \"[PLACEHOLDER - do not translate].Database tactical summary for Planet_08's named area C: Panacea.\", description = \"database-item-namedarea-planet_08-c\", enabled = true, guid = #9E6AFEDA5A83683300001CE0618080D1, lineVersion = 0, maxLength = 42, text = \"Beware the aggressive Capradillo\"}"
		myLocalizedNarrative "contextComment = \"[PLACEHOLDER - do not translate].\nDatabase narrative description for Planet_08's named area C: Panacea.\", description = \"database-item-namedarea-planet_08-c\", enabled = true, guid = #A08A88CF588F6B39000091F07A8E531B, lineVersion = 0, maxLength = 313, text = \"An emerald algae forest upon which the Oospore feeds, that grows back from the wounds of The Rash, the Panacea represents the planet's natural state. Waving weeds and algae make for the most hospitable place on the disgusting world of Vylus.\""
		myPortrait onward/baked/textures/ui/icons/database_banner_large/planet_vylus/ui-database-vylus-panacea-large.dds
		mySprite "mySpriteId = -589412533, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database.spritesheet\""
		myUnlockedChallengeType Discover_Planet08_NamedAreaC
		myCollectibleSubType Biome
		mySimUnitFiles
		{
			file 1 "onward/game system data/juice/sim/named_place_planet_08_c.msimunit"
		}
	}
}

SimUnitDatabaseEntries Fauna
{
	SimUnitDatabaseEntry Manylegs < uid=1ABBD50B59497A0F0001F571786777B5 >
	{
		myLocalizedDescription "contextComment = \"[PLACEHOLDER - do not translate].\nDatabase tactics text for the Manylegs fauna, now called Mortopede, a nightmarish tongue-centipede\", description = \"database-item-fauna-manylegs-tactics\", enabled = true, guid = #9E6AFEDA5A8368F100001CE6698E2D0C, lineVersion = 0, maxLength = 87, text = \"Retalliates if threatened\n\nShed legs can be used in Mod development\""
		myLocalizedNarrative "contextComment = \"[PLACEHOLDER - do not translate].\nDatabase narrative text for the Manylegs fauna, now called Mortopede, a nightmarish tongue-centipede\", description = \"database-item-fauna-manylegs\", enabled = true, guid = #A08A88CF588F6AEB000082DB0A42ECF7, lineVersion = 0, maxLength = 227, text = \"Surely one of the more unsettling lifeforms in Atlas, these blood-hungry predators are blind, meaning they must navigate the Oospore by feel and smell alone in search of prey.\""
		myPortrait onward/baked/textures/ui/icons/database_banner_large/planet_vylus/ui-database-vylus-manylegs-large.dds
		mySprite "mySpriteId = -120059231, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database.spritesheet\""
		myRevealedChallengeType FullyScan_Fauna16
		myUnlockedChallengeType FullyScan_Fauna16
		myCollectibleSubType Fauna
		mySimUnitFiles
		{
			file 1 "onward/game system data/juice/sim/fauna_16.msimunit"
		}
	}
	SimUnitDatabaseEntry Noxitoad < uid=1ABBD50B59497A0F0001F572DDBAD7D4 >
	{
		myLocalizedDescription "contextComment = \"[PLACEHOLDER - do not translate].\nDatabase tactics text for the Bileburp fauna, now Noxitoad, a poisonous frog\", description = \"database-item-fauna-bileburp-tactics\", enabled = true, guid = #9E6AFEDA5A83699C00001CEC257B37DE, lineVersion = 0, maxLength = 94, text = \"Flees if threatened\n\nDiscarded Stomachs can be found on the forest floor\""
		myLocalizedNarrative "contextComment = \"[PLACEHOLDER - do not translate].\nDatabase narrative text for the Bileburp fauna, now Noxitoad, a poisonous frog\", description = \"database-item-fauna-bileburp\", enabled = true, guid = #A08A88CF588F6AEB000082C4CBA4CC69, lineVersion = 0, maxLength = 213, text = \"Like the starfish of Earth, these amphibious omnivores eject their stomachs from their mouths to catch prey, before pulling it back inside themselves for digestion.\""
		myPortrait onward/baked/textures/ui/icons/database_banner_large/planet_vylus/ui-database-vylus-bileburp-large.dds
		mySprite "mySpriteId = -1033344938, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database.spritesheet\""
		myRevealedChallengeType FullyScan_Fauna21
		myUnlockedChallengeType FullyScan_Fauna21
		myCollectibleSubType Fauna
		mySimUnitFiles
		{
			file 1 "onward/game system data/juice/sim/fauna_21.msimunit"
		}
	}
	SimUnitDatabaseEntry Capradillo < uid=1ABBD50B59497A0F0001F57375960E46 >
	{
		myLocalizedDescription "contextComment = \"[PLACEHOLDER - do not translate].\nDatabase tactics text for the Pentelope fauna, now Capradillo, a pangolin-goat\", description = \"database-item-fauna-pentelope-tactics\", enabled = true, guid = #9E6AFEDA5A836A3D00001CF219E212CC, lineVersion = 0, maxLength = 22, text = \"Highly Aggressive\""
		myLocalizedNarrative "contextComment = \"[PLACEHOLDER - do not translate].\nDatabase narrative text for the Pentelope fauna, now Capradillo, a pangolin-goat\", description = \"database-item-fauna-pentelope\", enabled = true, guid = #A08A88CF588F6AEA000082B29485F231, lineVersion = 0, maxLength = 269, text = \"|empty|Don't let their cute, goat-like appearance fool you: these armoured herbivores are fiercely territorial, and will attack just about anything they see. Attempts to domesticate them have largely failed.\"}"
		myPortrait onward/baked/textures/ui/icons/database_banner_large/planet_vylus/ui-database-vylus-pentolope-large.dds
		mySprite "mySpriteId = -178840798, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database.spritesheet\""
		myRevealedChallengeType FullyScan_Fauna18
		myUnlockedChallengeType FullyScan_Fauna18
		myCollectibleSubType Fauna
		mySimUnitFiles
		{
			file 1 "onward/game system data/juice/sim/fauna_18.msimunit"
		}
	}
}

SimUnitDatabaseEntry XFactor < uid=A08A88CF598A078600018A5937F2F2D8 >
{
	myLocalizedDescription "contextComment = \"Database tactics tip for Vylus's X-Factor site.\nCurrently left blank so narrative text can use this field's vertical space\", description = \"collectibles_database_xfactor_planet_08_tactics\", enabled = true, guid = #A08A88CF598A076A000187B3947BDFB4, lineVersion = 0, maxLength = 2, text = \" \""
	myLocalizedShortDescription "contextComment = \"[Placeholder - do not translate] Short descriptive text for Vylus's X-Factor site, shown when selecting it on the Starmap\", description = \"Starmap_shortDesc_planet_08_xfactor\", enabled = true, guid = #9E6AFEDA5A836A9100001D0692DA6CD7, lineVersion = 0, maxLength = 136, text = \"A crashed Warden Vault containing microbial samples. Get the Warden Relic without catching anything else!\"}"
	myLocalizedNarrative "contextComment = \"[PLACEHOLDER - do not translate] Database narrative blurb for the Catalog, the unique X-Factor location on the gross planet Vylus\", description = \"collectibles_database_xfactor_planet_08_description\", enabled = true, guid = #A08A88CF598A09210001B05447ED60C9, lineVersion = 1, maxLength = 672, text = \"A Warden vault once stationed in orbit around Vylus, intended as an archive for microbial life samples gathered from across the galaxy. Its caretaker refused to abandon the Catalog once the Wardens left Atlas, and opted instead to crash it into Vylus, hoping to give his microbial pets one last chance at life. After landing on the planet, which spread The Rash outward from the point of impact, a particularly tenacious form of slime mould escaped the Catalog and took hold on Vylus, eventually becoming the Oospore.\""
	myPortrait onward/baked/textures/ui/icons/database_banner_large/planet_vylus/ui-database-vylus-catalogue-large.dds
	mySprite "mySpriteId = -191865565, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myBannerSprite "mySpriteId = -191865565, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myAttachScreenSprite "mySpriteId = -191865565, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myRevealedChallengeType Discover_Planet08_XFactor
	myUnlockedChallengeType Discover_Planet08_XFactor
	myCollectibleSubType XFactor
	mySimUnitFiles
	{
		file planet_08 "onward/game system data/juice/sim/container_x_factor_base_planet_08.msimunit"
	}
}

