CustomDatabaseEntry FloraSample16 < uid=9E6AFEDA5A82395D00001B6DBF898CA3 >
{
	myLocalizedDescription "contextComment = \"[Placeholder - do not translate] Database tactical summary for Noxitoad Stomach, a sample the player can pluck from environment props on Vylus\", description = \"database-description-FloraSample16\", enabled = true, guid = #B36AB223A05A48D88DC709E6CB8A54CF, lineVersion = 0, maxLength = 250, text = \"Valued by Expedition Observatories\n\nCan be used to develop Regenerative Mods\""
	myLocalizedNarrative "contextComment = \"[Placeholder - do not translate] Database narrative description for Noxitoad Stomach, a sample the player can pluck from environment props on Vylus\", description = \"database-narrative-FloraSample16\", enabled = true, guid = #CBDDB01E275C4AC9B788ECF8C9D8D682, lineVersion = 0, maxLength = 300, text = \"Noxitoad eject their stomachs from their mouths to catch their prey. Sometimes, when prey fight back, the stomach is pulled right out. Nobody knows how Noxitoad can survive without a stomach, but it is suspected they can somehow grow a new one.\""
	myPortrait onward/baked/textures/ui/icons/database_banner_large/planet_vylus/ui-database-sonatus-flora-sample-16-large.dds
	mySprite "mySpriteId = -355325250, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myBannerSprite "mySpriteId = -355325250, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myAttachScreenSprite "mySpriteId = -355325250, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myRevealedChallengeType Discover_FloraSample16
	myUnlockedChallengeType Discover_FloraSample16
	myCollectibleSubType Samples
	myLocalizedName "contextComment = \"[Placeholder - do not translate] Database name for Noxitoad Stomach, a sample the player can pluck from environment props on Vylus\", description = \"database-name-FloraSample16\", enabled = true, guid = #773103E5D40F40D7A43ECE2DA044FF14, lineVersion = 0, maxLength = 30, text = \"Noxitoad Stomach\""
}

CustomDatabaseEntry FloraSample17 < uid=9E6AFEDA5A82395D00001B6EB25CB963 >
{
	myLocalizedDescription "contextComment = \"[Placeholder - do not translate] Database tactical summary for Spornacle, a sample the player can pluck from environment props on Vylus\", description = \"database-description-FloraSample17\", enabled = true, guid = #2B50214618B24FAABBBC0DF0F4B4E133, lineVersion = 0, maxLength = 250, text = \"Valued by Expedition Observatories\n\nCan be used to develop Exotic Mods\""
	myLocalizedNarrative "contextComment = \"[Placeholder - do not translate] Database narrative description for Spornacle, a sample the player can pluck from environment props on Vylus\", description = \"database-narrative-FloraSample17\", enabled = true, guid = #456E1E4EB51C4A53B74C775543115731, lineVersion = 0, maxLength = 300, text = \"The Oospore's webbing is often covered in these predatory spores, which leech nutrients through the skin of their host. It seems that removing them, however, is actually somehow harmful to the Oospore. Which is really the parasite, and which is the host?\""
	myPortrait onward/baked/textures/ui/icons/database_banner_large/planet_vylus/ui-database-sonatus-flora-sample-17-large.dds
	mySprite "mySpriteId = -342457107, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myBannerSprite "mySpriteId = -342457107, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myAttachScreenSprite "mySpriteId = -342457107, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myRevealedChallengeType Discover_FloraSample17
	myUnlockedChallengeType Discover_FloraSample17
	myCollectibleSubType Samples
	myLocalizedName "contextComment = \"[Placeholder - do not translate] Database name for Spornacle, a sample the player can pluck from environment props on Vylus\", description = \"database-name-FloraSample17\", enabled = true, guid = #D8F49B23B61348D1869915140F89EBEB, lineVersion = 0, maxLength = 30, text = \"Spornacle\""
}

CustomDatabaseEntry FloraSample18 < uid=9E6AFEDA5A82395D00001B6FCD8AC55E >
{
	myLocalizedDescription "contextComment = \"[Placeholder - do not translate] Database tactical summary for Gas Glob,  a sample the player can pluck from environment props on Vylus\", description = \"database-description-FloraSample18\", enabled = true, guid = #F460C2D05BBB4A47866EDDF54D13238C, lineVersion = 0, maxLength = 250, text = \"Valued by Expedition Observatories\n\nCan be used to develop Stasis Mods\""
	myLocalizedNarrative "contextComment = \"[Placeholder - do not translate] Database narrative description for Gas Glob, a sample the player can pluck from environment props on Vylus\", description = \"database-narrative-FloraSample18\", enabled = true, guid = #DE0D0944CCE146239B5F521B7664668D, lineVersion = 0, maxLength = 300, text = 'Perhaps the most unsettling sound heard on Vylus is the strange sighing of the flora. It is not known how or why plants like the Gas Glob \"breathe\", filling their skin-like sacs by taking in air. On Vylus, the line between plant and animal seems blurred.'"
	myPortrait onward/baked/textures/ui/icons/database_banner_large/planet_vylus/ui-database-sonatus-flora-sample-18-large.dds
	mySprite "mySpriteId = 2085669851, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myBannerSprite "mySpriteId = 2085669851, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myAttachScreenSprite "mySpriteId = 2085669851, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myRevealedChallengeType Discover_FloraSample18
	myUnlockedChallengeType Discover_FloraSample18
	myCollectibleSubType Samples
	myLocalizedName "contextComment = \"[Placeholder - do not translate] Database name for Gas Glob, a sample the player can pluck from environment props on Vylus\", description = \"database-name-FloraSample18\", enabled = true, guid = #8E283BA896084513A0CB6F78A5C38004, lineVersion = 0, maxLength = 30, text = \"Gas Glob\""
}

CustomDatabaseEntry FaunaSample16 < uid=9E6AFEDA5A82395D00001B70FED80F64 >
{
	myLocalizedDescription "contextComment = \"[Placeholder - do not translate] Database tactical summary for Mortopede Proboscis, a piece that can be collected from an animal on Vylus\", description = \"database-description-FaunaSample16\", enabled = true, guid = #3303FC75E9FE4726B898B05713C88E12, lineVersion = 0, maxLength = 250, text = \"Valued by Expedition Workshops\n\nCan be used to develop Energetic Mods\""
	myLocalizedNarrative "contextComment = \"[Placeholder - do not translate] Database narrative description for Mortopede Proboscis, a piece that can be collected from an animal on Vylus\", description = \"database-narrative-FaunaSample16\", enabled = true, guid = #EC0E54BFA16B4AAF9371B2B17627133C, lineVersion = 0, maxLength = 300, text = \"The unique neurochemistry of this vampiric animal includes enzymes used to pacify and liquify its prey. Horrific as it sounds, these compounds could be key to major medicinal breakthroughs.\""
	myPortrait onward/baked/textures/ui/icons/database_banner_large/planet_vylus/ui-database-sonatus-fauna-sample-16-large.dds
	mySprite "mySpriteId = 1016402065, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myBannerSprite "mySpriteId = 1016402065, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myAttachScreenSprite "mySpriteId = 1016402065, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myRevealedChallengeType Discover_FaunaSample16
	myUnlockedChallengeType Discover_FaunaSample16
	myCollectibleSubType Samples
	myLocalizedName "contextComment = \"[Placeholder - do not translate] Database name for Mortopede Proboscis, a piece that can be collected from an animal on Vylus\", description = \"database-name-FaunaSample16\", enabled = true, guid = #5B11A08DBFE54C0D84425DADCEA3EA3F, lineVersion = 0, maxLength = 30, text = \"Mortopede Proboscis\""
}

CustomDatabaseEntry Secrets < uid=9E6AFEDA5A96F53D00001B8463D8ADAA >
{
	myLocalizedDescription "contextComment = \"Database tactics tips for Vylus's \\"secret\\" database entry, awarded for discovering everything else on the planet.\nCurrently left blank so narrative text can use the full height of the card.\", description = \"database-description-planet-secrets-08\", enabled = true, guid = #9E6AFEDA5A96F4DB00001B77F02EF0E3, lineVersion = 0, maxLength = 2, text = \" \"}"
	myLocalizedNarrative "contextComment = \"[Placeholder - do not translate] Database narrative for Vylus's \\"secret\\" database entry, awarded for discovering everything else on the planet.\", description = \"database-narrative-planet-secrets-08\", enabled = true, guid = #9E6AFEDA5A96F4DB00001B7BB092195E, lineVersion = 0, maxLength = 750, text = \"Formerly the universe’s largest petri dish, Vylus is now home to the universe’s largest sentient slime mould. The rich algae beds of the planet's natural state are currently languishing due to the putrid wounds of a planetwide bacterial infection, which somehow gave birth to this main attraction – unnerving local Prospectors and consuming overzealous Expedition scientists.\n\nWhat at first appears to be a planet suffering from a vile disease is actually a thriving, healthy ecosystem - no matter how disgusting it might look to everyone who visits.\""
