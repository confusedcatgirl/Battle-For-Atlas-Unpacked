SimUnitDatabaseEntry XFactor < uid=A08A88CF598A074F0001852DAD54E717 >
{
	myLocalizedDescription "contextComment = \"Database tactics tip for Ashar's X-Factor site.\nCurrently left blank so narrative text can use this field's vertical space\", description = \"collectibles_database_xfactor_planet_15_tactics\", enabled = true, guid = #A08A88CF598A07160001800B14427B5B, lineVersion = 0, maxLength = 2, text = \" \""
	myLocalizedShortDescription "contextComment = \"[Placeholder - do not translate] Short descriptive text for Ashar's X-Factor site, shown when selecting it on the Starmap\", description = \"Starmap_shortDesc_planet_15_xfactor\", enabled = true, guid = #9E6AFEDA5A83541300001C9887DD6F77, lineVersion = 0, maxLength = 138, text = \"An Arena where Outlaws would battle in jury rigged ships. Could there be Warden Relics among the wreckage?\"}"
	myLocalizedNarrative "contextComment = \"[PLACEHOLDER - do not translate] Database narrative blurb for the Junkyard, the unique X-Factor location on the fire planet.\", description = \"collectibles_database_xfactor_planet_15_description\", enabled = true, guid = #A08A88CF598A09140001AF252117836F, lineVersion = 1, maxLength = 764, text = \"For Outlaws imprisoned on Ashar, the best chance of getting off-world and chasing their dreams of fortune and glory was to participate in the deadly combat of the Junkyard - an arena where two ships would enter, and only one would leave. \n\nNo rules and no restrictions meant the ships that convicts would scrabble together for themselves were vicious, horrible-looking, ill-constructed monstrosities of steel, fire, and energy. Their remains litter the shattered husk of the Junkyard, long abandoned after the majority of the Outlaw population chased the fun - and the money - into space.\""
	myPortrait onward/baked/textures/ui/icons/database_banner_large/planet_ashar/ui-database-ashar-fate-anchor-large.dds
	mySprite "mySpriteId = -1351665535, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myBannerSprite "mySpriteId = -1351665535, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myAttachScreenSprite "mySpriteId = -1351665535, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myRevealedChallengeType Discover_Planet15_XFactor
	myUnlockedChallengeType Discover_Planet15_XFactor
	myCollectibleSubType XFactor
	mySimUnitFiles
	{
		file planet_15 "onward/game system data/juice/sim/container_x_factor_base_planet_15.msimunit"
	}
}

CustomDatabaseEntry FloraSample19 < uid=9E6AFEDA5A83413000001C515A004E10 >
{
	myLocalizedDescription "contextComment = \"[Placeholder - do not translate] Database tactical summary for Bandit's Brush, a sample the player can pluck from environment props on Ashar\", description = \"database-description-FloraSample19\", enabled = true, guid = #E940F76DB3EF48A8B625CA6F3C1B4450, lineVersion = 0, maxLength = 250, text = \"Valued by Expedition Observatories\n\nCan be used to develop Defensive Mods\""
	myLocalizedNarrative "contextComment = \"[Placeholder - do not translate] Database narrative description for Bandit's Brush, a sample the player can pluck from environment props on Ashar\", description = \"database-narrative-FloraSample19\", enabled = true, guid = #8771A19F52784594BC58B7A36D6E9ABA, lineVersion = 0, maxLength = 300, text = \"Outlaws jealously guard their secrets, including the method they use to prepare and eat this rare flowering vegetable. Its rich nutritional value is locked away behind forbidding spines and a disagreeable flavour, but they found a way to enjoy it nonetheless.\""
	myPortrait onward/baked/textures/ui/icons/database_banner_large/planet_ashar/ui-database-ashar-flora-sample-19-large.dds
	mySprite "mySpriteId = 764996877, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myBannerSprite "mySpriteId = 764996877, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myAttachScreenSprite "mySpriteId = 764996877, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myRevealedChallengeType Discover_FloraSample19
	myUnlockedChallengeType Discover_FloraSample19
	myCollectibleSubType Samples
	myLocalizedName "contextComment = \"[Placeholder - do not translate] Database name for Bandit's Brush, a sample the player can pluck from environment props on Ashar\", description = \"database-name-FloraSample19\", enabled = true, guid = #4FEE6ED7F97A474784110166C67B2DBC, lineVersion = 0, maxLength = 30, text = \"Bandit's Brush\""
}

CustomDatabaseEntry FloraSample20 < uid=9E6AFEDA5A83413000001C52CD525D3C >
{
	myLocalizedDescription "contextComment = \"[Placeholder - do not translate] Database tactical summary for Enderbite Egg, a sample the player can pluck from environment props on Ashar\", description = \"database-description-FloraSample20\", enabled = true, guid = #EAA0871C6B9C457EB0B0B6443B257003, lineVersion = 0, maxLength = 250, text = \"Valued by Expedition Observatories\n\nCan be used to develop Heat Mods\""
	myLocalizedNarrative "contextComment = \"[Placeholder - do not translate] Database narrative description for Enderbite Egg, a sample the player can pluck from environment props on Ashar\", description = \"database-narrative-FloraSample20\", enabled = true, guid = #8FFE4F5D1482439CB5759EAEB417A636, lineVersion = 0, maxLength = 300, text = \"The embryo inside this egg glows from the heat of the planet's surface. The egg's interior can reach temperatures of up to 473 degrees Kelvin! Why this temperature seems necessary for the Enderbite's development remains a mystery.\""
	myPortrait onward/baked/textures/ui/icons/database_banner_large/planet_ashar/ui-database-ashar-flora-sample-20-large.dds
	mySprite "mySpriteId = -1362379458, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myBannerSprite "mySpriteId = -1362379458, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myAttachScreenSprite "mySpriteId = -1362379458, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myRevealedChallengeType Discover_FloraSample20
	myUnlockedChallengeType Discover_FloraSample20
	myCollectibleSubType Samples
	myLocalizedName "contextComment = \"[Placeholder - do not translate] Database name for Enderbite Egg, a sample the player can pluck from environment props on Ashar\", description = \"database-name-FloraSample20\", enabled = true, guid = #87900A08CA404EBA9CD1A218A8889DBE, lineVersion = 0, maxLength = 30, text = \"Enderbite Egg\""
}

CustomDatabaseEntry FloraSample21 < uid=9E6AFEDA5A83413000001C5330B0CD02 >
{
	myLocalizedDescription "contextComment = \"[Placeholder - do not translate] Database tactical summary for Ashpepper, a sample the player can pluck from environment props on Ashar\", description = \"database-description-FloraSample21\", enabled = true, guid = #8E18857B88CC43AA88DEAA63A0C61489, lineVersion = 0, maxLength = 250, text = \"Valued by Expedition Observatories\n\nCan be used to develop Exotic Mods\""
	myLocalizedNarrative "contextComment = \"[Placeholder - do not translate] Database narrative description for Ashpepper, a sample the player can pluck from environment props on Ashar\", description = \"database-narrative-FloraSample21\", enabled = true, guid = #7F924A0BABCF4228800353F7C705C826, lineVersion = 0, maxLength = 300, text = \"Nobody knows for sure why the Ashpepper grows on Ashar, since its fruit is instantly charred by the extreme heat as it grows. Some botanists suspect it is not native to Ashar, but was actually brought from Sonatus, a distant relative of the Spice Pop.\""
	myPortrait onward/baked/textures/ui/icons/database_banner_large/planet_ashar/ui-database-ashar-flora-sample-21-large.dds
	mySprite "mySpriteId = -846800154, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myBannerSprite "mySpriteId = -846800154, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myAttachScreenSprite "mySpriteId = -846800154, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myRevealedChallengeType Discover_FloraSample21
	myUnlockedChallengeType Discover_FloraSample21
	myCollectibleSubType Samples
	myLocalizedName "contextComment = \"[Placeholder - do not translate] Database name for Ashpepper, a sample the player can pluck from environment props on Ashar\", description = \"database-name-FloraSample21\", enabled = true, guid = #39B631C99969461B9E0D0C07C1156BEC, lineVersion = 0, maxLength = 30, text = \"Ashpepper\""
}

CustomDatabaseEntry FaunaSample19 < uid=9E6AFEDA5A83413000001C54D128E409 >
{
	myLocalizedDescription "contextComment = \"[Placeholder - do not translate] Database tactical summary for Lithogoyle Spine, a piece that can be collected from an animal on Ashar\", description = \"database-description-FaunaSample19\", enabled = true, guid = #9FBEC8FB81264550AD9B1526E5EB0590, lineVersion = 0, maxLength = 250, text = \"Valued by Expedition Workshops\n\nCan be used to develop Offensive Mods\""
	myLocalizedNarrative "contextComment = \"[Placeholder - do not translate] Database narrative description for Lithogoyle Spine, a piece that can be collected from an animal on Ashar\", description = \"database-narrative-FaunaSample19\", enabled = true, guid = #01C401265F21496DAA606BD7C84AB5A7, lineVersion = 0, maxLength = 300, text = \"The Lithogoyle's crest of spines appears to have something to do with generating their fiery lava breath. Expedition scientists speculate it could hold the secrets to powering new & devastating weaponry.\""
	myPortrait onward/baked/textures/ui/icons/database_banner_large/planet_ashar/ui-database-ashar-fauna-sample-19-large.dds
	mySprite "mySpriteId = -68459239, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myBannerSprite "mySpriteId = -68459239, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myAttachScreenSprite "mySpriteId = -68459239, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database-02.spritesheet\""
	myStarmapThreatKnownSprite "mySpriteId = -455779427, mySpritesheet = F\"onward/ui/spritesheets/ui-icon-placeholder.spritesheet\""
	myRevealedChallengeType Discover_FaunaSample19
	myUnlockedChallengeType Discover_FaunaSample19
	myCollectibleSubType Samples
