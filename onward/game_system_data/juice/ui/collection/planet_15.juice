include "onward/game system data/fruit/ui/collection/databasesubcategory.fruit"

PlanetDatabaseEntry Overview < uid=1ABBD50B59497A190001F829CD10A454 >
{
	myLocalizedDescription "contextComment = \"[PLACEHOLDER - do not translate] Database tactics tips for the fiery lava & ash planet Ashar\", description = \"collectibles_database_planet_15_overview_tactics\", enabled = true, guid = #1ABBD50B584B05EC0000319FA70DF83D, lineVersion = 1, maxLength = 99, text = \"Sector C\n\nExtremely Hot\n\nHeat-type Legion and Mods\ncan be found in abundance\""
	myLocalizedNarrative "contextComment = \"[PLACEHOLDER - do not translate] Database narrative summary for the fiery lava & ash planet Ashar\", description = \"collectibles_database_planet_15_overview_description\", enabled = true, guid = #A08A88CF589A3C5F0000005D9D31122D, lineVersion = 1, maxLength = 632, text = \"Forever locked in a cycle of cleansing fire, Ashar is a place of constant devastation and constant rebirth. The Warden structure known as The Great Anchor triggers continent-sized firestorms that roll over the landscape, leaving life to struggle back in their wake. Early settlers discovered completely unique forms of plant and animal life in this harsh environment – sentient rock, ash-breathing flowers, and of course, one of nature's most startling children, the Jewel of the Ash.\"}"
	myPortrait onward/baked/textures/ui/icons/database_banner_large/planet_ashar/ui-database-planet-ashar-large.dds
	mySprite "mySpriteId = 611915653, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database.spritesheet\""
	myBannerSprite "mySpriteId = 79948054, mySpritesheet = F\"onward/ui/spritesheets/ui-icon-planets.spritesheet\""
	myUnlockedChallengeType Discover_Planet15
	myPlanetUIDs
	{
		uid 1 CC9485AB560DABE6000000B1513C7CDA
	}
	myLocalizedName "contextComment = \"Name for the fiery lava & ash planet Ashar\", description = \"collectibles_database_planet_15_overview_name\", enabled = true, guid = #1ABBD50B584B05EC0000319D1BFFBAFF, lineVersion = 1, maxLength = 1, text = \"Ashar\""
}

SimUnitDatabaseEntries Landmarks
{
	SimUnitDatabaseEntry "Temples of Reckoning" < uid=1ABBD50B59497A190001F82A1B53159B >
	{
		myLocalizedDescription "contextComment = \"[PLACEHOLDER - do not translate].\nDatabase tactics tips for Planet_15's named area A: Temples of Reckoning.\", description = \"database-item-namedarea-planet_15-a-tactics\", enabled = true, guid = #9E6AFEDA5A83447300001C56D6E45753, lineVersion = 0, maxLength = 68, text = \"Home to the terrifying Lithogoyle\nand Enderbite Eggs\"}"
		myLocalizedNarrative "contextComment = \"[PLACEHOLDER - do not translate].\nDatabase narrative for Planet_15's named area A: Temples of Reckoning.\", description = \"database-item-namedarea-planet_15-a\", enabled = true, guid = #A08A88CF588F6C1C0000CC567F94A5BD, lineVersion = 0, maxLength = 152, text = \"Rocky towers that glow from within, evidence of Ashar’s intense internal heat and the recent presence of firestorms\"}"
		myPortrait onward/baked/textures/ui/icons/database_banner_large/planet_ashar/ui-database-ashar-temples-of-reckoning-large.dds
		mySprite "mySpriteId = -1146706496, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database.spritesheet\""
		myUnlockedChallengeType Discover_Planet15_NamedAreaA
		myCollectibleSubType Biome
		mySimUnitFiles
		{
			file 1 "onward/game system data/juice/sim/named_place_planet_15_a.msimunit"
		}
	}
	SimUnitDatabaseEntry "Resurrection Valley" < uid=1ABBD50B59497A190001F82C058C4676 >
	{
		myLocalizedDescription "contextComment = \"[PLACEHOLDER - do not translate].\nDatabase tactics tips for Planet_15's named area C: Resurrection Valley.\", description = \"database-item-namedarea-planet_15-c-tactics\", enabled = true, guid = #9E6AFEDA5A83453900001C5CEA8A62C8, lineVersion = 0, maxLength = 92, text = \"Obsidian Enderbite roam the meadows,\namong Bandit's Brush and Ashpepper\""
		myLocalizedNarrative "contextComment = \"[PLACEHOLDER - do not translate].\nDatabase narrative for Planet_15's named area C: Resurrection Valley.\", description = \"database-item-namedarea-planet_15-c\", enabled = true, guid = #A08A88CF588F6C190000CC5296486432, lineVersion = 0, maxLength = 207, text = \"Following one of Ashar's frequent, cataclysmic volcanic eruptions, there is often a dormant period, where life begins to thrive on the fertile ash left behind.\""
		myPortrait onward/baked/textures/ui/icons/database_banner_large/planet_ashar/ui-database-ashar-resurrection-valley-large.dds
		mySprite "mySpriteId = -1965272971, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database.spritesheet\""
		myUnlockedChallengeType Discover_Planet15_NamedAreaC
		myCollectibleSubType Biome
		mySimUnitFiles
		{
			file 1 "onward/game system data/juice/sim/named_place_planet_15_c.msimunit"
		}
	}
	SimUnitDatabaseEntry "Pools of Despair" < uid=1ABBD50B59497A190001F82B80747970 >
	{
		myLocalizedDescription "contextComment = \"[PLACEHOLDER - do not translate].\nDatabase tactics tips for Planet_15's named area B: Pools of Despair.\", description = \"database-item-namedarea-planet_15-b-tactics\", enabled = true, guid = #9E6AFEDA5A8349BB00001C62AA16DEFD, lineVersion = 0, maxLength = 87, text = \"Super-heats ships that fly too close\n\nBreeding grounds of the Snood\"}"
		myLocalizedNarrative "contextComment = \"[PLACEHOLDER - do not translate].\nDatabase narrative blurb for Planet_15's named area B: Pools of Despair.\", description = \"database-item-namedarea-planet_15-b\", enabled = true, guid = #A08A88CF588F6C1B0000CC54FD06CC88, lineVersion = 0, maxLength = 75, text = \"Basins of sizzling acid that herald the coming of new life\"}"
		myPortrait onward/baked/textures/ui/icons/database_banner_large/planet_ashar/ui-database-ashar-pools-of-despair-large.dds
		mySprite "mySpriteId = -1848721717, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database.spritesheet\""
		myUnlockedChallengeType Discover_Planet15_NamedAreaB
		myCollectibleSubType Biome
		mySimUnitFiles
		{
			file 1 "onward/game system data/juice/sim/named_place_planet_15_b.msimunit"
		}
	}
}

SimUnitDatabaseEntries Fauna
{
	SimUnitDatabaseEntry Lithogoyle < uid=1ABBD50B59497A190001F82D4DF67097 >
	{
		myLocalizedDescription "contextComment = \"[PLACEHOLDER - do not translate].\nDatabase tactics tips for the Lithogoyle fauna, a fire-breathing T-Rex\", description = \"database-item-fauna-lithogoyle-tactics\", enabled = true, guid = #9E6AFEDA5A8352B500001C7E945FC5E2, lineVersion = 0, maxLength = 125, text = \"Highly aggressive, spits molten fire\n\nChipped parts of its Spines can be used in Mod development\""
		myLocalizedNarrative "contextComment = \"[PLACEHOLDER - do not translate].\nDatabase narrative blurb for the Lithogoyle fauna, a fire-breathing T-Rex\", description = \"database-item-fauna-lithogoyle\", enabled = true, guid = #A08A88CF588F6C160000CC50B89DCC73, lineVersion = 0, maxLength = 287, text = \"Every gentle Enderbite soon becomes one of these huge, deadly predators, whose flaming vomit has reduced many a foolhardy pilot to ash. They're hostile, frightening, and mean: Ashar itself in a dragon's impenetrable skin.\""
		myPortrait onward/baked/textures/ui/icons/database_banner_large/planet_ashar/ui-database-ashar-lithogyle-large.dds
		mySprite "mySpriteId = 829844759, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database.spritesheet\""
		myRevealedChallengeType FullyScan_Fauna19
		myUnlockedChallengeType FullyScan_Fauna19
		myCollectibleSubType Fauna
		mySimUnitFiles
		{
			file 1 "onward/game system data/juice/sim/fauna_19.msimunit"
		}
	}
	SimUnitDatabaseEntry Snood < uid=1ABBD50B59497A190001F82ECE8A4B7F >
	{
		myLocalizedDescription "contextComment = \"[PLACEHOLDER - do not translate].\nDatabase tactics tip for the Itch fauna, (now Snood), a diseased-looking bird\", description = \"database-item-fauna-itch-tactics\", enabled = true, guid = #9E6AFEDA5A83538100001C8C3DFD7D5D, lineVersion = 0, maxLength = 22, text = \"Highly aggressive\""
		myLocalizedNarrative "contextComment = \"[PLACEHOLDER - do not translate].\nDatabase narrative blurb for the Itch fauna, (now Snood), a diseased-looking bird\", description = \"database-item-fauna-itch\", enabled = true, guid = #A08A88CF588F6C150000CC4E608DBF99, lineVersion = 0, maxLength = 253, text = \"The pathetic appearance of these avian predators disguises a nasty attitude. Outlaw bards sing of their vengeful behaviour, as though they are striking back at a world to which they don't belong.\"}"
		myPortrait onward/baked/textures/ui/icons/database_banner_large/planet_ashar/ui-database-ashar-itch-large.dds
		mySprite "mySpriteId = -657837317, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database.spritesheet\""
		myRevealedChallengeType FullyScan_Fauna20
		myUnlockedChallengeType FullyScan_Fauna20
		myCollectibleSubType Fauna
		mySimUnitFiles
		{
			file 1 "onward/game system data/juice/sim/fauna_20.msimunit"
		}
	}
	SimUnitDatabaseEntry "Obsidian Enderbrite" < uid=1ABBD50B59497A190001F82FED161427 >
	{
		myLocalizedDescription "contextComment = \"[PLACEHOLDER - do not translate].\nDatabase tactics tip for the Obsidian Enderbite fauna.\", description = \"database-item-fauna-obsidianenderbite-tactics\", enabled = true, guid = #9E6AFEDA5A8353E300001C924182CB2E, lineVersion = 0, maxLength = 25, text = \"Flees if threatened\""
		myLocalizedNarrative "contextComment = \"[PLACEHOLDER - do not translate].\nDatabase narrative blurb for the Obsidian Enderbite fauna.\", description = \"database-item-fauna-obsidianenderbite\", enabled = true, guid = #A08A88CF588F6C140000CC4C7868DE7D, lineVersion = 0, maxLength = 246, text = \"These shy reptiles are born in flame, nurtured by Ashar's extreme heat. Their gentle nature soon gives way to fierce predatory instinct when they grow into their adult form: the Lithogoyle.\"}"
		myPortrait onward/baked/textures/ui/icons/database_banner_large/planet_ashar/ui-database-ashar-enderbite-large.dds
		mySprite "mySpriteId = 267420693, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database.spritesheet\""
		myRevealedChallengeType FullyScan_Fauna17
		myUnlockedChallengeType FullyScan_Fauna17
		myCollectibleSubType Fauna
		mySimUnitFiles
		{
			file 1 "onward/game system data/juice/sim/fauna_17.msimunit"
		}
	}
}

