	myLocalizedDescription "contextComment = \"Database tactics tips for Ashar's \\"secret\\" database entry, awarded for discovering everything else on the planet.\nCurrently left blank so narrative text can use the full height of the card.\", description = \"database-description-planet-secrets-15\", enabled = true, guid = #9E6AFEDA5A96FFD800001C607A826497, lineVersion = 0, maxLength = 2, text = \" \"}"
	myLocalizedNarrative "contextComment = \"[Placeholder - do not translate] Database narrative for Ashar's \\"secret\\" database entry, awarded for discovering everything else on the planet.\", description = \"database-narrative-planet-secrets-15\", enabled = true, guid = #9E6AFEDA5A96FFD800001C640D20769A, lineVersion = 0, maxLength = 750, text = \"Forever locked in a cycle of cleansing fire, Ashar is a place of constant devastation and constant rebirth. The WARDEN structure known as FATE'S ANCHOR triggers continent-sized firestorms that roll over the landscape, leaving life to struggle back in their wake. Early settlers discovered completely unique forms of plant and animal life in this harsh environment – sentient rock, ash-breathing flowers, and of course, one of nature’s most startling children, the Jewel of the Ash. \""
