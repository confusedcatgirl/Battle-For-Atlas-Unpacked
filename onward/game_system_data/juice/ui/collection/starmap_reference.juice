SimUnitDatabaseEntry "Warden Ruins" < uid=63C8917A5A7B6B67000239A39566A9C4 >
{
	myLocalizedDescription "contextComment = \"[PLACEHOLDER - do not translate].\nText describing the warden ruins for the planet rollovers.\", description = \"ui-menu-starmap-rollover-wardenruin-description-solved\", enabled = true, guid = #63C8917A5A7B6B490002329CA58088B9, lineVersion = 0, maxLength = 183, text = \"How satisfying, to solve these ancient mysteries! But it's left us with more questions than answers... Perhaps other ruins will tell us more?\"}"
	myLocalizedShortDescription "contextComment = \"[PLACEHOLDER - do not translate].\nText describing the warden ruins for the planet rollovers.\", description = \"ui-menu-starmap-rollover-wardenruin-description-unsolved\", enabled = true, guid = #63C8917A5A7B6B490002329E83B2EBAF, lineVersion = 0, maxLength = 169, text = \"A relic hinting at the  ways of the mysterious Wardens. To be so huge, it must have served an important purpose; what's it hiding?\"}"
