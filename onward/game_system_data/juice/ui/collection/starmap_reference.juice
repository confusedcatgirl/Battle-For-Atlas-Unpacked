SimUnitDatabaseEntry "The Equinox" < uid=1ABBD50B594979490001BC0841F2A2EC >
{
	myLocalizedShortDescription "contextComment = \"[PLACEHOLDER - do not translate]\nA short description of the Equinox mothership shown when selecting it in the Starmap\", description = \"database-item-description-short-equinox\", enabled = true, guid = #A08A88CF594157FE000210F51E8D330F, lineVersion = 1, maxLength = 200, text = \"Mothership of the Starlink Initiative. Upgrade its facilities to strengthen your pilots, allies, and ships.\""
	myLocalizedNarrative "contextComment = \"[PLACEHOLDER - do not translate].\nDatabase description of the Equinox, the player's mothership.\", description = \"database-item-description-equinox\", enabled = true, guid = #A08A88CF594157FE000210F7D7268FC2, lineVersion = 1, maxLength = 400, text = \"The Equinox is the flagship of the Starlink Initiative, and the first Earth ship capable of faster-than light travel. St. Grand and Judge developed the ship together to help find Judge's homeworld. Now it serves as the base of operations for their scientific exploration.\""
	myPortrait onward/baked/textures/ui/icons/database_banner_large/onward_initiative/ui-database-onward-equinox-large.dds
	mySprite "mySpriteId = -1252830909, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database.spritesheet\""
	myBannerSprite "mySpriteId = -1252830909, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database.spritesheet\""
	myAttachScreenSprite "mySpriteId = -1252830909, mySpritesheet = F\"onward/ui/spritesheets/ui-icons-collection-database.spritesheet\""
	myRevealedChallengeType Act0
	myUnlockedChallengeType Act0
	myDeathChallengeType Act0
	mySimUnitFiles
	{
		file 1 "onward/game system data/juice/sim/onward_equinox_space.msimunit"
		file 2 "onward/game system data/juice/sim/onward_equinox_planet.msimunit"
	}
}

