	{
		myFontSize 27.0
		myFontStyle "Modelica Medium Font Style"
	}
	PresetFont "Subtitle Speaker - Large"
	{
		myFontSize 30.0
		myFontStyle "Modelica Medium Font Style"
	}
	PresetFont "Collection Banner - Planet"
	{
		myFontSize 90.0
		myFontScaling FixedSmall
		myFontStyle "Modelica Black Font Style"
	}
	PresetFont "Collection Banner - Named Area"
	{
		myFontSize 30.0
		myFontStyle "Modelica Extra Bold Font Style"
	}
	PresetFont "Medium - 20"
	{
		myFontSize 20.0
		myFontStyle "Modelica Medium Font Style"
	}
