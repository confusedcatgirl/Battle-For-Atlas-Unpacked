include font/presetfonts.fruit

PresetFonts myPresetFonts
{
	PresetFont default
	{
		myFontSize 40.0
		myUseMonospacedNumbers FALSE
		myBorder 0
		myFontStyle "Modelica Black Font Style"
	}
	PresetFont "Screen Title"
	{
		myFontSize 30.0
		myFontStyle "Modelica Bold Font Style"
	}
	PresetFont "Menu Item"
	{
		myFontSize 28.0
		myFontStyle "Modelica Bold Font Style"
	}
	PresetFont "PIP speaker name"
	{
		myFontSize 28.0
		myFontStyle "Modelica Bold Font Style"
	}
	PresetFont "Main Heading"
	{
		myFontSize 28.0
		myFontStyle "Modelica Extra Bold Font Style"
	}
	PresetFont Subheading
	{
		myFontSize 26.0
		myFontStyle "Modelica Bold Font Style"
	}
	PresetFont "HUD objective text / ability name"
	{
		myFontSize 26.0
		myFontStyle "Modelica Bold Font Style"
	}
	PresetFont "HUD tutorial text"
	{
		myFontSize 26.0
		myFontStyle "Modelica Bold Font Style"
	}
	PresetFont "Body text / important bullet text"
	{
		myFontSize 24.0
		myFontStyle "Modelica Medium Font Style"
	}
