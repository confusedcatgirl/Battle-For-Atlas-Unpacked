	{
		myFontSize 24.0
		myFontStyle "Modelica Bold Font Style"
	}
	PresetFont "List item label"
	{
		myFontSize 24.0
		myFontStyle "Modelica Medium Font Style"
	}
	PresetFont "Minor bullet point / flavour text"
	{
		myFontSize 20.0
		myFontStyle "Modelica Bold Font Style"
	}
	PresetFont "In-world marker text"
	{
		myFontSize 20.0
		myFontStyle "Modelica Bold Font Style"
	}
	PresetFont "Subtitle - Small"
	{
		myFontSize 24.0
		myFontStyle "Modelica Medium Font Style"
