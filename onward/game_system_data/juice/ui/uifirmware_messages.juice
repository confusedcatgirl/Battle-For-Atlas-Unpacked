		FirmwareToySwapError Disconnected
		{
			myTitle "contextComment = \"[Placeholder – DO NOT TRANSLATE]\", description = \"toyswap-disconnected-title\", enabled = true, guid = #B6120953593EA2600001DCA4AC6CA075, lineVersion = 1, maxLength = 22, text = \"No Mount Detected\""
			myErrorList
			{
				ToySwapMessage PS4
				{
					myText "contextComment = \"[Placeholder – DO NOT TRANSLATE]\", description = \"toyswap-disconnected-ps4\", enabled = true, guid = #B6120953593EA3560001DCA85D774114, lineVersion = 1, maxLength = 140, text = \"1. Unplug the Mount cable from both the Mount and the PS4. \n2. Reconnect the Mount, or try a different cable\""
				}
				ToySwapMessage XboxOne
				{
					myPlatformType XboxOne
					myText "contextComment = \"[Placeholder – DO NOT TRANSLATE]\", description = \"toyswap-disconnected-xboxone\", enabled = true, guid = #B6120953593EA6F40001DCAE92B278CB, lineVersion = 1, maxLength = 370, text = \"1. Grip your mount by the middle bridge and bottom tab.\n2. Pull back firmly to disconnect the Mount.\n3. Turn off your wireless controller by holding the Guide Button \n4. Turn your controller on, or use a different controller \n5. Reconnect your Mount, pressing in firmly until it clicks\""
				}
				ToySwapMessage Switch
				{
					myPlatformType Switch
					myText "contextComment = \"[Placeholder – DO NOT TRANSLATE]\", description = \"toyswap-disconnected-switch\", enabled = true, guid = #B6120953593EA73F0001DCB28DF77F16, lineVersion = 1, maxLength = 272, text = \"1. Disconnect your Joycon controllers from the controller Mount\n2. Turn off both Joycon controllers by holding the power button\n3. Turn your controllers back on\n4. Re-connect your Mount and parts one at a time\""
				}
				ToySwapMessage PC
				{
					myPlatformType PC
					myText "contextComment = \"Instructions for attaching or detaching mount from controller\", description = \"toyswap-disconnected-pc\", enabled = true, guid = #A1CDB8165C5A7F1F00033A08FBD1D053, lineVersion = 0, maxLength = 247, text = \"[Connect the Starlink Mount onto your controller, pressing firmly until it clicks into place\n\nTo remove or adjust your Mount,\n\nhold the Mount and controller in each hand and pull them apart]\""
				}
			}
			myErrorCode STARLINK-00
		}
