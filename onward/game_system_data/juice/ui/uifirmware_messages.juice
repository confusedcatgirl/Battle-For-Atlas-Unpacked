					myText "contextComment = \"[Placeholder – DO NOT TRANSLATE]\", description = \"toyswap-error_futurepart-switch\", enabled = true, guid = #B6120953593EA1840001DC9E6C0741E8, lineVersion = 1, maxLength = 176, text = \"You need to update your game to use this part.\n\nPlease connect your Switch to the Internet to update Starlink™ to the latest version.\""
