			{
				ToySwapMessage PS4
				{
					myText "contextComment = \"[Placeholder – DO NOT TRANSLATE]\", description = \"toyswap-error_futurepart-ps4\", enabled = true, guid = #B6120953593EA0CD0001DC964D77A81B, lineVersion = 1, maxLength = 172, text = \"You need to update your game to use this part.\n\nPlease connect your PS4 to the Internet to update Starlink™ to the latest version.\""
