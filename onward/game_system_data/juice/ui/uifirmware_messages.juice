		FirmwareToySwapError Error_ConsoleIncompatible
		{
			myMountState Error_ConsoleIncompatible
			myTitle "contextComment = \"Title shown on error screen when attaching a Pilot, Ship, Wing, or Weapon that's exclusive to a different console than the one the player is playing on. (eg. this toy might be usable only on the Nintendo Switch, so connecting it on the Xbox One will show this error)\", description = \"toyswap-incompatible-title\", enabled = true, guid = #9E6AFEDA5AEB546300001D74570235B5, lineVersion = 0, maxLength = 21, text = \"Cannot Link Part\"}"
			myErrorList
			{
				ToySwapMessage PS4
				{
					myText "contextComment = \"Toy swap error shown when the player tries to connect a part (Pilot, Ship, Wing, or Weapon) that's exclusive to a different console than the one they're playing on (PS4). The player cannot use this toy on their current console, and must detach it and use a different toy instead.\", description = \"toyswap-incompatible-ps4\", enabled = true, guid = #9E6AFEDA5AEB54C500001D7A1AC30688, lineVersion = 0, maxLength = 126, text = \"This part cannot be used on Starlink™ for PlayStation 4.\n\nPlease Link a different part instead.\""
