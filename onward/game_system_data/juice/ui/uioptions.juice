				myDescription "contextComment = \"Description for Options setting for mouse horizontal sensitivity. Increasing the slider value scales up the camera's rotation speed in vertical direction. Slower speeds help players aim more precisely/avoid disorienting themselves with quick turns, while higher speeds help players look around quickly\", description = \"ui-options-keyboardmouse-mousehorizontal-sensitivity-description\", enabled = true, guid = #A1CDB8165C6401820002C687A077C1E5, lineVersion = 2, maxLength = 142, text = '[Choose how quickly the vertical camera should turn when you look around with the <gameaction src=\"LookUp\">.]'}"
				myAvailableOnXboxOne FALSE
				myAvailableOnPS4 FALSE
				myAvailableOnNintendoSwitch FALSE
				myIsRestrictedToPrimaryPlayer TRUE
				myFloatOption MouseVerticalSensitivity
				myMinRange 0.0
				myMaxRange 100.0
				myStep 5.0
			}
		}
