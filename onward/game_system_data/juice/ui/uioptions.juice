				myDescription "contextComment = \"Description for Options setting for subtitle font size. Options are small, medium, and large\", description = \"ui-menu-options-languagesandsubtitles-subtitlesize-description\", enabled = true, guid = #9E6AFEDA5B3BDAE100002290BA55679D, lineVersion = 0, maxLength = 99, text = \"[Choose how large the subtitle text should be when characters are speaking.]\""
				myIsRestrictedToPrimaryPlayer TRUE
