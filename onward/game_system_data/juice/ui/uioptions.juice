				myAvailableOnNintendoSwitch FALSE
				myIsRestrictedToPrimaryPlayer TRUE
				myFloatOption MouseHorizontalSensitivity
				myMinRange 0.0
				myMaxRange 100.0
				myStep 5.0
			}
			RangeMenuItem "Mouse YSensitivity" < uid=A1CDB8165C2C83FA0001D49DF151C2BA >
			{
