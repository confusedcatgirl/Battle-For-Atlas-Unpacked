				myDescription "contextComment = \"Description for Options setting for temperature units - players can select degrees Celsius, Kelvin, or Fahrenheit.\", description = \"ui-options-subtitleslanguages-temperaturescale-description\", enabled = true, guid = #9E6AFEDA5B3BDAB20000228C0EE9A967, lineVersion = 0, maxLength = 123, text = \"[Choose which units to use for measuring temperatures: degrees Celsius, Kelvin, or Fahrenheit.]\""
