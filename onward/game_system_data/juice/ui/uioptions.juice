			{
				myName "contextComment = \"Allows the player to set horizontal sensitivity of their mouse\", description = \"ui-options-keyboardmouse-mousehorizontal-sensitivity\", enabled = true, guid = #A1CDB8165C405EC80002F3F658C44986, lineVersion = 1, maxLength = 65, text = '[<gameaction src=\"LookUp\"> Horizontal Sensitivity]'"
				myDescription "contextComment = \"Description for Options setting for mouse horizontal sensitivity. Increasing the slider value scales up the camera's rotation speed in horizontal direction. Slower speeds help players aim more precisely/avoid disorienting themselves with quick turns, while higher speeds help players look around quickly\", description = \"ui-options-keyboardmouse-mousehorizontal-sensitivity-description\", enabled = true, guid = #A1CDB8165C4060A9000366DD3742EB3D, lineVersion = 1, maxLength = 144, text = '[Choose how quickly the horizontal camera should turn when you look around with the <gameaction src=\"LookUp\">.]'}"
