			ActionMenuItem "Game Controls" < uid=A08A88CF59DD1C110001AB136BB0AA4A >
			{
				myName "contextComment = \"[PLACEHOLDER - do not translate].\nMenu option dealing with gameplay changes (ex: control schemes).\", description = \"ui-options-gameplay-controls\", enabled = true, guid = #A1CDB8165C36D695000FB1425F680026, lineVersion = 1, maxLength = 17, text = \"Show Controls\""
				myDescription "contextComment = \"Description for Options menu entry where the player can press [A] to show the controller mapping diagram, indicating what each button does.\", description = \"ui-options-gameplay-controls-description\", enabled = true, guid = #9E6AFEDA5B3BCEFF000022582B425166, lineVersion = 0, maxLength = 77, text = \"[View the control scheme for piloting your Starlink ships.]\""
				myAvailableOnXboxOne FALSE
				myAvailableOnPS4 FALSE
				myAvailableOnNintendoSwitch FALSE
				myAvailableOnPC TRUE
				myIsPlayerOption FALSE
			}
			TriBoolMenuItem "Use Alternate Boost Control" < uid=600A30F35C51E3480000004CF33A1A59 >
			{
				myName "contextComment = \"A game option allowing the player to select which button they would like to use to boost in-game.\", description = \"ui-options-boostcontrols\", enabled = true, guid = #600A30F35C52092A00007BBF11D6F045, lineVersion = 1, maxLength = 18, text = \"Boost Controls\""
				myDescription "contextComment = \"A description detailing out how boost controls can be set by the player, and what they mean.\", description = \"ui-options-boostcontrols-description\", enabled = true, guid = #A08A88CF5C67075900163BFB97FCDE96, lineVersion = 0, maxLength = 342, text = ' By default, boost with <gameaction src=\"Special_Boost_Default\">. \nYou can also choose to boost using <gameaction src=\"Special_Boost_Alternate\"> or to use <gameaction src=\"Special_Boost_Default\"> on planets and <gameaction src=\"Special_Boost_Alternate\"> in space.'"
				myAvailableOnXboxOne FALSE
				myAvailableOnPS4 FALSE
				myAvailableOnNintendoSwitch FALSE
				myAvailableOnPC TRUE
				myIsPlayerOption FALSE
				myIsSlotSpecific TRUE
				myIsRestrictedToPrimaryPlayer FALSE
				myTriBoolOption UseAlternateBoostControl
				myFalseText "contextComment = \"Default boost control (B/Circle)\", description = \"ui-options-boostcontrols-false\", enabled = true, guid = #600A30F35C52092A00007BC3DF568776, lineVersion = 0, maxLength = 66, text = 'Always use <gameaction src=\"Special_Boost_Default\">'"
				myMaybeText "contextComment = \"Alternate boost control (R1/ right bumper)\nPlease keep this line as short as possible. Even in English it doesn't have much room. \", description = \"ui-options-boostcontrols-maybe\", enabled = true, guid = #600A30F35C52092A00007BC52D51111B, lineVersion = 0, maxLength = 135, text = '<gameaction src=\"Special_Boost_Alternate\"> in space, <gameaction src=\"Special_Boost_Default\"> on planets'}"
				myTrueText "contextComment = \"Hybrid. R1 in space. B on planet.\", description = \"ui-options-boostcontrols-true\", enabled = true, guid = #600A30F35C52092A00007BC71F8C3E42, lineVersion = 0, maxLength = 69, text = 'Always use <gameaction src=\"Special_Boost_Alternate\">'"
			}
			BooleanMenuItem Vibration < uid=A1CDB8165C1127B1000EBB0398E308AC >
			{
				myName "contextComment = \"\", description = \"\", enabled = true, guid = #A1CDB8165C11273D000C38DD07BA96A1, lineVersion = 0, maxLength = 14, text = \"Vibration\""
				myDescription "contextComment = \"(Xbox One specific - please consult approved compliance terminology & translations) Description for Options setting for enabling controller vibration/rumble features\", description = \"ui-options-gameplay-rumble-xb1-description\", enabled = true, guid = #9E6AFEDA5B3BCEED0000224CA1F8BD7A, lineVersion = 0, maxLength = 113, text = \"[Choose whether your controller should vibrate in response to what your ship is doing.]\""
				myAvailableOnXboxOne FALSE
				myAvailableOnPS4 FALSE
				myAvailableOnNintendoSwitch FALSE
				myBooleanOption ControllerVibrationEnabled
			}
			TriBoolMenuItem "Right Stick Invert Horizontal" < uid=A08A88CF5C40A5B40000E32108E87E0C >
			{
				myName "contextComment = \"Option that inverts horizontal camera control.\", description = \"ui-options-gameplay-invertrightthorizontal\", enabled = true, guid = #A08A88CF5C40A5B10000E1D693BC0F95, lineVersion = 0, maxLength = 31, text = \"Invert Camera Left/Right\""
				myDescription "contextComment = \"Descriptino for the horizontal camera/ship movement inversion option.\", description = \"ui-options-gameplay-invertright-horizontal-description\", enabled = true, guid = #A08A88CF5C40A5B10000E1D7E044CFCF, lineVersion = 0, maxLength = 372, text = 'By default, tilting <gameaction src=\"LookUp\"> left will tilt your camera left and sheer your ship in the same direction.\n \nChoose \"Always Inverted\" to reverse this direction, or \"Inverted in Flight\" to reverse it only when flying in the air or in space, not when hovering on the ground.'"
				myAvailableOnXboxOne FALSE
				myAvailableOnPS4 FALSE
				myAvailableOnNintendoSwitch FALSE
				myAvailableOnPC TRUE
				myTriBoolOption InvertAimControlHorizontal
				myFalseText "contextComment = \"Default camera inversion option: pressing left on the right stick tilts the ship left.\", description = \"ui-options-gameplay-invertrighthorizontal-never\", enabled = true, guid = #A08A88CF5C40A5B10000E1D8C9012AAC, lineVersion = 0, maxLength = 30, text = \"Never Invert\""
				myMaybeText "contextComment = \"Alternate camera inversion option: when flying in the air or in space, pressing left turns the ship left, but the opposite is used on the ground.\", description = \"ui-options-gameplay-invertrighthorizontal-maybe\", enabled = true, guid = #A08A88CF5C40A5B10000E1D9BDA79A30, lineVersion = 0, maxLength = 30, text = \"Inverted In Flight\""
				myTrueText "contextComment = \"Alternative camera inversion: left is right and right is left for the purposes of turning the ship.\", description = \"ui-options-gameplay-invertright-horizontal-true\", enabled = true, guid = #A08A88CF5C40A5B10000E1DACE14EAB6, lineVersion = 0, maxLength = 30, text = \"Always Inverted\""
			}
			TriBoolMenuItem "Right Stick Invert Vertical" < uid=A08A88CF58EB9F9A00000083919ECF67 >
			{
				myName "contextComment = \"[PLACEHOLDER - do not translate].\nOption that inverts the right thumbstick vertically.\", description = \"ui-options-gameplay-invertrightvertical\", enabled = true, guid = #A08A88CF58EB9F7F00000082C38D416C, lineVersion = 0, maxLength = 30, text = \"Invert Camera Up/Down\""
				myDescription "contextComment = \"Description for Options setting for flipping the direction of right stick camera controls\", description = \"ui-options-gameplay-invertrightvertical-description\", enabled = true, guid = #9E6AFEDA5B3BCEF600002254FB549D0E, lineVersion = 0, maxLength = 342, text = '[By default, tilting <gameaction src=\"LookUp\"> forward will look up and steer your ship upward.\n \nChoose \"Always Inverted\" to reverse this direction, or \"Inverted in Flight\" to reverse it only when flying in the air or in space, not when hovering on the ground.] '"
				myAvailableOnXboxOne FALSE
				myAvailableOnPS4 FALSE
				myAvailableOnNintendoSwitch FALSE
				myAvailableOnPC TRUE
				myTriBoolOption InvertAimControl
				myFalseText "contextComment = \"[PLACEHOLDER - do not translate].\nDefault camera inversion option: pressing forward on the right stick looks up, and pulling back on the stick looks down\", description = \"ui-options-gameplay-invertrightvertical-never\", enabled = true, guid = #A08A88CF58ECDC5C00008BB87E4EBA90, lineVersion = 0, maxLength = 30, text = \"Never Invert\""
				myMaybeText "contextComment = \"[PLACEHOLDER - do not translate]\nAlternate camera inversion option: when flying in the air or in space, pressing forward on the right stick looks down, and pulling back on the stick looks up (like a flight yoke), but the opposite is used on the ground.\", description = \"ui-options-gameplay-invertrightvertical-maybe\", enabled = true, guid = #A08A88CF58ECDC6A00008BB96D54CA03, lineVersion = 0, maxLength = 30, text = \"Inverted In Flight\""
				myTrueText "contextComment = \"PLACEHOLDER - do not translate]\nAlternate camera inversion option: pressing forward on the right stick looks down, and pulling back on the stick looks up (like a flight yoke), both on ground and in air/space flight\", description = \"ui-options-gameplay-invertrightvertical-true\", enabled = true, guid = #A08A88CF58ECDC7B00008BBA08F097E9, lineVersion = 0, maxLength = 30, text = \"Always Inverted\""
			}
			RangeMenuItem "Camera Sensitivity" < uid=E22BA6D759F0F2B4000000382A54D268 >
			{
				myName "contextComment = \"\", description = \"\", enabled = true, guid = #E22BA6D759F0F2B40000003A535F3B72, lineVersion = 0, maxLength = 23, text = \"Camera Sensitivity\""
				myDescription "contextComment = \"Description for Options setting for camera sensitivity. Increasing the slider value scales up the camera's rotation speeds. Slower speeds help players aim more precisely/avoid disorienting themselves with quick turns, while higher speeds help players look around quickly.\", description = \"ui-options-gameplay-camerasensitivity-description\", enabled = true, guid = #9E6AFEDA5B3BCEE80000224493D2DA45, lineVersion = 0, maxLength = 126, text = '[Choose how quickly your camera should turn when you look around with <gameaction src=\"LookUp\">.]'}"
				myAvailableOnXboxOne FALSE
				myAvailableOnPS4 FALSE
				myAvailableOnNintendoSwitch FALSE
				myAvailableOnPC TRUE
				myMinRange 0.0
				myMaxRange 100.0
				myStep 5.0
			}
			RangeMenuItem "Left Stick Horizontal Sensitivity" < uid=A08A88CF58EBA1F0000000B533B59AA7 >
			{
				myName "contextComment = \"[PLACEHOLDER - do not translate].\nAllows the player to adjust the horizontal sensitivity of their thumbstick.\", description = \"ui-options-gameplay-leftstick-horizontalsensitivity\", enabled = true, guid = #A08A88CF58EBA155000000A30E4C971B, lineVersion = 0, maxLength = 46, text = \"Left Stick - Horizontal Sensitivity\""
				myDescription "contextComment = \"Description for Options setting for left stick (ship movement) horizontal sensitivity.\nReducing this value below the default makes the deadzones larger, so the game ignores small deviations left & right, helpful for players with less fine motor control, or old gamepads with biased sticks.\nIncreasing this value above the default makes the plateau zone tighter, so stick input ramps up from zero to max over a narrower angle, useful for players with reduced range of motion.\", description = \"ui-options-gameplay-leftstick-horizontalsensitivity-description\", enabled = true, guid = #9E6AFEDA5B3BCEE50000224231ACF663, lineVersion = 0, maxLength = 343, text = '[Choose how sharply the ship should react as you tilt <gameaction src=\"PushRight\"> left & right.\n\nReduce this if you find your steering drifts or wobbles accidentally, or increase it to reach maximum steering input with less <gameaction src=\"PushRight\"> movement.]'"
				myAvailableOnXboxOne FALSE
				myAvailableOnPS4 FALSE
				myAvailableOnNintendoSwitch FALSE
				myAvailableOnPC TRUE
				myFloatOption LeftHorizontalSensitivity
				myMinRange 0.0
				myMaxRange 100.0
				myStep 5.0
			}
			RangeMenuItem "Left Stick Vertical Sensitivity" < uid=A08A88CF58EBA1F0000000B676E2D012 >
			{
				myName "contextComment = \"[PLACEHOLDER - do not translate].\nAllows the player to adjust the vertical sensitivity of their thumbstick.\", description = \"ui-options-gameplay-leftstick-verticalsensitivity\", enabled = true, guid = #A08A88CF58EBA195000000AA4C09532D, lineVersion = 0, maxLength = 43, text = \"Left Stick - Vertical Sensitivity\""
				myDescription "contextComment = \"Description for Options setting for left stick (ship movement) vertical sensitivity.\nReducing this value below the default makes the deadzones larger, so the game ignores small deviations forward & back, helpful for players with less fine motor control, or old gamepads with biased sticks.\nIncreasing this value above the default makes the plateau zone tighter, so stick input ramps up from zero to max over a narrower angle, useful for players with reduced range of motion.\", description = \"ui-options-gameplay-leftstick-verticalsensitivity-description\", enabled = true, guid = #9E6AFEDA5B3BD7FE0000226ED35F9867, lineVersion = 0, maxLength = 338, text = '[Choose how sharply the ship should react as you tilt <gameaction src=\"PushRight\"> up & down.\n\nReduce this if you find your steering drifts or wobbles accidentally, or increase it to reach maximum driving input with less <gameaction src=\"PushRight\"> movement.]'"
				myAvailableOnXboxOne FALSE
				myAvailableOnPS4 FALSE
				myAvailableOnNintendoSwitch FALSE
				myAvailableOnPC TRUE
				myFloatOption LeftVerticalSensitivity
				myMinRange 0.0
				myMaxRange 100.0
				myMaxRemap 1.0
				myStep 5.0
			}
			RangeMenuItem "Right Stick Horizontal Sensitivity" < uid=A08A88CF58EBA1F0000000B77289A423 >
			{
				myName "contextComment = \"[PLACEHOLDER - do not translate].\nAllows the player to adjust the horizontal sensitivity of their thumbstick.\", description = \"ui-options-gameplay-rightstick-horizontalsensitivity\", enabled = true, guid = #A08A88CF58EBA1C9000000AF93DC3908, lineVersion = 0, maxLength = 47, text = \"Right Stick - Horizontal Sensitivity\""
				myDescription "contextComment = \"Description for Options setting for right stick (camera) horizontal sensitivity.\nReducing this value below the default makes the deadzones larger, so the game ignores small deviations left & right, helpful for players with less fine motor control, or old gamepads with biased sticks.\nIncreasing this value above the default makes the plateau zone tighter, so stick input ramps up from zero to max over a narrower angle, useful for players with reduced range of motion.\", description = \"ui-options-gameplay-rightstick-horizontalsensitivity-description\", enabled = true, guid = #9E6AFEDA5B3BCEE1000022404223AC11, lineVersion = 0, maxLength = 330, text = '[Choose how sharply the camera should react as you tilt <gameaction src=\"LookUp\"> left & right.\n\nReduce this if you find your view drifts or wobbles accidentally, or increase it to reach maximum camera input with less <gameaction src=\"LookUp\"> movement.]'"
				myAvailableOnXboxOne FALSE
				myAvailableOnPS4 FALSE
				myAvailableOnNintendoSwitch FALSE
				myAvailableOnPC TRUE
				myFloatOption RightHorizontalSensitivity
				myMinRange 0.0
				myMaxRange 100.0
				myStep 5.0
			}
			RangeMenuItem "Right Stick Vertical Sensitivity" < uid=A08A88CF58EBA1F0000000B8E4D10898 >
			{
				myName "contextComment = \"[PLACEHOLDER - do not translate].\nAllows the player to adjust the vertical sensitivity of their thumbstick.\", description = \"ui-options-gameplay-rightstick-verticalsensitivity\", enabled = true, guid = #A08A88CF58EBA1E5000000B4C42A5C86, lineVersion = 0, maxLength = 44, text = \"Right Stick - Vertical Sensitivity\""
				myDescription "contextComment = \"Description for Options setting for right stick (camera) vertical sensitivity.\nReducing this value below the default makes the deadzones larger, so the game ignores small deviations forward & back, helpful for players with less fine motor control, or old gamepads with biased sticks.\nIncreasing this value above the default makes the plateau zone tighter, so stick input ramps up from zero to max over a narrower angle, useful for players with reduced range of motion.\", description = \"ui-options-gameplay-rightstick-verticalsensitivity-description\", enabled = true, guid = #9E6AFEDA5B3BD85F00002274DE49A30A, lineVersion = 0, maxLength = 326, text = '[Choose how sharply the camera should react as you tilt <gameaction src=\"LookUp\"> up & down.\n\nReduce this if you find your view drifts or wobbles accidentally, or increase it to reach maximum camera input with less <gameaction src=\"LookUp\"> movement.]'"
				myAvailableOnXboxOne FALSE
				myAvailableOnPS4 FALSE
				myAvailableOnNintendoSwitch FALSE
				myAvailableOnPC TRUE
				myFloatOption RightVerticalSensitivity
				myMinRange 0.0
				myMaxRange 100.0
				myStep 5.0
			}
			ActionMenuItem "Exit Co-op" < uid=A1CDB8165C36D42D000F462056D6DF8D >
			{
				myName "contextComment = \"\", description = \"ui-options-controller-exit-coop\", enabled = true, guid = #A1CDB8165C36D403000F3C4753B0C360, lineVersion = 0, maxLength = 16, text = \"Exit Co-op\""
				myAvailableOnXboxOne FALSE
				myAvailableOnPS4 FALSE
				myAvailableOnNintendoSwitch FALSE
				myAvailableOnPC FALSE
				myIsPlayerOption FALSE
				myAvailableOnDigitalSKU FALSE
			}
			RangeMenuItem "Ls Vertical Deadzone" < uid=A1CDB8165C407B1B0007C243B00371C2 >
			{
				myName "contextComment = \"Allows the player to adjust the vertical deadzone of their thumbstick.\", description = \"ui-options-controller-leftstick-verticaldeadzone\", enabled = true, guid = #A1CDB8165C40780500074F2C0AEF6193, lineVersion = 0, maxLength = 62, text = '[<gameaction src=\"PushRight\"> Vertical Deadzone]'"
				myDescription "contextComment = \"Description for Options setting for left stick (ship movement) horizontal sensitivity.\nReducing this value below the default makes the deadzones larger, so the game ignores small deviations left & right, helpful for players with less fine motor control, or old gamepads with biased sticks.\nIncreasing this value above the default makes the plateau zone tighter, so stick input ramps up from zero to max over a narrower angle, useful for players with reduced range of motion.\", description = \"ui-options-controller-leftstick-verticaldeadzone-description\", enabled = false, guid = #A1CDB8165C40780500074F2E6F3B2530, lineVersion = 0, maxLength = 343, text = '[Choose how sharply the ship should react as you tilt <gameaction src=\"PushRight\"> left & right.\n\nReduce this if you find your steering drifts or wobbles accidentally, or increase it to reach maximum steering input with less <gameaction src=\"PushRight\"> movement.]'"
				myAvailableOnXboxOne FALSE
				myAvailableOnPS4 FALSE
				myAvailableOnNintendoSwitch FALSE
				myAvailableOnPC FALSE
				myIsPlayerOption FALSE
				myAvailableOnDigitalSKU FALSE
				myFloatOption UI_ScaleHUD
			}
			RangeMenuItem "Ls Horizontal Deadzone" < uid=A1CDB8165C407B1B0007C244CEE09C0A >
			{
				myName "contextComment = \"Allows the player to adjust the horizontal deadzone of their thumbstick.\", description = \"ui-options-controller-leftstick-horizontaldeadzone\", enabled = true, guid = #A1CDB8165C40798C000789EE539A4670, lineVersion = 0, maxLength = 65, text = '[<gameaction src=\"PushRight\"> Horizontal Deadzone]'"
				myDescription "contextComment = \"\", description = \"\", enabled = false, guid = #A1CDB8165C40798C000789F04EB4C25A, lineVersion = 0, maxLength = 1, text = \"|empty|\""
				myAvailableOnXboxOne FALSE
				myAvailableOnPS4 FALSE
				myAvailableOnNintendoSwitch FALSE
				myAvailableOnPC FALSE
				myIsPlayerOption FALSE
				myAvailableOnDigitalSKU FALSE
				myFloatOption Audio_SFXVolume
			}
			RangeMenuItem "Rs Vertical Deadzone" < uid=A1CDB8165C407B1B0007C245F0837877 >
			{
				myName "contextComment = \"Allows the player to adjust the vertical deadzone of their thumbstick.\", description = \"ui-options-controller-rightstick-verticaldeadzone\", enabled = true, guid = #A1CDB8165C407A1000079C6E9650DDA4, lineVersion = 0, maxLength = 58, text = '[<gameaction src=\"LookUp\"> Vertical Deadzone]'"
				myAvailableOnXboxOne FALSE
				myAvailableOnPS4 FALSE
				myAvailableOnNintendoSwitch FALSE
				myAvailableOnPC FALSE
				myIsPlayerOption FALSE
				myFloatOption Audio_SpeechVolume
			}
			NamedIntegerMenuItem "Rs Horizontal Deadzone" < uid=A1CDB8165C407B1B0007C2461ACFE37F >
			{
				myName "contextComment = \"Allows the player to adjust the horizontal deadzone of their thumbstick.\", description = \"ui-options-controller-rightstick-horizontaldeadzone\", enabled = true, guid = #A1CDB8165C407A960007AF625068D778, lineVersion = 0, maxLength = 60, text = '[<gameaction src=\"LookUp\">Horizontal Deadzone]'"
				myAvailableOnXboxOne FALSE
				myAvailableOnPS4 FALSE
				myAvailableOnNintendoSwitch FALSE
				myAvailableOnPC FALSE
				myIsPlayerOption FALSE
				myAvailableOnDigitalSKU FALSE
				myIntegerOption Graphics_AAQuality
			}
		}
	}
	UIOptionMenuDescription "Visual Menu" < uid=A08A88CF58EB9CF10000004D10790ABA >
	{
		myOption Visual
		myTitle "contextComment = \"[PLACEHOLDER - do not translate].\nMenu option dealing with visual changes (ex: enabling/disabling HUD elements).\", description = \"ui-options-visual\", enabled = true, guid = #A08A88CF58EB9D080000005FAE2B616E, lineVersion = 0, maxLength = 10, text = \"Visual\""
		myMenuItems
		{
			ActionMenuItem "Adjust Screen Gamma" < uid=A08A88CF5953F4030001F11A6C7DD3DA >
			{
				myName "contextComment = \"[PLACEHOLDER - do not translate].\", description = \"ui-options-visual-adjust-gamma\", enabled = true, guid = #A08A88CF5953F3F00001EAA0598886B1, lineVersion = 0, maxLength = 16, text = \"Adjust Gamma\""
				myDescription "contextComment = \"Description for Options menu entry where players can press [A] to enter the gamma calibration screen, adjusting the brightness correction curve so colours look right on their screen.\", description = \"ui-options-visual-adjust-gamma-description\", enabled = true, guid = #9E6AFEDA5B3BDB9B00002298C94F2487, lineVersion = 0, maxLength = 127, text = \"[Adjust the brightness & darkness of colors to look best for your display and viewing conditions.]\""
				myIsRestrictedToPrimaryPlayer TRUE
				myOptionAction Open_Gamma
			}
			NamedIntegerMenuItem "Colour Scheme" < uid=A08A88CF5B89530C0000220545C99B55 >
			{
				myName "contextComment = \"The name of the option that allows playesr to control the colour scheme of some of their more important items. (Colourblindness options)\", description = \"ui-options-visual-colourscheme\", enabled = true, guid = #A08A88CF5B8952E8000021FEE82C86E3, lineVersion = 0, maxLength = 16, text = \"Color Scheme\""
				myDescription "contextComment = \"Description for the colour blind/colour scheme menu option. After the description, a number of icons in the relevant colour swap will be displayed to the player.\", description = \"ui-options-visual-colourscheme-description\", enabled = true, guid = #A08A88CF5B8952E8000022003E97E12E, lineVersion = 0, maxLength = 173, text = \"This option lets you choose the colors that look best for you! \nHere's what some of the icons will look like with the selected color:\"}"
				myIsRestrictedToPrimaryPlayer TRUE
				myIntegerOption ColourScheme
				myEntries
				{
					NamedIntegerEntry Default
					{
						myText "contextComment = \"This is the default colour option.\", description = \"ui-options-visual-colourscheme-default\", enabled = true, guid = #A08A88CF5B89534C0000220789D90741, lineVersion = 0, maxLength = 11, text = \"Default\""
					}
					NamedIntegerEntry "Protanomaly / Abnormal Red"
					{
						myValue 2
						myText "contextComment = \"This colour scheme is designed to support people with protanomaly-type colourblindness. It makes the effort to separate red, orange, and yellow from green.\", description = \"ui-options-visual-colourscheme-protanomaly\", enabled = true, guid = #A08A88CF5B8953E00000220FC567B299, lineVersion = 0, maxLength = 14, text = \"Protanomaly\""
					}
					NamedIntegerEntry "Deuteranomaly / Abnormal Green"
					{
						myValue 1
						myText "contextComment = \"This colour scheme is designed to support people with deuteranomaly-type colourblindness. It makes the effort to distinguish yellows and greens from red, as well as to separate blues and violets.\", description = \"ui-options-visual-colourscheme-deuteranomaly\", enabled = true, guid = #A08A88CF5B8953B80000220B4B889B9B, lineVersion = 0, maxLength = 17, text = \"Deuteranomaly\""
					}
					NamedIntegerEntry "Tritanomaly / Abnormal Blue"
					{
						myValue 6
						myText "contextComment = \"This colour scheme is designed to support people with tritanomaly-type colourblindness. It attempts to separate blue from green and yellow from red/pink.\", description = \"ui-options-visual-colourscheme-tritanomaly\", enabled = true, guid = #A08A88CF5B89541100002219B6B90FB7, lineVersion = 0, maxLength = 14, text = \"Tritanomaly\""
					}
					NamedIntegerEntry "Protanopia / Absent Red"
					{
						myValue 3
						myText "contextComment = \"This colour scheme is designed to support people with protanopia-type colourblindness. It avoids the use of red and makes the effort to separate orange and green from yellow. \", description = \"ui-options-visual-colourscheme-protanopia\", enabled = true, guid = #A08A88CF5B8953F300002213CD35C824, lineVersion = 0, maxLength = 16, text = \"Protanopia\""
					}
					NamedIntegerEntry "Deuteranopia / Absent Green"
					{
						myValue 4
						myText "contextComment = \"This colour scheme is designed to support people with deuteranopia-type colourblindness. Reds and greens are distinguished from yellow.\", description = \"ui-options-visual-colourscheme-deuteranopia\", enabled = true, guid = #A08A88CF5B89540100002215B7370E50, lineVersion = 0, maxLength = 16, text = \"Deuteranopia\""
					}
					NamedIntegerEntry "Tritanopia / Absent Blue"
					{
						myValue 5
						myText "contextComment = \"This colour scheme is designed to support people with tritanopia-type colourblindness. It separates blue from green and yellow from purple.\", description = \"ui-options-visual-colourscheme-tritanopia\", enabled = true, guid = #A08A88CF5B8954100000221713E2C843, lineVersion = 0, maxLength = 16, text = \"Tritanopia\""
					}
				}
			}
			BooleanMenuItem "HUD - Disable All" < uid=A08A88CF58EBAABE0000013272007DD5 >
			{
				myName "contextComment = \"[PLACEHOLDER - do not translate].\nOption that disables the entire HUD. \", description = \"ui-options-visual-disableall\", enabled = true, guid = #A08A88CF58EBAA9F0000012F38D2DB82, lineVersion = 0, maxLength = 18, text = \"Enable All HUD\""
				myDescription "contextComment = \"Description for Options setting for enabling/disabling all heads-up display elements (tutorials / subtitles not included). Turning this off helps capture UI-free vistas and videos, but it's difficult to play without your reticle, interaction prompts, and mission reminders\", description = \"ui-options-visual-disableall-description\", enabled = true, guid = #9E6AFEDA5B3BDBE30000229C9BCD195C, lineVersion = 0, maxLength = 220, text = '[Choose whether to show Heads-Up Display information.\n\nIt is best to keep this \"On\" for normal piloting; turning HUD \"Off\" can help when capturing screenshots or video.]'}"
				myBooleanOption UI_EnableHUD
			}
			BooleanMenuItem "HUD - Display Minimap" < uid=A08A88CF58EBA396000000D983F05FAB >
			{
				myName "contextComment = \"[PLACEHOLDER - do not translate].\nAllows the player to choose when to display the minimap.\", description = \"ui-options-visual-displayminimap\", enabled = true, guid = #A08A88CF58EBA33A000000CDB8CD40CE, lineVersion = 0, maxLength = 20, text = \"Display Minimap\""
				myDescription "contextComment = \"Description for Options setting for toggling display of the minimap/radar\", description = \"ui-options-visual-displayminimap-description\", enabled = true, guid = #9E6AFEDA5B3BDCAA000022A0BE60179C, lineVersion = 0, maxLength = 131, text = \"[Choose whether to show a map of nearby landmarks and units in the lower-right corner of the screen.]\""
				myBooleanOption UI_DisplayMinimap
			}
			TriBoolMenuItem "HUD - Display Pilot PiP" < uid=A08A88CF58EBA452000000E2831AB306 >
			{
				myName "contextComment = \"[PLACEHOLDER - do not translate].\nAllows the player to see the pilot pip always, in conversations only, and never.\", description = \"ui-options-visual-displaypilot\", enabled = true, guid = #A08A88CF58EBA427000000DF74BD9668, lineVersion = 0, maxLength = 17, text = \"Display Pilot\""
				myDescription "contextComment = \"Description for Options setting for toggling the display of the pilot picture-in-picture video in the HUD.\", description = \"ui-options-visual-displaypilot-description\", enabled = true, guid = #9E6AFEDA5B3BDCDF000022A40F411989, lineVersion = 0, maxLength = 198, text = \"[Choose when to show your current pilot in the lower-left corner of the screen: at all times, only when talking with other characters, or never at all.]\""
				myTriBoolOption UI_DisplayPilotPiP
				myFalseText "contextComment = \"[PLACEHOLDER - do not translate].\", description = \"ui-options-visual-displaypilot-false\", enabled = true, guid = #A08A88CF58ECDE3B00008BEE4E31B0A5, lineVersion = 0, maxLength = 8, text = \"Never\""
				myMaybeText "contextComment = \"[PLACEHOLDER - do not translate].\", description = \"ui-options-visual-displaypilot-maybe\", enabled = true, guid = #A08A88CF58ECDE3E00008BEF6AB3C43E, lineVersion = 0, maxLength = 26, text = \"During Conversations\""
				myTrueText "contextComment = \"[PLACEHOLDER - do not translate].\", description = \"ui-options-visual-displaypilot-true\", enabled = true, guid = #A08A88CF58ECDE4000008BF00A4F6C45, lineVersion = 0, maxLength = 10, text = \"Always\""
			}
			TriBoolMenuItem "HUD - Display Currency Mode" < uid=9E6AFEDA59E936140000018EB1B517E6 >
			{
				myName "contextComment = \"[PLACEHOLDER - do not translate].\nUI Option heading - controls whether Electrum & Nova wallet is shown in the HUD { Never / Briefly when collecting / Always }\", description = \"ui-options-visual-displaycurrencymode\", enabled = true, guid = #9E6AFEDA59E934E50000017F5252AB1B, lineVersion = 0, maxLength = 30, text = \"Display Electrum & Nova\""
				myDescription "contextComment = \"Description for Options setting for toggling display of the player's currency wallet in the HUD.\", description = \"ui-options-visual-displaycurrencymode-description\", enabled = true, guid = #9E6AFEDA5B3BDD1B000022A892868202, lineVersion = 0, maxLength = 217, text = \"[Choose when to show your current Electrum and Nova stock in the top-left corner of the screen: at all times, only when collecting Electrum and Nova, or never at all.]\"}"
				myIsRestrictedToPrimaryPlayer TRUE
				myTriBoolOption UI_DisplayCurrencyMode
				myFalseText "contextComment = \"[PLACEHOLDER - do not translate].\nUI Option setting to hide Electrum & Nova wallet in the HUD\", description = \"ui-options-visual-displaycurrencymode-false\", enabled = true, guid = #9E6AFEDA59E934E500000181A708D5F3, lineVersion = 0, maxLength = 30, text = \"Never\""
				myMaybeText "contextComment = \"[PLACEHOLDER - do not translate].\nUI Option setting to show Electrum & Nova wallet in the HUD for a few seconds after collecting currency, then hide it again\", description = \"ui-options-visual-displaycurrencymode-maybe\", enabled = true, guid = #9E6AFEDA59E934E500000183D2BC5654, lineVersion = 0, maxLength = 30, text = \"When Collecting\""
				myTrueText "contextComment = \"[PLACEHOLDER - do not translate].\nUI Option setting to show Electrum & Nova wallet in the HUD at all times\", description = \"ui-options-visual-displaycurrencymode-true\", enabled = true, guid = #9E6AFEDA59E934E50000018592B64EB0, lineVersion = 0, maxLength = 30, text = \"Always\""
			}
			BooleanMenuItem "HUD - Navigation Prompts" < uid=A08A88CF58EBA4E8000000F11B52609B >
			{
				myName "contextComment = \"[PLACEHOLDER - do not translate].\nAllows the player to toggle navigational prompts (ex: flight, hyper drive) on and off.\", description = \"ui-options-visual-navigationprompts\", enabled = true, guid = #A08A88CF58EBA4C6000000ED3536B080, lineVersion = 1, maxLength = 43, text = \"[Display Flight & Towing Prompts]\""
				myDescription "contextComment = 'Description for Options setting for toggling display of \"Take Off\" \"Cut Engine\" \"Hyperdrive\" \"Stop Hyperdrive\" \"Throw\" and \"Drop\" button prompts along the bottom of the screen', description = \"ui-options-visual-navigationprompts-description\", enabled = true, guid = #9E6AFEDA5B3BDD67000022ACE4C235A7, lineVersion = 0, maxLength = 125, text = \"[Choose whether to show button prompts for flight, hyperdrive, throwing & dropping towed items.]\""
				myBooleanOption UI_DisplayNavigationPrompts
			}
			BooleanMenuItem "HUD - Contextual Prompts" < uid=A08A88CF58EBAA3F0000012DAD1A699F >
			{
				myName "contextComment = \"[PLACEHOLDER - do not translate].\nAllows the player to toggle contextual interaction prompts (ex: hack, hail).\", description = \"ui-options-visual-interactionprompts\", enabled = true, guid = #A08A88CF58EBAA1E0000012C33069901, lineVersion = 0, maxLength = 35, text = \"Display Interaction Prompts\""
				myDescription "contextComment = \"Description for Options setting for toggling display of contextural interaction prompts like picking up/towing items, plucking fruit or prying open doors, scanning, or otherwise activating objects.\", description = \"ui-options-visual-interactionprompts-description\", enabled = true, guid = #9E6AFEDA5B3BDDCC000022B0C36A435F, lineVersion = 0, maxLength = 139, text = \"[Choose whether to show button prompts for picking up, plucking, scanning, and using objects in the world.]\""
				myBooleanOption UI_DisplayContextualPrompts
			}
			TriBoolMenuItem "HUD - Fly Information" < uid=A08A88CF5BC73AA7002D932C6CF73FA0 >
			{
				myName "contextComment = \"The name of the option that allows the player to toggle and manage fly combat information.\", description = \"ui-options-visual-combatinfo\", enabled = true, guid = #A08A88CF5BC739B1001CF2F139391393, lineVersion = 0, maxLength = 25, text = \"Display Combat Info\""
				myDescription "contextComment = \"A description of the features that the 'Display Combat Info' option toggles. \", description = \"ui-options-visual-combatinfo-description\", enabled = true, guid = #A08A88CF5BC739B1001CF2F3EC05A772, lineVersion = 0, maxLength = 239, text = \"Choose whether to show on-screen combat information, such as fly damage text, status effect combos, and critical hits. Minimal only shows status effect combos and critical damage text.\""
				myIsSlotSpecific TRUE
				myTriBoolOption UI_DisplayFlyInfo
				myFalseText "contextComment = \"This option indicates that the player will see all combat HUD information.\", description = \"ui-options-visual-combatinfo-false\", enabled = true, guid = #A08A88CF5BC739B1001CF2F5C4BAB8C4, lineVersion = 0, maxLength = 5, text = \"All\""
				myMaybeText "contextComment = \"This option allows players to see a reduced number of on-screen fly informations during combat. \", description = \"ui-options-visual-combatinfo-maybe\", enabled = true, guid = #A08A88CF5BC739B1001CF2F7E3EFC36E, lineVersion = 0, maxLength = 11, text = \"Minimal\""
				myTrueText "contextComment = \"This option turns off all combat fly info.\", description = \"ui-options-visual-combatinfo-true\", enabled = true, guid = #A08A88CF5BC739B1001CF2F9B3AEDAEE, lineVersion = 0, maxLength = 6, text = \"None\""
			}
			BooleanMenuItem "HUD - Frame Elements" < uid=A08A88CF58EBA8CA0000011E4303FB17 >
			{
				myName "contextComment = \"[PLACEHOLDER - do not translate].\nAllows the player to toggle framing elements.\", description = \"ui-options-visual-displayframeelements\", enabled = true, guid = #A08A88CF58EBA8B80000011CB4FD9942, lineVersion = 0, maxLength = 22, text = \"Display HUD Frame\""
				myDescription "contextComment = \"Description for Options setting for toggling display of decorative borders on the sides of the screen\", description = \"ui-options-visual-displayframeelements-description\", enabled = true, guid = #9E6AFEDA5B3BDDFA000022B4444766CE, lineVersion = 0, maxLength = 100, text = \"[Choose whether to show borders at the sides of the ship's Heads-Up Display.]\"}"
				myBooleanOption UI_DisplayHUDFrame
			}
		}
	}
