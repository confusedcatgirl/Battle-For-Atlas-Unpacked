	myUpsellFirstLinkDescription "contextComment = \"A suggestion to buy the given toy, either physically or digitally. This message is shown if the player has never equipped the part they're seeing the upsell for.\n{0} - The name of the part. \", description = \"ui-menu-upsell-locked-digitalorphysical-orbis\", enabled = true, guid = #A08A88CF5AF1AED0000B5154E940DA68, lineVersion = 0, maxLength = 166, text = \"[Visit your local retailer to add {0} to your collection! \nYou can also visit the Playstation store to purchase a digital copy.]\"}"
