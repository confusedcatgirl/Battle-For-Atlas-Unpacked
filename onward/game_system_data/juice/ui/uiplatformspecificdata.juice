	myUpsellFirstLinkDescription "contextComment = \"A suggestion to buy the given toy, either physically or digitally. This message is shown if the player has never equipped the part they're seeing the upsell for.\n{0} - The name of the part. \", description = \"ui-menu-upsell-locked-digitalorphysical-pc\", enabled = true, guid = #685592F95C3F2F92000003762AF15B92, lineVersion = 0, maxLength = 157, text = \"[Visit your local retailer to add {0} to your collection! \nYou can also visit the Uplay store to purchase a digital copy.]\"}"
	myUpsellRelinkDescription "contextComment = \"If the player has previously acquired/used the toy, this prompt suggests they either relink the physical toy to start the timed unlock again, or to purchase a digital copy.\n{0} - The name of the part.\", description = \"ui-menu-upsell-unlocked-digitalorphysical-pc\", enabled = true, guid = #685592F95C3F2F87000003759AD7B329, lineVersion = 0, maxLength = 133, text = \"[Re-link {0} to play with it digitally!\nYou can also visit the Uplay store to purchase a digital copy.]\""
}

