class LightEffectElement
{
	float myOffset 0.5
	float mySize 0.5
	float myOpacity 0.5
}

list LightEffectElementList
{
	LightEffectElement
}

class LightEffect
{
	file myTexture "" < assettype="Texture" >
	float myMaskRadius 0.0

	LightEffectElementList myElements
}

list LightEffectList
{
	LightEffect
}

class LightEffects
{
	LightEffectList myList
}

