		float4 mul_321 = transform_316 * float4(0, 0, 1, 1);
		float2 lerp_278 = lerp(float2(-0.5, -0.5), float2(0.5, 0.5), Gfx_UV);
		float3 transform_276 = MR_Transform(Gfx_ObjectToWorldMatrix, float3(0, 0, 0));
		float3 sub_302 = MR_ViewConstants.LODCameraPosition - transform_276;
		float length_307 = length(sub_302);
		float sub_384 = length_307 - customData.myStartRange;
		float sub_383 = customData.myEndRange - customData.myStartRange;
		float div_387 = sub_384 / sub_383;
		float saturate_390 = saturate(div_387);
		float lerp_394 = lerp(customData.myMinTestScale, customData.myMaxTestScale, saturate_390);
		float2 smear_400 = float2(lerp_394, lerp_394);
		float2 mul_415 = lerp_278 * smear_400;
		float4 transform_324 = MR_Transform(GetP_51, transform_316);
		float4 combine_281 = float4(float2(1, 1).x, float2(1, 1).y, float(0), float(0));
		float4 lerp_332 = lerp(float4(0, 0, 0, 1), transform_324, combine_281);
		float4 sub_342 = transform_324 - lerp_332;
		float2 combine_357 = float2(sub_342.x, sub_342.y);
		float length_365 = length(combine_357);
		float2 smear_373 = float2(length_365, length_365);
		float2 lerp_378 = lerp(float2(1, 1), smear_373, float2(0, 0));
