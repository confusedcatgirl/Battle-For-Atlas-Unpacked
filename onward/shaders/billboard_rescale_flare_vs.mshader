		float add_311 = transform_275.y + add_308;
		float add_317 = Gfx_Environment.time + add_311;
		float sin_325 = sin(add_317);
		float abs_334 = abs(sin_325);
		float mul_410 = add_409 * abs_334;
		float2 combine_429 = float2(mul_410, mul_410);
		float2 mul_544 = mul_381 * combine_429;
		float2 mul_562 = mul_544 * lerp_278;
		float2 add_580 = mul_415 + mul_562;
		float4 combine_617 = float4(add_580.x, add_580.y, float(0), float(0));
