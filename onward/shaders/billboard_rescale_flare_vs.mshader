		float2 div_546 = combine_513 / smear_514;
		float2 GetDepthbuffer_564 = GetDepthbuffer(div_546);
		float GetDepthbuffer2_582 = GetDepthbuffer2(GetDepthbuffer_564);
		float add_600 = GetDepthbuffer2_582 + mul_399;
		float step_619 = step(transform_479.w, add_600);
		float max_638 = max(step_618, step_619);
		float2 combine_282 = float2(float(-0.5), float(0.5));
		float2 mul_413 = combine_398 * combine_282;
		float4 combine_448 = float4(mul_413.x, mul_413.y, float(0), float(0));
		float4 add_464 = transform_316 + combine_448;
		float4 transform_480 = MR_Transform(GetP_51, add_464);
		float2 combine_515 = float2(transform_480.x, transform_480.y);
		float2 smear_516 = float2(transform_480.w, transform_480.w);
		float2 div_547 = combine_515 / smear_516;
		float2 GetDepthbuffer_565 = GetDepthbuffer(div_547);
		float GetDepthbuffer2_583 = GetDepthbuffer2(GetDepthbuffer_565);
		float add_601 = GetDepthbuffer2_583 + mul_399;
		float step_620 = step(transform_480.w, add_601);
		float2 combine_283 = float2(float(-0.5), float(-0.5));
		float2 mul_414 = combine_398 * combine_283;
		float4 combine_449 = float4(mul_414.x, mul_414.y, float(0), float(0));
		float4 add_465 = transform_316 + combine_449;
		float4 transform_481 = MR_Transform(GetP_51, add_465);
		float2 combine_517 = float2(transform_481.x, transform_481.y);
		float2 smear_518 = float2(transform_481.w, transform_481.w);
		float2 div_548 = combine_517 / smear_518;
		float2 GetDepthbuffer_566 = GetDepthbuffer(div_548);
		float GetDepthbuffer2_584 = GetDepthbuffer2(GetDepthbuffer_566);
		float add_602 = GetDepthbuffer2_584 + mul_399;
		float step_621 = step(transform_481.w, add_602);
		float max_640 = max(step_620, step_621);
		float max_653 = max(max_638, max_640);
		float min_661 = min(mul_376, max_653);
		float4 smear_667 = float4(min_661, min_661, min_661, min_661);
		float4 lerp_673 = lerp(float4(0, 0, 0, 0.1), combine_672, smear_667);
		Gfx_ClipPosition = lerp_673;
