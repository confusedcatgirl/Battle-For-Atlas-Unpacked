	import "shaders/MRender/MR_DepthBuffer.h"
	struct CustomData {
		float myStartRange <default = 0, label = "Start Range", pinId = 118>;
		float myMidRange <default = 0, label = "Mid Range", pinId = 125>;
		float myEndRange <default = 0, label = "End Range", pinId = 119>;
		float myMinScale <default = 0, label = "Min Scale", pinId = 120>;
		float myMidScale <default = 0, label = "Mid Scale", pinId = 124>;
		float myMaxScale <default = 0, label = "Max Scale", pinId = 121>;
		float myMinTestScale <default = 0, label = "Min Test Scale", pinId = 122>;
		float myMaxTestScale <default = 0, label = "Max Test Scale", pinId = 123>;
	};
	float4x4 GetP()
	{
		return MR_ViewConstants.cameraToClip;
	}
	void OW_SFT_AFL(inout float3 aPosition)
	{
		OW_SFT_ApplyOld(aPosition);
	}
	float2 GetDepthbuffer(float2 aClipPos)
	{
		return MR_ClipToFramebufferUV (aClipPos);
	}
	float GetDepthbuffer2(float2 aUV)
	{
		return MR_SampleLod0(Depthbuffer, aUV).x;
	}
	void ClipSpaceModifier(inout float4 Gfx_ClipPosition : Gfx_ClipPosition, 
		CustomData customData : Gfx_CustomData0, float2 Gfx_UV : Gfx_UV0, 
		float3x4 Gfx_ObjectToWorldMatrix : Gfx_ObjectToWorldMatrix0)
	{
		float4x4 GetP_51 = GetP();
		float3 transform_275 = MR_Transform(Gfx_ObjectToWorldMatrix, float3(0, 0, 0));
