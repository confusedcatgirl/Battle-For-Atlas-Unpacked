		float remap_385 = float(0) + saturate((length_307 - customData.myStartRange) / (customData.myMidRange - customData.myStartRange)) * (float(1) - float(0));
		float saturate_388 = saturate(remap_385);
		float sub_392 = float(1) - saturate_388;
		float mul_396 = customData.myMinScale * sub_392;
		float remap_386 = float(0) + saturate((length_307 - customData.myEndRange) / (customData.myMidRange - customData.myEndRange)) * (float(1) - float(0));
		float saturate_389 = saturate(remap_386);
		float mul_391 = saturate_388 * saturate_389;
		float mul_395 = customData.myMidScale * mul_391;
		float add_408 = mul_396 + mul_395;
		float sub_393 = float(1) - saturate_389;
		float mul_397 = sub_393 * customData.myMaxScale;
		float add_409 = add_408 + mul_397;
		float mul_303 = transform_275.x * float(1.35);
		float mul_304 = transform_275.z * float(2.57);
