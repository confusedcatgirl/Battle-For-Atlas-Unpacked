		float2 smear_512 = float2(transform_478.w, transform_478.w);
		float2 div_545 = combine_511 / smear_512;
		float2 GetDepthbuffer_563 = GetDepthbuffer(div_545);
		float GetDepthbuffer2_581 = GetDepthbuffer2(GetDepthbuffer_563);
		float mul_399 = lerp_394 * float(0.8);
