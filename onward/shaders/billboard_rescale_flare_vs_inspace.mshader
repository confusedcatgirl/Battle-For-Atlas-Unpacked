		float2 GetDepthbuffer_572 = GetDepthbuffer(div_554);
		float GetDepthbuffer2_590 = GetDepthbuffer2(GetDepthbuffer_572);
		float add_608 = GetDepthbuffer2_590 + mul_404;
		float step_627 = step(transform_487.w, add_608);
		float max_644 = max(step_626, step_627);
		float2 combine_293 = float2(float(-0.5), float(0.5));
		float2 mul_422 = combine_403 * combine_293;
		float4 combine_456 = float4(mul_422.x, mul_422.y, float(0), float(0));
		float4 add_472 = transform_309 + combine_456;
		float4 transform_488 = MR_Transform(GetP_124, add_472);
		float2 combine_531 = float2(transform_488.x, transform_488.y);
		float2 smear_532 = float2(transform_488.w, transform_488.w);
		float2 div_555 = combine_531 / smear_532;
		float2 GetDepthbuffer_573 = GetDepthbuffer(div_555);
		float GetDepthbuffer2_591 = GetDepthbuffer2(GetDepthbuffer_573);
		float add_609 = GetDepthbuffer2_591 + mul_404;
		float step_628 = step(transform_488.w, add_609);
		float2 combine_294 = float2(float(-0.5), float(-0.5));
		float2 mul_423 = combine_403 * combine_294;
		float4 combine_457 = float4(mul_423.x, mul_423.y, float(0), float(0));
		float4 add_473 = transform_309 + combine_457;
		float4 transform_489 = MR_Transform(GetP_124, add_473);
		float2 combine_533 = float2(transform_489.x, transform_489.y);
		float2 smear_534 = float2(transform_489.w, transform_489.w);
		float2 div_556 = combine_533 / smear_534;
		float2 GetDepthbuffer_574 = GetDepthbuffer(div_556);
		float GetDepthbuffer2_592 = GetDepthbuffer2(GetDepthbuffer_574);
		float add_610 = GetDepthbuffer2_592 + mul_404;
		float step_629 = step(transform_489.w, add_610);
		float max_646 = max(step_628, step_629);
		float max_656 = max(max_644, max_646);
		float min_663 = min(mul_367, max_656);
		float4 smear_669 = float4(min_663, min_663, min_663, min_663);
		float4 lerp_671 = lerp(float4(0, 0, 0, 0.1), combine_665, smear_669);
		Gfx_ClipPosition = lerp_671;
	}
	void UV0Modifier(inout float2 Gfx_UV0 : Gfx_UV0, float2 Gfx_UV : Gfx_UV0)
	{
