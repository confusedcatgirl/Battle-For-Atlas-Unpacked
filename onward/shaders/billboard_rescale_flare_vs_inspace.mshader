		float3 transform_276 = MR_Transform(Gfx_ObjectToWorldMatrix, float3(0, 0, 0));
		float3 sub_302 = MR_ViewConstants.LODCameraPosition - transform_276;
		float length_307 = length(sub_302);
		float sub_384 = length_307 - customData.myStartRange;
		float sub_383 = customData.myEndRange - customData.myStartRange;
		float div_387 = sub_384 / sub_383;
		float saturate_390 = saturate(div_387);
		float lerp_394 = lerp(customData.myMinTestScale, customData.myMaxTestScale, saturate_390);
		float2 smear_405 = float2(lerp_394, lerp_394);
		float2 mul_424 = lerp_289 * smear_405;
		float4 transform_315 = MR_Transform(GetP_124, transform_309);
		float4 combine_292 = float4(float2(1, 1).x, float2(1, 1).y, float(0), float(0));
		float4 lerp_319 = lerp(float4(0, 0, 0, 1), transform_315, combine_292);
		float4 sub_329 = transform_315 - lerp_319;
		float2 combine_346 = float2(sub_329.x, sub_329.y);
		float length_354 = length(combine_346);
		float2 smear_361 = float2(length_354, length_354);
		float2 lerp_369 = lerp(float2(1, 1), smear_361, float2(0, 0));
		float4 sub_328 = float4(0, 0, 0, 1) - lerp_319;
