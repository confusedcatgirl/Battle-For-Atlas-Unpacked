<emission = true, shaderType = "Object", keywords = { "LIGHT_FROM_SPACE", "ISNT_MAIN_PLANET", "GFX_FORWARD_SHADER", }, >
import "shaders/MRender/MR_ViewConstants.h"
import "shaders/nodes/shader/functions/unpack normal.h"
import "shaders/nodes/shader/functions/onward/lighting/ow_fullspacebaselighting.h"
import "shaders/nodes/shader/functions/ow emissive intensity multiplier.h"
import "shaders/nodes/shader/functions/onward/lighting/ow_spacefog.h"
pixel
{
	MR_Sampler2D BaseColor : MR_Texture0 {
		texture = "onward/baked/textures/default_b.dds",
	} <label = "Base Color", pinId = 102>;
	MR_Sampler2D Normal : MR_Texture1 {
		texture = "onward/baked/textures/default_n.dds",
	} <pinId = 103>;
	MR_Sampler2D Material : MR_Texture2 {
		texture = "onward/baked/textures/default_m.dds",
	} <pinId = 104>;
	MR_Sampler2D PackedStatusEffects : MR_Texture3 {
		texture = "onward/baked/textures/FX/fx_status_effects_noise_b.dds",
	} <label = "Packed Status Effects", pinId = 110>;
	MR_Sampler2D GravityAndStasisGradient : MR_Texture4 {
		wrap = clamp clamp repeat,
	} <label = "Gravity And Stasis Gradient", pinId = 132>;
	MR_Sampler2D Texture : MR_Texture5 {
		wrap = clamp,
	} <pinId = 133>;
	MR_Sampler2D Decal : MR_Texture6 {
		wrap = clamp,
	} <pinId = 138>;
	MR_Sampler2D Sampler_199 : MR_Texture7 {
		texture = "onward/baked/textures/plasma_m.dds",
	};
	struct CustomData {
		float4 myEmissive <config = { type = "ColorBox", }, default = 1 1 1 1, label = "Emissive", pinId = 117>;
		float myEmissionIntensity <default = 0, label = "Emission Intensity", pinId = 106>;
		float myDissolve <config = { max = 1, min = 0, type = "Slider", }, default = 0, label = "Dissolve", pinId = 108>;
		float myFreeze <default = 0, label = "Freeze", pinId = 124>;
		float mySunder <default = 0, label = "Sunder", pinId = 125>;
		float myGravityAndStasis <default = 0, label = "Gravity And Stasis ", pinId = 126>;
		float myChill <default = 0, label = "Chill", pinId = 130>;
		float myPackedStatusUVScale <default = 0.5, label = "Packed Status UV Scale", pinId = 131>;
		float myAtmosphereTransition <default = 0, label = "Atmosphere Transition", pinId = 135>;
		float3 myCenter <default = 0 0 0, label = "Center", pinId = 136>;
		float myLength <config = { min = 0.01, }, default = 1, label = "Length", pinId = 137>;
		float4 myMaterial1 <default = 0 0 0 0, label = "Material1", pinId = 139>;
		float4 myMaterial2 <default = 0 0 0 0, label = "Material2", pinId = 140>;
		float4 myMaterial3 <default = 0 0 0 0, label = "Material3", pinId = 141>;
		float4 myMaterial4 <default = 0 0 0 0, label = "Material4", pinId = 142>;
		float4 myRoughness <default = 0 0 0 0, label = "Roughness", pinId = 143>;
		float myDecalEnabled <default = 0, label = "DecalEnabled", pinId = 144>;
		float myIsWing <config = { max = 1, min = 0, type = "CheckBox", }, default = 0, label = "IsWing", pinId = 145>;
		float3 myScaleOffset <default = 1 0 0, label = "ScaleOffset", pinId = 146>;
	};
	float3 SelectColor(in float3 aColorA, in float3 aColorB, in bool aCond)
	{
		return aCond ? aColorA : aColorB;
	}
	main(out float4 colorOut : MR_Color0, float2 Gfx_UV : Gfx_UV0, 
		CustomData customData : Gfx_CustomData0, 
		float3 Gfx_ModelSpaceNormal : Gfx_ModelSpaceNormal0, 
		float3 Gfx_ModelSpacePos : Gfx_ModelSpacePos0, 
		float3 Gfx_FlattenedWorldNormal : Gfx_FlattenedWorldNormal0, 
		float3 Gfx_WorldSpacePos : Gfx_WorldSpacePos0, 
		float3x3 Gfx_TangentToWorld : Gfx_TangentToWorld0, 
		Gfx_LightingDataStruct Gfx_LightingData : Gfx_LightingData0, 
		float4 MR_FragCoord : MR_FragCoord, float Gfx_AlphaRef : Gfx_AlphaRef0)
	{
		float4 sample_367 = MR_Sample(BaseColor, Gfx_UV);
		float3 combine_404 = float3(sample_367.x, sample_367.y, sample_367.z);
		float add_375 = customData.myMaterial3.x + customData.myMaterial3.y;
		float add_376 = add_375 + customData.myMaterial3.z;
		float step_397 = step(float(0.01), add_376);
		float3 normalize_277 = normalize(Gfx_ModelSpaceNormal);
		float lerp_411 = lerp(normalize_277.y, normalize_277.x, customData.myIsWing);
		float abs_422 = abs(lerp_411);
		float sub_429 = abs_422 - float(0.75);
		float saturate_436 = saturate(sub_429);
		float mul_442 = saturate_436 * float(10);
		float saturate_449 = saturate(mul_442);
		float4 smear_456 = float4(saturate_449, saturate_449, saturate_449, saturate_449);
		float clamp_308 = clamp(Gfx_ModelSpacePos.y, float(-2), float(2));
		float remap_312 = float(0) + saturate((clamp_308 - float(-2)) / (float(2) - float(-2))) * (float(0.5) - float(0));
		float clamp_309 = clamp(Gfx_ModelSpacePos.z, float(-3), float(5));
		float remap_313 = float(0) + saturate((clamp_309 - float(-3)) / (float(5) - float(-3))) * (float(1) - float(0));
		float3 combine_314 = float3(remap_312, remap_313, float(0));
		float mul_377 = float(-2) * customData.myScaleOffset.x;
		float mul_378 = float(2) * customData.myScaleOffset.x;
		float remap_393 = float(0) + saturate((Gfx_ModelSpacePos.x - mul_377) / (mul_378 - mul_377)) * (float(0.5) - float(0));
		float mul_379 = float(-3) * customData.myScaleOffset.x;
		float add_381 = mul_379 + customData.myScaleOffset.y;
		float mul_380 = float(5) * customData.myScaleOffset.x;
		float add_382 = mul_380 + customData.myScaleOffset.y;
		float remap_394 = float(1) + saturate((Gfx_ModelSpacePos.z - add_381) / (add_382 - add_381)) * (float(0) - float(1));
		float3 combine_395 = float3(remap_393, remap_394, float(0));
		float3 lerp_396 = lerp(combine_314, combine_395, float3(1, 1, 1));
		float remap_306 = float(0.5) + saturate((Gfx_ModelSpacePos.y - float(0)) / (float(4) - float(0))) * (float(1) - float(0.5));
		float remap_307 = float(0.5) + saturate((Gfx_ModelSpacePos.z - float(-2)) / (float(2) - float(-2))) * (float(1) - float(0.5));
		float3 combine_310 = float3(remap_306, remap_307, float(0));
		float3 smear_364 = float3(customData.myIsWing, customData.myIsWing, customData.myIsWing);
		float3 lerp_410 = lerp(lerp_396, combine_310, smear_364);
		float2 truncate_421 = float2(lerp_410.xy);
		float4 sample_428 = MR_Sample(Decal, truncate_421);
		float4 mul_465 = smear_456 * sample_428;
		float mul_482 = step_397 * mul_465.z;
		float4 smear_488 = float4(mul_482, mul_482, mul_482, mul_482);
		float4 lerp_492 = lerp(customData.myMaterial4, customData.myMaterial3, smear_488);
		float add_373 = customData.myMaterial2.x + customData.myMaterial2.y;
		float add_374 = add_373 + customData.myMaterial2.z;
		float step_398 = step(float(0.01), add_374);
		float mul_481 = step_398 * mul_465.y;
		float4 smear_487 = float4(mul_481, mul_481, mul_481, mul_481);
		float4 lerp_496 = lerp(lerp_492, customData.myMaterial2, smear_487);
		float add_371 = customData.myMaterial1.x + customData.myMaterial1.y;
