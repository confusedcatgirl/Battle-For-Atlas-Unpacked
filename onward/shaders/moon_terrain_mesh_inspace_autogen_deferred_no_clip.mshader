		float2 combine_305 = float2(normalize_273.x, normalize_273.z);
		float GetPlanetRadius_59 = GetPlanetRadius();
		float mul_251 = GetPlanetRadius_59 * float(6.28319);
		float mul_252 = mul_251 * float(0.01);
