pixel
{
	MR_Sampler2D Palette : MR_Texture0 {
		wrap = clamp,
	} <pinId = 129>;
	MR_Sampler2D Texture : MR_Texture1 <pinId = 125>;
	MR_Sampler2D Texture2 : MR_Texture2 <pinId = 126>;
	MR_Sampler2D Texture3 : MR_Texture3 <pinId = 127>;
	main(bool MR_IsFrontFace : MR_IsFrontFace, 
		out Gfx_DeferredData deferredOut : Gfx_Deferred, 
		float3 Gfx_UnflattenedWorldPos : Gfx_UnflattenedWorldPos0, 
		float3 Gfx_WorldSpaceNormal : Gfx_WorldSpaceNormal0, 
		float4 Gfx_Color : Gfx_Color0)
	{
		float2 combine_269 = float2(Gfx_UnflattenedWorldPos.z, Gfx_UnflattenedWorldPos.y);
		float2 mul_282 = combine_269 * float2(0.01, 0.01);
		float4 sample_360 = MR_Sample(Texture3, mul_282);
		float3 abs_249 = abs(Gfx_WorldSpaceNormal);
		float3 combine_266 = float3(float(16.1875), float(16.1875), float(16.1875));
		float3 pow_270 = pow(abs(abs_249), combine_266);
		float3 normalize_283 = normalize(pow_270);
		float add_315 = normalize_283.x + normalize_283.y;
		float add_316 = add_315 + normalize_283.z;
		float3 combine_327 = float3(add_316, add_316, add_316);
		float3 div_334 = normalize_283 / combine_327;
		float mul_386 = sample_360.z * div_334.x;
		float2 combine_267 = float2(Gfx_UnflattenedWorldPos.x, Gfx_UnflattenedWorldPos.z);
		float2 mul_280 = combine_267 * float2(0.01, 0.01);
		float4 sample_358 = MR_Sample(Texture3, mul_280);
		float mul_387 = sample_358.z * div_334.y;
		float add_397 = mul_386 + mul_387;
		float2 combine_268 = float2(Gfx_UnflattenedWorldPos.x, Gfx_UnflattenedWorldPos.y);
		float2 mul_281 = combine_268 * float2(0.01, 0.01);
		float4 sample_359 = MR_Sample(Texture3, mul_281);
		float mul_388 = sample_359.z * div_334.z;
		float add_398 = add_397 + mul_388;
		float saturate_259 = saturate(Gfx_Color.x);
		float mul_278 = saturate_259 * float(0.0625);
		float add_296 = mul_278 + float(0.75);
		float add_311 = add_296 + float(0.03125);
		float2 combine_406 = float2(add_398, add_311);
		float4 sample_414 = MR_SampleLod(Palette, combine_406, float(0));
		float saturate_258 = saturate(Gfx_Color.x);
		float mul_277 = saturate_258 * float(0.0625);
		float add_295 = mul_277 + float(0.5);
		float add_309 = add_295 + float(0.03125);
		float2 combine_405 = float2(add_398, add_309);
		float4 sample_413 = MR_SampleLod(Palette, combine_405, float(0));
		float4 smear_257 = float4(Gfx_Color.w, Gfx_Color.w, Gfx_Color.w, Gfx_Color.w);
		float4 lerp_422 = lerp(sample_414, sample_413, smear_257);
		float saturate_260 = saturate(Gfx_Color.x);
		float mul_279 = saturate_260 * float(0.0625);
		float add_297 = mul_279 + float(0.25);
		float add_313 = add_297 + float(0.03125);
		float2 combine_407 = float2(add_398, add_313);
		float4 sample_415 = MR_SampleLod(Palette, combine_407, float(0));
		float4 smear_256 = float4(Gfx_Color.z, Gfx_Color.z, Gfx_Color.z, Gfx_Color.z);
		float4 lerp_423 = lerp(lerp_422, sample_415, smear_256);
		float3 truncate_431 = float3(lerp_423.xyz);
		float3 GetPlanetPosition_92 = GetPlanetPosition();
		float3 sub_207 = Gfx_UnflattenedWorldPos - GetPlanetPosition_92;
		float3 normalize_253 = normalize(sub_207);
