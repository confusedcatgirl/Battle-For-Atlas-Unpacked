<keywords = { "LIGHT_FROM_SPACE", "ISNT_MAIN_PLANET", "GFX_DEFERRED_SHADER", }, >
import "shaders/modules/graphics/deferred_data.h"
import "shaders/modules/graphics/normal_encode.h"
import "shaders/modules/graphics/environment.h"
import "shaders/nodes/shader/functions/ow emissive intensity multiplier.h"
pixel
{
	MR_Sampler2D GradientTexture : MR_Texture0 {
		wrap = clamp,
	} <label = "Gradient Texture", pinId = 121>;
	MR_Sampler2D TextureOne : MR_Texture1 <label = "Texture One", pinId = 101>;
	struct CustomData {
		float myIntensity <default = 0, label = "Intensity", pinId = 122>;
		float2 myUVspeed <default = 0 0, label = "UV speed", pinId = 102>;
		float myUVRotation <default = 0, label = "UV Rotation", pinId = 103>;
		float myRotationSpeed <default = 0, label = "Rotation Speed", pinId = 104>;
		float2 myScaleUV <default = 1 1, label = "Scale UV", pinId = 105>;
		float2 myOffsetUV <default = 0 0, label = "Offset UV", pinId = 106>;
		float myErosion <default = 0, label = "Erosion", pinId = 108>;
		float2 myErosionScaleUV <default = 1 1, label = "Erosion Scale UV", pinId = 109>;
		float2 myErosionOffsetUV <default = 0 0, label = "Erosion Offset UV", pinId = 110>;
		float2 myErosionUVSpeed <default = 0 0, label = "Erosion UV Speed", pinId = 111>;
		float myErosionUVRotation <default = 0, label = "Erosion UV Rotation", pinId = 112>;
		float myErosionUVRotationSpeed <default = 0, label = "Erosion UV Rotation Speed", pinId = 113>;
		float4 myMaskChannelControl <default = 1 0 0 0, label = "Mask Channel Control", pinId = 120>;
		float2 myMaskScaleUV <default = 1 1, label = "Mask Scale UV", pinId = 115>;
		float2 myMaskOffsetUV <default = 0 0, label = "Mask Offset UV", pinId = 116>;
		float2 myMaskUVSpeed <default = 0 0, label = "Mask UV Speed", pinId = 117>;
		float myMaskUVRotation <default = 0, label = "Mask UV Rotation", pinId = 118>;
		float myMaskUVRotationSpeed <default = 0, label = "Mask UV Rotation Speed", pinId = 119>;
		float myUseUnscaledGameTime <default = 0, label = "Use Unscaled Game Time", pinId = 123>;
		float myUnscaledGameTime <default = 0, label = "Unscaled Game Time", pinId = 124>;
	};
	main(bool MR_IsFrontFace : MR_IsFrontFace, 
		out Gfx_DeferredData deferredOut : Gfx_Deferred <emission = true,>, 
		CustomData customData : Gfx_CustomData0, float2 Gfx_UV : Gfx_UV0, 
		float3 Gfx_FlattenedWorldNormal : Gfx_FlattenedWorldNormal0)
	{
		float lerp_123 = lerp(Gfx_Environment.time, customData.myUnscaledGameTime, customData.myUseUnscaledGameTime);
		float mul_126 = lerp_123 * customData.myUVspeed.x;
		float2 sub_110 = Gfx_UV - float2(0.5, 0.5);
		float mul_132 = lerp_123 * customData.myRotationSpeed;
		float add_135 = customData.myUVRotation + mul_132;
		float sinAngle_138 = sin(add_135);
		float cosAngle_138 = cos(add_135);
		float2x2 rotMat_138 = { cosAngle_138, -sinAngle_138, sinAngle_138, cosAngle_138 };
		float2 rot2d_138 = MR_Transform(rotMat_138, sub_110);
		float2 add_141 = rot2d_138 + float2(0.5, 0.5);
		float2 mul_144 = add_141 * customData.myScaleUV;
		float2 add_147 = mul_144 + customData.myOffsetUV;
		float add_153 = mul_126 + add_147.x;
		float mul_127 = lerp_123 * customData.myUVspeed.y;
		float add_154 = mul_127 + add_147.y;
		float2 combine_159 = float2(add_153, add_154);
		float4 sample_162 = MR_Sample(TextureOne, combine_159);
		float2 combine_168 = float2(sample_162.x, float(0.5));
		float4 sample_173 = MR_Sample(GradientTexture, combine_168);
		float3 truncate_178 = float3(sample_173.xyz);
		deferredOut.color = truncate_178;
		float4 smear_116 = float4(customData.myIntensity, customData.myIntensity, customData.myIntensity, customData.myIntensity);
		float4 mul_177 = sample_173 * smear_116;
		float3 truncate_182 = float3(mul_177.xyz);
		float4 truncate_186 = float4(truncate_182.xyz, 1);
		float4 OWEmissiveIntensityMultiplier_189 = OWEmissiveIntensityMultiplier(truncate_186);
		float3 truncate_194 = float3(OWEmissiveIntensityMultiplier_189.xyz);
		deferredOut.emission = truncate_194;
		deferredOut.roughness = float(1);
		deferredOut.metalness = float(0);
		deferredOut.ao = float(1);
		float3 flippedNormal = Gfx_FlattenedWorldNormal;
		if (!MR_IsFrontFace)
		    flippedNormal = -flippedNormal;
		deferredOut.worldNormal = flippedNormal;
	}
}
