pixel
{
	struct CustomData {
		float myFogDepth <default = 2, label = "Fog Depth", pinId = 102>;
	};
	main(CustomData customData : Gfx_CustomData, out float4 colorOut : MR_Color0, 
		float Gfx_AlphaRef : Gfx_AlphaRef0)
	{
		if (float(1) < Gfx_AlphaRef) discard;
		float4 shadowResult = float4(0.0, 0.0, 0.0, float(1));
		colorOut = shadowResult;
	}
}
