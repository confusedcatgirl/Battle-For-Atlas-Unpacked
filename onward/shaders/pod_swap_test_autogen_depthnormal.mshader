pixel
{
	MR_Sampler2D BaseColor : MR_Texture0 {
		texture = "onward/baked/textures/default_b.dds",
	} <label = "Base Color", pinId = 102>;
	struct CustomData {
		float myUVOffset <default = 0, label = "UV Offset", pinId = 107>;
		float myEmissiveMultiplier <default = 1, label = "Emissive Multiplier", pinId = 108>;
	};
	main(out float4 colorOut : MR_Color0, float2 Gfx_UV : Gfx_UV0, 
		CustomData customData : Gfx_CustomData0, float Gfx_AlphaRef : Gfx_AlphaRef0, 
		float3 Gfx_CameraSpacePos : Gfx_CameraSpacePos0)
	{
		float add_63 = Gfx_UV.y + customData.myUVOffset;
		float2 combine_66 = float2(Gfx_UV.x, add_63);
		float4 sample_68 = MR_Sample(BaseColor, combine_66);
		if (sample_68.w < Gfx_AlphaRef) discard;
		float4 depthResult = float4(Gfx_CameraSpacePos.z, 0, 0, sample_68.w);
		colorOut = depthResult;
	}
}
