		float saturate_475 = saturate(saturate_473);
		float sub_477 = saturate_365 - saturate_475;
		float clamp_479 = clamp(sub_477, float(0), float(1));
		float add_481 = clamp_479 + saturate_473;
		float saturate_483 = saturate(add_481);
		float add_334 = customData.myThickness + float(0.001);
		float add_335 = customData.myThickness + float(0.001);
		float2 combine_347 = float2(add_334, add_335);
		float2 mul_352 = Gfx_UV * combine_347;
		float add_336 = customData.myThickness + float(0.001);
		float sub_348 = add_336 - float(1);
		float mul_353 = sub_348 * float(-0.5);
		float2 smear_356 = float2(mul_353, mul_353);
		float2 add_364 = mul_352 + smear_356;
		float mul_329 = customData.myRoundness * float(0.5);
		float sub_330 = float(1) - mul_329;
		float mul_328 = customData.mySoftness * float(0.5);
		float add_344 = sub_330 + mul_328;
		float draw_corner_circles_374 = draw_corner_circles(add_364, mul_329, sub_330, add_344);
		float add_342 = customData.myRoundness + float(0.001);
		float add_332 = customData.myThickness + float(0.001);
		float add_333 = customData.myThickness + float(0.001);
		float2 combine_346 = float2(add_332, add_333);
		float2 mul_351 = Gfx_UV * combine_346;
		float add_331 = customData.myThickness + float(0.001);
		float sub_345 = add_331 - float(1);
		float mul_350 = sub_345 * float(-0.5);
		float2 smear_354 = float2(mul_350, mul_350);
		float2 add_355 = mul_351 + smear_354;
		float add_366 = add_355.x + add_355.x;
		float saturate_375 = saturate(add_366);
		float step_367 = step(add_355.x, float(0.5));
		float sub_376 = float(1) - step_367;
		float sub_383 = saturate_375 - sub_376;
		float saturate_391 = saturate(sub_383);
		float2 sub_360 = add_355 - float2(0.5, 0.5);
		float sinAngle_370 = sin(float(3.14159));
		float cosAngle_370 = cos(float(3.14159));
		float2x2 rotMat_370 = { cosAngle_370, -sinAngle_370, sinAngle_370, cosAngle_370 };
		float2 rot2d_370 = MR_Transform(rotMat_370, sub_360);
		float2 add_379 = rot2d_370 + float2(0.5, 0.5);
		float add_393 = add_379.x + add_379.x;
		float saturate_403 = saturate(add_393);
		float step_394 = step(add_379.x, float(0.5));
