		float saturate_445 = saturate(smoothStep_439);
		float add_326 = float(0) + customData.mySoftness;
		float2 sub_361 = add_355 - float2(0.5, 0.5);
		float sinAngle_371 = sin(float(1.5708));
		float cosAngle_371 = cos(float(1.5708));
		float2x2 rotMat_371 = { cosAngle_371, -sinAngle_371, sinAngle_371, cosAngle_371 };
		float2 rot2d_371 = MR_Transform(rotMat_371, sub_361);
		float2 add_380 = rot2d_371 + float2(0.5, 0.5);
		float add_395 = add_380.x + add_380.x;
		float saturate_405 = saturate(add_395);
		float step_396 = step(add_380.x, float(0.5));
		float sub_406 = float(1) - step_396;
		float sub_414 = saturate_405 - sub_406;
		float saturate_420 = saturate(sub_414);
		float2 sub_387 = add_380 - float2(0.5, 0.5);
		float sinAngle_397 = sin(float(3.14159));
		float cosAngle_397 = cos(float(3.14159));
		float2x2 rotMat_397 = { cosAngle_397, -sinAngle_397, sinAngle_397, cosAngle_397 };
		float2 rot2d_397 = MR_Transform(rotMat_397, sub_387);
