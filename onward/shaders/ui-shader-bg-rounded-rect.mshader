		float add_421 = add_407.x + add_407.x;
		float saturate_428 = saturate(add_421);
		float step_422 = step(add_407.x, float(0.5));
		float sub_429 = float(1) - step_422;
		float sub_434 = saturate_428 - sub_429;
		float saturate_440 = saturate(sub_434);
		float add_446 = saturate_420 + saturate_440;
		float saturate_449 = saturate(add_446);
		float smoothStep_453 = smoothstep(float(0), add_326, saturate_449);
		float sub_457 = float(1) - smoothStep_453;
