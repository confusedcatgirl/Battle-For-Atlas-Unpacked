		float step_303 = step(add_289.y, float(0.5));
		float sub_309 = float(1) - step_303;
		float sub_313 = saturate_308 - sub_309;
		float saturate_315 = saturate(sub_313);
		float add_317 = saturate_301 + saturate_315;
		float saturate_319 = saturate(add_317);
		float smoothStep_450 = smoothstep(float(0), add_323, saturate_319);
		float sub_454 = float(1) - smoothStep_450;
		float saturate_458 = saturate(sub_454);
		float sub_462 = saturate_442 - saturate_458;
		float saturate_466 = saturate(sub_462);
		float add_469 = saturate_465 + saturate_466;
		float saturate_471 = saturate(add_469);
		float saturate_473 = saturate(saturate_471);
		float sub_475 = saturate_363 - saturate_473;
		float clamp_477 = clamp(sub_475, float(0), float(1));
		float add_479 = clamp_477 + saturate_471;
		float saturate_481 = saturate(add_479);
		float add_332 = customData.myThickness + float(0.001);
		float add_333 = customData.myThickness + float(0.001);
		float2 combine_345 = float2(add_332, add_333);
		float2 mul_350 = Gfx_UV * combine_345;
		float add_334 = customData.myThickness + float(0.001);
		float sub_346 = add_334 - float(1);
		float mul_351 = sub_346 * float(-0.5);
		float2 smear_354 = float2(mul_351, mul_351);
		float2 add_362 = mul_350 + smear_354;
		float mul_327 = customData.myRoundness * float(0.5);
		float sub_328 = float(1) - mul_327;
		float mul_326 = customData.mySoftness * float(0.5);
		float add_342 = sub_328 + mul_326;
		float draw_corner_circles_372 = draw_corner_circles(add_362, mul_327, sub_328, add_342);
		float add_340 = customData.myRoundness + float(0.001);
		float add_330 = customData.myThickness + float(0.001);
		float add_331 = customData.myThickness + float(0.001);
		float2 combine_344 = float2(add_330, add_331);
		float2 mul_349 = Gfx_UV * combine_344;
		float add_329 = customData.myThickness + float(0.001);
		float sub_343 = add_329 - float(1);
		float mul_348 = sub_343 * float(-0.5);
		float2 smear_352 = float2(mul_348, mul_348);
		float2 add_353 = mul_349 + smear_352;
		float add_364 = add_353.x + add_353.x;
		float saturate_373 = saturate(add_364);
		float step_365 = step(add_353.x, float(0.5));
		float sub_374 = float(1) - step_365;
		float sub_381 = saturate_373 - sub_374;
		float saturate_389 = saturate(sub_381);
		float2 sub_358 = add_353 - float2(0.5, 0.5);
		float sinAngle_368 = sin(float(3.14159));
		float cosAngle_368 = cos(float(3.14159));
		float2x2 rotMat_368 = { cosAngle_368, -sinAngle_368, sinAngle_368, cosAngle_368 };
		float2 rot2d_368 = MR_Transform(rotMat_368, sub_358);
		float2 add_377 = rot2d_368 + float2(0.5, 0.5);
		float add_391 = add_377.x + add_377.x;
		float saturate_401 = saturate(add_391);
		float step_392 = step(add_377.x, float(0.5));
		float sub_402 = float(1) - step_392;
		float sub_411 = saturate_401 - sub_402;
		float saturate_417 = saturate(sub_411);
		float add_425 = saturate_389 + saturate_417;
		float saturate_431 = saturate(add_425);
		float smoothStep_437 = smoothstep(customData.myRoundness, add_340, saturate_431);
		float saturate_443 = saturate(smoothStep_437);
		float add_324 = float(0) + customData.mySoftness;
		float2 sub_359 = add_353 - float2(0.5, 0.5);
		float sinAngle_369 = sin(float(1.5708));
		float cosAngle_369 = cos(float(1.5708));
		float2x2 rotMat_369 = { cosAngle_369, -sinAngle_369, sinAngle_369, cosAngle_369 };
		float2 rot2d_369 = MR_Transform(rotMat_369, sub_359);
		float2 add_378 = rot2d_369 + float2(0.5, 0.5);
		float add_393 = add_378.x + add_378.x;
		float saturate_403 = saturate(add_393);
		float step_394 = step(add_378.x, float(0.5));
		float sub_404 = float(1) - step_394;
		float sub_412 = saturate_403 - sub_404;
		float saturate_418 = saturate(sub_412);
		float2 sub_385 = add_378 - float2(0.5, 0.5);
		float sinAngle_395 = sin(float(3.14159));
		float cosAngle_395 = cos(float(3.14159));
		float2x2 rotMat_395 = { cosAngle_395, -sinAngle_395, sinAngle_395, cosAngle_395 };
		float2 rot2d_395 = MR_Transform(rotMat_395, sub_385);
		float2 add_405 = rot2d_395 + float2(0.5, 0.5);
		float add_419 = add_405.x + add_405.x;
		float saturate_426 = saturate(add_419);
		float step_420 = step(add_405.x, float(0.5));
		float sub_427 = float(1) - step_420;
		float sub_432 = saturate_426 - sub_427;
		float saturate_438 = saturate(sub_432);
		float add_444 = saturate_418 + saturate_438;
		float saturate_447 = saturate(add_444);
		float smoothStep_451 = smoothstep(float(0), add_324, saturate_447);
		float sub_455 = float(1) - smoothStep_451;
		float saturate_459 = saturate(sub_455);
		float sub_463 = saturate_443 - saturate_459;
		float saturate_467 = saturate(sub_463);
