		float sub_453 = float(1) - smoothStep_449;
		float saturate_457 = saturate(sub_453);
		float sub_461 = saturate_441 - saturate_457;
		float saturate_465 = saturate(sub_461);
		float add_339 = customData.myRoundness + float(0.001);
		float add_246 = add_236.y + add_236.y;
		float saturate_254 = saturate(add_246);
		float step_247 = step(add_236.y, float(0.5));
		float sub_255 = float(1) - step_247;
		float sub_261 = saturate_254 - sub_255;
		float saturate_269 = saturate(sub_261);
		float2 sub_242 = add_236 - float2(0.5, 0.5);
