<shaderType = "UI", >
import "shaders/modules/graphics/drawer/drawer.h"
blend {
	writeMask = rgba,
	src = 1,
	src.a = 0,
}
pixel
{
	struct CustomData {
		float3 myColor <default = 0 0 0, label = "Color", pinId = 109>;
		float myOpacity <default = 1, label = "Opacity", pinId = 110>;
		float myThickness <default = 1.1, label = "Thickness", pinId = 106>;
		float mySoftness <default = 0.04, label = "Softness", pinId = 107>;
		float myRoundness <default = 0.5, label = "Roundness", pinId = 108>;
	};
	float draw_corner_circles(float2 UVs, float offset, float smstep_min, float smstep_max)
	{
		float circle = 1 - distance(UVs, float2(offset, offset));
		circle = saturate(circle);
		circle = smoothstep(smstep_min, smstep_max, circle);

		float circle2 = 1 - distance(UVs, float2(offset, 1-offset));
		circle2 = saturate(circle2);
		circle2 = smoothstep(smstep_min, smstep_max, circle2);

		float circle3 = 1 - distance(UVs, float2(1-offset, offset));
		circle3 = saturate(circle3);
		circle3 = smoothstep(smstep_min, smstep_max, circle3);

		float circle4 = 1 - distance(UVs, float2(1-offset, 1-offset));
		circle4 = saturate(circle4);
		circle4 = smoothstep(smstep_min, smstep_max, circle4);

		return (circle+circle2+circle3+circle4);
	}
	main(out float4 colorOut : MR_Color0, CustomData customData : Gfx_CustomData0, 
		float2 Gfx_UV : Gfx_UV0)
	{
		float2 mul_235 = Gfx_UV * float2(1, 1);
		float2 add_237 = mul_235 + float2(-0, -0);
		float mul_336 = customData.myRoundness * float(0.5);
		float sub_337 = float(1) - mul_336;
		float mul_335 = customData.mySoftness * float(0.5);
