constants : MR_ConstantBuffer0
{
	float4x4 WorldToClip;
}

vertex
{
	in
	{
		float3 position;
		float4<NATIVE_ARGB_UNORM8> color;
	}

	out
	{
		float4 color;
	}

	main(out float4 clipPos : MR_Position)
	{
		Out.color = In.color;
		
		clipPos = MR_Transform(WorldToClip, In.position.xyz);
	}
}

pixel
{
	in
	{
		float4 color;
	}

	main(out float4 outColor : MR_Color)
	{
		outColor = In.color;
	}
}
