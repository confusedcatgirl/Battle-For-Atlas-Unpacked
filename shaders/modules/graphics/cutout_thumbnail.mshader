
@include "shaders/modules/graphics/postfx/pixel_in.h"

pixel
{
	MR_Sampler2D Color : MR_Texture0 { filter = point };
	MR_Sampler2D Depth : MR_Texture1 { filter = point };

	main(out float4 outColor : MR_Color)
	{
		float3 color = MR_SampleLod0(Color, In.uv0).rgb;
		float depth = MR_SampleLod0(Depth, In.uv0).r;

		float alpha = step(depth, 0.9999);

		outColor = float4(lerp(vec3(0), color, alpha), alpha);
	}
}
