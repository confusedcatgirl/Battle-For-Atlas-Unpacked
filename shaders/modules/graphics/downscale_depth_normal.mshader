@include "shaders/modules/graphics/postfx/pixel_in.h"

pixel
{
	MR_Sampler2D Depth : MR_Texture0 { anisotropy = 0, filter = point };
	MR_Sampler2D Normal : MR_Texture1 { anisotropy = 0, filter = point };

	main(out float4 depth : MR_Color0, out float4 normal : MR_Color1)
	{
		depth = float4(MR_SampleLod0(Depth, In.uv0).x, 0,0,0);
		normal = float4(MR_SampleLod0(Normal, In.uv0).xyz, 0);
	}
}
