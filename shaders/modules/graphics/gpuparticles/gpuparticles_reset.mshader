import "shaders/modules/graphics/gpuparticles/gpuparticles_common.h"

computeParameters
{
	numThreads 1 1 1
}

compute
{
	MR_RWStructuredBuffer< SCommonData > CommonData : MR_RW_Buffer0;
	
	main()
	{
		CommonData[0].myFirstActiveParticle = 0;
		CommonData[0].myNumActiveParticles = 0;
		CommonData[0].myFirstParticleToCreate = 0;
		CommonData[0].myNumParticlesToCreate = 0;
		CommonData[0].myPartialCreation = 0;
	}
}
