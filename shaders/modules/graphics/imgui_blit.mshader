@include "shaders/modules/graphics/postfx/pixel_in.h"
blend {
	src = 1,
	dest = src.a
}

pixel
{
	MR_Sampler2D Color : MR_Texture0 { wrap = repeat, filter = point };

	main(out float4 color : MR_Color, float4 MR_FragCoord : MR_FragCoord)
	{
		color = MR_SampleLod0(Color, In.uv0);
	}
}
