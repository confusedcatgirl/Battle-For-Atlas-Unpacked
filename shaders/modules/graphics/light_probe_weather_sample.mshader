import "shaders/nodes/Shader/Functions/Sample Weather Mask.h"

computeParameters
{
	numThreads 64 1 1,
}

compute
{		
	MR_Buffer< float2 > 			Points : MR_Buffer0;
	MR_RWBuffer< float > 			Output : MR_RW_Buffer0;
		
	main( in uint3 threadIdWithinDispatch : MR_DispatchThreadId )
	{
		Output[threadIdWithinDispatch.x] = SampleWeatherMask( Points[threadIdWithinDispatch.x] ).r;
	}
}