
computeParameters
{
	numThreads 1 1 1
}

compute
{
	MR_RWBuffer< uint > OutputToReset : MR_RW_Buffer0;

	main(uint3 dispatchThreadId : MR_DispatchThreadId)
	{
		OutputToReset[0] = 0xffffffff;
		OutputToReset[1] = 0xffffffff;
		OutputToReset[2] = 0xffffffff;
		OutputToReset[3] = 0;
		OutputToReset[4] = 0;
		OutputToReset[5] = 0;

		OutputToReset[6] = 0;
	}
}
