@include "shaders/modules/graphics/postfx/pixel_in.h"

pixel
{
	import "shaders/modules/graphics/getstencil.h"

	main(out float4 colorOut : MR_Color0, out float4 reflectionOut : MR_Color1, float4 fc : MR_FragCoord)
	{
		reflectionOut = 0;

		uint stencil = GetStencil(fc.xy);
		if(stencil == 0)
		{
			colorOut = float4(1,0,1,0.1);
		}
		else
		{
			colorOut = float4(1,1,1,0.1);
		}
	}
}