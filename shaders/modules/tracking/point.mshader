import "shaders/MRender/MR_ViewConstants.h"

constants : MR_ConstantBuffer0
{
    float Scale;
	float AlphaFactor;	
}

vertex
{
	in
	{
		float3 corner;
		float2 uv;

		stream 1 steprate=1
		{
			float4 center;
			float4 color;
			float4 indexColor; // Ignored here
		}
	}

	out
	{
		float4 color;
		float2 uv;
	}

	main(out float4 clipPos : MR_Position)
	{
	    Out.uv = In.uv;
	
	    float4 color = In.color;
	    color.a *= AlphaFactor;	
	    Out.color = color;
	
	    float4 position = MR_Transform(MR_ViewConstants.worldToClip, In.center.xyz);		
		clipPos = position + float4(In.corner, 0) * 2 * Scale * position.w / float4(MR_ViewConstants.viewportSize, 1, 1);
	}
}

pixel
{
	in
	{
		float4 color;
		float2 uv;
	}
	
	MR_Sampler2D InputTexture : MR_Texture0 { filter = linear, wrap = clamp };

	main(out float4 color : MR_Color)
	{
		float4 textureColor = MR_Sample(InputTexture, In.uv);
		color = In.color * textureColor;
	}
}